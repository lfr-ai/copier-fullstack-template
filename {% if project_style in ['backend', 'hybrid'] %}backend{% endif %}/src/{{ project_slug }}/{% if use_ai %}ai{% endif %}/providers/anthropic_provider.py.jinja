"""Anthropic provider implementation for the completion service."""

from __future__ import annotations

import logging
from typing import Final

from {{ project_slug }}.ai.models import CompletionRequest, CompletionResponse
from {{ project_slug }}.ai.providers.base import BaseProvider
from {{ project_slug }}.core.exceptions import ExternalServiceError

logger: Final[logging.Logger] = logging.getLogger(__name__)

_DEFAULT_TIMEOUT: Final[float] = 60.0


class AnthropicProvider(BaseProvider):
    """Provider backed by the Anthropic Claude API.

    Attributes:
        _api_key: Anthropic API key.
        _timeout: Request timeout in seconds.
    """

    __slots__ = ("_api_key", "_timeout")

    def __init__(
        self,
        *,
        api_key: str,
        timeout: float = _DEFAULT_TIMEOUT,
    ) -> None:
        self._api_key = api_key
        self._timeout = timeout

    async def complete(self, request: CompletionRequest) -> CompletionResponse:
        """Send completion request to Anthropic API.

        Args:
            request: Structured completion request.

        Returns:
            CompletionResponse: Completion with usage statistics.

        Raises:
            ExternalServiceError: When Anthropic API call fails.
        """
        try:
            from anthropic import AsyncAnthropic

            client = AsyncAnthropic(
                api_key=self._api_key,
                timeout=self._timeout,
            )

            system_parts = [m.content for m in request.messages if m.role == "system"]
            user_messages = [
                {"role": m.role, "content": m.content}
                for m in request.messages
                if m.role != "system"
            ]

            response = await client.messages.create(
                model=request.model,
                system=system_parts[0] if system_parts else "",
                messages=user_messages,
                max_tokens=request.max_tokens,
                temperature=request.temperature,
                stop_sequences=request.stop_sequences or None,
            )

            content = response.content[0].text if response.content else ""
            prompt_tokens = response.usage.input_tokens
            completion_tokens = response.usage.output_tokens

            logger.info(
                "Anthropic completion: model=%s, tokens=%d",
                request.model,
                prompt_tokens + completion_tokens,
            )

            return CompletionResponse(
                content=content,
                model=request.model,
                prompt_tokens=prompt_tokens,
                completion_tokens=completion_tokens,
                total_tokens=prompt_tokens + completion_tokens,
                finish_reason=response.stop_reason or "stop",
            )
        except Exception as exc:
            logger.error("Anthropic completion failed: %s", exc, exc_info=True)
            raise ExternalServiceError(f"Anthropic API error: {exc}") from exc

    async def health_check(self) -> bool:
        """Verify connectivity to Anthropic API.

        Returns:
            bool: True if API is reachable.
        """
        try:
            from anthropic import AsyncAnthropic

            client = AsyncAnthropic(
                api_key=self._api_key,
                timeout=self._timeout,
            )
            await client.messages.create(
                model="claude-sonnet-4-20250514",
                messages=[{"role": "user", "content": "ping"}],
                max_tokens=1,
            )
            return True
        except Exception:
            logger.warning("Anthropic health check failed", exc_info=True)
            return False


__all__ = ["AnthropicProvider"]
