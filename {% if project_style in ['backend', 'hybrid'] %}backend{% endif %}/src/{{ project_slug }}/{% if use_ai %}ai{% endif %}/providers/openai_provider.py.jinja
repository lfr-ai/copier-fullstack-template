"""OpenAI provider implementation for the completion service."""

from __future__ import annotations

import logging
from typing import Final

from {{ project_slug }}.ai.models import CompletionRequest, CompletionResponse
from {{ project_slug }}.ai.providers.base import BaseProvider
from {{ project_slug }}.core.exceptions import ExternalServiceError

logger: Final[logging.Logger] = logging.getLogger(__name__)

_DEFAULT_TIMEOUT: Final[float] = 60.0


class OpenAIProvider(BaseProvider):
    """Provider backed by the OpenAI API.

    Attributes:
        _api_key: OpenAI API key.
        _api_base: Optional API base URL override.
        _timeout: Request timeout in seconds.
    """

    __slots__ = ("_api_base", "_api_key", "_timeout")

    def __init__(
        self,
        *,
        api_key: str,
        api_base: str | None = None,
        timeout: float = _DEFAULT_TIMEOUT,
    ) -> None:
        self._api_key = api_key
        self._api_base = api_base
        self._timeout = timeout

    async def complete(self, request: CompletionRequest) -> CompletionResponse:
        """Send completion request to OpenAI API.

        Args:
            request: Structured completion request.

        Returns:
            CompletionResponse: Completion with usage statistics.

        Raises:
            ExternalServiceError: When OpenAI API call fails.
        """
        try:
            from openai import AsyncOpenAI

            client = AsyncOpenAI(
                api_key=self._api_key,
                base_url=self._api_base,
                timeout=self._timeout,
            )
            response = await client.chat.completions.create(
                model=request.model,
                messages=[{"role": m.role, "content": m.content} for m in request.messages],
                max_tokens=request.max_tokens,
                temperature=request.temperature,
                stop=request.stop_sequences or None,
            )
            choice = response.choices[0]
            usage = response.usage

            logger.info(
                "OpenAI completion: model=%s, tokens=%d",
                request.model,
                usage.total_tokens if usage else 0,
            )

            return CompletionResponse(
                content=choice.message.content or "",
                model=request.model,
                prompt_tokens=usage.prompt_tokens if usage else 0,
                completion_tokens=usage.completion_tokens if usage else 0,
                total_tokens=usage.total_tokens if usage else 0,
                finish_reason=choice.finish_reason or "stop",
            )
        except Exception as exc:
            logger.error("OpenAI completion failed: %s", exc, exc_info=True)
            raise ExternalServiceError(f"OpenAI API error: {exc}") from exc

    async def health_check(self) -> bool:
        """Verify connectivity to OpenAI API.

        Returns:
            bool: True if OpenAI API is reachable.
        """
        try:
            from openai import AsyncOpenAI

            client = AsyncOpenAI(
                api_key=self._api_key,
                base_url=self._api_base,
                timeout=self._timeout,
            )
            await client.models.list()
            return True
        except Exception:
            logger.warning("OpenAI health check failed", exc_info=True)
            return False


__all__ = ["OpenAIProvider"]
