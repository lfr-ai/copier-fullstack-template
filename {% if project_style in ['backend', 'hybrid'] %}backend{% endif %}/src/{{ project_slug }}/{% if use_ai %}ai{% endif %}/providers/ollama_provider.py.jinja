"""Ollama local provider implementation for the completion service."""

from __future__ import annotations

import logging
from typing import Final

from {{ project_slug }}.ai.models import CompletionRequest, CompletionResponse
from {{ project_slug }}.ai.providers.base import BaseProvider
from {{ project_slug }}.core.exceptions import ExternalServiceError

logger: Final[logging.Logger] = logging.getLogger(__name__)

_DEFAULT_BASE_URL: Final[str] = "http://localhost:11434"


class OllamaProvider(BaseProvider):
    """Provider backed by a local Ollama server.

    Attributes:
        _base_url: Ollama server base URL.
    """

    __slots__ = ("_base_url",)

    def __init__(self, *, base_url: str = _DEFAULT_BASE_URL) -> None:
        self._base_url = base_url

    async def complete(self, request: CompletionRequest) -> CompletionResponse:
        """Send completion request to local Ollama server.

        Args:
            request: Structured completion request.

        Returns:
            CompletionResponse: Completion response from Ollama.

        Raises:
            ExternalServiceError: When Ollama server call fails.
        """
        try:
            from ollama import AsyncClient

            client = AsyncClient(host=self._base_url)
            response = await client.chat(
                model=request.model,
                messages=[{"role": m.role, "content": m.content} for m in request.messages],
                options={
                    "temperature": request.temperature,
                    "num_predict": request.max_tokens,
                },
            )

            content = response.get("message", {}).get("content", "")
            eval_count = response.get("eval_count", 0)
            prompt_eval_count = response.get("prompt_eval_count", 0)

            logger.info(
                "Ollama completion: model=%s, eval_count=%d",
                request.model,
                eval_count,
            )

            return CompletionResponse(
                content=content,
                model=request.model,
                prompt_tokens=prompt_eval_count,
                completion_tokens=eval_count,
                total_tokens=prompt_eval_count + eval_count,
                finish_reason="stop",
            )
        except Exception as exc:
            logger.error("Ollama completion failed: %s", exc, exc_info=True)
            raise ExternalServiceError(f"Ollama error: {exc}") from exc

    async def health_check(self) -> bool:
        """Verify connectivity to local Ollama server.

        Returns:
            bool: True if Ollama server is reachable.
        """
        try:
            from ollama import AsyncClient

            client = AsyncClient(host=self._base_url)
            await client.list()
            return True
        except Exception:
            logger.warning("Ollama health check failed", exc_info=True)
            return False


__all__ = ["OllamaProvider"]
