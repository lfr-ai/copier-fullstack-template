# Normalize line endings to LF on checkout.
# Prevents CRLF/LF inconsistencies across Windows/macOS/Linux contributors.

* text=auto eol=lf

# Explicitly declare text files
*.py text eol=lf
*.py.jinja text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.toml.jinja text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.zsh text eol=lf
*.ps1 text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.jinja text eol=lf
*.sql text eol=lf
*.bicep text eol=lf
*.hcl text eol=lf

# Binary files — do not modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar.gz binary
