# EditorConfig — https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{py,py.jinja}]
indent_size = 4
max_line_length = 88

[*.{ts,tsx,js,jsx,json,css,html}]
indent_size = 2

[*.{yml,yaml,toml}]
indent_size = 2

[*.{sh,zsh,bash}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[copier.yml]
indent_size = 2
