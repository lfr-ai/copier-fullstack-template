# syntax=docker/dockerfile:1
#
# Multi-stage production image for {{ project_name }}.
#
# Targets:
#   dev  — includes dev dependencies + uv for hot-reload workflows
#   prod — minimal, non-root, read-only, health-checked
#
# Build (from project root):
#   {{ container_runtime }} build -t {{ project_slug }}:latest -f Containerfile --target prod .
#   {{ container_runtime }} build -t {{ project_slug }}:dev   -f Containerfile --target dev  .

ARG UV_VERSION=0.10

# ── Builder ──────────────────────────────────────────────────────────────
FROM python:{{ python_version }}-slim AS builder

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

WORKDIR /app

COPY --from=ghcr.io/astral-sh/uv:${UV_VERSION} /uv /uvx /usr/local/bin/

COPY backend/pyproject.toml backend/uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-editable

COPY backend/src/ src/

# ── App base ─────────────────────────────────────────────────────────────
FROM python:{{ python_version }}-slim AS app-base

WORKDIR /app

RUN groupadd --gid 1000 appuser \
    && useradd --uid 1000 --gid 1000 --shell /usr/sbin/nologin appuser \
    && mkdir -p /app/logs && chown appuser:appuser /app/logs
{%- if database_backend == "sqlite" %}

RUN mkdir -p /app/data && chown appuser:appuser /app/data
{%- endif %}

COPY --from=builder /app/.venv /app/.venv
COPY --from=builder /app/src /app/src

ENV PATH="/app/.venv/bin:${PATH}" \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONHASHSEED=random

# ── Dev target ───────────────────────────────────────────────────────────
FROM app-base AS dev

ARG UV_VERSION=0.10
COPY --from=ghcr.io/astral-sh/uv:${UV_VERSION} /uv /uvx /usr/local/bin/
COPY backend/pyproject.toml backend/uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-editable

USER appuser

EXPOSE 8000

CMD ["uvicorn", "{{ project_slug }}.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--reload-dir", "src"]

# ── Prod target ──────────────────────────────────────────────────────────
FROM app-base AS prod

LABEL org.opencontainers.image.title="{{ project_slug }}" \
    org.opencontainers.image.description="{{ project_description }}" \
    org.opencontainers.image.authors="{{ author_name }} <{{ author_email }}>" \
    org.opencontainers.image.source="https://github.com/{{ github_username }}/{{ project_slug }}" \
    org.opencontainers.image.licenses="{{ license }}"

COPY backend/pyproject.toml ./

USER appuser

EXPOSE 8000

STOPSIGNAL SIGTERM

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD ["python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/health', timeout=3)"]

ENV WEB_CONCURRENCY=4

CMD ["uvicorn", "{{ project_slug }}.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "4"]
