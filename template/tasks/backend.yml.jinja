tasks:
  dev:
    desc: "Start FastAPI development server"
    dir: backend
    cmds:
      - uv run uvicorn {{ project_slug }}.ports.api.app:create_api_app --factory --reload --port 8000

  build:
    desc: "Build Python package"
    dir: backend
    cmds:
      - uv build

  install:
    desc: "Install backend dependencies"
    dir: backend
    cmds:
      - uv sync --all-extras

  shell:
    desc: "Start Python REPL"
    dir: backend
    cmds:
      - uv run python


  test:
    desc: "Run backend tests via tox"
    dir: backend
    cmds:
      - uv run tox -e py{{ python_version | replace('.', '') }} -- {% raw %}{{.CLI_ARGS}}{% endraw %}

  test:unit:
    desc: "Run unit tests only"
    dir: backend
    cmds:
      - uv run tox -e py{{ python_version | replace('.', '') }} -- tests/unit

  test:integration:
    desc: "Run integration tests via tox"
    dir: backend
    cmds:
      - uv run tox -e integration

  test:property:
    desc: "Run property-based tests via tox"
    dir: backend
    cmds:
      - uv run tox -e property -- {% raw %}{{.CLI_ARGS}}{% endraw %}

  test:performance:
    desc: "Run performance tests via tox"
    dir: backend
    cmds:
      - uv run tox -e performance -- {% raw %}{{.CLI_ARGS}}{% endraw %}

  test:coverage:
    desc: "Run tests with coverage"
    dir: backend
    cmds:
      - uv run tox -e coverage


  lint:
    desc: "Lint Python code"
    dir: backend
    cmds:
      - uv run ruff check src/ tests/

  lint:fix:
    desc: "Lint and auto-fix issues"
    dir: backend
    cmds:
      - uv run ruff check src/ tests/ --fix

  format:
    desc: "Format Python code"
    dir: backend
    cmds:
      - uv run ruff format src/ tests/

  format:check:
    desc: "Check formatting"
    dir: backend
    cmds:
      - uv run ruff format src/ tests/ --check

  typecheck:
    desc: "Type check Python code"
    dir: backend
    cmds:
      - uv run ty check src/

  security:
    desc: "Security scan"
    dir: backend
    cmds:
      - uv run ruff check --select S src/

  profile:cpu:
    desc: "Profile backend startup with pyinstrument"
    dir: backend
    cmds:
      - mkdir -p profiles/cpu
      - >-
        uv run python -m pyinstrument
        -r html
        -o profiles/cpu/startup_$(date +%Y%m%d_%H%M%S).html
        -m uvicorn {{ project_slug }}.ports.api.app:create_api_app
        --factory --host 127.0.0.1 --port 8000 --timeout-keep-alive 2
        {% raw %}{{.CLI_ARGS}}{% endraw %}

  profile:memory:
    desc: "Profile backend startup memory with tracemalloc"
    dir: backend
    cmds:
      - mkdir -p profiles/memory
      - >-
        uv run python -X tracemalloc=25 -c "
        import tracemalloc, datetime;
        tracemalloc.start(25);
        from {{ project_slug }}.ports.api.app import create_api_app;
        app = create_api_app();
        snap = tracemalloc.take_snapshot();
        ts = datetime.datetime.now().strftime('%Y%m%d_%H%M%S');
        snap.dump(f'profiles/memory/startup_{ts}.snapshot');
        stats = snap.statistics('lineno')[:30];
        print('Top 30 memory allocations:');
        [print(f'  {s}') for s in stats];
        peak = tracemalloc.get_traced_memory()[1] / 1024 / 1024;
        print(f'Peak memory: {peak:.2f} MB');
        "

  profile:report:
    desc: "Open the latest profiling HTML report"
    dir: backend
    cmds:
      - |
        LATEST=$(find profiles -name '*.html' -type f 2>/dev/null | sort -r | head -1)
        if [ -z "$LATEST" ]; then
          echo "No HTML profiling reports found in profiles/"
          exit 1
        fi
        echo "Opening: $LATEST"
        {% raw %}{{if eq OS "windows"}}{% endraw %}start "$LATEST"{% raw %}{{else if eq OS "darwin"}}{% endraw %}open "$LATEST"{% raw %}{{else}}{% endraw %}xdg-open "$LATEST"{% raw %}{{end}}{% endraw %}

  profile:clean:
    desc: "Remove all saved profiling reports"
    dir: backend
    cmds:
      - rm -rf profiles/
      - echo "Profiling reports cleaned."

{% if use_celery %}
  worker:
    desc: "Start Celery worker"
    dir: backend
    cmds:
      - uv run celery -A {{ project_slug }}.config.celery:celery_app worker --loglevel=info
{% endif %}
{% if use_ai %}
  ai:setup:
    desc: "Set up AI infrastructure (FAISS index, KG, directories)"
    cmds:
      - zsh scripts/setup-ai.zsh

  ai:validate:
    desc: "Validate AI dependencies and wiring"
    dir: backend
    cmds:
      - >-
        uv run python -c "
        from {{ project_slug }}.config.settings import get_settings;
        s = get_settings();
        print(f'AI enabled: {getattr(s, \"openai_api_key\", None) is not None}');
        print('AI config OK');
        "
{% if use_mcp %}
  mcp:dev:
    desc: "Start MCP server in development mode (stdio transport)"
    dir: backend
    cmds:
      - uv run python -m {{ project_slug }}.ai.mcp.server
{% endif %}
{% endif %}
  clean:
    desc: "Clean backend build artifacts"
    dir: backend
    cmds:
      - rm -rf dist/ build/ htmlcov/ .coverage coverage.xml
      - find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
      - find . -type d -name .pytest_cache -exec rm -rf {} + 2>/dev/null || true
      - find . -type d -name .ruff_cache -exec rm -rf {} + 2>/dev/null || true
      - find . -type d -name '*.egg-info' -exec rm -rf {} + 2>/dev/null || true
