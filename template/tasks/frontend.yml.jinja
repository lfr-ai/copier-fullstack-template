version: "3"

tasks:
  dev:
    desc: "Start Vite dev server"
    dir: frontend
    cmds:
      - bun run dev

  build:
    desc: "Build for production"
    dir: frontend
    cmds:
      - bun run build

  build:staging:
    desc: "Build for staging"
    dir: frontend
    cmds:
      - bun run build:staging

  build:test:
    desc: "Build for test"
    dir: frontend
    cmds:
      - bun run build:test

  install:
    desc: "Install frontend dependencies"
    dir: frontend
    cmds:
      - bun install --frozen-lockfile

  test:unit:
    desc: "Run unit tests"
    dir: frontend
    cmds:
      - bun run test

  test:coverage:
    desc: "Run tests with coverage"
    dir: frontend
    cmds:
      - bun run test:coverage
{% if use_playwright %}
  test:e2e:
    desc: "Run E2E tests (headless)"
    dir: frontend
    cmds:
      - bun run test:e2e

  test:e2e:ui:
    desc: "Run E2E tests with Playwright UI"
    dir: frontend
    cmds:
      - bunx playwright test --ui
{% endif %}
  lint:
    desc: "Lint frontend code"
    dir: frontend
    cmds:
      - bun run lint

  format:
    desc: "Format frontend code"
    dir: frontend
    cmds:
      - bun run format

  typecheck:
    desc: "Type check TypeScript"
    dir: frontend
    cmds:
      - bun run typecheck

  clean:
    desc: "Remove build artifacts"
    dir: frontend
    cmds:
      - rm -rf dist node_modules/.vite coverage playwright-report test-results storybook-static

  profile:bundle:
    desc: "Build with bundle analysis (rollup-plugin-visualizer)"
    dir: frontend
    cmds:
      - ANALYZE=true bun run build
      - |
        if [ -f dist/stats.html ]; then
          echo "Bundle analysis: dist/stats.html"
          {% raw %}{{if eq OS "windows"}}{% endraw %}start dist/stats.html{% raw %}{{else if eq OS "darwin"}}{% endraw %}open dist/stats.html{% raw %}{{else}}{% endraw %}xdg-open dist/stats.html{% raw %}{{end}}{% endraw %}
        fi

  profile:lighthouse:
    desc: "Run Lighthouse CI performance audit"
    dir: frontend
    cmds:
      - bunx lhci autorun --collect.url=http://localhost:3000 --collect.numberOfRuns=3 || true
      - echo "See .lighthouseci/ for reports"

  profile:lighthouse:ci:
    desc: "Run Lighthouse CI in headless mode (for CI pipelines)"
    dir: frontend
    cmds:
      - >-
        bunx lhci autorun
        --collect.url=http://localhost:3000
        --collect.numberOfRuns=5
        --assert.preset=lighthouse:recommended
        --assert.assertions.categories:performance=off
        || true
{% if use_storybook %}
  storybook:
    desc: "Start Storybook development server"
    dir: frontend
    cmds:
      - bun run storybook

  storybook:build:
    desc: "Build Storybook static site"
    dir: frontend
    cmds:
      - bun run storybook:build
{% endif %}
