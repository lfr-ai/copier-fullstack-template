# OpenAPI Specification Tasks
# Generated by copier-fullstack-template
---
version: "3"

vars:
  API_SPEC_DIR: docs/api
  API_SPEC_FILE: docs/api/openapi.yaml
  GENERATED_SPEC: docs/api/openapi.generated.json

tasks:
  spec:
    desc: "Extract OpenAPI spec from FastAPI application"
    dir: backend
    cmds:
      - |
        uv run python -c "
        import json
        import sys
        sys.path.insert(0, 'src')
        from {{ project_slug }}.composition.container import create_app
        app = create_app()
        spec = app.openapi()
        with open('../{% raw %}{{.GENERATED_SPEC}}{% endraw %}', 'w') as f:
            json.dump(spec, f, indent=2)
        print('OpenAPI spec extracted to {% raw %}{{.GENERATED_SPEC}}{% endraw %}')
        "
    generates:
      - "{% raw %}{{.GENERATED_SPEC}}{% endraw %}"

  spec:lint:
    desc: "Lint OpenAPI specification with Spectral"
    deps: [spec]
    cmds:
      - npx @stoplight/spectral-cli lint {% raw %}{{.GENERATED_SPEC}}{% endraw %} --ruleset .spectral.yaml --format stylish
    preconditions:
      - sh: test -f {% raw %}{{.GENERATED_SPEC}}{% endraw %}
        msg: "OpenAPI spec not found. Run 'task api:spec' first."

  spec:validate:
    desc: "Validate OpenAPI specification with Redocly"
    deps: [spec]
    cmds:
      - npx @redocly/cli lint {% raw %}{{.GENERATED_SPEC}}{% endraw %} --skip-rule=no-path-trailing-slash
    preconditions:
      - sh: test -f {% raw %}{{.GENERATED_SPEC}}{% endraw %}
        msg: "OpenAPI spec not found. Run 'task api:spec' first."

  spec:check:
    desc: "Run all OpenAPI spec checks (lint + validate)"
    cmds:
      - task: spec:lint
      - task: spec:validate

  spec:diff:
    desc: "Show diff between current and previous OpenAPI spec"
    deps: [spec]
    cmds:
      - |
        if command -v oasdiff &> /dev/null; then
          oasdiff diff {% raw %}{{.API_SPEC_FILE}}{% endraw %} {% raw %}{{.GENERATED_SPEC}}{% endraw %} --format=text
        else
          echo "oasdiff not installed. Install with: curl -sSfL https://raw.githubusercontent.com/Tufin/oasdiff/main/install.sh | sh"
          exit 1
        fi

  spec:breaking:
    desc: "Check for breaking changes in OpenAPI spec"
    deps: [spec]
    cmds:
      - |
        if command -v oasdiff &> /dev/null; then
          oasdiff breaking {% raw %}{{.API_SPEC_FILE}}{% endraw %} {% raw %}{{.GENERATED_SPEC}}{% endraw %} --format=text
        else
          echo "oasdiff not installed. Install with: curl -sSfL https://raw.githubusercontent.com/Tufin/oasdiff/main/install.sh | sh"
          exit 1
        fi

  spec:update:
    desc: "Extract and update the committed OpenAPI spec file"
    deps: [spec]
    cmds:
      - cp {% raw %}{{.GENERATED_SPEC}}{% endraw %} {% raw %}{{.API_SPEC_FILE}}{% endraw %}
      - echo "OpenAPI spec updated at {% raw %}{{.API_SPEC_FILE}}{% endraw %}"

  docs:
    desc: "Generate static HTML API documentation"
    deps: [spec]
    cmds:
      - |
        npx @redocly/cli build-docs {% raw %}{{.GENERATED_SPEC}}{% endraw %} \
          --output {% raw %}{{.API_SPEC_DIR}}{% endraw %}/index.html \
          --title "{{ project_name }} API Documentation"
    generates:
      - "{% raw %}{{.API_SPEC_DIR}}{% endraw %}/index.html"

  docs:serve:
    desc: "Serve generated API documentation locally"
    deps: [docs]
    cmds:
      - npx serve {% raw %}{{.API_SPEC_DIR}}{% endraw %} -p 8080
    interactive: true

  client:typescript:
    desc: "Generate TypeScript/Axios API client from OpenAPI spec"
    deps: [spec]
    vars:
      OUTPUT_DIR: frontend/src/api/generated
    cmds:
      - mkdir -p {% raw %}{{.OUTPUT_DIR}}{% endraw %}
      - |
        npx @openapitools/openapi-generator-cli generate \
          -i {% raw %}{{.GENERATED_SPEC}}{% endraw %} \
          -g typescript-axios \
          -o {% raw %}{{.OUTPUT_DIR}}{% endraw %} \
          --additional-properties=supportsES6=true,withInterfaces=true,useSingleRequestParameter=true
      - echo "TypeScript client generated at {% raw %}{{.OUTPUT_DIR}}{% endraw %}"
    generates:
      - "{% raw %}{{.OUTPUT_DIR}}{% endraw %}/**/*.ts"

  client:python:
    desc: "Generate Python API client from OpenAPI spec"
    deps: [spec]
    vars:
      OUTPUT_DIR: clients/python
    cmds:
      - mkdir -p {% raw %}{{.OUTPUT_DIR}}{% endraw %}
      - |
        npx @openapitools/openapi-generator-cli generate \
          -i {% raw %}{{.GENERATED_SPEC}}{% endraw %} \
          -g python \
          -o {% raw %}{{.OUTPUT_DIR}}{% endraw %} \
          --additional-properties=packageName={{ project_slug }}_client,projectName={{ project_slug }}-client
      - echo "Python client generated at {% raw %}{{.OUTPUT_DIR}}{% endraw %}"
    generates:
      - "{% raw %}{{.OUTPUT_DIR}}{% endraw %}/**/*.py"

  install:tools:
    desc: "Install OpenAPI tooling globally"
    cmds:
      - npm install -g @stoplight/spectral-cli @redocly/cli @openapitools/openapi-generator-cli
      - curl -sSfL https://raw.githubusercontent.com/Tufin/oasdiff/main/install.sh | sh -s -- -b /usr/local/bin
      - echo "OpenAPI tools installed successfully"
