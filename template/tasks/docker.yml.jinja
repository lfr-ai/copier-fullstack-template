version: "3"

tasks:
  up:
    desc: "Start all services"
    cmds:
      - {{ container_runtime }} compose up -d

  down:
    desc: "Stop all services"
    cmds:
      - {{ container_runtime }} compose down

  restart:
    desc: "Restart all services"
    cmds:
      - {{ container_runtime }} compose restart

  logs:
    desc: "Follow logs"
    cmds:
      - {{ container_runtime }} compose logs -f {% raw %}{{.CLI_ARGS}}{% endraw %}

  ps:
    desc: "List running services"
    cmds:
      - {{ container_runtime }} compose ps

  build:
    desc: "Build all container images"
    cmds:
      - {{ container_runtime }} compose build

  build:clean:
    desc: "Build without cache"
    cmds:
      - {{ container_runtime }} compose build --no-cache

  clean:
    desc: "Stop and remove containers"
    cmds:
      - {{ container_runtime }} compose down --remove-orphans

  db:
    desc: "Start database service only"
    cmds:
      - {{ container_runtime }} compose up -d db

  clean:volumes:
    desc: "Stop and remove containers + volumes"
    cmds:
      - {{ container_runtime }} compose down --volumes --remove-orphans

  prod:
    desc: "Start services with production overrides"
    cmds:
      - {{ container_runtime }} compose --env-file .env --env-file .env.prod -f compose.yml -f compose.prod.yml up -d --build

  staging:
    desc: "Start services with staging overrides"
    cmds:
      - {{ container_runtime }} compose --env-file .env --env-file .env.staging -f compose.yml -f compose.staging.yml up -d --build

  test:
    desc: "Start services with test overrides"
    cmds:
      - {{ container_runtime }} compose --env-file .env --env-file .env.test -f compose.yml -f compose.test.yml up -d --build

  dev:
    desc: "Start services with dev overrides (shared development server)"
    cmds:
      - {{ container_runtime }} compose --env-file .env --env-file .env.dev -f compose.yml -f compose.dev.yml up -d --build

  shell:
    desc: "Open a shell inside the running app container"
    cmds:
      - {{ container_runtime }} compose exec app /bin/sh
{%- if use_caddy %}

  gateway:
    desc: "Start all services including Caddy reverse proxy"
    cmds:
      - {{ container_runtime }} compose --profile gateway up -d

  gateway:logs:
    desc: "Follow Caddy reverse proxy logs"
    cmds:
      - {{ container_runtime }} compose --profile gateway logs -f caddy

  gateway:reload:
    desc: "Reload Caddy configuration without downtime"
    cmds:
      - {{ container_runtime }} compose exec caddy caddy reload --config /etc/caddy/Caddyfile

  gateway:validate:
    desc: "Validate Caddyfile syntax"
    cmds:
      - {{ container_runtime }} compose exec caddy caddy validate --config /etc/caddy/Caddyfile

  gateway:fmt:
    desc: "Format Caddyfile"
    cmds:
      - {{ container_runtime }} compose exec caddy caddy fmt --overwrite /etc/caddy/Caddyfile
{%- endif %}
{%- if container_runtime == "docker" %}

  bake:
    desc: "Build images with Docker Buildx Bake (default: dev targets)"
    cmds:
      - docker buildx bake {% raw %}{{.CLI_ARGS}}{% endraw %}

  bake:prod:
    desc: "Build production images with Docker Buildx Bake"
    cmds:
      - docker buildx bake prod

  bake:print:
    desc: "Preview bake build plan (dry-run)"
    cmds:
      - docker buildx bake --print {% raw %}{{.CLI_ARGS | default "prod"}}{% endraw %}

  bake:list:
    desc: "List available Bake targets and variables"
    cmds:
      - docker buildx bake --list=targets
      - docker buildx bake --list=variables

  bake:check:
    desc: "Run BuildKit build checks against Containerfiles"
    cmds:
      - docker buildx bake --check {% raw %}{{.CLI_ARGS | default "prod"}}{% endraw %}

  bake:clean:
    desc: "Remove local Bake build cache"
    cmds:
      - cmd: rm -rf .bake-cache
        platforms: [linux, darwin]
      - cmd: if exist .bake-cache rd /s /q .bake-cache
        platforms: [windows]
{%- endif %}
