version: "3"

tasks:
  up:
    desc: "Start all services"
    cmds:
      - {{ container_runtime }} compose up -d

  down:
    desc: "Stop all services"
    cmds:
      - {{ container_runtime }} compose down

  restart:
    desc: "Restart all services"
    cmds:
      - {{ container_runtime }} compose restart

  logs:
    desc: "Follow logs"
    cmds:
      - {{ container_runtime }} compose logs -f {% raw %}{{.CLI_ARGS}}{% endraw %}

  ps:
    desc: "List running services"
    cmds:
      - {{ container_runtime }} compose ps

  build:
    desc: "Build all container images"
    cmds:
      - {{ container_runtime }} compose build

  build:clean:
    desc: "Build without cache"
    cmds:
      - {{ container_runtime }} compose build --no-cache

  clean:
    desc: "Stop and remove containers"
    cmds:
      - {{ container_runtime }} compose down --remove-orphans

  db:
    desc: "Start database service only"
    cmds:
      - {{ container_runtime }} compose up -d db

  clean:volumes:
    desc: "Stop and remove containers + volumes"
    cmds:
      - {{ container_runtime }} compose down --volumes --remove-orphans

  prod:
    desc: "Start services with production overrides"
    cmds:
      - {{ container_runtime }} compose -f compose.yml -f compose.prod.yml --env-file .env.prod up -d --build

  staging:
    desc: "Start services with staging overrides"
    cmds:
      - {{ container_runtime }} compose -f compose.yml -f compose.staging.yml --env-file .env.staging up -d --build

  test:
    desc: "Start services with test overrides"
    cmds:
      - {{ container_runtime }} compose -f compose.yml -f compose.test.yml --env-file .env.test up -d --build

  dev:
    desc: "Start services with dev overrides (shared development server)"
    cmds:
      - {{ container_runtime }} compose -f compose.yml -f compose.dev.yml --env-file .env.dev up -d --build

  shell:
    desc: "Open a shell inside the running app container"
    cmds:
      - {{ container_runtime }} compose exec app /bin/sh
