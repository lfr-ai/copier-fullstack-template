{
  // ── Terminal ──────────────────────────────────────────────────
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.windows": "PowerShell 7",
  "terminal.integrated.profiles.windows": {
    "PowerShell 7": {
      "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe"
    },
    "zsh": {
      "path": "C:\\Windows\\System32\\wsl.exe",
      "args": ["-e", "zsh"]
    }
  },
  "terminal.external.windowsExec": "C:\\Windows\\System32\\wsl.exe",

  // ── Python ────────────────────────────────────────────────────
  "python.terminal.activateEnvironment": false,
  "python.analysis.typeCheckingMode": "strict",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.diagnosticMode": "workspace",
  "python.defaultInterpreterPath": "./backend/.venv/bin/python",
  "python.analysis.extraPaths": ["${workspaceFolder}/backend/src"],
  "python.testing.cwd": "${workspaceFolder}/backend",
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["tests", "-q", "--tb=short"],

  // ── Ruff ──────────────────────────────────────────────────────
  "ruff.lineLength": 88,
  "ruff.lint.args": ["--config=backend/ruff.toml"],
  "ruff.format.args": ["--config=backend/ruff.toml"],

  // ── Editor ────────────────────────────────────────────────────
  "editor.aiStats.enabled": false,
  "editor.autoIndentOnPaste": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.shellcheck": "explicit",
    "source.fixAll.ruff": "explicit",
    "source.organizeImports.ruff": "explicit",
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit",
    "source.organizeImports": "never"
  },
  "editor.formatOnSave": true,
  "editor.folding": false,
  "editor.rulers": [88],
  "editor.tabCompletion": "on",
  "editor.trimAutoWhitespace": true,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "trailing",
  "editor.suggestSelection": "first",
  "editor.linkedEditing": true,
  "editor.stickyScroll.enabled": true,
  "editor.defaultFormatter": "biomejs.biome",

  // ── Diff Editor ───────────────────────────────────────────────
  "diffEditor.ignoreTrimWhitespace": true,

  // ── Language-Specific Formatters ──────────────────────────────
  "[python]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    },
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },{% if cloud_provider == 'azure' %}
  "[azure-pipelines]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },{% endif %}
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "[markdown]": {
    "editor.defaultFormatter": "davidanson.vscode-markdownlint",
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },

  // ── JavaScript/TypeScript ─────────────────────────────────────
  "html.format.indentInnerHtml": true,
  "javascript.referencesCodeLens.enabled": true,
  "javascript.referencesCodeLens.showOnAllFunctions": true,
  "javascript.suggest.completeFunctionCalls": true,
  "javascript.inlayHints.functionLikeReturnTypes.enabled": true,
  "javascript.inlayHints.parameterNames.enabled": "all",
  "javascript.inlayHints.parameterTypes.enabled": true,
  "javascript.inlayHints.propertyDeclarationTypes.enabled": true,
  "javascript.inlayHints.variableTypes.enabled": true,
  "typescript.suggest.completeFunctionCalls": true,
  "typescript.inlayHints.enumMemberValues.enabled": true,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.parameterTypes.enabled": true,
  "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  // ── Biome ────────────────────────────────────────────────────────
  "biome.enabled": true,

  // ── Files ─────────────────────────────────────────────────────
  "files.associations": {
    "*.css": "tailwindcss",
    "*.html.j2": "jinja-html",
    "*.zsh": "shellscript",
    "*.azcli": "shellscript",
    "Caddyfile": "caddyfile",
    "Taskfile.yml": "yaml",
    ".env.*": "dotenv"{% if cloud_provider == 'azure' %},
    "**/ci/*.yml": "azure-pipelines"{% endif %}
  },
  "files.autoSave": "afterDelay",
  "files.trimTrailingWhitespace": true,
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.exclude": {
    "**/__pycache__": true,
    "**/node_modules": true,
    "**/.venv": true,
    "**/dist": true,
    "**/.vite": true,
    "**/*.egg-info": true
  },

  // ── Workbench ─────────────────────────────────────────────────
  "workbench.iconTheme": "vscode-icons",
  "workbench.panel.defaultLocation": "right",
  "workbench.colorCustomizations": {
    "editorRuler.foreground": "#FF69B4"
  },
  "workbench.editor.closeOnFileDelete": true,

  // ── vsicons ───────────────────────────────────────────────────
  "vsicons.associations.folders": [
    {
      "icon": "test",
      "extensions": ["tests"],
      "format": "svg",
      "overrides": "test"
    }
  ],

  // ── Spell Checking ────────────────────────────────────────────
  "cSpell.language": "en,da",

  // ── TOML ──────────────────────────────────────────────────────
  "evenBetterToml.formatter.arrayAutoCollapse": true,
  "evenBetterToml.formatter.arrayAutoExpand": true,

  // ── Extensions ────────────────────────────────────────────────
  "extensions.ignoreRecommendations": true,

  // ── Copilot / Chat ────────────────────────────────────────────
  "chat.instructionsFilesLocations": {
    ".github/instructions": true,
    ".claude/rules": true
  },
  "chat.agent.maxRequests": 250,
  "chat.detectParticipant.enabled": false,
  "chat.useAgentSkills": true,
  "chat.useCustomizationsInParentRepositories": true,

  // ── Copilot Agent Plugins ─────────────────────────────────────
  "chat.plugins.enabled": true,
  "chat.plugins.marketplaces": [
    "obra/superpowers"
  ],
  "chat.enabledPlugins": {
    "awesome-copilot@awesome-copilot": true,
    "context-engineering@awesome-copilot": true,
    "doublecheck@awesome-copilot": true,
    "frontend-web-dev@awesome-copilot": true,
    "project-planning@awesome-copilot": true,
    "security-best-practices@awesome-copilot": true,
    "testing-automation@awesome-copilot": true,
    "structured-autonomy@awesome-copilot": true{% if database_backend != 'none' %},
    "database-data-management@awesome-copilot": true{% endif %}{% if cloud_provider == 'azure' %},
    "azure@awesome-copilot": true,
    "azure-cloud-development@awesome-copilot": true{% endif %}
  },

  // ── Copilot Agent Hooks ───────────────────────────────────────
  "chat.hookFilesLocations": {
    ".github/hooks": true,
    ".claude/settings.json": true,
    ".claude/settings.local.json": true
  },
  "chat.useCustomAgentHooks": true,

  // ── Copilot Safety ────────────────────────────────────────────
  // Require manual approval for edits to hook scripts to prevent
  // the agent from modifying its own safety guardrails
  "chat.tools.edits.autoApprove": {
    ".github/hooks/**": false
  },

  // ── Copilot Features ──────────────────────────────────────────
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.nextEditSuggestions.allowWhitespaceOnlyChanges": false,

  // ── MCP ───────────────────────────────────────────────────────
  "chat.mcp.autoStart": true,

  // ── Search Exclusions ─────────────────────────────────────────
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/__pycache__": true,
    "**/.venv": true,
    "**/logs": true,
    "**/htmlcov": true,
    "**/.ruff_cache": true,
    "**/.mypy_cache": true,
    "**/.pytest_cache": true,
    "**/bun.lock": true,
    "**/uv.lock": true,
    "**/.lycheecache": true,
    "**/jscpd-report": true
  },

  // ── CSS ───────────────────────────────────────────────────────
  // Disabled: Biome handles CSS linting; built-in validator conflicts
  // with Tailwind CSS @theme/@layer directives.
  "css.validate": false,

  // ── Vitest ────────────────────────────────────────────────────
  "vitest.vitestPackagePath": "${workspaceFolder}/frontend/node_modules/vitest/package.json",
{% if use_playwright %}
  // ── Playwright ────────────────────────────────────────────────
  "playwright.reuseBrowser": true,
  "playwright.configs": ["frontend/playwright.config.ts"],
{% endif %}
  // ── Git ───────────────────────────────────────────────────────
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.autofetch": true,

  // ── Emmet ─────────────────────────────────────────────────────
  "emmet.includeLanguages": {
    "jinja-html": "html"
  },

  // ── Container ─────────────────────────────────────────────────
  "docker.composeCommand": "{{ container_runtime }} compose"
}
