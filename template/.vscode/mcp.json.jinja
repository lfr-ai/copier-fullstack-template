{
  "servers": {
    // ── Documentation ─────────────────────────────────────────
    "context7": {
      "command": "bunx",
      "args": ["--bun", "@upstash/context7-mcp@latest"]
    },

    // ── GitHub ────────────────────────────────────────────────
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },

    // ── shadcn/ui ─────────────────────────────────────────────
    "shadcn": {
      "command": "npx",
      "args": ["-y", "shadcn@latest", "mcp"]
    },
{% if use_playwright %}

    // ── Playwright ────────────────────────────────────────────
    "playwright": {
      "command": "bunx",
      "args": ["--bun", "@microsoft/mcp-server-playwright"]
    },
{% endif %}
{% if cloud_provider == 'azure' %}

    // ── Azure ─────────────────────────────────────────────────
    "azure": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/azure"
    },
{% endif %}

    // ── Microsoft Docs ────────────────────────────────────────
    "microsoft-docs": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/microsoft-docs"
    }{% if with_gitnexus %},

    // ── GitNexus (code intelligence graph) ───────────────────
    "gitnexus": {
      "command": "npx",
      "args": ["-y", "gitnexus@latest", "mcp"]
    }{% endif %}
  }
}
