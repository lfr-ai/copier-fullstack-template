{
"$schema": "https://json-schema.org/draft/2020-12/schema",
"name": "{{ project_name }}",
"host": "REPLACE_WITH_HOST",
"protocol": "sftp",
"port": 22,
"username": "REPLACE_WITH_USER",
"remotePath": "/home/REPLACE_WITH_USER/{{ project_slug }}",
"privateKeyPath": "${env:HOME}/.ssh/id_ed25519",
"uploadOnSave": false,
"useTempFile": true,
"openSsh": true,
"ignore": [
".vscode",
".git",
".DS_Store",
"node_modules",
"__pycache__",
".venv",
"*.pyc",
".env",
".env.*",
"logs",
"dist",
"build",
"htmlcov",
".coverage",
".mypy_cache",
".ruff_cache",
".pytest_cache"
],
"watcher": {
"files": "**/*",
"autoUpload": false,
"autoDelete": false
},
"syncOption": {
"skipCreate": false,
"delete": false
}
}
