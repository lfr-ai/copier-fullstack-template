# syntax=docker/dockerfile:1
#
# Caddy reverse proxy with built-in frontend static assets.
# Single entry point: automatic HTTPS, HTTP/3, compression, security headers, SPA routing.
#
# Targets:
#   (default) — production Caddy with pre-built frontend assets
#
# Build (from project root):
#   {{ container_runtime }} build -t {{ project_slug }}-caddy:latest -f caddy/Containerfile .

# ── Pinned versions ────────────────────────────────────────────────────────
ARG CADDY_VERSION=2.9
ARG BUN_VERSION=1

# ── Frontend build stage ───────────────────────────────────────────────────
FROM oven/bun:${BUN_VERSION}-alpine AS frontend-build

SHELL ["/bin/sh", "-o", "pipefail", "-c"]

ENV CI=true
WORKDIR /build

COPY frontend/package.json frontend/bun.lock ./
RUN --mount=type=cache,target=/root/.bun/install/cache \
    bun install --frozen-lockfile

COPY frontend/ ./
RUN bun run build

# ── Caddy production image ─────────────────────────────────────────────────
FROM caddy:${CADDY_VERSION}-alpine AS prod

SHELL ["/bin/sh", "-o", "pipefail", "-c"]

LABEL org.opencontainers.image.title="{{ project_slug }}-caddy" \
    org.opencontainers.image.description="Caddy reverse proxy with built-in frontend assets for {{ project_name }}" \
    org.opencontainers.image.authors="{{ author_name }} <{{ author_email }}>" \
    org.opencontainers.image.source="https://github.com/{{ github_username }}/{{ project_slug }}" \
    org.opencontainers.image.licenses="{{ license }}"

COPY caddy/Caddyfile /etc/caddy/Caddyfile
COPY --from=frontend-build /build/dist /srv

RUN addgroup -g 1000 -S appuser && \
    adduser -u 1000 -S appuser -G appuser && \
    chown -R appuser:appuser /data /config /srv /etc/caddy

USER appuser

EXPOSE 80 443 443/udp

STOPSIGNAL SIGTERM

HEALTHCHECK --interval=15s --timeout=5s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:80/health || exit 1
