
ARG CADDY_VERSION=2.9

FROM oven/bun:1-alpine AS frontend-build
ENV CI=true
WORKDIR /app
COPY frontend/package.json frontend/bun.lock ./
RUN bun install --frozen-lockfile
COPY frontend/ ./
RUN bun run build

FROM caddy:${CADDY_VERSION}-alpine

LABEL org.opencontainers.image.title="{{ project_slug }}-caddy" \
    org.opencontainers.image.description="Caddy reverse proxy with built-in frontend assets"

COPY caddy/Caddyfile /etc/caddy/Caddyfile
COPY --from=frontend-build /app/dist /srv

EXPOSE 80 443

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost/health || exit 1
