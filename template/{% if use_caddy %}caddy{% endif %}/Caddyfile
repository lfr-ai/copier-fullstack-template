{
	admin off
}

{$CADDY_DOMAIN:localhost} {
	log {
		output stdout
		format json
	}

	encode gzip zstd

	header {
		X-Frame-Options          "SAMEORIGIN"
		X-Content-Type-Options   "nosniff"
		Referrer-Policy          "strict-origin-when-cross-origin"
		X-XSS-Protection         "0"
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		Content-Security-Policy  "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'self'"
		-Server
	}

	handle /health {
		respond "OK" 200
	}

	handle /api/* {
		reverse_proxy app:{$BACKEND_PORT:8000}
	}

	handle {
		root * /srv
		@production file /index.html

		handle @production {
			@immutable path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2
			header @immutable Cache-Control "public, max-age=31536000, immutable"
			try_files {path} /index.html
			file_server
		}

		handle {
			reverse_proxy frontend:{$FRONTEND_PORT:3000}
		}
	}
}
