## Keybindings

These shortcuts are optional. The project works with default VS Code
keybindings. Copy the block below into your **user** `keybindings.json`
(`Ctrl+K Ctrl+S` → open keyboard shortcuts JSON):

```jsonc
[
  // ── Terminal ──────────────────────────────────────────────────
  { "key": "ctrl+m",      "command": "workbench.action.terminal.split",
    "when": "terminalFocus && terminalProcessSupported || terminalFocus && terminalWebExtensionContributedProfile" },
  { "key": "ctrl+oem_3",  "command": "workbench.action.terminal.new",
    "when": "terminalProcessSupported || terminalWebExtensionContributedProfile" },
  { "key": "ctrl+down",   "command": "workbench.action.terminal.scrollToBottom",
    "when": "terminalFocusInAny && terminalHasBeenCreated && !terminalAltBufferActive" },
  { "key": "ctrl+up",     "command": "workbench.action.terminal.scrollToTop",
    "when": "terminalFocusInAny && terminalHasBeenCreated && !terminalAltBufferActive" },
  { "key": "ctrl+delete", "command": "workbench.action.terminal.kill" },

  // ── Navigation ────────────────────────────────────────────────
  { "key": "ctrl+d",         "command": "workbench.view.explorer",
    "when": "viewContainer.workbench.view.explorer.enabled" },
  { "key": "ctrl+e",         "command": "workbench.action.findInFiles" },
  { "key": "ctrl+n",         "command": "workbench.action.splitEditorRight" },
  { "key": "ctrl+q",         "command": "workbench.action.openGlobalKeybindings" },
  { "key": "ctrl+k ctrl+i",  "command": "workbench.action.openWorkspace" },

  // ── Editor ────────────────────────────────────────────────────
  { "key": "ctrl+shift+j",  "command": "editor.action.revealDefinition",
    "when": "editorHasDefinitionProvider && editorTextFocus" },
  { "key": "ctrl+alt+o",    "command": "editor.action.changeAll",
    "when": "editorTextFocus && !editorReadonly" },
  { "key": "ctrl+r ctrl+s", "command": "editor.action.rename",
    "when": "editorHasRenameProvider && editorTextFocus && !editorReadonly" },
  { "key": "alt+f",         "command": "editor.action.quickFix",
    "when": "editorHasCodeActionsProvider && textInputFocus && !editorReadonly" },

  // ── Debugging ─────────────────────────────────────────────────
  { "key": "ctrl+d r", "command": "workbench.action.debug.restart",    "when": "inDebugMode" },
  { "key": "ctrl+d d", "command": "workbench.action.debug.disconnect", "when": "focusedSessionIsAttach && inDebugMode" },
  { "key": "ctrl+d c", "command": "workbench.action.debug.continue",  "when": "debugState == 'stopped'" },
  { "key": "ctrl+d s", "command": "workbench.action.debug.stop",      "when": "inDebugMode && !focusedSessionIsAttach" },

  // ── SQL Tools ─────────────────────────────────────────────────
  { "key": "ctrl+shift+s",             "command": "workbench.view.extension.sqltoolsActivityBarContainer" },
  { "key": "ctrl+1",                   "command": "sqltools.executeCurrentQuery" },
  { "key": "ctrl+alt+q",               "command": "sqltools.newSqlFile" },
  { "key": "ctrl+oem_comma ctrl+oem_6","command": "sqltools.runFromBookmarks",
    "when": "!config.sqltools.disableChordKeybindings" },

  // ── Copilot / Chat ───────────────────────────────────────────
  { "key": "ctrl+alt+e",         "command": "github.copilot.chat.explain" },
  { "key": "ctrl+alt+g",         "command": "github.copilot.chat.generateDocs" },
  { "key": "ctrl+u",             "command": "workbench.action.chat.undoEdit" },
  { "key": "ctrl+alt+oem_minus", "command": "workbench.action.chat.openSessionTargetPicker" },

  // ── Auxiliary bar ─────────────────────────────────────────────
  { "key": "ctrl+alt+m",         "command": "workbench.action.maximizeAuxiliaryBar" },
  { "key": "ctrl+alt+oem_comma", "command": "workbench.action.restoreAuxiliaryBar" }
]
```

