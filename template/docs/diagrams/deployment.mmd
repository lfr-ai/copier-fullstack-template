graph TB
    subgraph Production
        LB[Load Balancer / CDN]
        Caddy[Caddy Reverse Proxy]
        App1[App Container 1]
        App2[App Container 2]
        Worker[Celery Worker]
        PG[(PostgreSQL)]
        RedisCache[(Redis)]
    end

    LB --> Caddy
    Caddy --> App1
    Caddy --> App2
    App1 --> PG
    App2 --> PG
    App1 --> RedisCache
    App2 --> RedisCache
    Worker --> PG
    Worker --> RedisCache
