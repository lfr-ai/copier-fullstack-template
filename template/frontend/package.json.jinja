{
  "name": "{{ project_slug }}-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --mode prod",
    "build:staging": "tsc && vite build --mode staging",
    "build:test": "tsc && vite build --mode test",
    "preview": "vite preview",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"{% if use_playwright %},
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ci": "playwright test --reporter=line"{% endif %}{% if use_storybook %},
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"{% endif %}
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.5.0",
    "@tanstack/react-query": "^5.75.0",
    "react-error-boundary": "^5.0.0",
    "react-hook-form": "^7.56.0",
    "@hookform/resolvers": "^5.0.0",
    "react-aria-components": "^1.7.0",
    "web-vitals": "^4.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/user-event": "^14.6.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0",
    "@vitest/coverage-v8": "^3.1.0",
    "@fast-check/vitest": "^0.1.3",
    "fast-check": "^3.23.0",
    "happy-dom": "^17.4.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "@lhci/cli": "^0.14.0"{% if use_playwright %},
    "@playwright/test": "^1.52.0"{% endif %}{% if use_storybook %},
    "@storybook/react-vite": "^9.0.0",
    "@storybook/addon-essentials": "^9.0.0",
    "@storybook/addon-interactions": "^9.0.0",
    "@storybook/addon-a11y": "^9.0.0",
    "storybook": "^9.0.0"{% endif %}
  }
}
