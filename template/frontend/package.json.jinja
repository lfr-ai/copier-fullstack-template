{
  "name": "{{ project_slug }}-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">={{ node_version }}",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --mode prod",
    "build:staging": "tsc && vite build --mode staging",
    "build:test": "tsc && vite build --mode test",
    "preview": "vite preview",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"{% if use_playwright %},
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ci": "playwright test --reporter=line"{% endif %}
  },
  "dependencies": {
{%- if frontend_framework == "lit" %}
    "lit": "^3.3.0",
    "@lit-labs/router": "^0.2.0",
    "@lit/context": "^1.2.0",
    "@lit/task": "^1.1.0",
    "@lit/reactive-element": "^2.1.0",
{%- elif frontend_framework == "react" %}
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.5.0",
    "@tanstack/react-query": "^5.75.0",
    "react-error-boundary": "^5.0.0",
{%- endif %}
    "web-vitals": "^4.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.0.0",
{%- if frontend_framework == "lit" %}
    "@open-wc/testing": "^4.0.0",
    "eslint-plugin-lit": "^2.1.0",
    "eslint-plugin-wc": "^2.2.0",
{%- elif frontend_framework == "react" %}
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/user-event": "^14.6.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
{%- endif %}
    "eslint": "^9.24.0",
    "eslint-plugin-import-x": "^4.11.0",
    "prettier": "^3.5.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.30.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0",
    "@vitest/coverage-v8": "^3.1.0",
    "happy-dom": "^17.4.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "@lhci/cli": "^0.14.0"{% if use_playwright %},
    "@playwright/test": "^1.52.0"{% endif %}
  }
}
