{
  "name": "{{ project_slug }}-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:staging": "tsc && vite build --mode staging",
    "build:test": "tsc && vite build --mode test",
    "preview": "vite preview",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"{% if use_playwright %},
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ci": "playwright test --reporter=line"{% endif %}
  },
  "dependencies": {
{%- if frontend_framework == "lit" %}
    "lit": "^3.2.0",
    "@lit-labs/router": "^0.1.0",
    "@lit/context": "^1.1.0",
    "@lit/task": "^1.0.0",
{%- elif frontend_framework == "react" %}
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "@tanstack/react-query": "^5.60.0",
    "react-error-boundary": "^5.0.0",
{%- endif %}
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
{%- if frontend_framework == "lit" %}
    "@open-wc/testing": "^4.0.0",
{%- elif frontend_framework == "react" %}
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
{%- endif %}
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "happy-dom": "^17.0.0"{% if use_playwright %},
    "@playwright/test": "^1.50.0"{% endif %}
  }
}
