{% extends "layouts/default.html.j2" %}

{% block title %}Dashboard - {{ project_name }}{% endblock %}

{% block page_content %}
<section class="dashboard">
  <h1>Dashboard</h1>
  <div class="stats-grid">
    <div class="stat-card">
      <h3>Users</h3>
      <span class="stat-value">{{ user_count | default(0) }}</span>
    </div>
  </div>
</section>
{% endblock %}
