/**
* AI Chat component — conversational RAG interface.
*
* Provides a chat interface for interacting with the AI backend.
* Supports conversation history, RAG-enhanced responses, and
* agent execution.
*/
import { LitElement, css, html } from 'lit';
import { customElement, property, state } from 'lit/decorators.js';
import { sendMessage, getConversationHistory, clearConversation } from '@/api/ai';
import type { ConversationMessage } from '@/api/ai';

@customElement('ai-chat')
export class AiChat extends LitElement {
@property({ type: String }) sessionId = crypto.randomUUID();
@state() private messages: ConversationMessage[] = [];
@state() private inputValue = '';
@state() private loading = false;
@state() private error = '';

static styles = css`
:host {
display: flex;
flex-direction: column;
height: 100%;
font-family: system-ui, sans-serif;
}
.messages {
flex: 1;
overflow-y: auto;
padding: 1rem;
display: flex;
flex-direction: column;
gap: 0.75rem;
}
.message {
padding: 0.75rem 1rem;
border-radius: 0.75rem;
max-width: 80%;
word-wrap: break-word;
}
.message.user {
align-self: flex-end;
background: var(--color-primary, #3b82f6);
color: white;
}
.message.assistant {
align-self: flex-start;
background: var(--color-surface, #f3f4f6);
color: var(--color-text, #1f2937);
}
.input-area {
display: flex;
gap: 0.5rem;
padding: 1rem;
border-top: 1px solid var(--color-border, #e5e7eb);
}
input {
flex: 1;
padding: 0.75rem;
border: 1px solid var(--color-border, #e5e7eb);
border-radius: 0.5rem;
font-size: 1rem;
}
button {
padding: 0.75rem 1.5rem;
background: var(--color-primary, #3b82f6);
color: white;
border: none;
border-radius: 0.5rem;
cursor: pointer;
font-size: 1rem;
}
button:disabled {
opacity: 0.5;
cursor: not-allowed;
}
.error {
color: var(--color-error, #ef4444);
padding: 0.5rem 1rem;
font-size: 0.875rem;
}
`;

connectedCallback(): void {
super.connectedCallback();
void this.loadHistory();
}

private async loadHistory(): Promise<void> {
    try {
    const data = await getConversationHistory(this.sessionId);
    this.messages = data.messages;
    } catch {
    // No history yet — that's fine
    }
    }

    private async handleSend(): Promise<void> {
        const content = this.inputValue.trim();
        if (!content || this.loading) return;

        this.inputValue = '';
        this.loading = true;
        this.error = '';

        // Optimistic user message
        this.messages = [...this.messages, { role: 'user', content }];

        try {
        const response = await sendMessage(this.sessionId, content);
        this.messages = [...this.messages, response.assistant_message];
        } catch (err) {
        this.error = err instanceof Error ? err.message : 'Failed to send message';
        } finally {
        this.loading = false;
        }
        }

        private handleKeyDown(e: KeyboardEvent): void {
        if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        void this.handleSend();
        }
        }

        private async handleClear(): Promise<void> {
            try {
            await clearConversation(this.sessionId);
            this.messages = [];
            this.sessionId = crypto.randomUUID();
            } catch (err) {
            this.error = err instanceof Error ? err.message : 'Failed to clear';
            }
            }

            render() {
            return html`
            <div class="messages" role="log" aria-live="polite" aria-label="Chat messages">
                ${this.messages.map(
                (msg) => html`<div class="message ${msg.role}">${msg.content}</div>`,
                )}
                ${this.loading ? html`<div class="message assistant" aria-busy="true">Thinking...</div>` : ''}
            </div>
            ${this.error ? html`<div class="error" role="alert">${this.error}</div>` : ''}
            <div class="input-area">
                <input .value=${this.inputValue} @input=${(e: InputEvent)=> {
                this.inputValue = (e.target as HTMLInputElement).value;
                }}
                @keydown=${this.handleKeyDown}
                placeholder="Ask a question..."
                aria-label="Chat message input"
                ?disabled=${this.loading}
                />
                <button @click=${this.handleSend} ?disabled=${this.loading} aria-label="Send message">Send</button>
                <button @click=${this.handleClear} ?disabled=${this.loading}
                    aria-label="Clear conversation">Clear</button>
            </div>
            `;
            }
            }

            declare global {
            interface HTMLElementTagNameMap {
            'ai-chat': AiChat;
            }
            }