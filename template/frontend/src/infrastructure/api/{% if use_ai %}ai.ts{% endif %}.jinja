/**
* AI API service — typed client for AI backend endpoints.
*
* Provides functions for RAG queries, document ingestion,
* agent execution, and conversation management.
*/
import { apiRequest } from '@/infrastructure/api/client';


export interface RAGQueryRequest {
question: string;
top_k?: number;
system_prompt?: string;
}

export interface RAGQueryResponse {
question: string;
answer: string;
sources: Array<{ id: string; score: number; content: string; }>;
    model: string;
    total_tokens: number;
    }

    export interface CompletionRequest {
    prompt: string;
    system_prompt?: string;
    max_tokens?: number;
    temperature?: number;
    }

    export interface CompletionResponse {
    text: string;
    model: string;
    usage: { prompt_tokens: number; completion_tokens: number; total_tokens: number };
    }

    export interface AgentRunRequest {
    goal: string;
    tools?: string[];
    max_steps?: number;
    agent_type?: 'react' | 'tool_calling';
    }

    export interface AgentRunResponse {
    goal: string;
    answer: string;
    steps: Array<{ step: number; thought: string; action: string; observation: string }>;
        tool_calls: number;
        success: boolean;
        }

        export interface ConversationMessage {
        role: 'user' | 'assistant';
        content: string;
        timestamp?: string;
        }

        export interface SendMessageResponse {
        user_message: ConversationMessage;
        assistant_message: ConversationMessage;
        sources: Array<Record<string, unknown>>;
            }


            /** Execute a RAG query against the knowledge base. */
            export function ragQuery(request: RAGQueryRequest): Promise<RAGQueryResponse> {
                return apiRequest<RAGQueryResponse>('/ai/rag/query', {
                    method: 'POST',
                    body: request,
                    });
                    }

                    /** Generate an AI completion. */
                    export function completion(request: CompletionRequest): Promise<CompletionResponse> {
                        return apiRequest<CompletionResponse>('/ai/completions', {
                            method: 'POST',
                            body: request,
                            });
                            }

                            /** Run an AI agent with a goal. */
                            export function runAgent(request: AgentRunRequest): Promise<AgentRunResponse> {
                                return apiRequest<AgentRunResponse>('/agents/run', {
                                    method: 'POST',
                                    body: request,
                                    });
                                    }

                                    /** Send a message in a conversation session. */
                                    export function sendMessage(
                                    sessionId: string,
                                    content: string,
                                    useRag = true,
                                    ): Promise<SendMessageResponse> {
                                        return apiRequest<SendMessageResponse>(`/conversations/${sessionId}/messages`, {
                                            method: 'POST',
                                            body: { content, use_rag: useRag },
                                            });
                                            }

                                            /** Get conversation history for a session. */
                                            export function getConversationHistory(
                                            sessionId: string,
                                            limit = 50,
                                            ): Promise<{ session_id: string; messages: ConversationMessage[] }> {
                                                return apiRequest(`/conversations/${sessionId}/history?limit=${limit}`);
                                                }

                                                /** Clear conversation history. */
                                                export function clearConversation(sessionId: string): Promise<void> {
                                                    return apiRequest(`/conversations/${sessionId}`, { method: 'DELETE'
                                                    });
                                                    }

                                                    /** Ingest a document into the knowledge base. */
                                                    export function ingestDocument(source: string): Promise<{ source:
                                                        string; chunk_count: number; success: boolean }> {
                                                        return apiRequest('/ai/rag/ingest', {
                                                        method: 'POST',
                                                        body: { source },
                                                        });
                                                        }


                                                        export interface KGNeighbor {
                                                        entity: string;
                                                        predicate?: string;
                                                        direction?: 'outgoing' | 'incoming';
                                                        relationships?: string[];
                                                        }

                                                        export interface KGQueryResponse {
                                                        entity: string;
                                                        depth: number;
                                                        neighbors: KGNeighbor[];
                                                        }

                                                        export interface KGTriplet {
                                                        subject: string;
                                                        predicate: string;
                                                        object: string;
                                                        }

                                                        export interface KGStatsResponse {
                                                        entity_count: number;
                                                        triplet_count: number;
                                                        backend: string;
                                                        }

                                                        export interface ExternalEntityResult {
                                                        id: string;
                                                        label: string;
                                                        description: string;
                                                        source: 'wikidata' | 'dbpedia' | 'conceptnet';
                                                        weight?: number;
                                                        }

                                                        {% if use_knowledge_graph %}
                                                        /** Query knowledge graph neighbors. */
                                                        export function queryKnowledgeGraph(entity: string, depth = 1):
                                                        Promise<KGQueryResponse> {
                                                            return apiRequest<KGQueryResponse>
                                                                ('/knowledge-graph/neighbors', {
                                                                method: 'POST',
                                                                body: { entity, depth },
                                                                });
                                                                }

                                                                /** Add a triplet to the knowledge graph. */
                                                                export function addKGTriplet(triplet: KGTriplet):
                                                                Promise<{ status: string }> {
                                                                    return apiRequest('/knowledge-graph/triplets', {
                                                                    method: 'POST',
                                                                    body: triplet,
                                                                    });
                                                                    }

                                                                    /** Get knowledge graph statistics. */
                                                                    export function getKGStats(): Promise
                                                                    <KGStatsResponse> {
                                                                        return apiRequest<KGStatsResponse>
                                                                            ('/knowledge-graph/stats');
                                                                            }
                                                                            {% endif %}
                                                                            {% if use_external_knowledge_graph is
                                                                            defined and use_external_knowledge_graph %}
                                                                            /** Look up an entity in an external
                                                                            knowledge graph. */
                                                                            export function lookupExternalEntity(
                                                                            entity: string,
                                                                            source: 'wikidata' | 'dbpedia' |
                                                                            'conceptnet' = 'wikidata',
                                                                            language = 'en',
                                                                            limit = 5,
                                                                            ): Promise<{ entity: string; results:
                                                                                ExternalEntityResult[] }> {
                                                                                return
                                                                                apiRequest('/knowledge-graph/external/lookup',
                                                                                {
                                                                                method: 'POST',
                                                                                body: { entity, source, language, limit
                                                                                },
                                                                                });
                                                                                }

                                                                                /** Get relations for an external
                                                                                entity. */
                                                                                export function
                                                                                getExternalEntityRelations(
                                                                                entityId: string,
                                                                                source: 'wikidata' | 'dbpedia' |
                                                                                'conceptnet' = 'wikidata',
                                                                                limit = 50,
                                                                                ): Promise<{ entity_id: string;
                                                                                    relations: KGTriplet[] }> {
                                                                                    return
                                                                                    apiRequest('/knowledge-graph/external/relations',
                                                                                    {
                                                                                    method: 'POST',
                                                                                    body: { entity_id: entityId, source,
                                                                                    limit },
                                                                                    });
                                                                                    }
                                                                                    {% endif %}