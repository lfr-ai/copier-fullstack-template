{%- if frontend_framework == "lit" %}
/**
* Main application entry point — Lit web components.
*/
import { LitElement, html, css } from 'lit';
import { customElement } from 'lit/decorators.js';
import { Router } from '@lit-labs/router';
import { provide } from '@lit/context';
import { Task } from '@lit/task';
import { apiRequest } from '@/api/client';
import { configContext } from '@/config/context';
import { config } from '@/config/env';
import { HealthResponseSchema } from '@/models';
import type { HealthResponse } from '@/models';
import './styles/tailwind.css';
import './styles/main.css';

@customElement('app-root')
export class AppRoot extends LitElement {
static styles = css`
:host {
display: block;
font-family: var(--font-sans, system-ui, -apple-system, sans-serif);
min-height: 100vh;
}
`;

/** Provide global config via Lit Context (dependency injection). */
@provide({ context: configContext })
appConfig = config;

/** Client-side router using @lit-labs/router. */
private _router = new Router(this, [
{
path: '/',
render: () => html`
<section class="hero">
  <h1>Welcome</h1>
  <p>Application is running.</p>
</section>
`,
},
{
path: '/dashboard',
render: () => html`<app-dashboard></app-dashboard>`,
},
]);

render() {
return html`
<header class="site-header">
  <nav aria-label="Main navigation">
    <a href="/" class="logo">{{ project_name }}</a>
    <ul class="nav-links">
      <li><a href="/" @click=${this._navigate}>Home</a></li>
      <li><a href="/dashboard" @click=${this._navigate}>Dashboard</a></li>
    </ul>
  </nav>
</header>

<main id="main-content">
  ${this._router.outlet()}
</main>

<footer class="site-footer">
  <p>&copy; ${new Date().getFullYear()} {{ project_name }}</p>
</footer>
`;
}

/** Handle navigation without full page reload. */
private _navigate(e: Event) {
e.preventDefault();
const anchor = (e.target as HTMLElement).closest('a');
if (anchor) {
this._router.goto(anchor.pathname);
}
}
}

/**
* Dashboard component demonstrating @lit/task for async data loading.
*/
@customElement('app-dashboard')
export class AppDashboard extends LitElement {
static styles = css`
:host { display: block; padding: 2rem; }
.stat-card {
background: var(--color-bg, #fff);
border: 1px solid #e2e8f0;
border-radius: var(--radius, 0.375rem);
padding: 1.5rem;
box-shadow: var(--shadow);
}
`;

/** Async task for fetching backend health — automatic lifecycle management. */
private _healthTask = new Task(this, {
task: async () => {
const raw = await apiRequest<unknown>('/health');
  return HealthResponseSchema.parse(raw);
  },
  args: () => [],
  });

  render() {
  return html`
  <h1>Dashboard</h1>
  <section class="stat-card" aria-label="Backend health status">
    <h2>Backend Health</h2>
    ${this._healthTask.render({
    pending: () => html`<p>Checking…</p>`,
    error: () => html`<p style="color: var(--color-error)">Unable to reach backend.</p>`,
    complete: (data: HealthResponse) => html`<p style="color: var(--color-success)">Status: ${data.status}</p>`,
    })}
  </section>
  `;
  }
  }

  declare global {
  interface HTMLElementTagNameMap {
  'app-root': AppRoot;
  'app-dashboard': AppDashboard;
  }
  }
  {%- elif frontend_framework == "react" %}
  /**
  * Main application entry point — React.
  *
  * This bootstrapper imports the React root from bootstrap.tsx.
  * Vite's React plugin handles JSX transformation.
  * Providers (QueryClient, Router, ErrorBoundary) are configured in bootstrap.tsx.
  */
  import './bootstrap';
  {%- endif %}