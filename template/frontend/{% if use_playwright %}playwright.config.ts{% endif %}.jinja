/**
* @module playwright.config
*
* Playwright end-to-end test configuration.
*
* - Test directory: `tests/e2e`.
* - Runs tests fully in parallel.
* - Retries twice in CI, zero locally.
* - Automatically starts a Vite dev server before the first test.
* - Project: **Chromium**.
*/
import { defineConfig, devices } from "@playwright/test";

const DEV_PORT = process.env.FRONTEND_PORT ?? "3000";
const DEV_URL = `http://127.0.0.1:${DEV_PORT}`;

export default defineConfig({
testDir: "./tests/e2e",
fullyParallel: true,
forbidOnly: !!process.env.CI,
retries: process.env.CI ? 2 : 0,
workers: process.env.CI ? 1 : undefined,
reporter: process.env.CI ? "line" : "html",
use: {
baseURL: DEV_URL,
trace: "on-first-retry",
},
projects: [
{
name: "chromium",
use: { ...devices["Desktop Chrome"] },
},
],
webServer: {
command: `pnpm dev --host 127.0.0.1 --port ${DEV_PORT}`,
url: DEV_URL,
reuseExistingServer: !process.env.CI,
},
});