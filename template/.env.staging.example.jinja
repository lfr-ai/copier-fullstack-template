
# ─── Staging environment file ───
# Copy to .env.staging:  cp .env.staging.example .env.staging
# Use with:  task docker:staging  (or: docker compose -f compose.yml -f compose.staging.yml --env-file .env.staging up)
# Generate secrets with:  python -c "import secrets; print(secrets.token_urlsafe(64))"

{{ project_slug | upper }}_ENVIRONMENT=staging
{{ project_slug | upper }}_DEBUG=false
{{ project_slug | upper }}_LOG_LEVEL=INFO
{{ project_slug | upper }}_SECRET_KEY=  # Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
{%- if database_backend in ('postgresql', 'azure_postgresql') %}
{{ project_slug | upper }}_DATABASE_URL=postgresql+psycopg://app:CHANGE_ME@db:5432/{{ project_slug }}
{%- elif database_backend == 'sqlite' %}
{{ project_slug | upper }}_DATABASE_URL=sqlite+aiosqlite:///data/{{ project_slug }}.db
{%- endif %}
{% if use_redis %}
{{ project_slug | upper }}_REDIS_URL=redis://redis:6379/0
{% endif %}
{% if use_celery %}
{{ project_slug | upper }}_CELERY_BROKER_URL=redis://redis:6379/1
{{ project_slug | upper }}_CELERY_RESULT_BACKEND=redis://redis:6379/2
{% endif %}
{% if use_auth %}
{{ project_slug | upper }}_JWT_SECRET_KEY=  # Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
{% endif %}
{% if use_caddy %}
CADDY_DOMAIN=staging.{{ project_slug | replace('_', '-') }}.example.com
{% endif %}
{% if secret_backend == 'azure_kv' %}
{{ project_slug | upper }}_AZURE_KEY_VAULT_URL=https://your-staging-vault.vault.azure.net/
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
{% endif %}

{{ project_slug | upper }}_CORS_ALLOWED_ORIGINS=https://staging.{{ project_slug | replace('_', '-') }}.example.com
