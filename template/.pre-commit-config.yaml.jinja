minimum_pre_commit_version: "4.0"
default_language_version:
  python: python{{ python_version }}

repos:
  - repo: https://github.com/pre-commit/pre-commit-hooks
    rev: v6.0.0
    hooks:
      - id: trailing-whitespace
      - id: end-of-file-fixer
      - id: check-yaml
        args: [--unsafe]
      - id: check-toml
      - id: check-json
        exclude: ^\.vscode/
      - id: check-ast
      - id: check-merge-conflict
      - id: check-docstring-first
      - id: check-added-large-files
        args: [--maxkb=1000]
      - id: check-case-conflict
      - id: check-illegal-windows-names
      - id: check-symlinks
      - id: destroyed-symlinks
      - id: check-executables-have-shebangs
      - id: check-shebang-scripts-are-executable
      - id: detect-private-key
      - id: fix-byte-order-marker
      - id: mixed-line-ending
        args: [--fix=lf]
      - id: no-commit-to-branch
        args: [--branch=main]
      - id: debug-statements
      - id: name-tests-test
        args: [--pytest-test-first]
        files: ^backend/tests/

  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.15.11
    hooks:
      - id: ruff
        args: [--fix, --exit-non-zero-on-fix]
      - id: ruff-format

  - repo: local
    hooks:
      - id: module-docstrings
        name: module-level docstring enforcement
        entry: uv run python tools/conventions/check_module_docstrings.py
        language: system
        pass_filenames: false

      - id: dependency-audit
        name: dependency vulnerability audit
        entry: uv run python tools/security/dependency_audit.py
        language: system
        pass_filenames: false
        always_run: true

      - id: ty-check
        name: ty type check
        entry: uvx ty check
        language: system
        types: [python]
        pass_filenames: false

      - id: biome-check
        name: biome check (lint + format)
        entry: bun run --cwd frontend biome check
        language: system
        files: \.(js|ts|tsx|jsx|css|json)$
        pass_filenames: false

  - repo: https://github.com/commitizen-tools/commitizen
    rev: v4.13.10
    hooks:
      - id: commitizen
        stages: [commit-msg]

  - repo: https://github.com/Yelp/detect-secrets
    rev: v1.5.0
    hooks:
      - id: detect-secrets
        args:
          - --baseline
          - .secrets.baseline
          - --exclude-files
          - (^|[\\/])tests[\\/]

  - repo: https://github.com/shellcheck-py/shellcheck-py
    rev: v0.11.0.1
    hooks:
      - id: shellcheck
        args: [--severity=warning]

  - repo: https://github.com/adrienverge/yamllint
    rev: v1.38.0
    hooks:
      - id: yamllint
        args: [-c, .yamllint.yaml]

  - repo: https://github.com/hadolint/hadolint
    rev: v2.14.0
    hooks:
      - id: hadolint-docker

  - repo: https://github.com/crate-ci/typos
    rev: v1.45.1
    hooks:
      - id: typos

  - repo: https://github.com/rubik/xenon
    rev: v0.9.3
    hooks:
      - id: xenon
        args: [--max-absolute=B, --max-modules=B, --max-average=A]

  - repo: https://github.com/DavidAnson/markdownlint-cli2
    rev: v0.22.0
    hooks:
      - id: markdownlint-cli2
        args: ["--config", ".markdownlint-cli2.yaml"]
        files: ^(README|CONTRIBUTING|CHANGELOG|SECURITY|CODE_OF_CONDUCT|AGENTS)\.md$

  - repo: https://github.com/lycheeverse/lychee.git
    rev: lychee-v0.23.0
    hooks:
      - id: lychee
        args: ["--no-progress", "--config", ".lychee.toml"]
        types_or: [markdown, html, rst]
        stages: [manual]

  - repo: https://github.com/rhysd/actionlint
    rev: v1.7.12
    hooks:
      - id: actionlint
{% if api_style in ("rest", "both") %}
  - repo: local
    hooks:
      - id: spectral-lint
        name: spectral openapi lint
        entry: npx @stoplight/spectral-cli lint docs/api/openapi.yaml --ruleset .spectral.yaml
        language: system
        files: ^docs/api/openapi.*\.(yaml|yml|json)$
        pass_filenames: false
        stages: [pre-commit, pre-push, manual]
{% endif %}
  - repo: local
    hooks:
      - id: jscpd
        name: jscpd copy-paste detection
        entry: jscpd --config .jscpd.json
        language: node
        additional_dependencies: [jscpd@4.0.5]
        pass_filenames: false
        always_run: true
        stages: [pre-commit, pre-push, manual]

      - id: backend-test-suite
        name: backend tests (unit + property + registry)
        entry: uv run tox -c backend/tox.ini -e py{{ python_version | replace('.', '') }},registry-check,registry-test
        language: system
        pass_filenames: false
        always_run: true
        stages: [pre-push, manual]

      - id: frontend-test-suite
        name: frontend tests (unit)
        entry: bun --cwd frontend run test
        language: system
        pass_filenames: false
        always_run: true
        stages: [pre-push, manual]

      - id: backend-integration-tests
        name: backend integration tests
        entry: uv run tox -c backend/tox.ini -e integration
        language: system
        pass_filenames: false
        always_run: true
        stages: [pre-push, manual]
