# Spectral OpenAPI Linting Configuration
# https://docs.stoplight.io/docs/spectral/674b27b261c3c-overview
# Auto-generated by copier-fullstack-template
---
extends:
  - "spectral:oas"

# Rule severity levels: off, warn, error, info, hint

rules:
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # OpenAPI Core Rules (from spectral:oas)
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  # Strengthen default rules
  operation-operationId: error
  operation-description: warn
  operation-tags: warn
  operation-tag-defined: error
  info-contact: warn
  info-description: error
  info-license: off  # Not required for internal APIs
  openapi-tags: warn
  openapi-tags-alphabetical: off
  oas3-api-servers: warn
  oas3-examples-value-or-externalValue: error
  oas3-operation-security-defined: error
  oas3-schema: error
  oas3-unused-component: warn
  oas3-valid-media-example: error
  oas3-valid-schema-example: error
  path-keys-no-trailing-slash: error
  path-not-include-query: error
  no-$ref-siblings: error
  typed-enum: warn
  duplicated-entry-in-enum: error
  path-declarations-must-exist: error
  path-params: error

  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # Custom Production-Ready Rules
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  # Require operationId to be camelCase
  operation-operationId-valid-in-url:
    description: "operationId must be valid URL-safe string"
    severity: error
    given: "$.paths[*][*].operationId"
    then:
      function: pattern
      functionOptions:
        match: "^[a-zA-Z][a-zA-Z0-9]*$"

  # Require request body examples for POST/PUT/PATCH
  request-body-example:
    description: "Request body should have an example"
    severity: warn
    given: "$.paths[*][post,put,patch].requestBody.content[*]"
    then:
      field: example
      function: truthy

  # Require response examples for 2xx responses
  response-success-example:
    description: "Success responses should have examples"
    severity: warn
    given: "$.paths[*][*].responses[2*].content[*]"
    then:
      field: example
      function: truthy

  # Require descriptions for all parameters
  parameter-description:
    description: "Parameters should have descriptions"
    severity: warn
    given: "$.paths[*][*].parameters[*]"
    then:
      field: description
      function: truthy

  # Require schema descriptions for components
  component-schema-description:
    description: "Component schemas should have descriptions"
    severity: warn
    given: "$.components.schemas[*]"
    then:
      field: description
      function: truthy

  # Require summary for operations (not just description)
  operation-summary:
    description: "Operations should have a summary"
    severity: warn
    given: "$.paths[*][get,post,put,patch,delete]"
    then:
      field: summary
      function: truthy

  # Prevent overly generic response descriptions
  no-generic-response-description:
    description: "Responses should have meaningful descriptions"
    severity: warn
    given: "$.paths[*][*].responses[*].description"
    then:
      function: pattern
      functionOptions:
        notMatch: "^(OK|Success|Error|Bad Request|Not Found|Internal Server Error)$"

  # Require error response schemas to have message field
  error-response-schema:
    description: "Error responses should define a structured error format"
    severity: info
    given: "$.paths[*][*].responses[4*,5*].content['application/json'].schema"
    then:
      - field: properties.detail
        function: truthy

  # Enforce semantic versioning in info.version
  info-version-semver:
    description: "API version should follow semantic versioning"
    severity: warn
    given: "$.info.version"
    then:
      function: pattern
      functionOptions:
        match: "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"

  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # Security Rules
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  # Require security definition at spec level
  security-defined:
    description: "API should define security requirements"
    severity: warn
    given: "$"
    then:
      - field: security
        function: truthy
      - field: components.securitySchemes
        function: truthy

  # Prevent basic auth in production APIs
  no-basic-auth:
    description: "Basic authentication is discouraged"
    severity: warn
    given: "$.components.securitySchemes[*]"
    then:
      field: type
      function: pattern
      functionOptions:
        notMatch: "^http$"

  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # Naming Convention Rules
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  # Paths should be kebab-case
  path-casing:
    description: "Paths should use kebab-case"
    severity: warn
    given: "$.paths"
    then:
      field: "@key"
      function: pattern
      functionOptions:
        match: "^(\\/[a-z][a-z0-9-]*|\\{[a-zA-Z_][a-zA-Z0-9_]*\\})*\\/?$"

  # Property names should be snake_case (Python convention)
  property-casing:
    description: "Property names should use snake_case"
    severity: warn
    given: "$.components.schemas[*].properties"
    then:
      field: "@key"
      function: pattern
      functionOptions:
        match: "^[a-z][a-z0-9_]*$"

  # Schema names should be PascalCase
  schema-names-pascal-case:
    description: "Schema names should use PascalCase"
    severity: warn
    given: "$.components.schemas"
    then:
      field: "@key"
      function: pattern
      functionOptions:
        match: "^[A-Z][a-zA-Z0-9]*$"

  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # Pagination & Collections
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  # GET operations returning arrays should support pagination
  collection-pagination:
    description: "Collection endpoints should support pagination parameters"
    severity: info
    given: "$.paths[*].get"
    then:
      function: schema
      functionOptions:
        schema:
          type: object
          properties:
            parameters:
              type: array
              contains:
                type: object
                properties:
                  name:
                    enum: ["limit", "offset", "cursor", "page", "page_size"]

  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # Response Codes
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  # POST should return 201 or 202, not just 200
  post-response-codes:
    description: "POST operations should use 201 (Created) or 202 (Accepted)"
    severity: info
    given: "$.paths[*].post.responses"
    then:
      function: schema
      functionOptions:
        schema:
          type: object
          anyOf:
            - required: ["201"]
            - required: ["202"]
            - required: ["204"]

  # DELETE should return 204 for success
  delete-response-204:
    description: "DELETE operations should return 204 (No Content)"
    severity: info
    given: "$.paths[*].delete.responses"
    then:
      function: schema
      functionOptions:
        schema:
          type: object
          anyOf:
            - required: ["204"]
            - required: ["200"]
            - required: ["202"]

  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # Content Types
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  # Prefer application/json over text/plain for responses
  json-content-type:
    description: "Responses should use application/json content type"
    severity: info
    given: "$.paths[*][*].responses[2*].content"
    then:
      function: schema
      functionOptions:
        schema:
          type: object
          required: ["application/json"]

# Exceptions for specific paths or patterns
except:
  "docs/api/openapi.yaml#/info/license":
    - info-license
