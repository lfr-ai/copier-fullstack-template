# ─── Personal local-only overrides ────────────────────────────────────────
#
# Copy to .env.local:  cp .env.local.example .env.local
#
# Values here override .env for YOUR machine only.
# .env.local is always gitignored — never committed.
#
# Pydantic-settings loads .env first, then .env.local on top.
# Only list variables you need to change from .env defaults.

# Example: use a different local database password
# {{ project_slug | upper }}_DATABASE_URL=postgresql+psycopg://postgres:my-local-password@localhost:5432/{{ project_slug }}

# Example: bump log level for a noisy debugging session
# {{ project_slug | upper }}_LOG_LEVEL=TRACE

# Example: personal API keys for local AI development
# {{ project_slug | upper }}_OPENAI_API_KEY=sk-...
