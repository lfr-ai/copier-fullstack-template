{
  "version": "0.2",
  "language": "en",
  "dictionaries": [
    "python",
    "typescript",
    "node",
    "html",
    "css",
    "bash",
    "docker",
    "softwareTerms"
  ],
  "words": [
    "{{ project_slug }}",
    "{{ project_name | lower | replace(' ', '') }}",
    "fastapi",
    "uvicorn",
    "pydantic",
    "sqlalchemy",
    "alembic",
    "asyncpg",
    "psycopg",
    "httpx",
    "structlog",
    "jinja",
    "celery",
    "redis",
    "tailwindcss",
    "vitest",
    "vite",
    "eslint",
    "prettier",
    "biome",
    "biomejs",
    "ruff",
    "hadolint",
    "shellcheck",
    "editorconfig",
    "markdownlint",
    "devcontainer",
    "pyproject",
    "fullstack",
    "copier",
    "uv",
    "buildx",
    "bake",
    "lychee",
    "jscpd",
    "hmas",
    "jsonrpc"
{%- if api_style in ('graphql', 'both') -%}
    ,
    "graphql",
    "graphiql",
    "strawberry",
    "dataloaders",
    "dataloader"
{%- endif %}

  ],
  "ignorePaths": [
    "node_modules/**",
    ".venv/**",
    "dist/**",
    "build/**",
    "htmlcov/**",
    "coverage/**",
    "*.lock",
    "uv.lock",
    "bun.lock",
    "*.parquet",
    "**/__pycache__/**",
    ".tox/**",
    ".ruff_cache/**",
    ".ty/**"
  ],
  "overrides": [
    {
      "filename": "**/*.py",
      "language": "en",
      "dictionaries": ["python"]
    },
    {
      "filename": "**/*.{ts,tsx}",
      "language": "en",
      "dictionaries": ["typescript"]
    }
  ]
}
