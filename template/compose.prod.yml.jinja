
services:
  app:
    build:
      target: prod
    image: {{ project_slug }}-app:${TAG:-latest}
    restart: unless-stopped
    security_opt: [no-new-privileges:true]
    read_only: true
    tmpfs: ["/tmp", "/app/logs"]
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    environment:
      {{ project_slug | upper }}_ENVIRONMENT: prod
      {{ project_slug | upper }}_LOG_LEVEL: WARNING
      {{ project_slug | upper }}_SECRET_KEY: ${{ '{' }}{{ project_slug | upper }}_SECRET_KEY:?SECRET_KEY must be set for production{{ '}' }}
    deploy:
      resources:
        limits:
          cpus: "${APP_CPU_LIMIT:-2.0}"
          memory: ${APP_MEMORY_LIMIT:-1024M}
{%- if use_celery %}

  worker:
    build:
      target: prod
    image: {{ project_slug }}-app:${TAG:-latest}
    restart: unless-stopped
    security_opt: [no-new-privileges:true]
    read_only: true
    tmpfs: ["/tmp", "/app/logs"]
    environment:
      {{ project_slug | upper }}_ENVIRONMENT: prod
      {{ project_slug | upper }}_LOG_LEVEL: WARNING
    deploy:
      resources:
        limits:
          cpus: "${WORKER_CPU_LIMIT:-1.0}"
          memory: ${WORKER_MEMORY_LIMIT:-512M}
{%- endif %}

{%- if use_caddy %}

  frontend:
    deploy:
      replicas: 0

  caddy:
    build:
      context: .
      dockerfile: caddy/Containerfile
    image: {{ project_slug }}-caddy:${TAG:-latest}
    restart: unless-stopped
    security_opt: [no-new-privileges:true]
    profiles: []  # override gateway profile from base compose.yml
    environment:
      CADDY_DOMAIN: ${CADDY_DOMAIN:?CADDY_DOMAIN is required in production}
      BACKEND_PORT: "8000"
      FRONTEND_PORT: "3000"
{%- else %}

  frontend:
    build:
      target: prod
    image: {{ project_slug }}-frontend:${TAG:-latest}
    restart: unless-stopped
    security_opt: [no-new-privileges:true]
{%- endif %}
{%- if use_redis %}

  redis:
    restart: unless-stopped
    security_opt: [no-new-privileges:true]
    command: ["redis-server", "--requirepass", "${REDIS_PASSWORD:?REDIS_PASSWORD must be set for production}"]
    deploy:
      resources:
        limits:
          cpus: "${REDIS_CPU_LIMIT:-1.0}"
          memory: ${REDIS_MEMORY_LIMIT:-256M}
{%- endif %}
{%- if database_backend == "postgresql" %}

  db:
    restart: unless-stopped
    security_opt: [no-new-privileges:true]
    environment:
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:?POSTGRES_PASSWORD must be set for production}
    deploy:
      resources:
        limits:
          cpus: "${DB_CPU_LIMIT:-2.0}"
          memory: ${DB_MEMORY_LIMIT:-1024M}
{%- endif %}
