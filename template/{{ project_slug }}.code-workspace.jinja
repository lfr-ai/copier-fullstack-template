{
  "folders": [
    {
      "name": "Root",
      "path": "."
    },
    {
      "name": "Backend (src)",
      "path": "src/{{ project_slug }}"
    },
    {
      "name": "Frontend",
      "path": "frontend"
    },
    {
      "name": "Tests",
      "path": "tests"
    }
  ],
  "settings": {
    "files.exclude": {
      "**/__pycache__": true,
      "**/.pytest_cache": true,
      "**/.ruff_cache": true,
      "**/node_modules": true,
      "**/.venv": true
    },
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.testing.pytestEnabled": true,
    "editor.formatOnSave": true,
    "[python]": {
      "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "[typescript]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode"
    }
  },
  "extensions": {
    "recommendations": [
      "charliermarsh.ruff",
      "ms-python.python",
      "esbenp.prettier-vscode",
      "dbaeumer.vscode-eslint",
      "tamasfe.even-better-toml",
      "redhat.vscode-yaml"
    ]
  }
}
