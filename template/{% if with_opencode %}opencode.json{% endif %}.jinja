{%- if with_opencode %}
{
"$schema": "https://opencode.ai/config.json",

"provider": {
"github-copilot": {
"options": {
"timeout": 600000
}
},
"openai": {
"options": {
"timeout": 600000,
"setCacheKey": true
}
},
"anthropic": {
"options": {
"timeout": 600000,
"setCacheKey": true
}
},
"google": {
"options": {
"timeout": 600000
}
},
"openrouter": {
"options": {
"timeout": 600000
}
}
},

"model": "openai/gpt-5-mini",
"default_agent": "coordinator",

"enabled_providers": [
"github-copilot",
"openai",
"anthropic",
"google",
"openrouter"
],

"autoupdate": "notify",
"share": "manual",

"mcp": {
"context7": {
"type": "remote",
"url": "https://mcp.context7.com/mcp",
"enabled": true,
"timeout": 15000
},
"gh_grep": {
"type": "remote",
"url": "https://mcp.grep.app",
"enabled": true,
"timeout": 15000
}
},

"plugin": [
"oh-my-opencode",
"opencode-agent-skills",
"opencode-dynamic-context-pruning",
"opencode-shell-strategy",
"superpowers@git+https://github.com/obra/superpowers.git"
],

"instructions": [
".github/instructions/**",
".claude/rules/**",
".opencode/context/**",
".opencode/agents/**",
"AGENTS.md",
"CONTRIBUTING.md",
"agent-instructions.md",
"docs/OPENCODE.md",
"docs/ARCHITECTURE.md",
"docs/DEVELOPMENT.md",
"docs/TESTING.md",
"docs/conventions/*.md"
],

"formatter": {
"ruff": {
"command": ["ruff", "format", "--line-length", "88", "$FILE"],
"extensions": [".py"]
},
"prettier": {
"command": ["npx", "prettier", "--write", "--print-width", "88", "$FILE"],
"extensions": [".ts", ".tsx", ".js", ".jsx", ".json", ".jsonc", ".css", ".less", ".html", ".yaml", ".yml", ".md"]
}
},

"permission": {
"edit": "ask",
"bash": {
"*": "ask",
"task *": "allow",
"uv *": "allow",
"pnpm *": "allow",
"python -m pytest*": "allow",
"ruff *": "allow",
"mypy *": "allow",
"git status*": "allow",
"git diff*": "allow",
"git log*": "allow",
"git branch*": "allow",
"git show*": "allow",
"grep *": "allow",
"find *": "allow",
"cat *": "allow",
"head *": "allow",
"tail *": "allow",
"wc *": "allow",
"ls *": "allow",
"rm -rf *": "deny",
"git push*": "deny",
"git merge*": "deny",
"git rebase*": "deny",
"git reset --hard*": "deny",
"docker rm*": "deny",
"docker system prune*": "deny",
"sudo *": "deny",
"gsd *": "allow",
"npx gsd-pi*": "allow",
"opencode --agent*": "allow",
"bunx oh-my-opencode*": "allow",
"bunx oh-my-openagent*": "allow"
},
"webfetch": "allow",
"skill": {
"*": "allow"
}
},

"tui": {
"scroll_acceleration": {
"enabled": true
},
"diff_style": "auto"
},

"watcher": {
"ignore": [
".git/**",
"node_modules/**",
".venv/**",
"dist/**",
"build/**",
"coverage/**",
"playwright-report/**",
"test-results/**",
"**/__pycache__/**",
"*.pyc",
".mypy_cache/**",
".ruff_cache/**",
".pytest_cache/**",
"htmlcov/**",
".tox/**",
".gsd/**",
".sisyphus/**",
"profiles/**"
]
},

"compaction": {
"auto": true,
"prune": true,
"reserved": 10000
}
}
{%- endif %}