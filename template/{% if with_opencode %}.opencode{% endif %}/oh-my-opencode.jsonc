{%- if with_opencode %}
{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // ── Agent Model Overrides ──────────────────────────────────────────────
  // Override built-in agent models. Available agents:
  // sisyphus, hephaestus, prometheus, oracle, librarian, explore,
  // multimodal-looker, metis, momus, atlas
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-6",
      "ultrawork": { "model": "anthropic/claude-opus-4-6", "variant": "max" },
      "fallback_models": ["openrouter/z-ai/glm-5", "kimi-for-coding/k2p5"]
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "high"
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-6",
      "prompt_append": "Use deep & quick agents in parallel. Identify scope and ambiguities before planning."
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1"
    },
    "librarian": {
      "model": "google/gemini-3-flash"
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6",
      "prompt_append": "Focus on codebase navigation, file discovery, and structural analysis. Prefer breadth-first exploration."
    },
    "momus": {
      "model": "anthropic/claude-sonnet-4-6",
      "prompt_append": "Provide constructive, actionable critique. Focus on correctness, edge cases, and architecture compliance."
    },
    "metis": {
      "model": "google/gemini-3-flash",
      "variant": "high"
    }
  },

  // ── Category Model Delegation ──────────────────────────────────────────
  // Domain-specific model routing used by the task() tool.
  // When Sisyphus delegates, it picks a category, not a model name.
  "categories": {
    "visual-engineering": {
      "model": "google/gemini-3.1-pro",
      "variant": "high"
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "high"
    },
    "quick": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "artistry": {
      "model": "google/gemini-3.1-pro",
      "variant": "high"
    },
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "unspecified-high": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max"
    },
    "writing": {
      "model": "google/gemini-3-flash"
    }
  },

  // ── Background Task Concurrency ────────────────────────────────────────
  "background_task": {
    "defaultConcurrency": 10,
    "staleTimeoutMs": 240000,
    "providerConcurrency": {
      "anthropic": 5,
      "openai": 8,
      "github-copilot": 8,
      "google": 12
    },
    "modelConcurrency": {
      "anthropic/claude-opus-4-6": 2,
      "openai/gpt-5.4": 3
    },
    "circuitBreaker": {
      "enabled": true,
      "failureThreshold": 3,
      "resetTimeoutMs": 60000
    }
  },

  // ── Sisyphus Orchestration ─────────────────────────────────────────────
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },

  // ── Disable oh-my-opencode built-in MCPs (project uses its own in opencode.json)
  "disabled_mcps": ["context7", "grep_app"],

  // ── Skills, Hooks, Commands ────────────────────────────────────────────
  "disabled_skills": [],
  "disabled_hooks": [],
  "disabled_commands": [],

  // ── Runtime Fallback ───────────────────────────────────────────────────
  // Auto-switches to backup models on API errors
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },

  // ── Hash-Anchored Edits ────────────────────────────────────────────────
  // LINE#ID content hash validates every change. Zero stale-line errors.
  "hashline_edit": true,

  // ── Comment Checker ────────────────────────────────────────────────────
  "comment_checker": {
    "custom_prompt": "Review code comments. Keep only high-signal comments explaining WHY, constraints, trade-offs, invariants, security implications, or non-obvious behavior. Rewrite vague comments to be precise and concise. Remove comments restating code. Comments:\\n\\n{{comments}}"
  },

  // ── Experimental Features ──────────────────────────────────────────────
  "experimental": {
    "aggressive_truncation": false,
    "task_system": true,
    "auto_resume": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "detailed",
      "turn_protection": { "enabled": true, "turns": 3 },
      "strategies": {
        "deduplication": { "enabled": true },
        "supersede_writes": { "enabled": true, "aggressive": false },
        "purge_errors": { "enabled": true, "turns": 5 }
      }
    }
  }
}
{%- endif %}
