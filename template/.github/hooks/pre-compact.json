{
  "hooks": {
    "PreCompact": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/save-context.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File .github\\hooks\\scripts\\save-context.ps1",
        "timeout": 10,
        "env": {
          "CONTEXT_LOG_DIR": "logs/copilot/context"
        }
      }
    ]
  }
}
