{
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/scan-secrets.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File .github\\hooks\\scripts\\scan-secrets.ps1",
        "timeout": 30,
        "env": {
          "SCAN_MODE": "warn",
          "SCAN_SCOPE": "diff",
          "SECRETS_LOG_DIR": "logs/copilot/secrets"
        }
      }
    ]
  }
}
