{% raw %}
name: CI

on:
  push:
    branches: [main, develop]
  pull_request:

concurrency:
  group: ci-${{ github.ref }}
  cancel-in-progress: true

permissions:
  contents: read

jobs:
  lint:
    name: Lint & Format
    runs-on: ubuntu-latest
    timeout-minutes: 10
    defaults:
      run:
        working-directory: backend
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v5
        with:
          python-version: "{% endraw %}{{ python_version }}{% raw %}"
          enable-cache: true
      - run: uv sync --frozen
      - name: Ruff lint
        run: uv run ruff check src/ tests/
      - name: Ruff format
        run: uv run ruff format --check src/ tests/

  typecheck:
    name: Type Check
    runs-on: ubuntu-latest
    timeout-minutes: 10
    defaults:
      run:
        working-directory: backend
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v5
        with:
          python-version: "{% endraw %}{{ python_version }}{% raw %}"
          enable-cache: true
      - run: uv sync --frozen
      - name: Type check
        run: uv run ty check src/

  security:
    name: Security Scan
    runs-on: ubuntu-latest
    timeout-minutes: 10
    defaults:
      run:
        working-directory: backend
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v5
        with:
          python-version: "{% endraw %}{{ python_version }}{% raw %}"
          enable-cache: true
      - run: uv sync --frozen
      - name: Bandit via Ruff
        run: uv run ruff check --select S src/
      - name: Dependency audit
        run: uv run pip-audit

  test:
    name: Test (Python ${{ matrix.python-version }})
    runs-on: ubuntu-latest
    timeout-minutes: 20
    defaults:
      run:
        working-directory: backend
    strategy:
      fail-fast: false
      matrix:
        python-version: ["{% endraw %}{{ python_version }}{% raw %}"{% endraw %}{% if python_version == "3.12" %}{% raw %}, "3.13"{% endraw %}{% endif %}{% raw %}]
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v5
        with:
          python-version: ${{ matrix.python-version }}
          enable-cache: true
      - run: uv sync --frozen
      - name: Unit & property tests
        run: uv run pytest tests/unit tests/property -v --tb=short --cov --cov-report=xml
      - name: Upload coverage
        if: matrix.python-version == '{% endraw %}{{ python_version }}{% raw %}'
        uses: codecov/codecov-action@v5
        with:
          file: coverage.xml
        env:
          CODECOV_TOKEN: ${{ secrets.CODECOV_TOKEN }}
{% endraw %}
{% if database_backend in ("postgresql", "sqlite") or use_redis %}
{% raw %}
  integration:
    name: Integration Tests
    runs-on: ubuntu-latest
    timeout-minutes: 20
    needs: [lint, typecheck]
    defaults:
      run:
        working-directory: backend
    services:
{% endraw %}
{%- if database_backend == "postgresql" %}
{% raw %}
      postgres:
        image: postgres:17-alpine
        env:
          POSTGRES_USER: postgres
          POSTGRES_PASSWORD: postgres
          POSTGRES_DB: {% endraw %}{{ project_slug }}_test{% raw %}
        ports:
          - 5432:5432
        options: >-
          --health-cmd "pg_isready -U postgres"
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
{% endraw %}
{%- endif %}
{%- if use_redis %}
{% raw %}
      redis:
        image: redis:7-alpine
        ports:
          - 6379:6379
        options: >-
          --health-cmd "redis-cli ping"
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
{% endraw %}
{%- endif %}
{% raw %}
    env:
      {% endraw %}{{ project_slug | upper }}{% raw %}_ENVIRONMENT: test
{% endraw %}
{%- if database_backend == "postgresql" %}
{% raw %}
      {% endraw %}{{ project_slug | upper }}{% raw %}_DATABASE_URL: postgresql+psycopg://postgres:postgres@localhost:5432/{% endraw %}{{ project_slug }}_test{% raw %}
{% endraw %}
{%- elif database_backend == "sqlite" %}
{% raw %}
      {% endraw %}{{ project_slug | upper }}{% raw %}_DATABASE_URL: sqlite+aiosqlite:///data/{% endraw %}{{ project_slug }}_test{% raw %}.db
{% endraw %}
{%- endif %}
{%- if use_redis %}
{% raw %}
      {% endraw %}{{ project_slug | upper }}{% raw %}_REDIS_URL: redis://localhost:6379/0
{% endraw %}
{%- endif %}
{% raw %}
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v5
        with:
          python-version: "{% endraw %}{{ python_version }}{% raw %}"
          enable-cache: true
      - run: uv sync --frozen
{% endraw %}
{%- if database_backend == "sqlite" %}
{% raw %}
      - name: Create SQLite data directory
        run: mkdir -p data
{% endraw %}
{%- endif %}
{% raw %}
      - name: Integration tests
        run: uv run pytest tests/integration -v --tb=short
{% endraw %}
{% endif %}
{% raw %}
  frontend:
    name: Frontend Checks
    runs-on: ubuntu-latest
    timeout-minutes: 15
    defaults:
      run:
        working-directory: frontend
    steps:
      - uses: actions/checkout@v4
      - uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest
      - run: bun install --frozen-lockfile
      - run: bun run lint
      - run: bun run typecheck
      - run: bun run test

  container:
    name: Container Build & Lint
    runs-on: ubuntu-latest
    timeout-minutes: 15
    steps:
      - uses: actions/checkout@v4
      - name: Lint Containerfiles
        uses: hadolint/hadolint-action@v3
        with:
          dockerfile: Containerfile
      - name: Lint frontend Containerfile
        uses: hadolint/hadolint-action@v3
        with:
          dockerfile: frontend/Containerfile
{%- endraw %}
{%- if use_caddy %}
{%- raw %}
      - name: Lint caddy Containerfile
        uses: hadolint/hadolint-action@v3
        with:
          dockerfile: caddy/Containerfile
{%- endraw %}
{%- endif %}
{%- raw %}
      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3
      - name: Build all production images
        uses: docker/bake-action@v7
        with:
          source: .
          targets: prod
          files: docker-bake.hcl
          load: true
          set: |
            *.cache-from=type=gha
            *.cache-to=type=gha,mode=max

  spellcheck:
    name: Spell Check
    runs-on: ubuntu-latest
    timeout-minutes: 5
    steps:
      - uses: actions/checkout@v4
      - uses: crate-ci/typos@v1
{% endraw %}
