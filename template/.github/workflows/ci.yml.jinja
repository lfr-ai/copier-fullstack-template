{% raw %}
name: CI

on:
  push:
    branches: [main, develop]
  pull_request:

concurrency:
  group: ci-${{ github.ref }}
  cancel-in-progress: true

permissions:
  contents: read

jobs:
  lint:
    name: Lint & Format
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@v6
      - uses: astral-sh/setup-uv@v7
        with:
          python-version: "{% endraw %}{{ python_version }}{% raw %}"
          enable-cache: true
      - run: uv sync --frozen
      - name: Ruff lint
        run: uv run ruff check src/ tests/
      - name: Ruff format
        run: uv run ruff format --check src/ tests/

  typecheck:
    name: Type Check
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@v6
      - uses: astral-sh/setup-uv@v7
        with:
          python-version: "{% endraw %}{{ python_version }}{% raw %}"
          enable-cache: true
      - run: uv sync --frozen
      - name: Type check
        run: uv run ty check src/

  security:
    name: Security Scan
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@v6
      - uses: astral-sh/setup-uv@v7
        with:
          python-version: "{% endraw %}{{ python_version }}{% raw %}"
          enable-cache: true
      - run: uv sync --frozen
      - name: Bandit via Ruff
        run: uv run ruff check --select S src/

  test:
    name: Test (Python ${{ matrix.python-version }})
    runs-on: ubuntu-latest
    timeout-minutes: 20
    strategy:
      fail-fast: false
      matrix:
        python-version: ["{% endraw %}{{ python_version }}{% raw %}"{% endraw %}{% if python_version == "3.12" %}{% raw %}, "3.13"{% endraw %}{% endif %}{% raw %}]
    steps:
      - uses: actions/checkout@v6
      - uses: astral-sh/setup-uv@v7
        with:
          python-version: ${{ matrix.python-version }}
          enable-cache: true
      - run: uv sync --frozen
      - name: Unit & property tests
        run: uv run pytest tests/unit tests/property -v --tb=short --cov --cov-report=xml
      - name: Upload coverage
        if: matrix.python-version == '{% endraw %}{{ python_version }}{% raw %}'
        uses: codecov/codecov-action@v5
        with:
          file: coverage.xml
        env:
          CODECOV_TOKEN: ${{ secrets.CODECOV_TOKEN }}
{% endraw %}
{% if database_backend == "postgresql" or use_redis %}
{% raw %}
  integration:
    name: Integration Tests
    runs-on: ubuntu-latest
    timeout-minutes: 20
    needs: [lint, typecheck]
    services:
{% endraw %}
{%- if database_backend == "postgresql" %}
{% raw %}
      postgres:
        image: postgres:17-alpine
        env:
          POSTGRES_USER: postgres
          POSTGRES_PASSWORD: postgres
          POSTGRES_DB: {% endraw %}{{ project_slug }}_test{% raw %}
        ports:
          - 5432:5432
        options: >-
          --health-cmd "pg_isready -U postgres"
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
{% endraw %}
{%- endif %}
{%- if use_redis %}
{% raw %}
      redis:
        image: redis:7-alpine
        ports:
          - 6379:6379
        options: >-
          --health-cmd "redis-cli ping"
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
{% endraw %}
{%- endif %}
{% raw %}
    env:
{% endraw %}
{%- if database_backend == "postgresql" %}
{% raw %}
      {% endraw %}{{ project_slug | upper }}{% raw %}_DATABASE_URL: postgresql+psycopg://postgres:postgres@localhost:5432/{% endraw %}{{ project_slug }}_test{% raw %}
{% endraw %}
{%- endif %}
{%- if use_redis %}
{% raw %}
      {% endraw %}{{ project_slug | upper }}{% raw %}_REDIS_URL: redis://localhost:6379/0
{% endraw %}
{%- endif %}
{% raw %}
    steps:
      - uses: actions/checkout@v6
      - uses: astral-sh/setup-uv@v7
        with:
          python-version: "{% endraw %}{{ python_version }}{% raw %}"
          enable-cache: true
      - run: uv sync --frozen
      - name: Integration tests
        run: uv run pytest tests/integration -v --tb=short
{% endraw %}
{% endif %}
{% raw %}
  frontend:
    name: Frontend Checks
    runs-on: ubuntu-latest
    timeout-minutes: 15
    defaults:
      run:
        working-directory: frontend
    steps:
      - uses: actions/checkout@v6
      - uses: pnpm/action-setup@v4
        with:
          version: 9
      - uses: actions/setup-node@v4
        with:
          node-version: "{% endraw %}{{ node_version }}{% raw %}"
          cache: pnpm
          cache-dependency-path: frontend/pnpm-lock.yaml
      - run: pnpm install --frozen-lockfile
      - run: pnpm run lint
      - run: pnpm run test

  container:
    name: Container Lint
    runs-on: ubuntu-latest
    timeout-minutes: 5
    steps:
      - uses: actions/checkout@v6
      - uses: hadolint/hadolint-action@v3.1.0
        with:
          dockerfile: Containerfile
{% endraw %}
