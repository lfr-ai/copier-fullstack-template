
# ─── Test environment file ───
# Copy to .env.test:  cp .env.test.example .env.test
# Use with:  task docker:test  (or: docker compose -f compose.yml -f compose.test.yml --env-file .env.test up)

{{ project_slug | upper }}_ENVIRONMENT=test
{{ project_slug | upper }}_DEBUG=false
{{ project_slug | upper }}_LOG_LEVEL=WARNING
{{ project_slug | upper }}_SECRET_KEY=test-secret-key-not-for-production-at-least-32-char
{%- if database_backend in ('postgresql', 'azure_postgresql') %}
{{ project_slug | upper }}_DATABASE_URL=postgresql+psycopg://postgres:test-password@localhost:5432/{{ project_slug }}_test
{%- elif database_backend == 'sqlite' %}
{{ project_slug | upper }}_DATABASE_URL=sqlite+aiosqlite:///data/{{ project_slug }}_test.db
{%- endif %}
{% if use_redis %}
{{ project_slug | upper }}_REDIS_URL=redis://localhost:6379/15
{% endif %}
{% if use_celery %}
{{ project_slug | upper }}_CELERY_BROKER_URL=memory://
{{ project_slug | upper }}_CELERY_RESULT_BACKEND=cache+memory://
{{ project_slug | upper }}_CELERY_TASK_ALWAYS_EAGER=true
{% endif %}
{% if use_auth %}
{{ project_slug | upper }}_JWT_SECRET_KEY=test-jwt-secret-not-for-production-at-least-32-ch
{% endif %}
{% if secret_backend == 'azure_kv' %}
# Tests should typically mock secrets — set if integration testing against Key Vault.
{{ project_slug | upper }}_AZURE_KEY_VAULT_URL=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
{% endif %}

{{ project_slug | upper }}_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://testserver
