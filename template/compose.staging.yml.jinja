{# Staging compose override — production-like with QA-friendly logging. -#}
services:
  app:
    build:
      target: prod
    image: {{ project_slug }}-app:${TAG:-latest}
    restart: unless-stopped
    init: true
    security_opt: [no-new-privileges:true]
    read_only: true
    tmpfs: ["/tmp", "/app/logs"]
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "5"
    env_file:
      - path: .env
        required: false
      - path: .env.staging
        required: false
    environment:
      {{ project_slug | upper }}_ENVIRONMENT: staging
      {{ project_slug | upper }}_LOG_LEVEL: INFO
      {{ project_slug | upper }}_SECRET_KEY: ${{ '{' }}{{ project_slug | upper }}_SECRET_KEY:?SECRET_KEY must be set for staging{{ '}' }}
{%- if database_backend in ("postgresql", "azure_postgresql") %}
      {{ project_slug | upper }}_DATABASE_URL: ${{ '{' }}DATABASE_URL:?DATABASE_URL must be set for staging{{ '}' }}
{%- endif %}
{%- if use_redis %}
      {{ project_slug | upper }}_REDIS_URL: redis://:${REDIS_PASSWORD:?REDIS_PASSWORD must be set for staging}@redis:6379/0
{%- endif %}
    deploy:
      resources:
        limits:
          cpus: "${APP_CPU_LIMIT:-2.0}"
          memory: ${APP_MEMORY_LIMIT:-1024M}
        reservations:
          cpus: "0.5"
          memory: 256M
{%- if use_celery %}

  worker:
    build:
      target: prod
    image: {{ project_slug }}-app:${TAG:-latest}
    restart: unless-stopped
    init: true
    stop_grace_period: 30s
    security_opt: [no-new-privileges:true]
    read_only: true
    tmpfs: ["/tmp", "/app/logs"]
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    env_file:
      - path: .env
        required: false
      - path: .env.staging
        required: false
    environment:
      {{ project_slug | upper }}_ENVIRONMENT: staging
      {{ project_slug | upper }}_LOG_LEVEL: INFO
      {{ project_slug | upper }}_SECRET_KEY: ${{ '{' }}{{ project_slug | upper }}_SECRET_KEY:?SECRET_KEY must be set for staging{{ '}' }}
{%- if database_backend in ("postgresql", "azure_postgresql") %}
      {{ project_slug | upper }}_DATABASE_URL: ${{ '{' }}DATABASE_URL:?DATABASE_URL must be set for staging{{ '}' }}
{%- endif %}
{%- if use_redis %}
      {{ project_slug | upper }}_REDIS_URL: redis://:${REDIS_PASSWORD:?REDIS_PASSWORD must be set for staging}@redis:6379/0
{%- endif %}
    deploy:
      resources:
        limits:
          cpus: "${WORKER_CPU_LIMIT:-1.0}"
          memory: ${WORKER_MEMORY_LIMIT:-512M}
        reservations:
          cpus: "0.25"
          memory: 128M

  beat:
    build:
      target: prod
    image: {{ project_slug }}-app:${TAG:-latest}
    restart: unless-stopped
    init: true
    stop_grace_period: 10s
    security_opt: [no-new-privileges:true]
    read_only: true
    tmpfs: ["/tmp"]
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    env_file:
      - path: .env
        required: false
      - path: .env.staging
        required: false
    environment:
      {{ project_slug | upper }}_ENVIRONMENT: staging
      {{ project_slug | upper }}_LOG_LEVEL: INFO
      {{ project_slug | upper }}_SECRET_KEY: ${{ '{' }}{{ project_slug | upper }}_SECRET_KEY:?SECRET_KEY must be set for staging{{ '}' }}
{%- if database_backend in ("postgresql", "azure_postgresql") %}
      {{ project_slug | upper }}_DATABASE_URL: ${{ '{' }}DATABASE_URL:?DATABASE_URL must be set for staging{{ '}' }}
{%- endif %}
{%- if use_redis %}
      {{ project_slug | upper }}_REDIS_URL: redis://:${REDIS_PASSWORD:?REDIS_PASSWORD must be set for staging}@redis:6379/0
{%- endif %}
    deploy:
      resources:
        limits:
          cpus: "0.5"
          memory: 256M
        reservations:
          cpus: "0.1"
          memory: 64M
{%- endif %}

{%- if use_caddy %}

  frontend:
    deploy:
      replicas: 0

  caddy:
    build:
      context: .
      dockerfile: caddy/Containerfile
    image: {{ project_slug }}-caddy:${TAG:-latest}
    restart: unless-stopped
    init: true
    cap_add:
      - NET_BIND_SERVICE
    security_opt: [no-new-privileges:true]
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,size=64m
      - /config:noexec,nosuid,size=16m
    volumes:
      - caddy_data:/data
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    profiles: []
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "5"
        tag: "{% raw %}{{.Name}}{% endraw %}"
    environment:
      CADDY_DOMAIN: ${CADDY_DOMAIN:?CADDY_DOMAIN is required in staging}
      CADDY_LOG_LEVEL: ${CADDY_LOG_LEVEL:-INFO}
      BACKEND_PORT: "8000"
      FRONTEND_PORT: "3000"
    deploy:
      resources:
        limits:
          cpus: "${CADDY_CPU_LIMIT:-1.0}"
          memory: ${CADDY_MEMORY_LIMIT:-256M}
        reservations:
          cpus: "0.25"
          memory: 64M
{%- else %}

  frontend:
    build:
      target: prod
    image: {{ project_slug }}-frontend:${TAG:-latest}
    restart: unless-stopped
    init: true
    security_opt: [no-new-privileges:true]
    read_only: true
    tmpfs:
      - /var/cache/nginx:noexec,nosuid,size=64m
      - /var/run:noexec,nosuid,size=1m
      - /tmp:noexec,nosuid,size=64m
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    deploy:
      resources:
        limits:
          cpus: "${FRONTEND_CPU_LIMIT:-1.0}"
          memory: ${FRONTEND_MEMORY_LIMIT:-256M}
        reservations:
          cpus: "0.1"
          memory: 64M
{%- endif %}
{%- if use_redis %}

  redis:
    restart: unless-stopped
    security_opt: [no-new-privileges:true]
    command: ["redis-server", "--requirepass", "${REDIS_PASSWORD:?REDIS_PASSWORD must be set for staging}"]
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    deploy:
      resources:
        limits:
          cpus: "${REDIS_CPU_LIMIT:-1.0}"
          memory: ${REDIS_MEMORY_LIMIT:-256M}
{%- endif %}
{%- if database_backend == "postgresql" %}

  db:
    restart: unless-stopped
    security_opt: [no-new-privileges:true]
    ports: []  # DB port NOT exposed in staging — only backend network
    environment:
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:?POSTGRES_PASSWORD must be set for staging}
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "5"
    deploy:
      resources:
        limits:
          cpus: "${DB_CPU_LIMIT:-2.0}"
          memory: ${DB_MEMORY_LIMIT:-1024M}
        reservations:
          cpus: "0.5"
          memory: 256M
{%- endif %}
