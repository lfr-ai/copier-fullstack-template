x-common-env: &common-env
  APP_ENVIRONMENT: local
{%- if database_backend == "postgresql" %}
  {{ project_slug | upper }}_DATABASE_URL: postgresql+psycopg://postgres:postgres@db:5432/{{ project_slug }}
{%- else %}
  {{ project_slug | upper }}_DATABASE_URL: sqlite+aiosqlite:///./data/app.db
{%- endif %}
  {{ project_slug | upper }}_SECRET_KEY: {{ '' }}
{%- if use_redis %}
  {{ project_slug | upper }}_REDIS_URL: {{ '' }}
{%- endif %}

services:
  app:
    build:
      context: .
      dockerfile: Containerfile
    ports:
      - "8000:8000"
    environment:
      <<: *common-env
    volumes:
      - ./src:/app/src:ro
{%- if use_redis or database_backend == "postgresql" %}
    depends_on:
{%- endif %}
{%- if use_redis %}
      redis:
        condition: service_healthy
{%- endif %}
{%- if database_backend == "postgresql" %}
      db:
        condition: service_healthy
{%- endif %}
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/api/v1/health')"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

  frontend:
    build:
      context: frontend
    ports:
      - "3000:3000"
    volumes:
      - ./frontend/src:/app/frontend/src:ro
    command: ["pnpm", "dev", "--host"]
{%- if use_redis %}

  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    volumes:
      - redis-data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 3s
      retries: 5
{%- endif %}
{%- if database_backend == "postgresql" %}

  db:
    image: postgres:17-alpine
    ports:
      - "5432:5432"
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: {{ project_slug }}
    volumes:
      - postgres-data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d {{ project_slug }}"]
      interval: 10s
      timeout: 5s
      retries: 5
{%- endif %}
{%- if use_celery %}

  worker:
    build:
      context: .
      dockerfile: Containerfile
    environment:
      <<: *common-env
    command: ["celery", "-A", "{{ project_slug }}.config.celery:celery_app", "worker", "--loglevel=info"]
{%- if use_redis %}
    depends_on:
      - redis
{%- endif %}
{%- endif %}
{%- if use_redis or database_backend == "postgresql" %}

volumes:
{%- endif %}
{%- if use_redis %}
  redis-data:
{%- endif %}
{%- if database_backend == "postgresql" %}
  postgres-data:
{%- endif %}
