{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    }{% if use_playwright %},
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--headless"]
    }{% endif %}{% if cloud_provider == 'azure' %},
    "azure": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/azure"
    }{% endif %}
  }
}
