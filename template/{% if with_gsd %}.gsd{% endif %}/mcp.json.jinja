{
  "mcpServers": {
    "context7": {
      "command": "bunx",
      "args": ["--bun", "@upstash/context7-mcp@latest"]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    }{% if use_playwright %},
    "playwright": {
      "command": "bunx",
      "args": ["--bun", "@microsoft/mcp-server-playwright"]
    }{% endif %}{% if cloud_provider == 'azure' %},
    "azure": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/azure"
    }{% endif %}
  }
}
