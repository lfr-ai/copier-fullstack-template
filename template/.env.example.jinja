# ─── Default environment file (local development) ───
# Copy to .env:  cp .env.example .env
# Docker compose reads .env automatically.

{{ project_slug | upper }}_ENVIRONMENT=local
{{ project_slug | upper }}_DEBUG=true
{{ project_slug | upper }}_LOG_LEVEL=DEBUG
{{ project_slug | upper }}_SECRET_KEY=change-me-to-a-real-secret-key-at-least-32-chars

{%- if database_backend in ('postgresql', 'azure_postgresql') %}
{{ project_slug | upper }}_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/{{ project_slug }}
{%- endif %}
{% if use_redis %}
{{ project_slug | upper }}_REDIS_URL=redis://localhost:6379/0{% endif %}
{% if use_celery %}
{{ project_slug | upper }}_CELERY_BROKER_URL=redis://localhost:6379/1
{{ project_slug | upper }}_CELERY_RESULT_BACKEND=redis://localhost:6379/2{% endif %}
{% if use_auth %}
{{ project_slug | upper }}_JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-characters-long{% endif %}
{% if secret_backend == 'azure_kv' %}
{{ project_slug | upper }}_AZURE_KEY_VAULT_URL=https://your-vault-name.vault.azure.net/
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET={% endif %}

{{ project_slug | upper }}_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Profiling (development only)
# {{ project_slug | upper }}_PROFILING_ENABLED=true
# {{ project_slug | upper }}_PROFILING_SECRET=change-me-profiling-secret-at-least-32-chars
# {{ project_slug | upper }}_PROFILING_DIR=profiles
{% if use_ai %}
# AI / LLM
{{ project_slug | upper }}_OPENAI_API_KEY=
{{ project_slug | upper }}_OPENAI_MODEL=gpt-4o
{{ project_slug | upper }}_EMBEDDING_MODEL=text-embedding-3-small
{{ project_slug | upper }}_EMBEDDING_DIMENSION=1536{% endif %}
{% if use_anthropic %}
# Anthropic
{{ project_slug | upper }}_ANTHROPIC_API_KEY=
{{ project_slug | upper }}_ANTHROPIC_MODEL=claude-sonnet-4-6{% endif %}
{% if use_azure_openai %}
# Azure OpenAI
{{ project_slug | upper }}_AZURE_OPENAI_ENDPOINT=
{{ project_slug | upper }}_AZURE_OPENAI_API_KEY=
{{ project_slug | upper }}_AZURE_OPENAI_API_VERSION=2025-04-01-preview
{{ project_slug | upper }}_AZURE_OPENAI_DEPLOYMENT={% endif %}
{% if use_ai_search %}
# Azure AI Search
{{ project_slug | upper }}_AZURE_AI_SEARCH_ENDPOINT=
{{ project_slug | upper }}_AZURE_AI_SEARCH_API_KEY=
{{ project_slug | upper }}_AZURE_AI_SEARCH_INDEX={{ project_slug }}-index{% endif %}
{% if use_document_intelligence %}
# Azure Document Intelligence
{{ project_slug | upper }}_AZURE_DOC_INTELLIGENCE_ENDPOINT=
{{ project_slug | upper }}_AZURE_DOC_INTELLIGENCE_API_KEY={% endif %}
{% if use_faiss %}
# FAISS
{{ project_slug | upper }}_FAISS_PERSIST_DIR=data/faiss{% endif %}
{% if use_pgvector %}
# pgvector
{{ project_slug | upper }}_PGVECTOR_TABLE_NAME=vector_embeddings{% endif %}
{% if use_knowledge_graph %}
# Knowledge Graph
{{ project_slug | upper }}_KNOWLEDGE_GRAPH_BACKEND={{ knowledge_graph_backend | default('networkx') }}
{{ project_slug | upper }}_KNOWLEDGE_GRAPH_PATH=data/knowledge_graph.json
{{ project_slug | upper }}_NEO4J_URI=bolt://localhost:7687
{{ project_slug | upper }}_NEO4J_USER=neo4j
{{ project_slug | upper }}_NEO4J_PASSWORD=changeme
{{ project_slug | upper }}_NEO4J_DATABASE=neo4j{% endif %}
{% if use_rag %}
# RAG
{{ project_slug | upper }}_CHUNK_SIZE=512
{{ project_slug | upper }}_CHUNK_OVERLAP=64
{{ project_slug | upper }}_RAG_SCORE_THRESHOLD=0.0
{{ project_slug | upper }}_RAG_RETRIEVAL_STRATEGY=similarity
{{ project_slug | upper }}_EMBEDDING_BATCH_SIZE=100{% endif %}
{% if use_mcp %}
# MCP
{{ project_slug | upper }}_MCP_ENABLED=false
{{ project_slug | upper }}_MCP_SERVER_NAME={{ project_name }} MCP{% endif %}
{% if use_agents %}
# Agents
{{ project_slug | upper }}_AGENT_MAX_STEPS=10
{{ project_slug | upper }}_AGENT_DEFAULT_MODEL=gpt-4o
{{ project_slug | upper }}_CHECKPOINTER_BACKEND=memory{% endif %}
{% if use_crewai %}
# CrewAI
{{ project_slug | upper }}_CREWAI_DEFAULT_MODEL=gpt-4o
{{ project_slug | upper }}_CREWAI_VERBOSE=false
{{ project_slug | upper }}_CREWAI_EMBEDDER_PROVIDER=openai
# {{ project_slug | upper }}_CREWAI_EMBEDDER_MODEL=text-embedding-3-small
{{ project_slug | upper }}_CREWAI_MEMORY_SCORING=default{% endif %}
