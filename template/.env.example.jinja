# ─── Environment Configuration ───────────────────────────────────────────
#
# This is the single source of truth for all environment variables.
# Copy it once per environment, then adjust the values that differ:
#
#   cp .env.example .env           # Local development (docker compose default)
#   cp .env.example .env.dev       # Shared dev server   (task start:dev)
#   cp .env.example .env.test      # Test / CI            (task start:test)
#   cp .env.example .env.staging   # Staging              (task start:staging)
#   cp .env.example .env.prod      # Production           (task start:prod)
#
# Personal overrides: create .env.local (always gitignored).
# Generate secrets:   python -c "import secrets; print(secrets.token_urlsafe(64))"
# NEVER commit actual .env files — only this .env.example is tracked by Git.
#
# See "Per-Environment Quick Reference" at the bottom for what to change.

# ─── Docker Compose ──────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME={{ project_slug }}

# ─── Application ─────────────────────────────────────────────────────────
{{ project_slug | upper }}_ENVIRONMENT=local
{{ project_slug | upper }}_DEBUG=true
{{ project_slug | upper }}_LOG_LEVEL=DEBUG
{{ project_slug | upper }}_SECRET_KEY=__CHANGE_ME_GENERATE_64B__
{{ project_slug | upper }}_HOST=0.0.0.0
{{ project_slug | upper }}_PORT=8000

# ─── Database ────────────────────────────────────────────────────────────
{%- if database_backend in ('postgresql', 'azure_postgresql') %}
{{ project_slug | upper }}_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/{{ project_slug }}
{%- elif database_backend == 'sqlite' %}
{{ project_slug | upper }}_DATABASE_URL=sqlite+aiosqlite:///data/{{ project_slug }}.db
{%- endif %}
{% if use_redis %}
# ─── Redis ───────────────────────────────────────────────────────────────
{{ project_slug | upper }}_REDIS_URL=redis://localhost:6379/0
{%- endif %}
{% if use_celery %}
# ─── Celery ──────────────────────────────────────────────────────────────
{{ project_slug | upper }}_CELERY_BROKER_URL=redis://localhost:6379/1
{{ project_slug | upper }}_CELERY_RESULT_BACKEND=redis://localhost:6379/2
{%- endif %}
{% if use_auth %}
# ─── Authentication ──────────────────────────────────────────────────────
{{ project_slug | upper }}_JWT_SECRET_KEY=__CHANGE_ME_GENERATE_64B__
{{ project_slug | upper }}_JWT_EXPIRE_MINUTES=30
{%- endif %}

# ─── Security & Rate Limiting ────────────────────────────────────────────
{{ project_slug | upper }}_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
{{ project_slug | upper }}_RATE_LIMIT=100/minute
{% if use_caddy %}
# ─── Caddy (staging / production only) ───────────────────────────────────
# CADDY_DOMAIN=your-domain.example.com
{%- endif %}
{% if secret_backend == 'azure_kv' %}
# ─── Azure Key Vault ─────────────────────────────────────────────────────
{{ project_slug | upper }}_AZURE_KEY_VAULT_URL=https://your-vault-name.vault.azure.net/
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
{%- endif %}

# ─── Profiling (development only) ────────────────────────────────────────
# {{ project_slug | upper }}_PROFILING_ENABLED=true
# {{ project_slug | upper }}_PROFILING_SECRET=__CHANGE_ME_GENERATE_64B__
# {{ project_slug | upper }}_PROFILING_DIR=profiles
{% if use_ai %}
# ─── AI / LLM ───────────────────────────────────────────────────────────
{{ project_slug | upper }}_OPENAI_API_KEY=
{{ project_slug | upper }}_OPENAI_MODEL=gpt-4o
{{ project_slug | upper }}_EMBEDDING_MODEL=text-embedding-3-small
{{ project_slug | upper }}_EMBEDDING_DIMENSION=1536
{%- endif %}
{% if use_anthropic %}
# ─── Anthropic ───────────────────────────────────────────────────────────
{{ project_slug | upper }}_ANTHROPIC_API_KEY=
{{ project_slug | upper }}_ANTHROPIC_MODEL=claude-sonnet-4-6
{%- endif %}
{% if use_azure_openai %}
# ─── Azure OpenAI ────────────────────────────────────────────────────────
{{ project_slug | upper }}_AZURE_OPENAI_ENDPOINT=
{{ project_slug | upper }}_AZURE_OPENAI_API_KEY=
{{ project_slug | upper }}_AZURE_OPENAI_API_VERSION=2025-04-01-preview
{{ project_slug | upper }}_AZURE_OPENAI_DEPLOYMENT=
{%- endif %}
{% if use_ai_search %}
# ─── Azure AI Search ─────────────────────────────────────────────────────
{{ project_slug | upper }}_AZURE_AI_SEARCH_ENDPOINT=
{{ project_slug | upper }}_AZURE_AI_SEARCH_API_KEY=
{{ project_slug | upper }}_AZURE_AI_SEARCH_INDEX={{ project_slug }}-index
{%- endif %}
{% if use_document_intelligence %}
# ─── Azure Document Intelligence ─────────────────────────────────────────
{{ project_slug | upper }}_AZURE_DOC_INTELLIGENCE_ENDPOINT=
{{ project_slug | upper }}_AZURE_DOC_INTELLIGENCE_API_KEY=
{%- endif %}
{% if use_faiss %}
# ─── FAISS ───────────────────────────────────────────────────────────────
{{ project_slug | upper }}_FAISS_PERSIST_DIR=data/faiss
{%- endif %}
{% if use_pgvector %}
# ─── pgvector ────────────────────────────────────────────────────────────
{{ project_slug | upper }}_PGVECTOR_TABLE_NAME=vector_embeddings
{%- endif %}
{% if use_knowledge_graph %}
# ─── Knowledge Graph ─────────────────────────────────────────────────────
{{ project_slug | upper }}_KNOWLEDGE_GRAPH_BACKEND={{ knowledge_graph_backend | default('networkx') }}
{{ project_slug | upper }}_KNOWLEDGE_GRAPH_PATH=data/knowledge_graph.json
{{ project_slug | upper }}_NEO4J_URI=bolt://localhost:7687
{{ project_slug | upper }}_NEO4J_USER=neo4j
{{ project_slug | upper }}_NEO4J_PASSWORD=__CHANGE_ME_NEO4J_PASSWORD__
{{ project_slug | upper }}_NEO4J_DATABASE=neo4j
{%- endif %}
{% if use_rag %}
# ─── RAG ─────────────────────────────────────────────────────────────────
{{ project_slug | upper }}_CHUNK_SIZE=512
{{ project_slug | upper }}_CHUNK_OVERLAP=64
{{ project_slug | upper }}_RAG_SCORE_THRESHOLD=0.0
{{ project_slug | upper }}_RAG_RETRIEVAL_STRATEGY=similarity
{{ project_slug | upper }}_EMBEDDING_BATCH_SIZE=100
{%- endif %}
{% if use_mcp %}
# ─── MCP ─────────────────────────────────────────────────────────────────
{{ project_slug | upper }}_MCP_ENABLED=false
{{ project_slug | upper }}_MCP_SERVER_NAME={{ project_name }} MCP
{%- endif %}
{% if use_agents %}
# ─── Agents ──────────────────────────────────────────────────────────────
{{ project_slug | upper }}_AGENT_MAX_STEPS=10
{{ project_slug | upper }}_AGENT_DEFAULT_MODEL=gpt-4o
{{ project_slug | upper }}_CHECKPOINTER_BACKEND=memory
{%- endif %}
{% if use_crewai %}
# ─── CrewAI ──────────────────────────────────────────────────────────────
{{ project_slug | upper }}_CREWAI_DEFAULT_MODEL=gpt-4o
{{ project_slug | upper }}_CREWAI_VERBOSE=false
{{ project_slug | upper }}_CREWAI_EMBEDDER_PROVIDER=openai
# {{ project_slug | upper }}_CREWAI_EMBEDDER_MODEL=text-embedding-3-small
{{ project_slug | upper }}_CREWAI_MEMORY_SCORING=default
{%- endif %}

# ─── Container Resources (staging / production) ─────────────────────────
# APP_CPU_LIMIT=2.0
# APP_MEMORY_LIMIT=1024M
# WORKER_CPU_LIMIT=1.0
# WORKER_MEMORY_LIMIT=512M
# TAG=latest
{%- if database_backend == 'postgresql' %}
# POSTGRES_PASSWORD=__CHANGE_ME_POSTGRES_PASSWORD__   # required by compose.staging/prod
{%- endif %}
{%- if use_redis %}
# REDIS_PASSWORD=__CHANGE_ME_REDIS_PASSWORD__         # required by compose.staging/prod
{%- endif %}
{%- if use_caddy %}
# CADDY_DOMAIN=your-domain.example.com                # required when using Caddy in staging/prod
{%- endif %}

# Frontend env vars are in frontend/.env* (Vite mode files, committed to Git).
# For personal frontend overrides, use frontend/.env.local (gitignored).

