# Application
APP_ENVIRONMENT=local
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG
APP_SECRET_KEY=change-me-to-a-real-secret-key-at-least-32-chars
APP_NAME={{ project_name }}

# Database{% if database_backend == 'postgresql' %}
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/{{ project_slug }}_dev{% else %}
DATABASE_URL=sqlite+aiosqlite:///./{{ project_slug }}.db{% endif %}
{% if use_redis %}
# Redis
REDIS_URL=redis://localhost:6379/0{% endif %}
{% if use_celery %}
# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1{% endif %}
{% if secret_backend == 'azure_kv' %}
# Azure Key Vault
AZURE_KEY_VAULT_URL=https://your-vault-name.vault.azure.net/
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET={% endif %}
