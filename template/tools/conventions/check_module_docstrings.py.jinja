"""Enforce module-level docstrings in generated project Python files."""

from __future__ import annotations

from pathlib import Path
import argparse
import re

_ENCODING_PATTERN = re.compile(r'^\s*#.*coding[:=]')
_STRING_START_PATTERN = re.compile(r"\s*(?:[rubfRUBF]{,2})?('''|\"\"\")")
_DEFAULT_PATHS = ('backend/src', 'registry', 'tools')


def _iter_python_files(*, roots: list[Path]) -> list[Path]:
    """Collect Python files recursively.

    Args:
        roots (list[Path]): Paths to scan.

    Returns:
        list[Path]: Sorted Python file paths.
    """
    files: list[Path] = []
    for root in roots:
        if root.is_file() and root.name.endswith('.py'):
            files.append(root)
            continue
        if not root.exists():
            continue
        files.extend(path for path in root.rglob('*.py') if path.is_file())
    return sorted(set(files))


def _has_module_docstring(*, text: str) -> bool:
    """Check whether source text contains a module docstring.

    Args:
        text (str): Source text.

    Returns:
        bool: True when first significant statement is a docstring.
    """
    for line in text.splitlines():
        stripped = line.strip()
        if not stripped:
            continue
        if stripped.startswith('#!'):
            continue
        if _ENCODING_PATTERN.match(stripped):
            continue
        if stripped.startswith('#'):
            continue
        return _STRING_START_PATTERN.match(line) is not None
    return False


def _parse_args() -> argparse.Namespace:
    """Parse command-line arguments.

    Returns:
        argparse.Namespace: Parsed arguments.
    """
    parser = argparse.ArgumentParser(
        description='Enforce module-level docstrings in generated project files.',
    )
    parser.add_argument(
        'paths',
        nargs='*',
        default=list(_DEFAULT_PATHS),
        help='Paths to scan recursively. Defaults to backend/src, registry, tools.',
    )
    parser.add_argument(
        '--allow-init',
        action='store_true',
        help='Include __init__.py files in validation. Disabled by default.',
    )
    return parser.parse_args()


def main() -> int:
    """Run module-level docstring checks.

    Returns:
        int: Process exit code.
    """
    args = _parse_args()
    roots = [Path(path) for path in args.paths]
    files = _iter_python_files(roots=roots)

    offenders: list[str] = []
    for file_path in files:
        if not args.allow_init and file_path.name == '__init__.py':
            continue
        text = file_path.read_text(encoding='utf-8', errors='ignore')
        if not _has_module_docstring(text=text):
            offenders.append(file_path.as_posix())

    if offenders:
        print('[FAIL] Missing module-level docstring in:')
        for offender in offenders:
            print(f'  - {offender}')
        return 1

    print('[OK] Module-level docstrings are present')
    return 0


if __name__ == '__main__':
    raise SystemExit(main())
