[pytest]
minversion = 8.0
testpaths = tests
pythonpath = src
asyncio_mode = auto
addopts = -ra --strict-markers --strict-config --tb=short
markers =
    unit: Unit tests
    integration: Integration tests
    slow: Slow-running tests
    property: Property-based tests
    performance: Benchmarks and performance regression tests
    profiling: Profiling tests (CPU, memory, SQL)
    benchmark: pytest-benchmark performance benchmarks
filterwarnings =
    error
    ignore::DeprecationWarning:celery.*
    ignore::DeprecationWarning:kombu.*
    ignore::ResourceWarning
    ignore::pytest.PytestUnraisableExceptionWarning
