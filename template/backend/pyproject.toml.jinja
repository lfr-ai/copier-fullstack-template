[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_description }}"
readme = "../README.md"
license = { text = "{{ license }}" }
requires-python = ">={{ python_version }}"
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
keywords = ["fastapi", "hexagonal-architecture", "fullstack"]
classifiers = [
    "Development Status :: 3 - Alpha",
    "Framework :: FastAPI",
    "Intended Audience :: Developers",
    "Programming Language :: Python :: {{ python_version }}",
    "Typing :: Typed",
]

[project.urls]
Homepage = "https://github.com/{{ github_username }}/{{ project_slug }}"
Repository = "https://github.com/{{ github_username }}/{{ project_slug }}"
Issues = "https://github.com/{{ github_username }}/{{ project_slug }}/issues"
Documentation = "https://github.com/{{ github_username }}/{{ project_slug }}/tree/main/docs"

dependencies = [
    "fastapi>=0.115",
    "uvicorn[standard]>=0.34",
    "pydantic>=2.10",
    "pydantic-settings>=2.7",
    "jinja2>=3.1",
    "httpx>=0.28",
    "tenacity>=9.0",
    "structlog>=24.4",
    "slowapi>=0.1",
    "click>=8.1",
    "rich>=13.9",
    "tqdm>=4.67",
    "python-multipart>=0.0.18",{% if database_backend != 'none' %}
    "sqlalchemy[asyncio]>=2.0",
    "alembic>=1.14",{% endif %}{% if database_backend in ('postgresql', 'azure_postgresql') %}
    "psycopg[binary]>=3.2",
    "asyncpg>=0.30",{% endif %}{% if use_celery %}
    "celery[redis]>=5.4",{% endif %}{% if use_redis %}
    "redis>=5.2",{% endif %}{% if use_auth %}
    "python-jose[cryptography]>=3.3",
    "passlib[bcrypt]>=1.7",{% endif %}{% if secret_backend == 'azure_kv' %}
    "azure-identity>=1.20",
    "azure-keyvault-secrets>=4.9",{% endif %}{% if cloud_provider == 'azure' %}
    "azure-storage-blob>=12.24",{% endif %}
]

[dependency-groups]
dev = [
    "pytest>=8.3,<9.0",
    "pytest-asyncio>=0.25.3,<1.0",
    "pytest-cov>=6.0",
    "pytest-xdist>=3.5",
    "pytest-mock>=3.14",
    "hypothesis>=6.120",
    "factory-boy>=3.3",
    "freezegun>=1.4",
    "respx>=0.22",{% if use_playwright %}
    "playwright>=1.49",
    "pytest-playwright>=0.6",{% endif %}{% if use_celery %}
    "pytest-celery>=1.1",{% endif %}
    "ruff>=0.9",
    "ty>=0.0.1a23",
    "pre-commit>=4.0",
    "tox>=4.23",
    "tox-uv>=1.16",
    "pip-audit>=2.7",
    "detect-secrets>=1.5",
]

[project.scripts]
{{ project_slug }} = "{{ project_slug }}.ports.cli.app:main"

[build-system]
requires = ["hatchling>=1.27"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ project_slug }}"]

[tool.ruff]
target-version = "py{{ python_version | replace('.', '') }}"
line-length = 99
src = ["src", "tests"]

[tool.ruff.lint]
select = [
    "F",      # pyflakes
    "E", "W", # pycodestyle
    "C90",    # mccabe
    "I",      # isort
    "N",      # pep8-naming
    "UP",     # pyupgrade
    "S",      # flake8-bandit
    "B",      # flake8-bugbear
    "A",      # flake8-builtins
    "C4",     # flake8-comprehensions
    "DTZ",    # flake8-datetimez
    "T10",    # flake8-debugger
    "T20",    # flake8-print
    "ISC",    # flake8-implicit-str-concat
    "ICN",    # flake8-import-conventions
    "PIE",    # flake8-pie
    "PT",     # flake8-pytest-style
    "Q",      # flake8-quotes
    "RSE",    # flake8-raise
    "RET",    # flake8-return
    "SLF",    # flake8-self
    "SIM",    # flake8-simplify
    "TID",    # flake8-tidy-imports
    "TCH",    # flake8-type-checking
    "ARG",    # flake8-unused-arguments
    "PTH",    # flake8-use-pathlib
    "ERA",    # eradicate
    "PL",     # pylint
    "TRY",    # tryceratops
    "FLY",    # flynt
    "PERF",   # perflint
    "FURB",   # refurb
    "LOG",    # flake8-logging
    "RUF",    # ruff-specific
    "ANN",    # flake8-annotations
    "D",      # pydocstyle
]
ignore = [
    "D100",   # missing docstring in public module (relaxed for now)
    "D104",   # missing docstring in public package
    "S101",   # use of assert (needed in tests)
    "I001",   # import sorting noise handled separately when desired
    "E501",   # line too long (handled by formatter)
    "TRY003", # long exception messages
    "ISC001", # conflicts with formatter
    "TCH001", # type-checking import placement (application imports)
    "TCH002", # type-checking import placement (third-party imports)
    "TCH003", # type-checking import placement (stdlib imports)
    "UP046",  # PEP 695 generic type parameter syntax migration (classes)
    "UP047",  # PEP 695 generic type parameter syntax migration (functions)
]

[tool.ruff.lint.per-file-ignores]
"tests/**/*.py" = ["S101", "ANN", "D", "ARG", "PLR2004"]
"alembic/**/*.py" = ["D", "ANN", "ERA"]
"scripts/**/*.py" = ["T20"]
"**/__init__.py" = ["I001"]

[tool.ruff.lint.isort]
known-first-party = ["{{ project_slug }}"]
force-single-line = false
lines-after-imports = 2

[tool.ruff.lint.pydocstyle]
convention = "google"

[tool.ruff.lint.pylint]
max-args = 8

[tool.ruff.format]
quote-style = "double"
indent-style = "space"
line-ending = "lf"
docstring-code-format = true

[tool.ty]
python-version = "{{ python_version }}"

[tool.pytest.ini_options]
testpaths = ["tests"]
asyncio_mode = "auto"
addopts = [
    "-ra",
    "--strict-markers",
    "--strict-config",
    "-x",
    "--tb=short",
]
markers = [
    "unit: Unit tests",
    "integration: Integration tests",
    "slow: Slow-running tests",
    "property: Property-based tests",
    "performance: Benchmarks and performance regression tests",
]
filterwarnings = [
    "error",
    "ignore::DeprecationWarning",
    "ignore::ResourceWarning",
    "ignore::pytest.PytestUnraisableExceptionWarning",
]

[tool.coverage.run]
source = ["src/{{ project_slug }}"]
branch = true
parallel = true
omit = [
    "*/tests/*",
    "*/__main__.py",
    "*/alembic/*",
]

[tool.coverage.report]
show_missing = true
fail_under = 80
precision = 2
exclude_lines = [
    "pragma: no cover",
    "if TYPE_CHECKING:",
    "raise NotImplementedError",
    "@overload",
    "class .*\\bProtocol\\):",
    "@(abc\\.)?abstractmethod",
]

[tool.coverage.html]
directory = "htmlcov"

[tool.coverage.xml]
output = "coverage.xml"
