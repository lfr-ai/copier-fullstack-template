[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_description }}"
license = { text = "{{ license }}" }
requires-python = ">={{ python_version }}"
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
keywords = ["fastapi", "clean-architecture", "fullstack"]
classifiers = [
    "Development Status :: 3 - Alpha",
    "Framework :: FastAPI",
    "Intended Audience :: Developers",
    "Programming Language :: Python :: {{ python_version }}",
    "Typing :: Typed",
]

dependencies = [
    "fastapi>=0.115",
    "uvicorn[standard]>=0.34",
    "pydantic>=2.10",
    "pydantic-settings>=2.7",
    "jinja2>=3.1",
    "httpx>=0.28",
    "tenacity>=9.0",
    "structlog>=24.4",
    "slowapi>=0.1",
    "click>=8.1",
    "rich>=13.9",
    "tqdm>=4.67",
    "python-multipart>=0.0.18",
    "pyinstrument>=5.1",{% if api_style in ('graphql', 'both') %}
    "strawberry-graphql[fastapi]>=0.262",{% endif %}{% if database_backend != 'none' %}
    "sqlalchemy[asyncio]>=2.0",
    "alembic>=1.14",{% endif %}{% if database_backend in ('postgresql', 'azure_postgresql') %}
    "psycopg[binary]>=3.2",
    "asyncpg>=0.30",{% endif %}{% if database_backend == 'sqlite' %}
    "aiosqlite>=0.20",{% endif %}{% if use_celery %}
    "celery[redis]>=5.4",{% endif %}{% if use_redis %}
    "redis>=5.2",{% endif %}{% if use_auth %}
    "PyJWT[crypto]>=2.10",{% endif %}{% if secret_backend == 'azure_kv' %}
    "azure-identity>=1.20",
    "azure-keyvault-secrets>=4.9",{% endif %}{% if cloud_provider == 'azure' %}
    "azure-storage-blob>=12.24",{% endif %}{% if use_ai %}
    "openai>=1.80",
    "litellm>=1.90",
    "tiktoken>=0.9",
    "numpy>=2.0",{% endif %}{% if use_faiss %}
    "faiss-cpu>=1.14",{% endif %}{% if use_pgvector %}
    "pgvector>=0.3",{% endif %}{% if use_langchain %}
    "langchain>=0.4",
    "langchain-core>=0.4",
    "langchain-openai>=0.4",
    "langchain-text-splitters>=0.4",{% endif %}{% if use_langchain and use_anthropic %}
    "langchain-anthropic>=0.4",{% endif %}{% if use_llamaindex %}
    "llama-index-core>=0.14",
    "llama-index-readers-file>=0.4",
    "llama-index-embeddings-openai>=0.3",{% endif %}{% if use_knowledge_graph %}
    "networkx>=3.4",{% if knowledge_graph_backend == 'rdflib' %}
    "rdflib>=7.0",
    "SPARQLWrapper>=2.0",{% endif %}{% if knowledge_graph_backend == 'neo4j' %}
    "neo4j>=5.26",{% endif %}{% endif %}{% if use_mcp %}
    "mcp[cli]>=1.30",{% endif %}{% if use_crewai %}
    "crewai>=1.15",
    "crewai-tools>=0.40",
    "pyyaml>=6.0",{% endif %}{% if use_rag %}
    "beautifulsoup4>=4.12",
    "pymupdf>=1.25",
    "python-docx>=1.1",
    "trafilatura>=2.0",
    "sentence-transformers>=3.3",{% endif %}{% if use_agents %}
    "langchain-community>=0.4",
    "langgraph>=1.3",
    "langgraph-checkpoint>=2.0",
    "langgraph-checkpoint-sqlite>=2.0",{% endif %}{% if use_agents and database_backend in ('postgresql', 'azure_postgresql') %}
    "langgraph-checkpoint-postgres>=2.0",{% endif %}{% if use_anthropic %}
    "anthropic>=0.52",{% endif %}{% if use_ai_search %}
    "azure-search-documents>=11.6",{% endif %}{% if use_document_intelligence %}
    "azure-ai-documentintelligence>=1.0",{% endif %}
]

[project.urls]
Homepage = "https://github.com/{{ github_username }}/{{ project_slug }}"
Repository = "https://github.com/{{ github_username }}/{{ project_slug }}"
Issues = "https://github.com/{{ github_username }}/{{ project_slug }}/issues"
Documentation = "https://github.com/{{ github_username }}/{{ project_slug }}/tree/main/docs"

[dependency-groups]
dev = [
    "pytest>=8.3,<9.0",
    "pytest-asyncio>=0.25.3,<1.0",
    "pytest-cov>=6.0",
    "pytest-xdist>=3.5",
    "pytest-mock>=3.14",
    "pytest-benchmark[histogram]>=5.2",
    "hypothesis>=6.120",
    "factory-boy>=3.3",
    "freezegun>=1.4",
    "respx>=0.22",{% if use_celery %}
    "pytest-celery>=1.1",{% endif %}
    "bandit[toml]>=1.9.4",
    "ruff>=0.9",
    "ty>=0.0.1a23",
    "pre-commit>=4.0",
    "tox>=4.23",
    "tox-uv>=1.16",
    "pip-audit>=2.7",
    "detect-secrets>=1.5",
    "commitizen>=4.13",
    "yamllint>=1.37",
    "xenon>=0.9.3",
]

[project.scripts]
{{ project_slug }} = "{{ project_slug }}.presentation.cli.app:main"

[build-system]
requires = ["setuptools>=69", "wheel"]
build-backend = "setuptools.build_meta"

[tool.uv]
package = true
default-groups = ["dev"]

