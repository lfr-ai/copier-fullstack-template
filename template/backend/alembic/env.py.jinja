"""Alembic migration environment configuration."""

from __future__ import annotations

import asyncio
from logging.config import fileConfig

import structlog
from alembic import context
from sqlalchemy import text
from sqlalchemy.ext.asyncio import AsyncConnection, create_async_engine

from {{ project_slug }}.infrastructure.persistence.orm.base import ORMBase
from {{ project_slug }}.config.settings import get_settings
from {{ project_slug }}.infrastructure.persistence.session import schema_for_environment

# Ensure model metadata is registered on ORMBase.metadata for autogenerate.
from {{ project_slug }}.infrastructure.persistence.orm.user_model import UserModel  # noqa: F401

_logger = structlog.get_logger(__name__)

config = context.config

if config.config_file_name is not None:
    fileConfig(config.config_file_name)

target_metadata = ORMBase.metadata


async def ensure_schemas_exist(connection: AsyncConnection) -> list[str]:
    """Create environment-specific schemas if they don't exist.

    Args:
        connection (AsyncConnection): Database connection.

    Returns:
        list[str]: List of schemas that were verified/created.
    """
{%- if database_backend == "sqlite" %}
    # SQLite does not support schemas
    return []
{%- else %}
    schemas_to_create = ["dev_schema", "test_schema", "staging_schema", "prod_schema"]
    created_schemas: list[str] = []

    for schema in schemas_to_create:
        await connection.execute(
            text(f"CREATE SCHEMA IF NOT EXISTS {schema}")
        )
        created_schemas.append(schema)

    _logger.info(
        "alembic_schema_setup",
        schemas_created=created_schemas,
    )

    return created_schemas
{%- endif %}


def run_migrations_offline() -> None:
    """Run migrations in offline mode."""
    settings = get_settings()
{%- if database_backend == "sqlite" %}
    context.configure(
        url=settings.database_url,
        target_metadata=target_metadata,
        literal_binds=True,
        dialect_opts={"paramstyle": "named"},
        render_as_batch=True,
    )
{%- else %}
    target_schema = schema_for_environment(settings.environment)

    # Create schemas first (only outputs DDL in offline mode)
    schemas_to_create = ["dev_schema", "test_schema", "staging_schema", "prod_schema"]
    schema_ddl = "\n".join(
        f"CREATE SCHEMA IF NOT EXISTS {schema};" for schema in schemas_to_create
    )

    _logger.info(
        "alembic_schema_setup",
        mode="offline",
        target_schema=target_schema,
        schemas_created=schemas_to_create,
    )

    context.configure(
        url=settings.database_url,
        target_metadata=target_metadata,
        literal_binds=True,
        dialect_opts={"paramstyle": "named"},
        # Set search_path for offline SQL generation
        include_schemas=True,
        version_table_schema=target_schema,
    )
{%- endif %}
    with context.begin_transaction():
{%- if database_backend != "sqlite" %}
        # Emit schema creation DDL
        context.execute(schema_ddl)
        # Set search_path for table DDL
        context.execute(f"SET search_path TO {target_schema};")
{%- endif %}
        context.run_migrations()


def do_run_migrations(connection: object) -> None:  # noqa: ANN401 -- Alembic run_sync passes untyped Connection
    """Run migrations with given connection.

    Args:
        connection (object): Database connection provided by Alembic run_sync.
    """
{%- if database_backend == "sqlite" %}
    context.configure(connection=connection, target_metadata=target_metadata, render_as_batch=True)
{%- else %}
    settings = get_settings()
    target_schema = schema_for_environment(settings.environment)

    # Set search_path before running migrations
    connection.execute(text(f"SET search_path TO {target_schema}"))

    _logger.debug(
        "alembic_migration_search_path",
        target_schema=target_schema,
        environment=settings.environment.name,
    )

    context.configure(connection=connection, target_metadata=target_metadata)
{%- endif %}
    with context.begin_transaction():
        context.run_migrations()


async def run_migrations_online() -> None:
    """Run migrations in online mode with async engine."""
    settings = get_settings()
    engine = create_async_engine(settings.database_url)
    async with engine.connect() as connection:
{%- if database_backend != "sqlite" %}
        # Ensure all environment schemas exist before running migrations
        await ensure_schemas_exist(connection)
{%- endif %}
        await connection.run_sync(do_run_migrations)
    await engine.dispose()


if context.is_offline_mode():
    run_migrations_offline()
else:
    asyncio.run(run_migrations_online())
