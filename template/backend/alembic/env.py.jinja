"""Alembic migration environment configuration."""

from __future__ import annotations

import asyncio
from logging.config import fileConfig

import structlog
from alembic import context
{%- if database_backend in ('postgresql', 'azure_postgresql') %}
from sqlalchemy import text
{%- endif %}
from sqlalchemy.ext.asyncio import AsyncConnection, create_async_engine

from {{ project_slug }}.infrastructure.persistence.orm.base import ORMBase
from {{ project_slug }}.config.settings import get_settings

# Ensure model metadata is registered on ORMBase.metadata for autogenerate.
from {{ project_slug }}.infrastructure.persistence.orm.user_model import UserModel  # noqa: F401

_logger = structlog.get_logger(__name__)

config = context.config

if config.config_file_name is not None:
    fileConfig(config.config_file_name)

target_metadata = ORMBase.metadata


{%- if database_backend in ('postgresql', 'azure_postgresql') %}


async def _ensure_extensions(connection: AsyncConnection) -> None:
    """Create required PostgreSQL extensions.

    Called before running migrations so that extension-provided types
    (e.g. ``uuid-ossp``) are available for table definitions.

    Args:
        connection: Active async database connection.
    """
    await connection.execute(text('CREATE EXTENSION IF NOT EXISTS "uuid-ossp"'))
    await connection.commit()
{%- endif %}


def run_migrations_offline() -> None:
    """Run migrations in offline mode.

    Configures the context with a URL and emits DDL to stdout
    without requiring a live database connection.
    """
    settings = get_settings()
{%- if database_backend == "sqlite" %}
    context.configure(
        url=settings.database_url,
        target_metadata=target_metadata,
        literal_binds=True,
        dialect_opts={"paramstyle": "named"},
        render_as_batch=True,
    )
{%- else %}
    context.configure(
        url=settings.database_url,
        target_metadata=target_metadata,
        literal_binds=True,
        dialect_opts={"paramstyle": "named"},
    )
{%- endif %}
    with context.begin_transaction():
        context.run_migrations()


def do_run_migrations(connection: object) -> None:  # noqa: ANN401 -- Alembic run_sync passes untyped Connection
    """Run migrations with the given connection.

    Each environment connects to its own database via ``DATABASE_URL``.
    All tables live in the default ``public`` schema.

    Args:
        connection: Database connection provided by Alembic ``run_sync``.
    """
{%- if database_backend == "sqlite" %}
    context.configure(connection=connection, target_metadata=target_metadata, render_as_batch=True)
{%- else %}
    context.configure(connection=connection, target_metadata=target_metadata)
{%- endif %}
    with context.begin_transaction():
        context.run_migrations()


async def run_migrations_online() -> None:
    """Run migrations in online mode with an async engine.

    Connects to the database specified by the current environment's
    ``DATABASE_URL``.  Each environment (local, dev, test, staging, prod)
    has its own database — migrations run against that single database
    using the default ``public`` schema.
    """
    settings = get_settings()
    engine = create_async_engine(settings.database_url)
    async with engine.connect() as connection:
{%- if database_backend in ('postgresql', 'azure_postgresql') %}
        await _ensure_extensions(connection)
{%- endif %}
        await connection.run_sync(do_run_migrations)
    await engine.dispose()


if context.is_offline_mode():
    run_migrations_offline()
else:
    asyncio.run(run_migrations_online())
