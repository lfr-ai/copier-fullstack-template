{%- endif %}
{%- if use_knowledge_graph %}

    # Knowledge Graph
    neo4j_uri: str = Field(
        default="bolt://localhost:7687",
        description="Neo4j database URI.",
        examples=["bolt://localhost:7687", "neo4j+s://my-instance.neo4j.io:7687"],
    )
    neo4j_user: str = Field(
        default="neo4j",
        description="Neo4j authentication username.",
    )
    neo4j_password: str = Field(
        default="changeme",
        description="Neo4j authentication password.",
    )
    neo4j_database: str = Field(
        default="neo4j",
        description="Neo4j database name.",
    )
{%- endif %}
{%- if use_crewai %}

    # CrewAI Multi-Agent
    crewai_default_model: str = Field(
        default="gpt-4o",
        description="Default LLM model for CrewAI agents.",
        examples=["gpt-4o", "gpt-4o-mini", "claude-sonnet-4-6"],
    )
    crewai_verbose: bool = Field(
        default=False,
        description="Enable verbose logging for CrewAI crew execution.",
    )
    crewai_embedder_provider: str = Field(
        default="openai",
        description="Embedding provider for CrewAI knowledge and memory.",
        examples=["openai", "azure", "ollama"],
    )
    crewai_embedder_model: str | None = Field(
        default=None,
        description="Override the default embedder model for CrewAI.",
        examples=["text-embedding-3-small", "text-embedding-ada-002"],
    )
    crewai_memory_scoring: str = Field(
        default="default",
        description="Memory scoring preset: 'default', 'sprint', or 'knowledge_base'.",
        examples=["default", "sprint", "knowledge_base"],
    )
{%- endif %}

    @model_validator(mode="after")
    def _check_default_secrets(self) -> "BaseAppSettings":
        """Reject insecure default secrets outside local environment."""
        if self.environment == Environment.LOCAL:
            return self
        insecure = {
            "secret_key": "change-me-in-production",
{%- if use_auth %}
            "jwt_secret_key": "change-me-jwt-secret",
{%- endif %}
{%- if use_knowledge_graph %}
            "neo4j_password": "changeme",
{%- endif %}
        }
        for attr, default_val in insecure.items():
            if getattr(self, attr, None) == default_val:
                msg = (
                    f"{attr!r} still has its insecure default value. "
                    f"Set {self.model_config.get('env_prefix', '')}{attr.upper()} before deploying."
                )
                raise ValueError(msg)
        if self.profiling_enabled and not self.profiling_secret:
            msg = (
                "profiling_secret must be set when profiling_enabled is True "
                "outside the LOCAL environment."
            )
            raise ValueError(msg)
        return self
