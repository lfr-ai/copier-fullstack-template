{%- endif %}
{%- if use_document_intelligence %}

    # Azure Document Intelligence
    azure_doc_intelligence_endpoint: str = Field(
        default="",
        description="Azure Document Intelligence endpoint URL.",
        examples=["https://my-di.cognitiveservices.azure.com/"],
    )
    azure_doc_intelligence_api_key: str = Field(
        default="",
        description="Azure Document Intelligence API key.",
