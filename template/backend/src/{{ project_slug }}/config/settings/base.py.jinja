"""Base application settings using pydantic-settings."""

from __future__ import annotations

from pydantic import Field, model_validator
from pydantic_settings import BaseSettings, SettingsConfigDict

from {{ project_slug }}.config.constants import (
    DEFAULT_HOST,
    DEFAULT_PORT,
    MAX_PORT,
{%- if use_auth %}
    TOKEN_EXPIRY_MINUTES,
{%- endif %}
)
from {{ project_slug }}.core.enums.environment import Environment
_MAX_GRAPHQL_DEPTH: int = 50
_MAX_AGENT_STEPS: int = 50


class BaseAppSettings(BaseSettings):
    """Base settings with environment variable loading.

    Reads from .env file and environment variables with
    configurable prefix.
    """

    model_config = SettingsConfigDict(
        env_file=".env",
        env_file_encoding="utf-8",
        env_prefix="{{ project_slug | upper }}_",
        case_sensitive=False,
        extra="ignore",
    )

    environment: Environment = Field(
        default=Environment.LOCAL,
        description="Deployment environment.",
        examples=["local", "dev", "test", "staging", "prod"],
    )
    debug: bool = Field(
        default=False,
        description="Enable debug mode.",
        examples=[False, True],
    )
    log_level: str = Field(
        default="INFO",
        description="Logging level.",
        examples=["INFO", "DEBUG", "WARNING"],
    )
    secret_key: str = Field(
        default="change-me-in-production",
        description="Application secret key for signing.",
        examples=["my-super-secret-key-at-least-32-chars"],
    )

    database_url: str = Field(
{%- if database_backend == "postgresql" %}
        default="postgresql+psycopg://postgres:postgres@localhost:5432/{{ project_slug }}",
        description="Async database connection URL.",
        examples=["postgresql+psycopg://user:pass@localhost/db"],
{%- elif database_backend == "azure_postgresql" %}
        default="",
        description="Azure PostgreSQL Flexible Server connection URL. Set via environment or Key Vault.",
        examples=["postgresql+psycopg://user:pass@myserver.postgres.database.azure.com:5432/{{ project_slug }}?sslmode=require"],
{%- else %}
        default="",
        description="Database connection URL. Leave empty if no database is configured.",
        examples=["postgresql+psycopg://user:pass@localhost/db"],
{%- endif %}
    )
    database_echo: bool = Field(
        default=False,
        description="Echo SQL queries to log.",
        examples=[False, True],
    )

    host: str = Field(
        default=DEFAULT_HOST,
        description="Server bind host.",
        examples=["127.0.0.1", "0.0.0.0"],
    )
    port: int = Field(
        default=DEFAULT_PORT,
        gt=0,
        le=MAX_PORT,
        description="Server bind port.",
        examples=[8000, 8080],
    )

    cors_allowed_origins: list[str] = Field(
        default_factory=list,
        description="Allowed CORS origins for non-local environments.",
        examples=[["https://example.com"]],
    )

    rate_limit: str = Field(
        default="60/minute",
        description="Default rate limit (slowapi format: 'count/period').",
        examples=["60/minute", "100/minute", "10/second"],
    )

    # Profiling
    profiling_enabled: bool = Field(
        default=False,
        description="Enable on-demand profiling middleware (?profile=cpu|memory).",
        examples=[False, True],
    )
    profiling_secret: str = Field(
        default="",
        description="Shared secret for X-Profile-Secret header (required when profiling_enabled).",
        examples=["change-me-profiling-secret"],
    )
    profiling_dir: str = Field(
        default="profiles",
        description="Directory for saved profiling reports.",
        examples=["profiles", "/tmp/profiles"],
    )
{%- if api_style in ('graphql', 'both') %}

    # GraphQL
    graphql_max_depth: int = Field(
        default=10,
        gt=0,
        le=_MAX_GRAPHQL_DEPTH,
        description="Maximum allowed query nesting depth for the GraphQL endpoint.",
        examples=[10, 15],
    )
    graphql_ide: str = Field(
        default="graphiql",
        description="GraphQL IDE to show in debug mode (graphiql, apollo-sandbox, pathfinder, or empty to disable).",
        examples=["graphiql", "apollo-sandbox", ""],
    )
{%- endif %}
{%- if use_redis %}

    redis_url: str = Field(
        default="redis://localhost:6379/0",
        description="Redis connection URL.",
        examples=["redis://localhost:6379/0"],
    )
    redis_ttl: int = Field(
        default=3600,
        gt=0,
        description="Default Redis TTL in seconds.",
        examples=[3600, 7200],
    )
{%- endif %}
{%- if use_celery %}

    celery_broker_url: str = Field(
        default="redis://localhost:6379/1",
        description="Celery broker connection URL.",
        examples=["redis://localhost:6379/1"],
    )
    celery_result_backend: str = Field(
        default="redis://localhost:6379/2",
        description="Celery result backend URL.",
        examples=["redis://localhost:6379/2"],
    )
{%- endif %}
{%- if use_auth %}

    jwt_secret_key: str = Field(
        default="change-me-jwt-secret",
        description="JWT signing secret key.",
        examples=["my-jwt-secret-key-at-least-32-chars"],
    )
    jwt_expire_minutes: int = Field(
        default=TOKEN_EXPIRY_MINUTES,
        gt=0,
        description="JWT token expiration in minutes.",
        examples=[30, 60],
    )
{%- endif %}
{%- if secret_backend == "azure_kv" %}

    azure_key_vault_url: str = Field(
        default="",
        description="Azure Key Vault URL.",
        examples=["https://my-vault.vault.azure.net/"],
    )
{%- endif %}
{%- if use_ai %}

    # AI / LLM
    openai_api_key: str = Field(
        default="",
        description="OpenAI API key for LLM and embedding.",
        examples=["sk-..."],
    )
    openai_model: str = Field(
        default="gpt-4o",
        description="Default OpenAI model for completions.",
        examples=["gpt-4o", "gpt-4o-mini"],
    )
    embedding_model: str = Field(
        default="text-embedding-3-small",
        description="Embedding model identifier.",
        examples=["text-embedding-3-small", "text-embedding-3-large"],
    )
    embedding_dimension: int = Field(
        default=1536,
        gt=0,
        description="Embedding vector dimension.",
        examples=[1536, 3072],
    )
{%- endif %}
{%- if use_azure_openai %}

    # Azure OpenAI
    azure_openai_endpoint: str = Field(
        default="",
        description="Azure OpenAI endpoint URL.",
        examples=["https://my-openai.openai.azure.com/"],
    )
    azure_openai_api_key: str = Field(
        default="",
        description="Azure OpenAI API key.",
        examples=["..."],
    )
    azure_openai_api_version: str = Field(
        default="2025-04-01-preview",
        description="Azure OpenAI API version.",
    )
    azure_openai_deployment: str = Field(
        default="",
        description="Azure OpenAI deployment name.",
    )
{%- endif %}
{%- if use_faiss %}

    # FAISS
    faiss_persist_dir: str | None = Field(
        default=None,
        description="Directory to persist FAISS index (None for in-memory only).",
