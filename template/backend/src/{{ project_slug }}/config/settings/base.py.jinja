"""Base application settings using pydantic-settings."""

from __future__ import annotations

from pydantic import model_validator
from pydantic_settings import BaseSettings, SettingsConfigDict

from {{ project_slug }}.config.constants import (
    DEFAULT_HOST,
    DEFAULT_PORT,
{%- if use_auth %}
    TOKEN_EXPIRY_MINUTES,
{%- endif %}
)
from {{ project_slug }}.core.enums.environment import Environment


class BaseAppSettings(BaseSettings):
    """Base settings with environment variable loading."""

    model_config = SettingsConfigDict(
        env_file=(".env", ".env.local"),
        env_file_encoding="utf-8",
        env_prefix="{{ project_slug | upper }}_",
        case_sensitive=False,
        extra="ignore",
    )

    environment: Environment = Environment.LOCAL
    debug: bool = False
    log_level: str = "INFO"
    secret_key: str = "change-me-in-production"

    database_url: str = {% if database_backend == "postgresql" %}"postgresql+psycopg://postgres:postgres@localhost:5432/{{ project_slug }}"{% elif database_backend == "azure_postgresql" %}""{% elif database_backend == "sqlite" %}"sqlite+aiosqlite:///data/{{ project_slug }}.db"{% else %}""{% endif %}

    database_echo: bool = False

    host: str = DEFAULT_HOST
    port: int = DEFAULT_PORT

    cors_allowed_origins: list[str] = []
    rate_limit: str = "60/minute"

    profiling_enabled: bool = False
    profiling_secret: str = ""
    profiling_dir: str = "profiles"
{%- if api_style in ('graphql', 'both') %}

    graphql_max_depth: int = 10
    graphql_ide: str = "graphiql"
{%- endif %}
{%- if use_redis %}

    redis_url: str = "redis://localhost:6379/0"
    redis_ttl: int = 3600
{%- endif %}
{%- if use_celery %}

    celery_broker_url: str = "redis://localhost:6379/1"
    celery_result_backend: str = "redis://localhost:6379/2"
{%- endif %}
{%- if use_auth %}

    jwt_secret_key: str = "change-me-jwt-secret"
    jwt_expire_minutes: int = TOKEN_EXPIRY_MINUTES
{%- endif %}
{%- if secret_backend == "azure_kv" %}

    azure_key_vault_url: str = ""
{%- endif %}
{%- if use_ai %}

    openai_api_key: str = ""
    openai_model: str = "gpt-4o"
    embedding_model: str = "text-embedding-3-small"
    embedding_dimension: int = 1536
{%- endif %}
{%- if use_azure_openai %}

    azure_openai_endpoint: str = ""
    azure_openai_api_key: str = ""
    azure_openai_api_version: str = "2025-04-01-preview"
    azure_openai_deployment: str = ""
{%- endif %}
{%- if use_faiss %}

    faiss_persist_dir: str | None = None
{%- endif %}
{%- if use_pgvector %}

    pgvector_table_name: str = "vector_embeddings"
{%- endif %}
{%- if use_knowledge_graph %}

    knowledge_graph_backend: str = "{{ knowledge_graph_backend | default('networkx') }}"
    knowledge_graph_path: str | None = None
{%- endif %}
{%- if use_rag %}

    chunk_size: int = 512
    chunk_overlap: int = 64
{%- endif %}
{%- if use_mcp %}

    mcp_server_name: str = "{{ project_name }} MCP"
    mcp_enabled: bool = False
{%- endif %}
{%- if use_anthropic %}

    anthropic_api_key: str = ""
    anthropic_model: str = "claude-sonnet-4-6"
{%- endif %}
{%- if use_ai_search %}

    azure_ai_search_endpoint: str = ""
    azure_ai_search_api_key: str = ""
    azure_ai_search_index: str = "{{ project_slug }}-index"
{%- endif %}
{%- if use_document_intelligence %}

    azure_doc_intelligence_endpoint: str = ""
    azure_doc_intelligence_api_key: str = ""
{%- endif %}
{%- if use_agents %}

    agent_max_steps: int = 10
    agent_default_model: str = "gpt-4o"
    checkpointer_backend: str = "memory"
{%- endif %}
{%- if use_rag %}

    rag_score_threshold: float = 0.0
    rag_retrieval_strategy: str = "similarity"
    embedding_batch_size: int = 100
{%- endif %}
{%- if use_knowledge_graph %}

    neo4j_uri: str = "bolt://localhost:7687"
    neo4j_user: str = "neo4j"
    neo4j_password: str = "changeme"
    neo4j_database: str = "neo4j"
{%- endif %}
{%- if use_crewai %}

    crewai_default_model: str = "gpt-4o"
    crewai_verbose: bool = False
    crewai_embedder_provider: str = "openai"
    crewai_embedder_model: str | None = None
    crewai_memory_scoring: str = "default"
{%- endif %}

    @model_validator(mode="after")
    def _check_default_secrets(self) -> "BaseAppSettings":
        """Reject insecure default secrets outside local environment."""
        if self.environment == Environment.LOCAL:
            return self
        insecure = {
            "secret_key": "change-me-in-production",
{%- if use_auth %}
            "jwt_secret_key": "change-me-jwt-secret",
{%- endif %}
{%- if use_knowledge_graph %}
            "neo4j_password": "changeme",
{%- endif %}
        }
        for attr, default_val in insecure.items():
            if getattr(self, attr, None) == default_val:
                msg = (
                    f"{attr!r} still has its insecure default value. "
                    f"Set {self.model_config.get('env_prefix', '')}{attr.upper()} before deploying."
                )
                raise ValueError(msg)
        if self.profiling_enabled and not self.profiling_secret:
            msg = (
                "profiling_secret must be set when profiling_enabled is True "
                "outside the LOCAL environment."
            )
            raise ValueError(msg)
        return self
