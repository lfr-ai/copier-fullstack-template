"""Prod settings with strict defaults."""

from __future__ import annotations

from pydantic import model_validator
from pydantic_settings import SettingsConfigDict

from {{ project_slug }}.config.settings.base import BaseAppSettings
from {{ project_slug }}.config.settings._validators import validate_secret_key_strength
from {{ project_slug }}.core.enums.environment import Environment


class ProdSettings(BaseAppSettings):
    """Settings for prod environment.

    Enforces strict security and performance defaults.
    """

    environment: Environment = Environment.PROD
    model_config = SettingsConfigDict(env_file=None)
    debug: bool = False
    log_level: str = "WARNING"
    host: str = "0.0.0.0"  # noqa: S104  -- intentional: container networking
    database_echo: bool = False

    @model_validator(mode="after")
    def _validate_secret_key(self) -> "ProdSettings":
        validate_secret_key_strength(
            secret_key=self.secret_key,
            env_prefix=self.model_config.get('env_prefix', ''),
        )
        return self
