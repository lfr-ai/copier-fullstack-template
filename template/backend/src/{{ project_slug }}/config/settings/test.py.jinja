"""Test environment settings."""

from __future__ import annotations

from {{ project_slug }}.config.settings.base import BaseAppSettings
from {{ project_slug }}.core.enums.environment import Environment
class TestSettings(BaseAppSettings):
    """Settings for test environment.

    Uses a dedicated test database for isolated test execution.
    Debug is OFF to match production behaviour — use log_level for
    troubleshooting test failures instead.
    """

    environment: Environment = Environment.TEST
    debug: bool = False
    log_level: str = "WARNING"
    host: str = "0.0.0.0"  # noqa: S104  -- intentional: container networking
{%- if database_backend in ('postgresql', 'azure_postgresql') %}
    database_url: str = "postgresql+psycopg://postgres:test-password@localhost:5432/{{ project_slug }}_test"
    database_schema: str = "test_schema"
{%- elif database_backend == 'sqlite' %}
    database_url: str = "sqlite+aiosqlite:///data/{{ project_slug }}_test.db"
{%- else %}
    database_url: str = ""
{%- endif %}
    database_echo: bool = False
