"""Development environment settings.

Used for shared development servers (not local machines).
Identical to local but binds to 0.0.0.0 and uses the container network
database URLs rather than localhost.
"""

from __future__ import annotations

from {{ project_slug }}.config.settings.base import BaseAppSettings
from {{ project_slug }}.core.enums.environment import Environment
class DevSettings(BaseAppSettings):
    """Settings for shared dev environment.

    Debug enabled, verbose logging, database echo on.
    Binds to all interfaces for container access.
    """

    environment: Environment = Environment.DEV
    debug: bool = True
    log_level: str = "DEBUG"
    host: str = "0.0.0.0"  # noqa: S104  – intentional: container networking
    database_echo: bool = True
