"""Settings module with environment-based factory."""

from __future__ import annotations

import structlog
import os
from functools import lru_cache

from {{ project_slug }}.config.settings.base import BaseAppSettings
from {{ project_slug }}.config.settings.dev import DevSettings
from {{ project_slug }}.config.settings.local import LocalSettings
from {{ project_slug }}.config.settings.prod import ProdSettings
from {{ project_slug }}.config.settings.staging import StagingSettings
from {{ project_slug }}.config.settings.test import TestSettings
from {{ project_slug }}.core.enums.environment import Environment

logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)
_SETTINGS_MAP: dict[Environment, type[BaseAppSettings]] = {
    Environment.LOCAL: LocalSettings,
    Environment.DEV: DevSettings,
    Environment.TEST: TestSettings,
    Environment.STAGING: StagingSettings,
    Environment.PROD: ProdSettings,
}


@lru_cache(maxsize=1)
def get_settings() -> BaseAppSettings:
    """Create settings instance based on environment variable.

    Reads {{ project_slug | upper }}_ENVIRONMENT to select the appropriate settings class.
    Cached so a single instance is reused throughout the application.

    Returns:
        BaseAppSettings: Configured application settings.
    """
    env_name = os.getenv("{{ project_slug | upper }}_ENVIRONMENT", "local")
    try:
        environment = Environment(env_name.lower())
    except ValueError:
        logger.warning(
            "Invalid environment %r -- falling back to LOCAL. "
            "Valid values: %s",
            env_name,
            ", ".join(e.value for e in Environment),
        )
        environment = Environment.LOCAL
    settings_class = _SETTINGS_MAP[environment]
    return settings_class()
