"""Staging environment settings.

Production-like but with slightly more permissive logging to aid
integration testing and QA validation.
"""

from __future__ import annotations

from pydantic import model_validator
from pydantic_settings import SettingsConfigDict

from {{ project_slug }}.config.settings.base import BaseAppSettings
from {{ project_slug }}.core.enums.environment import Environment

_MIN_SECRET_KEY_LENGTH = 32
_INSECURE_DEFAULT = "change-me-in-production"


class StagingSettings(BaseAppSettings):
    """Settings for staging / pre-production environment.

    Mirrors production security posture with INFO-level logging
    for easier debugging during QA cycles.
    """

    environment: Environment = Environment.STAGING
    model_config = SettingsConfigDict(env_file=None)
    debug: bool = False
    log_level: str = "INFO"
    host: str = "0.0.0.0"  # noqa: S104  -- intentional: container networking
    database_echo: bool = False

    @model_validator(mode="after")
    def _validate_secret_key(self) -> "StagingSettings":
        if (
            self.secret_key == _INSECURE_DEFAULT
            or "__CHANGE_ME__" in self.secret_key
            or len(self.secret_key) < _MIN_SECRET_KEY_LENGTH
        ):
            msg = (
                "secret_key must be at least 32 characters and not the default "
                "placeholder. Set the environment variable "
                f"{self.model_config.get('env_prefix', '')}SECRET_KEY."
            )
            raise ValueError(msg)
        return self
