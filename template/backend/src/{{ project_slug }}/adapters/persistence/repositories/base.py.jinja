"""Generic SQLAlchemy repository implementation."""

from __future__ import annotations

import structlog
from sqlalchemy import func, select
from sqlalchemy.ext.asyncio import AsyncSession

from {{ project_slug }}.adapters.persistence.orm.base import ORMBase
from {{ project_slug }}.core.constants import DEFAULT_LIST_LIMIT

__all__ = ["SQLAlchemyRepository"]

logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)


class SQLAlchemyRepository[ModelT: ORMBase]:
    """Generic repository for SQLAlchemy ORM models.

    Provides standard CRUD operations with async support
    and pagination.
    """

    def __init__(self, *, session: AsyncSession, model_class: type[ModelT]) -> None:
        """Initialize repository with session and model.

        Args:
            session (AsyncSession): Async SQLAlchemy session.
            model_class (type[ModelT]): ORM model class for this repository.
        """
        self._session = session
        self._model_class = model_class

    async def get_by_id(self, entity_id: str) -> ModelT | None:
        """Retrieve model by primary key.

        Args:
            entity_id (str): Primary key value.

        Returns:
            ModelT | None: Model instance or None if not found.
        """
        return await self._session.get(self._model_class, entity_id)

    async def add(self, instance: ModelT) -> ModelT:
        """Add model instance to session.

        Args:
            instance (ModelT): Model instance to persist.

        Returns:
            ModelT: Persisted model instance.
        """
        self._session.add(instance)
        await self._session.flush()
        await self._session.refresh(instance)
        logger.debug(
            "Added %s with id %s",
            self._model_class.__name__,
            getattr(instance, "id", "unknown"),
        )
        return instance

    async def update(self, instance: ModelT) -> ModelT:
        """Merge updated model instance.

        Args:
            instance (ModelT): Model instance with updated fields.

        Returns:
            ModelT: Merged model instance.
        """
        merged = await self._session.merge(instance)
        await self._session.flush()
        return merged

    async def delete(self, entity_id: str) -> bool:
        """Delete model by primary key.

        Args:
            entity_id (str): Primary key value.

        Returns:
            bool: True if instance was deleted.
        """
        instance = await self.get_by_id(entity_id)
        if instance is None:
            return False
        await self._session.delete(instance)
        await self._session.flush()
        return True

    async def list_all(
        self,
        *,
        offset: int = 0,
        limit: int = DEFAULT_LIST_LIMIT,
    ) -> list[ModelT]:
        """Retrieve paginated list of model instances.

        Args:
            offset (int): Number of records to skip.
            limit (int): Maximum records to return.

        Returns:
            list[ModelT]: List of model instances.
        """
        stmt = select(self._model_class).offset(offset).limit(limit)
        result = await self._session.execute(stmt)
        return list(result.scalars().all())

    async def count(self) -> int:
        """Count total records.

        Returns:
            int: Total number of records.
        """
        stmt = select(func.count()).select_from(self._model_class)
        result = await self._session.execute(stmt)
        return result.scalar_one()
