"""User repository SQLAlchemy implementation."""

from __future__ import annotations

from sqlalchemy import select
from sqlalchemy.ext.asyncio import AsyncSession

from {{ project_slug }}.adapters.persistence.orm.user_model import UserModel
from {{ project_slug }}.adapters.persistence.repositories.base import SQLAlchemyRepository
from {{ project_slug }}.core.constants import DEFAULT_LIST_LIMIT


class UserRepository(SQLAlchemyRepository[UserModel]):
    """Repository for user persistence operations."""

    def __init__(self, session: AsyncSession) -> None:
        super().__init__(session=session, model_class=UserModel)

    async def get_by_email(self, email: str) -> UserModel | None:
        """Retrieve user by email address.

        Args:
            email (str): User email address.

        Returns:
            UserModel | None: 'UserModel' instance or 'None' if not found.
        """
        stmt = select(UserModel).where(UserModel.email == email)
        result = await self._session.execute(stmt)
        return result.scalar_one_or_none()

    async def get_by_ids(self, ids: list[str]) -> list[UserModel]:
        """Retrieve multiple users by their IDs in a single query.

        Args:
            ids (list[str]): User identifiers.

        Returns:
            list[UserModel]: Found user models (may be fewer than requested).
        """
        if not ids:
            return []
        stmt = select(UserModel).where(UserModel.id.in_(ids))
        result = await self._session.execute(stmt)
        return list(result.scalars().all())

    async def get_active_users(
        self,
        *,
        offset: int = 0,
        limit: int = DEFAULT_LIST_LIMIT,
    ) -> list[UserModel]:
        """Retrieve active users with pagination.

        Args:
            offset (int): Number of records to skip.
            limit (int): Maximum records to return.

        Returns:
            list[UserModel]: List of active user models.
        """
        stmt = (
            select(UserModel)
            .where(UserModel.is_active.is_(True))
            .offset(offset)
            .limit(limit)
        )
        result = await self._session.execute(stmt)
        return list(result.scalars().all())
