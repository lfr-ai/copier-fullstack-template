"""CLI application factory using click."""

from __future__ import annotations

import json
from pathlib import Path

from alembic.config import main as alembic_main
import click
import uvicorn

from {{ project_slug }}.config.constants import DEFAULT_HOST, DEFAULT_PORT

_SEED_PATH: Path = Path("seeds/initial_data.json")


def _run_alembic_upgrade() -> None:
    """Run Alembic upgrade to head revision.

    Raises:
        click.ClickException: Raised when migration command fails.
    """
    try:
        alembic_main(argv=["upgrade", "head"])
    except SystemExit as error:
        raise click.ClickException("Command failed") from error


@click.group()
@click.version_option()
def cli() -> None:
    """{{ project_name }} CLI management tool."""


@cli.command()
def db_upgrade() -> None:
    """Run database migrations to head."""
    click.echo("Running database migrations...")
    _run_alembic_upgrade()
    click.echo("Database migrations complete")


@cli.command()
def db_seed() -> None:
    """Seed database with initial data.

    Raises:
        click.ClickException: Raised when seed file is not found.
    """
    if not _SEED_PATH.exists():
        raise click.ClickException("Seed file not found")

    with _SEED_PATH.open("r", encoding="utf-8") as handle:
        seed_data = json.load(handle)

    users = seed_data.get("users", [])
    click.echo("Loaded seed data")
    click.echo(f"Users in seed: {len(users)}")


@cli.command()
@click.option("--host", default=DEFAULT_HOST, help="Bind host")
@click.option("--port", default=DEFAULT_PORT, type=int, help="Bind port")
def serve(host: str, port: int) -> None:
    """Start development server.

    Args:
        host (str): Server bind address.
        port (int): Server bind port.
    """
    uvicorn.run(
        "{{ project_slug }}.presentation.api.app:create_api_app",
        host=host,
        port=port,
        factory=True,
        reload=True,
    )


main = cli

if __name__ == "__main__":
    main()
