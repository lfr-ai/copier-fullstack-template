"""On-demand CPU profiling middleware -- append '?profile=1' with 'X-Profile-Secret' header."""

from __future__ import annotations

import datetime
import pathlib
import re
from typing import override, final

import structlog
from starlette.middleware.base import BaseHTTPMiddleware, RequestResponseEndpoint
from starlette.requests import Request
from starlette.responses import Response

from {{ project_slug }}.config.constants import MS_PER_SECOND, PROFILING_INTERVAL

logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)

_SAFE_PATH_RE = re.compile(r"[^a-zA-Z0-9_-]")
_MAX_PATH_DISPLAY_LEN = 60


def _sanitize_path(path: str, *, max_len: int = _MAX_PATH_DISPLAY_LEN) -> str:
    cleaned = _SAFE_PATH_RE.sub("_", path.strip("/"))
    return cleaned[:max_len] or "root"


def _timestamp() -> str:
    return datetime.datetime.now(datetime.UTC).strftime("%Y%m%d_%H%M%S_%f")


@final
class ProfilingMiddleware(BaseHTTPMiddleware):
    """FastAPI middleware for on-demand request CPU profiling with pyinstrument."""

    @override
    async def dispatch(
        self,
        request: Request,
        call_next: RequestResponseEndpoint,
    ) -> Response:
        profile_param = request.query_params.get("profile", "").lower()
        if profile_param not in ("1", "cpu"):
            return await call_next(request)

        from {{ project_slug }}.config.settings import get_settings

        settings = get_settings()
        if not getattr(settings, "profiling_enabled", False):
            return await call_next(request)

        expected_secret = getattr(settings, "profiling_secret", "")
        provided_secret = request.headers.get("X-Profile-Secret", "")
        if not expected_secret or provided_secret != expected_secret:
            logger.warning("profiling_request_blocked", reason="bad_secret")
            return await call_next(request)

        try:
            from pyinstrument import Profiler
        except ImportError:
            logger.warning("pyinstrument_not_installed")
            return await call_next(request)

        profiler = Profiler(interval=PROFILING_INTERVAL, async_mode="enabled")
        profiler.start()

        try:
            response = await call_next(request)
        finally:
            profiler.stop()

        session = profiler.last_session
        duration_ms = (session.duration * MS_PER_SECOND) if session else 0

        profiling_dir = pathlib.Path(getattr(settings, "profiling_dir", "profiles"))
        out_dir = profiling_dir / "requests"
        out_dir.mkdir(parents=True, exist_ok=True)

        method = request.method.lower()
        path = _sanitize_path(request.url.path)
        filename = f"{_timestamp()}_{method}_{path}.html"
        html_path = out_dir / filename

        try:
            profiler.write_html(html_path)
            response.headers["X-Profile-Saved"] = "true"
        except Exception:  # noqa: BLE001 -- profile save is non-critical
            logger.exception("profile_save_failed")

        existing = response.headers.get("Server-Timing", "")
        profile_metric = f"profile;dur={duration_ms:.1f}"
        response.headers["Server-Timing"] = (
            f"{existing}, {profile_metric}" if existing else profile_metric
        )
        return response
