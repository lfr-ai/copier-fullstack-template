class ExternalLookupRequest(BaseModel):
    """Request to look up an entity in an external knowledge graph."""

    entity: str
    source: str = Field(default="wikidata", pattern="^(wikidata|dbpedia|conceptnet)$")
    language: str = "en"
    limit: int = Field(default=DEFAULT_ENTITY_LOOKUP_LIMIT, ge=1, le=_MAX_EXTERNAL_LOOKUP_LIMIT)


class ExternalRelationsRequest(BaseModel):
    """Request to get relations for an external entity."""

    entity_id: str
    source: str = Field(default="wikidata", pattern="^(wikidata|dbpedia|conceptnet)$")
    limit: int = Field(default=DEFAULT_RELATION_LIMIT, ge=1, le=_MAX_EXTERNAL_RELATIONS_LIMIT)


@router.post(
    "/external/lookup",
    status_code=status.HTTP_200_OK,
    summary="Look up entity in external knowledge graph",
)
async def external_lookup(request: ExternalLookupRequest, container: ContainerDep) -> dict[str, object]:
    """Look up an entity in Wikidata, DBpedia, or ConceptNet."""
    connectors = {
        "wikidata": "wikidata_connector",
        "dbpedia": "dbpedia_connector",
        "conceptnet": "conceptnet_connector",
    }
    method_name = connectors.get(request.source)
    if not method_name or not hasattr(container, method_name):
        raise HTTPException(
            status_code=status.HTTP_501_NOT_IMPLEMENTED,
            detail=f"External connector '{request.source}' not configured.",
        )

    connector = getattr(container, method_name)()
    results = await connector.lookup_entity(
        request.entity,
        language=request.language,
        limit=request.limit,
    )
    return {"entity": request.entity, "source": request.source, "results": results}


@router.post(
    "/external/relations",
    status_code=status.HTTP_200_OK,
    summary="Get entity relations from external knowledge graph",
)
async def external_relations(request: ExternalRelationsRequest, container: ContainerDep) -> dict[str, object]:
    """Get relations for an entity from Wikidata, DBpedia, or ConceptNet."""
    connectors = {
        "wikidata": "wikidata_connector",
        "dbpedia": "dbpedia_connector",
        "conceptnet": "conceptnet_connector",
    }
    method_name = connectors.get(request.source)
    if not method_name or not hasattr(container, method_name):
        raise HTTPException(
            status_code=status.HTTP_501_NOT_IMPLEMENTED,
            detail=f"External connector '{request.source}' not configured.",
        )

    connector = getattr(container, method_name)()
    relations = await connector.get_entity_relations(request.entity_id, limit=request.limit)
    return {
        "entity_id": request.entity_id,
        "source": request.source,
        "relations": [{"subject": s, "predicate": p, "object": o} for s, p, o in relations],
    }
