"""User management API routes."""

from __future__ import annotations


from fastapi import APIRouter, status

from {{ project_slug }}.application.dtos.user_dto import CreateUserDTO
from {{ project_slug }}.presentation.api.dependencies import UserServiceDep
from {{ project_slug }}.presentation.api.schemas.user_schema import CreateUserRequest, UserResponse

router = APIRouter()


@router.post("/", response_model=UserResponse, status_code=status.HTTP_201_CREATED)
async def create_user(
    payload: CreateUserRequest,
    service: UserServiceDep,
) -> UserResponse:
    """Create new user."""
    dto = CreateUserDTO(email=payload.email, display_name=payload.display_name, password=payload.password)
    user = await service.create_user(dto)
    return UserResponse(
        id=user.id,
        email=user.email,
        display_name=user.display_name,
        is_active=user.is_active,
    )


@router.get("/{user_id}", response_model=UserResponse)
async def get_user(
    user_id: str,
    service: UserServiceDep,
) -> UserResponse:
    """Retrieve user by ID.

    Raises:
        NotFoundError: If user not found (mapped to 404 by error handler).
    """
    user = await service.get_user(user_id)
    return UserResponse(
        id=user.id,
        email=user.email,
        display_name=user.display_name,
        is_active=user.is_active,
    )
