"""Central API router that aggregates all sub-routers."""

from __future__ import annotations

from fastapi import APIRouter

from {{ project_slug }}.presentation.api.routes import health, users
{%- if use_ai %}
from {{ project_slug }}.presentation.api.routes import ai as ai_routes
from {{ project_slug }}.presentation.api.routes import conversations as conv_routes
{%- if use_rag %}
from {{ project_slug }}.presentation.api.routes import documents as doc_routes
{%- endif %}
{%- if use_knowledge_graph %}
from {{ project_slug }}.presentation.api.routes import knowledge_graph as kg_routes
{%- endif %}
{%- if use_agents %}
from {{ project_slug }}.presentation.api.routes import agents as agent_routes
from {{ project_slug }}.presentation.api.routes import workflows as workflow_routes
{%- endif %}
{%- if use_crewai %}
from {{ project_slug }}.presentation.api.routes import crewai as crewai_routes
{%- endif %}
{%- endif %}

api_router = APIRouter()

api_router.include_router(health.router, tags=["health"])
api_router.include_router(users.router, prefix="/users", tags=["users"])
{%- if use_ai %}
api_router.include_router(ai_routes.router, prefix="/ai", tags=["ai"])
api_router.include_router(conv_routes.router, prefix="/conversations", tags=["conversations"])
{%- if use_rag %}
api_router.include_router(doc_routes.router, prefix="/documents", tags=["documents"])
{%- endif %}
{%- if use_knowledge_graph %}
api_router.include_router(kg_routes.router, prefix="/knowledge-graph", tags=["knowledge-graph"])
{%- endif %}
{%- if use_agents %}
api_router.include_router(agent_routes.router, prefix="/agents", tags=["agents"])
api_router.include_router(workflow_routes.router, prefix="/workflows", tags=["workflows"])
{%- endif %}
{%- if use_crewai %}
api_router.include_router(crewai_routes.router, prefix="/crewai", tags=["crewai"])
{%- endif %}
{%- endif %}
