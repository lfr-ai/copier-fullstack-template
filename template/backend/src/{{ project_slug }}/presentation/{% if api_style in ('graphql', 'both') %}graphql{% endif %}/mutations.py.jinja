    @strawberry.mutation(description="Process a multimodal document through RAG-Anything.")
    async def raganything_process_document(
        self,
        info: strawberry.Info[GraphQLContext],
        input: RAGAnythingDocumentInput,
    ) -> MutationResult:
        """Process a PDF, Office document, or image through RAG-Anything."""
        try:
            service = info.context.raganything_service
            await service.process_document(
                input.file_path,
                output_dir=input.output_dir,
                parse_method=input.parse_method,
            )
            return MutationResult(
                success=True,
                message=f"Document '{input.file_path}' processed successfully.",
            )
        except Exception as exc:  # noqa: BLE001
            return MutationResult(success=False, message=str(exc)[:_ERROR_MSG_MAX_LEN])

    @strawberry.mutation(description="Insert pre-parsed multimodal content into RAG-Anything.")
    async def raganything_insert_content(
        self,
        info: strawberry.Info[GraphQLContext],
        items: list[MultimodalContentItem],
        file_path: str = "direct_input",
    ) -> MutationResult:
        """Insert pre-parsed multimodal content directly."""
        try:
            service = info.context.raganything_service
            content_list = []
            for item in items:
                entry: dict[str, object] = {"type": item.content_type}
                if item.text is not None:
                    entry["text"] = item.text
                if item.image_path is not None:
                    entry["img_path"] = item.image_path
                if item.table_body is not None:
                    entry["table_body"] = item.table_body
                if item.latex is not None:
                    entry["latex"] = item.latex
                if item.caption is not None:
                    entry["table_caption"] = [item.caption]
                    entry["image_caption"] = [item.caption]
                if item.page_index is not None:
                    entry["page_idx"] = item.page_index
                content_list.append(entry)

            await service.insert_content_list(
                content_list,
                file_path=file_path,
            )
            return MutationResult(
                success=True,
                message=f"Inserted {len(items)} content items.",
            )
        except Exception as exc:  # noqa: BLE001
            return MutationResult(success=False, message=str(exc)[:_ERROR_MSG_MAX_LEN])
{%- endif %}
