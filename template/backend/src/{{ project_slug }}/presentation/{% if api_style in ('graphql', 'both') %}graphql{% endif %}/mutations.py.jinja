"""Strawberry GraphQL root mutation type."""

from __future__ import annotations

from typing import final

import strawberry

from {{ project_slug }}.application.dtos.user_dto import CreateUserDTO
from {{ project_slug }}.presentation.graphql.context import GraphQLContext
from {{ project_slug }}.presentation.graphql.types import (
    CreateUserInput,
    UserType,
{%- if use_ai %}
    CompletionInput,
    CompletionResult,
{%- endif %}
{%- if use_rag or use_lightrag or use_raganything %}
    MutationResult,
{%- endif %}
{%- if use_lightrag %}
    LightRAGEntityInput,
    LightRAGInsertInput,
    LightRAGMergeInput,
    LightRAGRelationInput,
{%- endif %}
{%- if use_raganything %}
    RAGAnythingDocumentInput,
    MultimodalContentItem,
{%- endif %}
)

{%- if use_ai %}
_DEFAULT_MAX_TOKENS = 256
_DEFAULT_TEMPERATURE = 0.7
{%- endif %}
{%- if use_rag or use_lightrag or use_raganything %}
_ERROR_MSG_MAX_LEN = 200
{%- endif %}


@strawberry.type(description="Root mutation type.")
@final
class Mutation:
    """All top-level GraphQL mutations."""

    @strawberry.mutation(description="Create a new user account.")
    async def create_user(
        self,
        info: strawberry.Info[GraphQLContext],
        input: CreateUserInput,
    ) -> UserType:
        """Create a user through the application service layer."""
        dto = CreateUserDTO(
            email=input.email,
            display_name=input.display_name,
            password=input.password,
        )
        user = await info.context.user_service.create_user(dto)
        return UserType(
            id=strawberry.ID(user.id),
            email=user.email,
            display_name=user.display_name,
            is_active=user.is_active,
        )
{%- if use_ai %}

    @strawberry.mutation(description="Send an AI completion request (mutation variant for side-effects).")
    async def ai_complete(
        self,
        info: strawberry.Info[GraphQLContext],
        input: CompletionInput,
    ) -> CompletionResult:
        """Execute a completion via AI service as a mutation."""
        from {{ project_slug }}.ai.models import CompletionRequest

        service = info.context.ai_service
        request = CompletionRequest(
            prompt=input.prompt,
            max_tokens=input.max_tokens or _DEFAULT_MAX_TOKENS,
            temperature=input.temperature or _DEFAULT_TEMPERATURE,
        )
        result = await service.complete(request)
        return CompletionResult(
            text=result.content,
            model=result.model,
            tokens_used=result.total_tokens,
        )
{%- endif %}
{%- if use_rag %}

    @strawberry.mutation(description="Ingest a document into the RAG pipeline.")
    async def ingest_document(
        self,
        info: strawberry.Info[GraphQLContext],
        source: str,
    ) -> MutationResult:
        """Ingest a document into the vector store."""
        try:
            service = info.context.rag_service
            result = await service.ingest(source)
            return MutationResult(
                success=True,
                message=f"Ingested {result.chunk_count} chunks from {result.source}.",
            )
        except Exception as exc:  # noqa: BLE001
            return MutationResult(success=False, message=str(exc)[:_ERROR_MSG_MAX_LEN])
{%- endif %}
{%- if use_lightrag %}

    @strawberry.mutation(description="Insert text into the LightRAG knowledge base.")
    async def lightrag_insert(
        self,
        info: strawberry.Info[GraphQLContext],
        input: LightRAGInsertInput,
    ) -> MutationResult:
        """Insert text into LightRAG for entity extraction and graph indexing."""
        try:
            from {{ project_slug }}.ai.lightrag.lightrag_service import LightRAGIngestRequest

            service = info.context.lightrag_service
            request = LightRAGIngestRequest(
                text=input.text,
                doc_id=input.doc_id,
                file_path=input.file_path,
            )
            result = await service.ingest(request)
            if result.success:
                return MutationResult(
                    success=True,
                    message=f"Inserted {len(input.text)} characters into LightRAG.",
                )
            return MutationResult(success=False, message=result.message[:_ERROR_MSG_MAX_LEN])
        except Exception as exc:  # noqa: BLE001
            return MutationResult(success=False, message=str(exc)[:_ERROR_MSG_MAX_LEN])

    @strawberry.mutation(description="Create a knowledge graph entity in LightRAG.")
    async def lightrag_create_entity(
        self,
        info: strawberry.Info[GraphQLContext],
        input: LightRAGEntityInput,
    ) -> MutationResult:
        """Create a new entity in the LightRAG knowledge graph."""
        try:
            service = info.context.lightrag_service
            entity = await service.create_entity(
                input.name,
                entity_type=input.entity_type,
                description=input.description,
            )
            return MutationResult(
                success=True,
                message=f"Entity '{entity.name}' created.",
            )
        except Exception as exc:  # noqa: BLE001
            return MutationResult(success=False, message=str(exc)[:_ERROR_MSG_MAX_LEN])

    @strawberry.mutation(description="Create a relation between entities in LightRAG.")
    async def lightrag_create_relation(
        self,
        info: strawberry.Info[GraphQLContext],
        input: LightRAGRelationInput,
    ) -> MutationResult:
        """Create a new relation in the LightRAG knowledge graph."""
        try:
            service = info.context.lightrag_service
            await service.create_relation(
                input.source,
                input.target,
                description=input.description,
                keywords=input.keywords,
                weight=input.weight,
            )
            return MutationResult(
                success=True,
                message=f"Relation '{input.source}' -> '{input.target}' created.",
            )
        except Exception as exc:  # noqa: BLE001
            return MutationResult(success=False, message=str(exc)[:_ERROR_MSG_MAX_LEN])

    @strawberry.mutation(description="Delete an entity from the LightRAG knowledge graph.")
    async def lightrag_delete_entity(
        self,
        info: strawberry.Info[GraphQLContext],
        entity_name: str,
