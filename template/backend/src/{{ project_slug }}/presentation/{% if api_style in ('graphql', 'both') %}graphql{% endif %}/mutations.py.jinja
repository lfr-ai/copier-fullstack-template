                success=True,
                message=f"Merged {len(input.source_entities)} entities into '{result.name}'.",
            )
        except Exception as exc:  # noqa: BLE001
            return MutationResult(success=False, message=str(exc)[:_ERROR_MSG_MAX_LEN])

    @strawberry.mutation(description="Delete a document from LightRAG by document ID.")
