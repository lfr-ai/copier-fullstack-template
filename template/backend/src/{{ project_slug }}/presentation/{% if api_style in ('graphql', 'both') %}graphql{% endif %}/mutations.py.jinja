"""Strawberry GraphQL root mutation type."""

from __future__ import annotations

import strawberry

from {{ project_slug }}.application.dtos.user_dto import CreateUserDTO
from {{ project_slug }}.ports.graphql.context import GraphQLContext
from {{ project_slug }}.ports.graphql.types import (
    CreateUserInput,
    UserType,
{%- if use_ai %}
    CompletionInput,
    CompletionResult,
{%- endif %}
{%- if use_rag %}
    MutationResult,
{%- endif %}
)

{%- if use_ai %}
_DEFAULT_MAX_TOKENS: int = 256
_DEFAULT_TEMPERATURE: float = 0.7
{%- endif %}
{%- if use_rag %}
_ERROR_MSG_MAX_LEN: int = 200
{%- endif %}


@strawberry.type(description="Root mutation type.")
class Mutation:
    """All top-level GraphQL mutations."""

    @strawberry.mutation(description="Create a new user account.")
    async def create_user(
        self,
        info: strawberry.Info[GraphQLContext],
        input: CreateUserInput,
    ) -> UserType:
        """Create a user through the application service layer."""
        dto = CreateUserDTO(
            email=input.email,
            display_name=input.display_name,
            password=input.password,
        )
        user = await info.context.user_service.create_user(dto)
        return UserType(
            id=strawberry.ID(user.id),
            email=user.email,
            display_name=user.display_name,
            is_active=user.is_active,
        )
{%- if use_ai %}

    @strawberry.mutation(description="Send an AI completion request (mutation variant for side-effects).")
    async def ai_complete(
        self,
        info: strawberry.Info[GraphQLContext],
        input: CompletionInput,
    ) -> CompletionResult:
        """Execute a completion via AI service as a mutation."""
        from {{ project_slug }}.ai.models import CompletionRequest

        service = info.context.ai_service
        request = CompletionRequest(
            prompt=input.prompt,
            max_tokens=input.max_tokens or _DEFAULT_MAX_TOKENS,
            temperature=input.temperature or _DEFAULT_TEMPERATURE,
        )
        result = await service.complete(request)
        return CompletionResult(
            text=result.content,
            model=result.model,
            tokens_used=result.total_tokens,
        )
{%- endif %}
{%- if use_rag %}

    @strawberry.mutation(description="Ingest a document into the RAG pipeline.")
    async def ingest_document(
        self,
        info: strawberry.Info[GraphQLContext],
        source: str,
    ) -> MutationResult:
        """Ingest a document into the vector store."""
        try:
            service = info.context.rag_service
            result = await service.ingest(source)
            return MutationResult(
                success=True,
                message=f"Ingested {result.chunk_count} chunks from {result.source}.",
            )
        except Exception as exc:  # noqa: BLE001
            return MutationResult(success=False, message=str(exc)[:_ERROR_MSG_MAX_LEN])
{%- endif %}
