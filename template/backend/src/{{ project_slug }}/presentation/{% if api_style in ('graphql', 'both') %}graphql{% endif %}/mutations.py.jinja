        except Exception as exc:  # noqa: BLE001
            return MutationResult(success=False, message=str(exc)[:_ERROR_MSG_MAX_LEN])

    @strawberry.mutation(description="Merge multiple entities in the LightRAG knowledge graph.")
    async def lightrag_merge_entities(
        self,
        info: strawberry.Info[GraphQLContext],
        input: LightRAGMergeInput,
    ) -> MutationResult:
        """Merge multiple entities into a single target entity."""
        try:
            service = info.context.lightrag_service
            result = await service.merge_entities(
