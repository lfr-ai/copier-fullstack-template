"""Strawberry GraphQL subscription type (WebSocket transport)."""

from __future__ import annotations

import asyncio
from collections.abc import AsyncGenerator

import strawberry

from {{ project_slug }}.presentation.graphql.context import GraphQLContext
from {{ project_slug }}.presentation.graphql.types import HealthType

_DEFAULT_HEARTBEAT_INTERVAL = 10
_MIN_INTERVAL = 1
_MAX_INTERVAL = 60


@strawberry.type(description="Root subscription type.")
class Subscription:
    """WebSocket-based GraphQL subscriptions."""

    @strawberry.subscription(description="Periodic health heartbeat (every N seconds).")
    async def health_heartbeat(
        self,
        info: strawberry.Info[GraphQLContext],
        interval_seconds: int = _DEFAULT_HEARTBEAT_INTERVAL,
    ) -> AsyncGenerator[HealthType, None]:
        """Yield a health snapshot at a regular interval."""
        from importlib.metadata import version

        from {{ project_slug }}.core.enums import ServiceStatus

        interval = max(_MIN_INTERVAL, min(interval_seconds, _MAX_INTERVAL))
        app_version = version("{{ project_slug }}")
        while True:
            yield HealthType(
                status=ServiceStatus.HEALTHY.value,
                version=app_version,
                dependencies=[],
            )
            await asyncio.sleep(interval)
