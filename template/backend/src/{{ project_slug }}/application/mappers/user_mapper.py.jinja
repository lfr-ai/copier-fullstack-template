"""User entity to/from DTO mapper."""

from __future__ import annotations

from {{ project_slug }}.application.dtos.user_dto import UserDTO
from {{ project_slug }}.core.entities.user import User

__all__ = ["UserMapper"]


class UserMapper:
    """Map between User domain entities and UserDTO data transfer objects.

    Mappers isolate the application layer from domain entity internals,
    ensuring DTOs can evolve independently of the domain model.
    """

    @staticmethod
    def to_dto(entity: User) -> UserDTO:
        """Convert User domain entity to UserDTO.

        Args:
            entity (User): Domain entity to convert.

        Returns:
            UserDTO: Data transfer object suitable for the application layer.
        """
        return UserDTO(
            id=str(entity.id),
            email=str(entity.email),
            display_name=entity.display_name,
            is_active=entity.is_active,
        )

    @staticmethod
    def to_dto_list(entities: list[User]) -> list[UserDTO]:
        """Convert list of User entities to DTOs.

        Args:
            entities (list[User]): Domain entities to convert.

        Returns:
            list[UserDTO]: List of data transfer objects.
        """
        return [UserMapper.to_dto(entity) for entity in entities]
