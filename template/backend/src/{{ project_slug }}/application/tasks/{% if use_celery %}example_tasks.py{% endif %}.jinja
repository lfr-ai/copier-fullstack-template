{%- if use_celery %}
"""Example Celery background tasks.

All tasks must be idempotent and handle retries gracefully.
Use ``autoretry_for`` with exponential backoff for transient failures.

.. note::

Celery is imported directly here as a pragmatic exception to clean
architecture layering. Background-task definitions are tightly coupled
to the task framework by nature; abstracting them behind a protocol
would add indirection with no practical benefit.
"""

from __future__ import annotations

from typing import Final

import structlog

from celery import shared_task

__all__ = ["cleanup_expired_sessions", "send_welcome_email"]

logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)

_WELCOME_BACKOFF_MAX: Final[int] = 600
"""Maximum backoff (seconds) between welcome-email retries."""

_WELCOME_MAX_RETRIES: Final[int] = 3
"""Maximum retry attempts for welcome-email delivery."""

_CLEANUP_BACKOFF_MAX: Final[int] = 300
"""Maximum backoff (seconds) between session-cleanup retries."""

_CLEANUP_MAX_RETRIES: Final[int] = 5
"""Maximum retry attempts for session cleanup."""


@shared_task(
bind=True,
autoretry_for=(ConnectionError, TimeoutError, OSError),
retry_backoff=True,
retry_backoff_max=_WELCOME_BACKOFF_MAX,
retry_kwargs={"max_retries": _WELCOME_MAX_RETRIES},
acks_late=True,
)
def send_welcome_email(self: object, *, user_id: str, email: str) -> dict[str, str]:
"""Send welcome email to newly registered user.

Args:
self: Celery task instance (bound).
user_id: Unique identifier of the user.
email: Recipient email address.

Returns:
Status dict with user_id and delivery result.
"""
logger.info("Sending welcome email to %s (user_id=%s)", email, user_id)
return {"user_id": user_id, "status": "sent"}


@shared_task(
bind=True,
autoretry_for=(ConnectionError, TimeoutError, OSError),
retry_backoff=True,
retry_backoff_max=_CLEANUP_BACKOFF_MAX,
retry_kwargs={"max_retries": _CLEANUP_MAX_RETRIES},
acks_late=True,
)
def cleanup_expired_sessions(self: object) -> dict[str, int]:
"""Periodic task to clean up expired sessions.

Schedule via Celery Beat in compose.yml.

Args:
self: Celery task instance (bound).

Returns:
Count of removed sessions.
"""
logger.info("Cleaning up expired sessions")
removed = 0
return {"removed": removed}
{%- endif %}