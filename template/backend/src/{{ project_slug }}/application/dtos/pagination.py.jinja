"""Pagination parameters DTO."""

from __future__ import annotations

from typing import Annotated

from pydantic import Field

from {{ project_slug }}.application.dtos.base import BaseDTO
from {{ project_slug }}.config.constants import DEFAULT_PAGE_SIZE, MAX_PAGE_SIZE

__all__ = ["DEFAULT_PAGE_SIZE", "MAX_PAGE_SIZE", "PaginationParams"]


class PaginationParams(BaseDTO):
    """Query parameters for paginated endpoints.

    Uses page/page_size convention aligned with the API pagination
    schema at ``ports/api/schemas/pagination.py``.
    """

    page: Annotated[
        int,
        Field(default=1, ge=1, description="Page number (1-indexed)", examples=[1, 5]),
    ]
    page_size: Annotated[
        int,
        Field(
            default=DEFAULT_PAGE_SIZE,
            gt=0,
            le=MAX_PAGE_SIZE,
            description="Items per page",
            examples=[20, 50],
        ),
    ]

    @property
    def offset(self) -> int:
        """Compute SQL offset from page parameters.

        Returns:
            int: Zero-based offset for SQL queries.
        """
        return (self.page - 1) * self.page_size

    @property
    def limit(self) -> int:
        """Alias for page_size — convenience for SQL LIMIT.

        Returns:
            int: Maximum records per query.
        """
        return self.page_size
