"""String utility functions."""

from __future__ import annotations

import re
import unicodedata

_DEFAULT_TRUNCATE_LENGTH = 100


def slugify(value: str) -> str:
    """Convert string to URL-safe slug.

    Args:
        value (str): String to slugify.

    Returns:
        str: Lowercase hyphenated slug.
    """
    normalized = unicodedata.normalize("NFKD", value)
    ascii_only = normalized.encode("ascii", "ignore").decode("ascii")
    cleaned = re.sub(r"[^\w\s-]", "", ascii_only).strip().lower()
    return re.sub(r"[-\s]+", "-", cleaned)


def truncate(value: str, *, max_length: int = _DEFAULT_TRUNCATE_LENGTH, suffix: str = "...") -> str:
    """Truncate string to maximum length with suffix.

    Args:
        value (str): String to truncate.
        max_length (int): Maximum allowed length.
        suffix (str): Truncation indicator suffix.

    Returns:
        str: Truncated string.
    """
    if len(value) <= max_length:
        return value
    return value[: max_length - len(suffix)] + suffix
