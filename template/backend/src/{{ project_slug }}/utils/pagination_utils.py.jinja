"""Pagination helper utilities used by application services."""

from __future__ import annotations

_DEFAULT_PAGE_SIZE = 20


def paginate_list[T](
    items: list[T], *, page: int = 1, page_size: int = _DEFAULT_PAGE_SIZE
) -> list[T]:
    """Return a page-sized slice from *items*.

    Pages are 1-indexed.

    Args:
        items (list[T]): Full list to paginate.
        page (int): 1-based page number.
        page_size (int): Maximum items per page.

    Returns:
        list[T]: Slice of *items* corresponding to the requested page.
    """
    start = (page - 1) * page_size
    return items[start : start + page_size]


def total_pages(*, total_items: int, page_size: int) -> int:
    """Calculate the number of pages for *total_items*.

    Args:
        total_items (int): Total item count.
        page_size (int): Items per page (returns '0' when non-positive).

    Returns:
        int: Number of pages required to display all items.
    """
    if page_size <= 0:
        return 0
    return (total_items + page_size - 1) // page_size
