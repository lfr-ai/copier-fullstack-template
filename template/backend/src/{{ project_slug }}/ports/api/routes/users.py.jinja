"""User management API routes."""

from __future__ import annotations

from typing import Final

from fastapi import APIRouter
from starlette import status

from {{ project_slug }}.application.dtos.user_dto import CreateUserDTO, UserDTO
from {{ project_slug }}.ports.api.dependencies import UserServiceDep
from {{ project_slug }}.ports.api.schemas.user_schema import CreateUserRequest, UserResponse

__all__ = ["create_user", "get_user", "router"]

router: Final[APIRouter] = APIRouter()


@router.post("/", response_model=UserResponse, status_code=status.HTTP_201_CREATED)
async def create_user(
    payload: CreateUserRequest,
    service: UserServiceDep,
) -> UserResponse:
    """Create new user.

    Args:
        payload (CreateUserRequest): User creation request.
        service (UserServiceDep): Injected user service.

    Returns:
        UserResponse: Created user data.
    """
    dto = CreateUserDTO(email=payload.email, display_name=payload.display_name)
    user = await service.create_user(dto)
    return UserResponse(
        id=user.id,
        email=user.email,
        display_name=user.display_name,
        is_active=user.is_active,
    )


@router.get("/{user_id}", response_model=UserResponse)
async def get_user(
    user_id: str,
    service: UserServiceDep,
) -> UserResponse:
    """Retrieve user by ID.

    Args:
        user_id (str): User identifier.
        service (UserServiceDep): Injected user service.

    Returns:
        UserResponse: User data.

    Raises:
        NotFoundError: If user not found (mapped to 404 by error handler).
    """
    user = await service.get_user(user_id)
    return UserResponse(
        id=user.id,
        email=user.email,
        display_name=user.display_name,
        is_active=user.is_active,
    )
