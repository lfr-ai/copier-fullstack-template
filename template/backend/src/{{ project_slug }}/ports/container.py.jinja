"""Dependency injection container setup."""

from __future__ import annotations

from functools import lru_cache

from {{ project_slug }}.adapters.cache.memory_cache import MemoryCacheAdapter
from {{ project_slug }}.adapters.messaging.memory_event_bus import MemoryEventBus
from {{ project_slug }}.adapters.persistence.session import create_engine, create_session_factory
from {{ project_slug }}.adapters.persistence.unit_of_work.sqlalchemy_uow import SQLAlchemyUnitOfWork
from {{ project_slug }}.application.services.user_service import UserService
from {{ project_slug }}.config.settings import get_settings

__all__ = ["Container", "get_container"]


class Container:
    """Simple dependency injection container.

    Provides factory methods for creating configured
    service instances with their dependencies.
    """

    def __init__(self) -> None:
        """Initialize container with application settings."""
        self._settings = get_settings()
        self._engine = create_engine(
            self._settings.database_url,
            echo=self._settings.database_echo,
        )
        self._session_factory = create_session_factory(self._engine)

    def unit_of_work(self) -> SQLAlchemyUnitOfWork:
        """Create unit of work instance.

        Returns:
            SQLAlchemyUnitOfWork: Configured SQLAlchemy unit of work.
        """
        return SQLAlchemyUnitOfWork(self._session_factory)

    def cache(self) -> MemoryCacheAdapter:
        """Create cache adapter instance.

        Returns:
            MemoryCacheAdapter: Memory cache adapter (swap with Redis in production).
        """
        return MemoryCacheAdapter()

    def event_bus(self) -> MemoryEventBus:
        """Create event bus instance.

        Returns:
            MemoryEventBus: In-memory event bus.
        """
        return MemoryEventBus()

    def user_service(self) -> UserService:
        """Create user service with its dependencies.

        Returns:
            UserService: Configured user service instance.
        """
        return UserService(
            uow=self.unit_of_work(),
        )


@lru_cache(maxsize=1)
def get_container() -> Container:
    """Get singleton container instance.

    Returns:
        Container: Application dependency container.
    """
    return Container()
