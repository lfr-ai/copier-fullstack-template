"""In-memory cache adapter for development and testing."""

from __future__ import annotations

import time
from dataclasses import dataclass

from {{ project_slug }}.config.constants import DEFAULT_CACHE_TTL_SECONDS


@dataclass(frozen=True, slots=True)
class _CacheEntry:
    """Internal cache entry with value and expiration."""

    value: str
    expires_at: float


class MemoryCacheAdapter:
    """In-memory cache implementing CacheGateway.

    Provides TTL-based expiration with lazy cleanup.
    Suitable for development and testing environments.
    """

    def __init__(self) -> None:
        self._store: dict[str, _CacheEntry] = {}

    async def get(self, key: str) -> str | None:
        """Retrieve a value from the memory cache.

        Args:
            key (str): Cache key.

        Returns:
            str | None: Cached value, or 'None' if missing or expired.
        """
        entry = self._store.get(key)
        if entry is None:
            return None
        if time.monotonic() > entry.expires_at:
            del self._store[key]
            return None
        return entry.value

    async def set(
        self,
        *,
        key: str,
        value: str,
        ttl_seconds: int | None = None,
    ) -> None:
        """Store a value in the memory cache with TTL.

        Args:
            key (str): Cache key.
            value (str): Value to store.
            ttl_seconds (int | None): Time-to-live in seconds; uses default if 'None'.
        """
        effective_ttl = ttl_seconds if ttl_seconds is not None else DEFAULT_CACHE_TTL_SECONDS
        expires_at = time.monotonic() + effective_ttl
        self._store[key] = _CacheEntry(value=value, expires_at=expires_at)

    async def delete(self, key: str) -> bool:
        """Remove a value from the memory cache.

        Args:
            key (str): Cache key to remove.

        Returns:
            bool: 'True' if the key existed and was removed.
        """
        return self._store.pop(key, None) is not None

    async def exists(self, key: str) -> bool:
        """Check if non-expired key exists."""
        result = await self.get(key)
        return result is not None
