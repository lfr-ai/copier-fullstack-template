{%- if cloud_provider == 'azure' %}
"""Azure Blob Storage adapter — upload, download, and manage binary objects."""

from __future__ import annotations

from typing import TYPE_CHECKING, BinaryIO

import structlog

if TYPE_CHECKING:
from azure.storage.blob.aio import BlobServiceClient

logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)


class AzureBlobStorageAdapter:
"""Upload, download, and manage files in Azure Blob Storage.

Implements the 'StoragePort' protocol defined in
'core/interfaces/storage.py'.

Requires 'azure-storage-blob' — already declared as a conditional
dependency in 'pyproject.toml' when 'cloud_provider == azure'.
"""

__slots__ = ("_client", "_container")

def __init__(
self,
*,
connection_string: str,
container_name: str,
) -> None:
"""Initialize Azure Blob Storage adapter.

Args:
connection_string (str): Azure Storage account connection string or
'DefaultAzureCredential'-compatible endpoint URL.
container_name (str): Name of the blob container to operate on.
"""
from azure.storage.blob.aio import BlobServiceClient as _BlobServiceClient

self._client: BlobServiceClient = _BlobServiceClient.from_connection_string(
connection_string,
)
self._container = container_name

async def upload(self, *, key: str, data: BinaryIO) -> str:
"""Upload binary data to Azure Blob Storage.

Args:
key (str): Blob name (path) inside the container.
data (BinaryIO): Binary stream to upload.

Returns:
str: Full blob URL of the uploaded object.
"""
container_client = self._client.get_container_client(self._container)
blob_client = container_client.get_blob_client(key)
await blob_client.upload_blob(data, overwrite=True)
url: str = blob_client.url
logger.info("Uploaded blob %s/%s", self._container, key)
return url

async def download(self, key: str) -> bytes:
"""Download a blob and return its raw bytes.

Args:
key (str): Blob name (path) inside the container.

Returns:
bytes: Raw bytes of the downloaded blob.
"""
container_client = self._client.get_container_client(self._container)
blob_client = container_client.get_blob_client(key)
stream = await blob_client.download_blob()
return await stream.readall()

async def delete(self, key: str) -> None:
"""Delete a blob from the container.

Args:
key (str): Blob name (path) inside the container.
"""
container_client = self._client.get_container_client(self._container)
blob_client = container_client.get_blob_client(key)
await blob_client.delete_blob()
logger.info("Deleted blob %s/%s", self._container, key)

async def exists(self, key: str) -> bool:
"""Check whether a blob exists in the container.

Args:
key (str): Blob name (path) inside the container.

Returns:
bool: True if the blob exists.
"""
container_client = self._client.get_container_client(self._container)
blob_client = container_client.get_blob_client(key)
return await blob_client.exists()

async def close(self) -> None:
"""Close the underlying HTTP client."""
await self._client.close()
{%- endif %}