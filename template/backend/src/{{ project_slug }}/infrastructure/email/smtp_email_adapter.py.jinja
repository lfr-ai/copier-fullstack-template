"""SMTP email adapter -- sends real emails via an SMTP relay."""

from __future__ import annotations

from typing import final

import asyncio
from email.message import EmailMessage

import structlog

from {{ project_slug }}.config.constants import DEFAULT_FROM_ADDRESS, DEFAULT_SMTP_PORT

logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)


@final
class SmtpEmailAdapter:
    """Send email via SMTP.

    This adapter implements the 'EmailGateway' protocol defined in
    'core/interfaces/email.py' and delegates to an SMTP server
    for actual delivery.

    The blocking 'smtplib' calls are offloaded to a thread via
    'asyncio.to_thread()' so the event loop is never blocked.
    """

    __slots__ = ("_host", "_password", "_port", "_username")

    def __init__(
        self,
        *,
        host: str,
        port: int = DEFAULT_SMTP_PORT,
        username: str = "",
        password: str = "",
    ) -> None:
        """Args:
            host (str): SMTP server hostname.
            port (int): SMTP server port.
            username (str): SMTP authentication username.
            password (str): SMTP authentication password.
        """
        self._host = host
        self._port = port
        self._username = username
        self._password = password

    def _send_sync(self, msg: EmailMessage) -> None:
        """Synchronous SMTP send -- runs inside a thread.

        Args:
            msg (EmailMessage): Fully composed email message.
        """
        import smtplib as _smtplib

        with _smtplib.SMTP(self._host, self._port) as server:
            if self._username:
                server.starttls()
                server.login(self._username, self._password)
            server.send_message(msg)

    async def send(
        self,
        *,
        to: str,
        subject: str,
        body: str,
        from_addr: str = DEFAULT_FROM_ADDRESS,
    ) -> None:
        """Send a single email message.

        The blocking SMTP operations are offloaded to a thread
        via 'asyncio.to_thread()' to avoid blocking the event loop.

        Args:
            to (str): Recipient email address.
            subject (str): Email subject line.
            body (str): Email body content.
            from_addr (str): Sender email address.
        """
        msg = EmailMessage()
        msg["Subject"] = subject
        msg["From"] = from_addr
        msg["To"] = to
        msg.set_content(body)

        logger.info("Sending email to %s via SMTP %s:%s", to, self._host, self._port)
        await asyncio.to_thread(self._send_sync, msg)

        logger.info("Email sent successfully to %s", to)
