logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)


@final
class Container:
    """Dependency injection container.

    Provides factory methods for creating configured
    service instances with their dependencies.
    """

    def __init__(self) -> None:
        self._settings = get_settings()
        self._engine = None
        self._session_factory = None
        self._cache: MemoryCacheAdapter | None = None
        self._event_bus: MemoryEventBus | None = None
{% if use_ai %}
        self._ai_config_loader = None
{%- endif %}
        if self._settings.database_url:
            from {{ project_slug }}.infrastructure.persistence.session import (
                create_engine,
                create_session_factory,
            )

            self._engine = create_engine(
                self._settings.database_url,
                echo=self._settings.database_echo,
            )
            self._session_factory = create_session_factory(self._engine)

    async def dispose(self) -> None:
        """Release resources held by the container (DB engine, etc.)."""
        if self._engine is not None:
            try:
                await self._engine.dispose()
                logger.info("database_engine_disposed")
            except Exception:  # noqa: BLE001 -- teardown cleanup, best-effort
                logger.exception("database_engine_dispose_failed")

    def unit_of_work(self) -> SQLAlchemyUnitOfWork:
        """Create unit of work instance with event bus integration."""
        if self._session_factory is None:
            msg = "Database not configured -- set database_url in settings."
            raise RuntimeError(msg)
        from {{ project_slug }}.infrastructure.persistence.unit_of_work.sqlalchemy_uow import (
            SQLAlchemyUnitOfWork,
        )

        return SQLAlchemyUnitOfWork(
            self._session_factory,
            event_bus=self.event_bus(),
        )

    def cache(self) -> MemoryCacheAdapter:
        """Return singleton cache adapter instance."""
        if self._cache is None:
            self._cache = MemoryCacheAdapter()
        return self._cache

    def event_bus(self) -> MemoryEventBus:
        """Return singleton event bus instance."""
        if self._event_bus is None:
            self._event_bus = MemoryEventBus()
        return self._event_bus

    def user_service(self) -> UserService:
        """Create user service with its dependencies."""
        from {{ project_slug }}.infrastructure.security.hashing import PBKDF2PasswordHasher

        return UserService(
            uow=self.unit_of_work(),
            password_hasher=PBKDF2PasswordHasher(),
        )


