    def workflow_engine(self) -> WorkflowEngineGateway:
        """Create a LangGraph workflow engine with durable execution support.

        Uses PostgreSQL checkpointing when a database is configured,
        otherwise falls back to an in-memory checkpointer.
        """
        from {{ project_slug }}.ai.workflows.langgraph_engine import LangGraphWorkflowEngine

        checkpointer = self._create_checkpointer()
        return LangGraphWorkflowEngine(
            llm=self._create_llm(),
            nodes=self._default_workflow_nodes(),
            checkpointer=checkpointer,
        )

    def _create_checkpointer(self) -> object | None:
        """Create a workflow checkpointer based on 'checkpointer_backend' setting.

        The 'postgres' backend requires async setup and must be
        initialized at runtime via an async setup hook -- this factory
        raises 'ValueError' if selected to signal the caller.
        """
        backend = self._settings.checkpointer_backend
        try:
            if backend == "sqlite":
                from {{ project_slug }}.ai.workflows.checkpointers import create_sqlite_checkpointer

                return create_sqlite_checkpointer()
            if backend == "postgres":
                msg = (
                    "PostgreSQL checkpointer requires async initialization. "
                    "Use create_postgres_checkpointer() in an async context."
                )
                raise ValueError(msg)
            from {{ project_slug }}.ai.workflows.checkpointers import create_memory_checkpointer

            return create_memory_checkpointer()
        except ImportError:
            return None

