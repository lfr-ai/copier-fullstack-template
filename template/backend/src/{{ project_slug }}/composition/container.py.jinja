    def load_ai_config(self, config_path: str | None = None) -> object | None:
        """Load AI configuration from YAML file using AIConfigLoader.

        When a config file exists, uses AIConfigLoader for component
        instantiation. Falls back to settings-based factory methods
        (_create_llm, _create_embedding, etc.) when config is missing.

        Args:
            config_path (str | None): Path to ai_config.yaml. Defaults to
                'config/ai_config.yaml' relative to project root.

        Returns:
            AIConfigLoader | None: Loader instance if config file exists,
                None if falling back to settings-based instantiation.

        Example:
            loader = container.load_ai_config()
            if loader:
                pipeline = loader.create_pipeline("self_crag")
            else:
                # Fallback to settings-based instantiation
                llm = container._create_llm()
        """
        from pathlib import Path

        # Use default path if not provided
        if config_path is None:
            config_path = "config/ai_config.yaml"

        config_file = Path(config_path)

        # Check if config file exists
        if not config_file.exists():
            logger.debug(
                "AI config file not found, falling back to settings-based instantiation",
                config_path=str(config_file.absolute()),
            )
            return None

        # Return cached loader if already initialized
        if self._ai_config_loader is not None:
            logger.debug("Returning cached AIConfigLoader")
            return self._ai_config_loader

        # Load config and create loader
        try:
            from {{ project_slug }}.ai.config_loader import AIConfigLoader

            self._ai_config_loader = AIConfigLoader(config_path=config_file)
            logger.info(
                "AI config file loaded successfully",
                config_path=str(config_file.absolute()),
                sections=list(self._ai_config_loader._config.keys()),
            )
            return self._ai_config_loader

        except Exception:
            logger.exception(
                "Failed to load AI config file, falling back to settings",
                config_path=str(config_file.absolute()),
            )
            return None

    def _get_openai_key(self) -> str:
        """Return OpenAI API key from settings or raise."""
        key = getattr(self._settings, "openai_api_key", "")
        if not key:
            msg = "OPENAI_API_KEY not configured. Set {{ project_slug | upper }}_OPENAI_API_KEY."
            logger.warning(msg)
            raise AttributeError(msg)
        return key

    def _create_llm(self) -> LLMGateway:
        """Create LLM adapter based on configuration.

        Uses :class:`LiteLLMAdapter` as the universal backend -- the model
        string prefix routes to the correct provider automatically.
        """
        from {{ project_slug }}.ai.llm.litellm_adapter import LiteLLMAdapter

{%- if use_azure_openai %}
        endpoint = getattr(self._settings, "azure_openai_endpoint", "")
        api_key = getattr(self._settings, "azure_openai_api_key", "")
        deployment = getattr(self._settings, "azure_openai_deployment", "")
        if endpoint and api_key and deployment:
            return LiteLLMAdapter(
                model=f"azure/{deployment}",
                api_key=api_key,
                api_base=endpoint,
                api_version=getattr(self._settings, "azure_openai_api_version", "2025-04-01-preview"),
            )
{%- endif %}
        model = getattr(self._settings, "openai_model", "gpt-4o")
        return LiteLLMAdapter(model=model, api_key=self._get_openai_key())

    def _create_embedding(self) -> EmbeddingGateway:
