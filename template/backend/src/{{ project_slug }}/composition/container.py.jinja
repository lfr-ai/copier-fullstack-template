    def llm_gateway(self) -> LLMGateway:
        """Create multi-provider LLM gateway with failover.

        Registers all configured LLM providers so the gateway can
        fall back to an alternative when the primary is unavailable.
        """
        from {{ project_slug }}.ai.llm.gateway import AIGateway
        from {{ project_slug }}.ai.llm.litellm_adapter import LiteLLMAdapter

        providers: dict[str, object] = {"default": self._create_llm()}
{%- if use_anthropic %}

        try:
            anthropic_key = getattr(self._settings, "anthropic_api_key", "")
            if anthropic_key:
                anthropic_model = getattr(self._settings, "anthropic_model", "claude-sonnet-4-6")
                providers["anthropic"] = LiteLLMAdapter(
                    model=f"anthropic/{anthropic_model}" if not anthropic_model.startswith("anthropic/") else anthropic_model,
                    api_key=anthropic_key,
                )
        except (AttributeError, ImportError):
            logger.debug("Anthropic provider not available for gateway")
