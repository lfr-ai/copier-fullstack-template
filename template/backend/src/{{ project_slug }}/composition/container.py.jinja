        dim = getattr(self._settings, "embedding_dimension", 1536)
        model = getattr(self._settings, "embedding_model", "text-embedding-3-small")
{%- if use_azure_openai %}
        endpoint = getattr(self._settings, "azure_openai_endpoint", "")
        api_key = getattr(self._settings, "azure_openai_api_key", "")
        if endpoint and api_key:
            return LiteLLMEmbeddingAdapter(
                model=f"azure/{model}",
                api_key=api_key,
                api_base=endpoint,
                api_version=getattr(self._settings, "azure_openai_api_version", "2025-04-01-preview"),
                dimension=dim,
            )
{%- endif %}
        return LiteLLMEmbeddingAdapter(
            model=model,
            api_key=self._get_openai_key(),
