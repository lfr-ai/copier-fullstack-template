"""Validation exception for domain rule violations."""

from __future__ import annotations

from {{ project_slug }}.core.exceptions.base import DomainError

__all__ = ["ValidationError"]


class ValidationError(DomainError):
    """Raised when domain validation fails.

    Supports both single-field and multi-field error reporting.
    """

    def __init__(
        self,
        message: str,
        *,
        field: str | None = None,
        field_errors: dict[str, list[str]] | None = None,
    ) -> None:
        """Initialize validation error.

        Args:
            message (str): Validation failure description.
            field (str | None): Single field that failed validation.
            field_errors (dict[str, list[str]] | None): Mapping of field names to error messages.
        """
        super().__init__(message=message, code="VALIDATION_ERROR")
        self.field = field
        self.field_errors: dict[str, list[str]] = field_errors or {}
