"""User domain entity — aggregate root for user management."""

from __future__ import annotations

from dataclasses import dataclass, field
from datetime import datetime

from {{ project_slug }}.core.entities.base import AggregateRoot, utcnow


@dataclass(slots=True)
class User(AggregateRoot):
    """User aggregate root with authentication attributes.

    Serves as the consistency boundary for user identity,
    email, activation status, and password hash.
    """

    email: str = ""
    display_name: str = ""
    password_hash: str = ""
    is_active: bool = True
    created_at: datetime = field(default_factory=utcnow)
