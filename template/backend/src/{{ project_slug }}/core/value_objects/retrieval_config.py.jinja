"""Retrieval configuration value object."""

from __future__ import annotations

from dataclasses import dataclass

from {{ project_slug }}.core.entities.base import ValueObject

_DEFAULT_TOP_K: int = 5
_DEFAULT_SCORE_THRESHOLD: float = 0.7
_DEFAULT_RERANKER_TOP_K: int = 3
_DEFAULT_GRAPH_DEPTH: int = 2


@dataclass(frozen=True, slots=True)
class RetrievalConfig(ValueObject):
    """Immutable retrieval pipeline configuration."""

    strategy: str = "hybrid"
    top_k: int = _DEFAULT_TOP_K
    score_threshold: float = _DEFAULT_SCORE_THRESHOLD
    use_reranker: bool = False
    reranker_top_k: int = _DEFAULT_RERANKER_TOP_K
    use_knowledge_graph: bool = False
    graph_depth: int = _DEFAULT_GRAPH_DEPTH
