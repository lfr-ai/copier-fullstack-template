"""Repository protocol definitions for domain persistence."""

from __future__ import annotations

from typing import Protocol, runtime_checkable

from {{ project_slug }}.core.constants import DEFAULT_LIST_LIMIT
from {{ project_slug }}.core.entities.base import Entity


@runtime_checkable
class Repository[EntityT: Entity](Protocol):
    """Generic repository protocol for entity persistence."""

    async def get_by_id(self, entity_id: str) -> EntityT | None:
        """Retrieve entity by unique identifier."""
        ...

    async def add(self, entity: EntityT) -> EntityT:
        """Persist new entity."""
        ...

    async def update(self, entity: EntityT) -> EntityT:
        """Update existing entity."""
        ...

    async def delete(self, entity_id: str) -> bool:
        """Remove entity by identifier."""
        ...

    async def list_all(
        self,
        *,
        offset: int = 0,
        limit: int = DEFAULT_LIST_LIMIT,
    ) -> list[EntityT]:
        """Retrieve paginated list of entities."""
        ...
