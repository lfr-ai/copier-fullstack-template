"""Retrieval-related domain events."""

from __future__ import annotations

from dataclasses import dataclass

from {{ project_slug }}.core.entities.base import DomainEvent
@dataclass(frozen=True, slots=True)
class RetrievalPerformed(DomainEvent):
    """Raised when a retrieval operation completes."""

    query: str = ""
    result_count: int = 0
    strategy: str = "vector"
    top_score: float = 0.0


@dataclass(frozen=True, slots=True)
class RAGResponseGenerated(DomainEvent):
    """Raised when a RAG response is generated from retrieved context."""

    query: str = ""
    source_count: int = 0
    model: str = ""
    tokens_used: int = 0
