"""Document-related domain events."""

from __future__ import annotations

from dataclasses import dataclass

from {{ project_slug }}.core.entities.base import DomainEvent
@dataclass(frozen=True, slots=True)
class DocumentIngested(DomainEvent):
    """Raised when a document is successfully ingested."""

    document_id: str = ""
    source: str = ""
    content_type: str = ""


@dataclass(frozen=True, slots=True)
class DocumentChunked(DomainEvent):
    """Raised when a document is split into chunks."""

    document_id: str = ""
    chunk_count: int = 0
    strategy: str = "recursive"


@dataclass(frozen=True, slots=True)
class DocumentEmbedded(DomainEvent):
    """Raised when document chunks are embedded into vectors."""

    document_id: str = ""
    chunk_count: int = 0
    dimensions: int = 0
