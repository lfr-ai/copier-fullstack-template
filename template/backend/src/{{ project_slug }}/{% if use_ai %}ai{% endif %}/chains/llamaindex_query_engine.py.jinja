"""LlamaIndex query engine adapter — bridges LlamaIndex's VectorStoreIndex
to the clean-architecture RAG pipeline.

Uses LlamaIndex's 'VectorStoreIndex' and 'RetrieverQueryEngine' for
sophisticated query processing with automatic chunking, metadata
filtering, and response synthesis.

Add 'llama-index-core' to project dependencies before using.
"""

from __future__ import annotations

import structlog

from {{ project_slug }}.ai.config import DEFAULT_SIMILARITY_TOP_K, SOURCE_TEXT_PREVIEW_LENGTH
from {{ project_slug }}.core.entities.document import Document
from {{ project_slug }}.core.interfaces.embedding import EmbeddingPort
from {{ project_slug }}.core.interfaces.llm import LLMPort

logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)
class LlamaIndexQueryEngine:
    """LlamaIndex-backed query engine with vector index.

    Provides an alternative RAG query path using LlamaIndex's built-in
    retrieval, synthesis, and response formatting capabilities.
    """

    __slots__ = ("_documents", "_embedding", "_index", "_llm")

    def __init__(
        self,
        *,
        llm: LLMPort,
        embedding: EmbeddingPort,
    ) -> None:
        self._llm = llm
        self._embedding = embedding
        self._index: object | None = None
        self._documents: list[object] = []

    async def add_documents(self, documents: list[Document]) -> int:
        """Add documents to the LlamaIndex vector index.

        Args:
            documents (list[Document]): Documents to index.

        Returns:
            int: Number of documents indexed.
        """
        try:
            from llama_index.core import Document as LIDoc  # type: ignore[import-untyped]
            from llama_index.core import VectorStoreIndex  # type: ignore[import-untyped]
        except ImportError as exc:
            msg = "llama-index-core is required — pip install llama-index-core"
            raise ImportError(msg) from exc

        li_docs = [
            LIDoc(
                text=doc.content,
                metadata={**doc.metadata, "source": doc.source},
            )
            for doc in documents
        ]
        self._documents.extend(li_docs)

        # Rebuild index with all documents
        self._index = VectorStoreIndex.from_documents(li_docs)
        logger.info("LlamaIndex: indexed %d documents", len(li_docs))
        return len(li_docs)

    async def query(
        self,
        question: str,
        *,
        similarity_top_k: int = DEFAULT_SIMILARITY_TOP_K,
    ) -> dict[str, object]:
        """Query the LlamaIndex vector index.

        Args:
            question (str): Natural language question.
            similarity_top_k (int): Number of similar chunks to retrieve.

        Returns:
            dict[str, object]: Dict with 'answer', 'sources', and 'question' keys.
        """
        if self._index is None:
            # No documents indexed — fall back to direct LLM
            answer = await self._llm.complete(
                prompt=f"Question: {question}\n\nAnswer:",
            )
            return {"question": question, "answer": answer, "sources": []}

        try:
            query_engine = self._index.as_query_engine(
                similarity_top_k=similarity_top_k,
            )
            response = query_engine.query(question)

            sources = []
            if hasattr(response, "source_nodes"):
                for node in response.source_nodes:
                    sources.append({
                        "content": node.text[:SOURCE_TEXT_PREVIEW_LENGTH] if hasattr(node, "text") else "",
                        "score": float(node.score) if hasattr(node, "score") else 0.0,
                        "metadata": dict(node.metadata) if hasattr(node, "metadata") else {},
                    })

            return {
                "question": question,
                "answer": str(response),
                "sources": sources,
            }
        except Exception:  # noqa: BLE001 — graceful fallback to direct LLM
            logger.exception("LlamaIndex query failed, falling back to direct LLM")
            answer = await self._llm.complete(
                prompt=f"Question: {question}\n\nAnswer:",
            )
            return {"question": question, "answer": answer, "sources": []}
