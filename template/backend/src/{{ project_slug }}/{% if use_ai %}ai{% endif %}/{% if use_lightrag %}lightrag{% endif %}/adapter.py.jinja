"""LightRAG adapter -- async wrapper around the 'lightrag' core library.

Provides a Clean Architecture-compliant adapter that wraps the LightRAG
graph-native RAG engine. LightRAG combines knowledge graph construction
with vector retrieval for superior comprehensiveness and diversity
compared to traditional RAG approaches.

Supports multiple storage backends:
* Graph: NetworkXStorage, Neo4JStorage, PGGraphStorage
* Vector: NanoVectorDBStorage, PGVectorStorage, FaissVectorDBStorage
* KV: JsonKVStorage, PGKVStorage, RedisKVStorage

Add 'lightrag-hku' to project dependencies before using.
"""

from __future__ import annotations

from dataclasses import dataclass, field
from typing import TYPE_CHECKING, final

import structlog

from {{ project_slug }}.ai.lightrag.config import LightRAGQueryMode

if TYPE_CHECKING:
    from {{ project_slug }}.ai.lightrag.config import LightRAGSettings

logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)

_DEFAULT_TOP_K = 60


@dataclass(frozen=True, slots=True)
@final
class LightRAGQueryResult:
    """Result of a LightRAG query."""

    query: str
    answer: str
    mode: str
    contexts: list[str] = field(default_factory=list)


@dataclass(frozen=True, slots=True)
@final
class LightRAGEntityInfo:
    """Information about a knowledge graph entity."""

    name: str
    entity_type: str = ""
    description: str = ""
    source_id: str = ""


@dataclass(frozen=True, slots=True)
@final
class LightRAGRelationInfo:
    """Information about a knowledge graph relation."""

    source: str
    target: str
    description: str = ""
    keywords: str = ""
    weight: float = 1.0
    source_id: str = ""


@dataclass(frozen=True, slots=True)
@final
class LightRAGInsertResult:
    """Result of a document insertion operation."""

    source: str
    success: bool
    document_count: int = 0
    message: str = ""


@final
class LightRAGAdapter:
    """Async adapter wrapping the LightRAG graph-native RAG engine.

    Manages lifecycle of the underlying 'lightrag.LightRAG' instance
    including storage initialization and teardown. All public methods
    are async-first for FastAPI compatibility.

    Typical usage::

        adapter = await LightRAGAdapter.create(settings)
        result = await adapter.query('What are the main themes?')
        await adapter.close()
    """

    __slots__ = ("_config", "_initialized", "_rag")

    def __init__(
        self,
        *,
        working_dir: str = "./data/lightrag",
        graph_storage: str = "NetworkXStorage",
        vector_storage: str = "NanoVectorDBStorage",
        kv_storage: str = "JsonKVStorage",
        doc_status_storage: str = "JsonDocStatusStorage",
        chunk_token_size: int = 1200,
        chunk_overlap_token_size: int = 100,
        embedding_batch_num: int = 32,
        embedding_max_async: int = 16,
        llm_max_async: int = 4,
        llm_model_func: object | None = None,
        embedding_func: object | None = None,
        llm_model_name: str = "gpt-4o-mini",
        enable_llm_cache: bool = True,
        addon_params: dict[str, object] | None = None,
        graph_storage_cls_kwargs: dict[str, object] | None = None,
        vector_db_storage_cls_kwargs: dict[str, object] | None = None,
    ) -> None:
        self._config: dict[str, object] = {
            "working_dir": working_dir,
            "graph_storage": graph_storage,
            "vector_storage": vector_storage,
            "kv_storage": kv_storage,
            "doc_status_storage": doc_status_storage,
            "chunk_token_size": chunk_token_size,
            "chunk_overlap_token_size": chunk_overlap_token_size,
            "embedding_batch_num": embedding_batch_num,
            "embedding_func_max_async": embedding_max_async,
            "llm_model_max_async": llm_max_async,
            "llm_model_name": llm_model_name,
            "enable_llm_cache": enable_llm_cache,
        }
        if llm_model_func is not None:
            self._config["llm_model_func"] = llm_model_func
        if embedding_func is not None:
            self._config["embedding_func"] = embedding_func
        if addon_params is not None:
            self._config["addon_params"] = addon_params
        if graph_storage_cls_kwargs is not None:
            self._config["graph_storage_cls_kwargs"] = graph_storage_cls_kwargs
        if vector_db_storage_cls_kwargs is not None:
            self._config["vector_db_storage_cls_kwargs"] = vector_db_storage_cls_kwargs

        self._rag: object | None = None
        self._initialized = False

    async def initialize(self) -> None:
        """Initialize LightRAG instance and storage backends.

        Must be called before any query or insert operations.
        """
        if self._initialized:
            return

        try:
            from lightrag import LightRAG
        except ImportError as exc:
            msg = "lightrag-hku is required -- pip install lightrag-hku"
            raise ImportError(msg) from exc

        self._rag = LightRAG(**self._config)
        await self._rag.initialize_storages()
        self._initialized = True

        logger.info(
            "lightrag_initialized",
            working_dir=self._config["working_dir"],
            graph_storage=self._config["graph_storage"],
        )

    @classmethod
    async def create(
        cls,
        settings: LightRAGSettings,
        *,
        llm_model_func: object | None = None,
        embedding_func: object | None = None,
    ) -> LightRAGAdapter:
        """Factory: create and initialize a LightRAGAdapter from settings.

        Args:
            settings (LightRAGSettings): LightRAG configuration.
            llm_model_func (object | None): Custom LLM function.
            embedding_func (object | None): Custom embedding function.

        Returns:
            LightRAGAdapter: Fully initialized adapter.
        """
        adapter = cls(
            working_dir=settings.working_dir,
            graph_storage=settings.graph_storage,
            vector_storage=settings.vector_storage,
            kv_storage=settings.kv_storage,
            doc_status_storage=settings.doc_status_storage,
            chunk_token_size=settings.chunk_token_size,
            chunk_overlap_token_size=settings.chunk_overlap_token_size,
            embedding_batch_num=settings.embedding_batch_num,
            embedding_max_async=settings.embedding_max_async,
            llm_max_async=settings.llm_max_async,
            llm_model_func=llm_model_func,
            embedding_func=embedding_func,
            llm_model_name=settings.llm_model_name,
            enable_llm_cache=settings.enable_llm_cache,
            addon_params=dict(settings.addon_params) if settings.addon_params else None,
        )
        await adapter.initialize()
        return adapter

    def _ensure_initialized(self) -> object:
        """Return the underlying LightRAG instance or raise."""
        if not self._initialized or self._rag is None:
            msg = "LightRAG not initialized -- call 'await adapter.initialize()' first."
            raise RuntimeError(msg)
        return self._rag

    async def close(self) -> None:
        """Finalize storage backends and release resources."""
        if self._rag is not None and self._initialized:
            try:
                await self._rag.finalize_storages()
                logger.info("lightrag_finalized")
            except Exception:
                logger.exception("lightrag_finalize_failed")
            finally:
                self._initialized = False

    # ── Insert operations ─────────────────────────────────────────

    async def insert(
        self,
        text: str,
        *,
        doc_id: str | None = None,
        file_path: str | None = None,
    ) -> LightRAGInsertResult:
        """Insert a text document into the LightRAG knowledge base.

        Args:
            text (str): Document text to ingest.
            doc_id (str | None): Optional custom document identifier.
            file_path (str | None): Optional source file path for citations.

        Returns:
            LightRAGInsertResult: Insertion outcome.
        """
        rag = self._ensure_initialized()
        try:
            kwargs: dict[str, object] = {}
            if doc_id is not None:
                kwargs["ids"] = [doc_id]
            if file_path is not None:
                kwargs["file_paths"] = [file_path]

            await rag.ainsert(text, **kwargs)
            logger.info("lightrag_document_inserted", text_length=len(text))
            return LightRAGInsertResult(
                source=file_path or "<inline>",
                success=True,
                document_count=1,
            )
        except Exception as exc:
            logger.exception("lightrag_insert_failed")
            return LightRAGInsertResult(
                source=file_path or "<inline>",
                success=False,
                message=str(exc),
            )

    async def insert_batch(
        self,
        texts: list[str],
        *,
        ids: list[str] | None = None,
        file_paths: list[str] | None = None,
    ) -> LightRAGInsertResult:
        """Batch-insert multiple text documents.

        Args:
            texts (list[str]): Document texts to ingest.
            ids (list[str] | None): Optional document identifiers.
            file_paths (list[str] | None): Optional file paths for citations.

        Returns:
            LightRAGInsertResult: Insertion outcome.
        """
        rag = self._ensure_initialized()
        try:
            kwargs: dict[str, object] = {}
            if ids is not None:
                kwargs["ids"] = ids
            if file_paths is not None:
                kwargs["file_paths"] = file_paths

            await rag.ainsert(texts, **kwargs)
            logger.info("lightrag_batch_inserted", count=len(texts))
            return LightRAGInsertResult(
                source="batch",
                success=True,
                document_count=len(texts),
            )
        except Exception as exc:
            logger.exception("lightrag_batch_insert_failed")
            return LightRAGInsertResult(source="batch", success=False, message=str(exc))

    async def insert_custom_kg(
        self,
        custom_kg: dict[str, list[dict[str, object]]],
    ) -> LightRAGInsertResult:
        """Insert a pre-built knowledge graph directly.

        Args:
            custom_kg (dict[str, list[dict[str, object]]]): KG data with
                'chunks', 'entities', and 'relationships' keys.

        Returns:
            LightRAGInsertResult: Insertion outcome.
        """
        rag = self._ensure_initialized()
        try:
            await rag.ainsert_custom_kg(custom_kg)
            entity_count = len(custom_kg.get("entities", []))
            rel_count = len(custom_kg.get("relationships", []))
            logger.info("lightrag_custom_kg_inserted", entities=entity_count, relations=rel_count)
            return LightRAGInsertResult(
                source="custom_kg",
                success=True,
                document_count=entity_count,
                message=f"Inserted {entity_count} entities and {rel_count} relationships.",
            )
        except Exception as exc:
            logger.exception("lightrag_custom_kg_insert_failed")
            return LightRAGInsertResult(source="custom_kg", success=False, message=str(exc))

    # ── Query operations ──────────────────────────────────────────

    async def query(
        self,
        question: str,
        *,
        mode: LightRAGQueryMode = LightRAGQueryMode.HYBRID,
        top_k: int = _DEFAULT_TOP_K,
        only_need_context: bool = False,
        response_type: str = "Multiple Paragraphs",
        conversation_history: list[dict[str, str]] | None = None,
        user_prompt: str | None = None,
    ) -> LightRAGQueryResult:
        """Execute a LightRAG query with the specified retrieval mode.

        Args:
            question (str): Natural language question.
            mode (LightRAGQueryMode): Retrieval strategy.
            top_k (int): Number of top items to retrieve.
            only_need_context (bool): Return only retrieved context without generation.
            response_type (str): Response format.
            conversation_history (list[dict[str, str]] | None): Prior conversation.
            user_prompt (str | None): Additional LLM instruction.

        Returns:
            LightRAGQueryResult: Query answer with metadata.
        """
        rag = self._ensure_initialized()
        from lightrag import QueryParam

        param = QueryParam(
            mode=mode.value,
            top_k=top_k,
            only_need_context=only_need_context,
            response_type=response_type,
        )
        if conversation_history:
            param.conversation_history = conversation_history
        if user_prompt is not None:
            param.user_prompt = user_prompt

        logger.info("lightrag_query_start", mode=mode.value, query_len=len(question))
        result = await rag.aquery(question, param=param)

        contexts: list[str] = []
        if isinstance(result, dict):
            contexts = result.get("contexts", [])
            answer = result.get("response", str(result))
        else:
            answer = str(result)

        logger.info("lightrag_query_complete", answer_len=len(answer))
        return LightRAGQueryResult(
            query=question,
            answer=answer,
            mode=mode.value,
            contexts=contexts,
        )

    # ── Entity management ─────────────────────────────────────────

    async def create_entity(
        self,
        name: str,
        *,
        entity_type: str = "",
        description: str = "",
    ) -> LightRAGEntityInfo:
        """Create a new entity in the knowledge graph.

        Args:
            name (str): Entity name.
            entity_type (str): Entity classification.
            description (str): Entity description.

        Returns:
            LightRAGEntityInfo: Created entity.
        """
        rag = self._ensure_initialized()
        entity_data: dict[str, str] = {}
        if entity_type:
            entity_data["entity_type"] = entity_type
        if description:
            entity_data["description"] = description

        await rag.acreate_entity(name, entity_data)
        logger.info("lightrag_entity_created", name=name)
        return LightRAGEntityInfo(name=name, entity_type=entity_type, description=description)

    async def delete_entity(self, name: str) -> None:
        """Delete an entity and all its relationships."""
        rag = self._ensure_initialized()
        await rag.adelete_by_entity(name)
        logger.info("lightrag_entity_deleted", name=name)

    async def merge_entities(
        self,
        source_entities: list[str],
        target_entity: str,
        *,
        merge_strategy: dict[str, str] | None = None,
        target_entity_data: dict[str, str] | None = None,
    ) -> LightRAGEntityInfo:
        """Merge multiple entities into a single target entity.

        Args:
            source_entities (list[str]): Entity names to merge from.
            target_entity (str): Target entity name.
            merge_strategy (dict[str, str] | None): Per-attribute merge strategy.
            target_entity_data (dict[str, str] | None): Custom target entity data.

        Returns:
            LightRAGEntityInfo: Merged target entity.
        """
        rag = self._ensure_initialized()
        kwargs: dict[str, object] = {
            "source_entities": source_entities,
            "target_entity": target_entity,
        }
        if merge_strategy is not None:
            kwargs["merge_strategy"] = merge_strategy
        if target_entity_data is not None:
            kwargs["target_entity_data"] = target_entity_data

        rag.merge_entities(**kwargs)
        logger.info("lightrag_entities_merged", sources=source_entities, target=target_entity)
        return LightRAGEntityInfo(
            name=target_entity,
            entity_type=target_entity_data.get("entity_type", "") if target_entity_data else "",
            description=target_entity_data.get("description", "") if target_entity_data else "",
        )

    # ── Relation management ───────────────────────────────────────

    async def create_relation(
        self,
        source: str,
        target: str,
        *,
        description: str = "",
        keywords: str = "",
        weight: float = 1.0,
    ) -> LightRAGRelationInfo:
        """Create a new relation between two entities.

        Args:
            source (str): Source entity name.
            target (str): Target entity name.
            description (str): Relation description.
            keywords (str): Keywords for the relation.
            weight (float): Relation weight/importance.

        Returns:
            LightRAGRelationInfo: Created relation.
        """
        rag = self._ensure_initialized()
        relation_data: dict[str, object] = {
            "description": description,
            "keywords": keywords,
            "weight": weight,
        }
        await rag.acreate_relation(source, target, relation_data)
        logger.info("lightrag_relation_created", source=source, target=target)
        return LightRAGRelationInfo(
            source=source,
            target=target,
            description=description,
            keywords=keywords,
            weight=weight,
        )

    async def delete_relation(self, source: str, target: str) -> None:
        """Delete a relation between two entities."""
        rag = self._ensure_initialized()
        await rag.adelete_by_relation(source, target)
        logger.info("lightrag_relation_deleted", source=source, target=target)

    async def delete_by_doc_id(self, doc_id: str) -> None:
        """Delete all data associated with a document ID."""
        rag = self._ensure_initialized()
        await rag.adelete_by_doc_id(doc_id)
        logger.info("lightrag_document_deleted", doc_id=doc_id)

    # ── Knowledge graph export ────────────────────────────────────

    async def get_knowledge_graph(self) -> dict[str, list[dict[str, object]]]:
        """Export the knowledge graph as nodes and edges.

        Returns a dict with 'nodes' and 'edges' keys. Each node has
        'name', 'label', 'properties'; each edge has 'source', 'target',
        'relationship', 'weight'.

        Returns:
            dict[str, list[dict[str, object]]]: Knowledge graph data.
        """
        rag = self._ensure_initialized()
        graph_storage = rag.chunk_entity_relation_graph
        nodes: list[dict[str, object]] = []
        edges: list[dict[str, object]] = []

        if hasattr(graph_storage, "_graph"):
            # NetworkX-based storage
            import networkx as nx

            graph: nx.Graph = graph_storage._graph  # noqa: SLF001
            for node_id, data in graph.nodes(data=True):
                nodes.append({
                    "name": str(node_id),
                    "label": str(data.get("entity_type", "")),
                    "properties": str({
                        k: v for k, v in data.items() if k != "entity_type"
                    }),
                })
            for src, tgt, data in graph.edges(data=True):
                edges.append({
                    "source": str(src),
                    "target": str(tgt),
                    "relationship": str(data.get("description", "")),
                    "weight": float(data.get("weight", 1.0)),
                })
        else:
            logger.warning("lightrag_kg_export_unsupported", storage=type(graph_storage).__name__)

        logger.info("lightrag_kg_exported", nodes=len(nodes), edges=len(edges))
        return {"nodes": nodes, "edges": edges}

    @property
    def is_initialized(self) -> bool:
        """Whether the adapter has been initialized."""
        return self._initialized

    @property
    def raw(self) -> object:
        """Return the underlying 'lightrag.LightRAG' instance."""
        return self._ensure_initialized()
