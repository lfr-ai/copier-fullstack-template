        "Answer the following question based on the provided context.\n\n"
        "Context:\n{{ context }}\n\n"
        "Question: {{ question }}\n\n"
        "Answer:"
    ),
    "summarize": (
        "Provide a concise summary of the following document.\n\n"
        "Document:\n{{ document }}\n\n"
        "Summary:"
    ),
    "entity_extraction": (
        "Extract all named entities and their relationships from the following text. "
        "Format each relationship as: (subject, predicate, object)\n\n"
        "Text:\n{{ text }}\n\n"
        "Entities and relationships:"
    ),
    "classify": (
        "Classify the following text into one of these categories: {{ categories }}\n\n"
        "Text:\n{{ text }}\n\n"
        "Category:"
    ),
    "agent_system": (
