@final
class Jinja2PromptTemplate(PromptTemplateGateway):
    """Prompt template manager using Jinja2 rendering.

    Supports built-in templates, programmatic registration, and
    loading templates from a directory ('*.txt' and '*.j2' files).
    """

    __slots__ = ("_descriptions", "_templates")

    def __init__(self, *, template_dir: str | None = None) -> None:
        self._templates: dict[str, str] = dict(_BUILTIN_TEMPLATES)
        self._descriptions: dict[str, str] = {}
        if template_dir:
            self.load_directory(template_dir)

    def get(self, name: str) -> str:
        """Retrieve a raw template string by name.

        Raises:
            KeyError: If template not found.
        """
        if name not in self._templates:
            msg = f"Prompt template '{name}' not found. Available: {sorted(self._templates)}"
            raise KeyError(msg)
        return self._templates[name]

    @override
    def render(self, *, template_name: str, variables: dict[str, object]) -> str:
        """Render a prompt template with Jinja2 variable substitution."""
        template_str = self._templates.get(template_name)
        if template_str is None:
            msg = f"Unknown prompt template: {template_name}"
            raise KeyError(msg)

        try:
            from jinja2 import BaseLoader, Environment
        except ImportError as exc:
            msg = "jinja2 is required -- pip install jinja2"
            raise ImportError(msg) from exc

        env = Environment(loader=BaseLoader(), autoescape=False)  # noqa: S701
        tmpl = env.from_string(template_str)
        return tmpl.render(**variables)

    @override
    def list_templates(self) -> list[str]:
        """Return names of all registered prompt templates."""
        return sorted(self._templates.keys())

    @override
    def register_template(
        self,
        *,
        name: str,
        template: str,
        description: str = "",
    ) -> None:
        """Register or override a prompt template."""
        self._templates[name] = template
        if description:
            self._descriptions[name] = description
        logger.info("Registered prompt template: %s", name)

    def load_directory(self, directory: str) -> None:
        """Load all '*.txt' and '*.j2' template files from *directory*."""
        path = Path(directory)
        if not path.is_dir():
            logger.warning("Prompt template directory does not exist: %s", directory)
            return
        for ext in ("*.txt", "*.j2"):
            for file in path.glob(ext):
                self._templates[file.stem] = file.read_text(encoding="utf-8")
                logger.debug("Loaded prompt template '%s' from %s", file.stem, file)
