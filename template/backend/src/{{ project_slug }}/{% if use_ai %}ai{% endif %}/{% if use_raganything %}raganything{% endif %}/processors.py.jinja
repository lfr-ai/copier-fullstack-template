async def process_equation(
    lightrag_instance: object,
    *,
    latex: str,
    description_text: str = "",
    entity_name: str = "",
    file_path: str = "unknown",
    llm_func: object | None = None,
) -> tuple[str, dict[str, object]]:
    """Process a mathematical equation through the RAG-Anything equation processor.

    Args:
        lightrag_instance (object): Raw LightRAG instance.
        latex (str): LaTeX representation of the equation.
        description_text (str): Human-readable description.
        entity_name (str): Knowledge graph entity name.
        file_path (str): Source document file path.
        llm_func (object | None): LLM callable for equation interpretation.

    Returns:
        tuple[str, dict[str, object]]: Description and entity info.
    """
    from raganything.modalprocessors import GenericModalProcessor

    processor = GenericModalProcessor(
        lightrag=lightrag_instance,
        modal_caption_func=llm_func,
    )

    equation_content = {
        "latex": latex,
        "text": description_text,
    }

    description, entity_info = await processor.process_multimodal_content(
        modal_content=equation_content,
        content_type="equation",
        file_path=file_path,
        entity_name=entity_name or f"Equation: {latex[:50]}",
    )
    logger.info("raganything_equation_processed", entity=entity_name)
    return description, entity_info
