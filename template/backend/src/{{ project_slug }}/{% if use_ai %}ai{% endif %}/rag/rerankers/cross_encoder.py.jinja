"""Cross-encoder reranker adapter -- implements 'RerankerGateway'.

Uses 'sentence-transformers' cross-encoder models to rerank
retrieval results by computing pairwise relevance scores.

Requires: 'pip install sentence-transformers>=3.3'
"""

from __future__ import annotations

import structlog
from typing import override, final

from {{ project_slug }}.ai.config import DEFAULT_CROSS_ENCODER_MODEL
from {{ project_slug }}.core.interfaces.reranker import RankedResult, RerankerGateway, _DEFAULT_RERANK_TOP_K

logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)
@final
class CrossEncoderReranker(RerankerGateway):
    """Reranker backed by a cross-encoder model.

    Cross-encoders jointly encode query-document pairs for
    higher accuracy reranking compared to bi-encoder scores.
    """

    __slots__ = ("_model", "_model_name")

    def __init__(self, *, model_name: str = DEFAULT_CROSS_ENCODER_MODEL) -> None:
        self._model_name = model_name
        self._model = None

    @classmethod
    def from_config(cls, config: dict[str, object]) -> CrossEncoderReranker:
        """Create a CrossEncoderReranker instance from a configuration dictionary.

        Expected config structure::

            {
                "model_name": "cross-encoder/ms-marco-MiniLM-L-6-v2",  # optional (default from config)
            }

        Args:
            config (dict[str, object]): Configuration dictionary.

        Returns:
            CrossEncoderReranker: Configured reranker instance.
        """
        model_name = str(config.get("model_name", DEFAULT_CROSS_ENCODER_MODEL))
        return cls(model_name=model_name)

    def _get_model(self) -> object:
        """Lazily load the cross-encoder model."""
        if self._model is not None:
            return self._model

        try:
            from sentence_transformers import CrossEncoder
        except ImportError as exc:
            msg = "sentence-transformers>=3.3 is required -- pip install sentence-transformers"
            raise ImportError(msg) from exc

        self._model = CrossEncoder(self._model_name)
        logger.info("Loaded cross-encoder model: %s", self._model_name)
        return self._model

    @override
    async def rerank(
        self,
        *,
        query: str,
        results: list[dict[str, object]],
        top_k: int = _DEFAULT_RERANK_TOP_K,
    ) -> list[RankedResult]:
        model = self._get_model()

        pairs = [(query, str(r.get("content", ""))) for r in results]
        if not pairs:
            return []

        scores = model.predict(pairs)

        ranked: list[RankedResult] = []
        for i, (result, score) in enumerate(zip(results, scores, strict=True)):
            ranked.append(
                RankedResult(
                    id=str(result.get("id", i)),
                    content=str(result.get("content", "")),
                    original_score=float(result.get("score", 0.0)),
                    rerank_score=float(score),
                    metadata={k: v for k, v in result.items() if k not in ("id", "content", "score")},
                )
            )

        ranked.sort(key=lambda r: r.rerank_score, reverse=True)
        logger.info("Reranked %d results, returning top %d", len(ranked), top_k)
        return ranked[:top_k]
