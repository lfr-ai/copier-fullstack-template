"""Adaptive RAG pipeline -- routes to Self-CRAG or DeepRAG based on query complexity.

Orchestrates adaptive retrieval by:
1. Routing queries to Self-CRAG (simple) or DeepRAG (MDP-based retrieval)
2. Integrating reranking before grading for improved relevance
3. Applying hallucination detection after generation
4. Preserving RetrievalResult interface for backward compatibility
"""

from __future__ import annotations

import asyncio
from types import SimpleNamespace
from typing import final

import structlog

from {{ project_slug }}.ai.rag.retrieval import RetrievalResult
from {{ project_slug }}.core.interfaces.embedding import EmbeddingGateway
from {{ project_slug }}.core.interfaces.knowledge_graph import KnowledgeGraphGateway
from {{ project_slug }}.core.interfaces.llm import LLMGateway
from {{ project_slug }}.core.interfaces.reranker import RerankerGateway
from {{ project_slug }}.core.interfaces.vector_store import VectorSearchResult, VectorStoreGateway

logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)


@final
class AdaptiveRAGPipeline:
    """Adaptive RAG pipeline with Self-CRAG and DeepRAG routing.

    Routes queries to appropriate workflow based on complexity:
    - use_graph=False -> Self-CRAG (self-corrective retrieval-grading cycles)
    - use_graph=True -> DeepRAG (MDP-based step-by-step retrieval)

    Integrates reranking, hallucination detection, and preserves
    RetrievalResult interface for backward compatibility.
    """

    __slots__ = (
        "_llm",
        "_embedding",
        "_vector_store",
        "_knowledge_graph",
        "_reranker",
        "_lightrag_service",
        "_self_crag_pipeline",
        "_deep_rag_pipeline",
    )

    def __init__(
        self,
        *,
        llm: LLMGateway,
        embedding: EmbeddingGateway,
        vector_store: VectorStoreGateway,
        knowledge_graph: KnowledgeGraphGateway | None = None,
        reranker: RerankerGateway | None = None,
        lightrag_service: object | None = None,
    ) -> None:
        """Initialize the adaptive RAG pipeline.

        Args:
            llm: LLM gateway for relevance grading, query rewriting, and answer generation.
            embedding: Embedding gateway for vector encoding.
            vector_store: Vector store gateway for similarity search.
            knowledge_graph: Optional knowledge graph gateway for DeepRAG traversal.
            reranker: Optional reranker for result reordering before grading.
            lightrag_service: Optional LightRAG service for graph-native retrieval.
        """
        self._llm = llm
        self._embedding = embedding
        self._vector_store = vector_store
        self._knowledge_graph = knowledge_graph
        self._reranker = reranker
        self._lightrag_service = lightrag_service

        # Lazy initialization of pipelines
        self._self_crag_pipeline = None
        self._deep_rag_pipeline = None

        log = logger.bind(
            workflow="adaptive-rag",
            has_knowledge_graph=knowledge_graph is not None,
            has_reranker=reranker is not None,
            has_lightrag=lightrag_service is not None,
        )
        log.info(
            "AdaptiveRAGPipeline initialized",
            kg_available=knowledge_graph is not None,
            reranker_available=reranker is not None,
            lightrag_available=lightrag_service is not None,
        )

    @classmethod
    def from_config(cls, config: dict[str, object]) -> AdaptiveRAGPipeline:
        """Create an AdaptiveRAGPipeline from a configuration dictionary.

        Expected config structure::

            {
                "llm": <LLMGateway>,
                "embedding": <EmbeddingGateway>,
                "vector_store": <VectorStoreGateway>,
                "knowledge_graph": <KnowledgeGraphGateway | None>,  # optional
                "reranker": <RerankerGateway | None>,  # optional
                "lightrag_service": <object | None>,  # optional
            }

        Args:
            config: Configuration dictionary.

        Returns:
            Configured pipeline instance.

        Raises:
            ValueError: If required parameters are missing.
        """
        llm = config.get("llm")
        if llm is None:
            msg = "llm is required"
            raise ValueError(msg)

        embedding = config.get("embedding")
        if embedding is None:
            msg = "embedding is required"
            raise ValueError(msg)

        vector_store = config.get("vector_store")
        if vector_store is None:
            msg = "vector_store is required"
            raise ValueError(msg)

        return cls(
            llm=llm,  # type: ignore[arg-type]
            embedding=embedding,  # type: ignore[arg-type]
            vector_store=vector_store,  # type: ignore[arg-type]
            knowledge_graph=config.get("knowledge_graph"),  # type: ignore[arg-type]
            reranker=config.get("reranker"),  # type: ignore[arg-type]
            lightrag_service=config.get("lightrag_service"),
        )

    async def _route_to_lightrag(
        self,
        *,
        question: str,
        top_k: int,
        lightrag_mode: str,
        user_prompt: str | None,
    ) -> RetrievalResult:
        """Route query to LightRAG when service is configured."""
        if self._lightrag_service is None:
            msg = "LightRAG service is not configured"
            raise RuntimeError(msg)

        request = SimpleNamespace(
            question=question,
            mode=lightrag_mode,
            top_k=top_k,
            response_type="Multiple Paragraphs",
            only_need_context=False,
            conversation_history=[],
            user_prompt=user_prompt,
        )

        result = await self._lightrag_service.query(request)
        contexts = list(getattr(result, "contexts", []) or [])

        sources = [
            VectorSearchResult(
                id=f"lightrag_ctx_{idx}",
                score=0.5,
                metadata={"content": context, "source": "lightrag"},
            )
            for idx, context in enumerate(contexts)
        ]

        return RetrievalResult(
            query=question,
            answer=str(getattr(result, "answer", "")),
            sources=sources[:top_k],
            graph_context=[
                {
                    "provider": "lightrag",
                    "mode": str(getattr(result, "mode", lightrag_mode)),
                    "context_count": len(contexts),
                }
            ],
        )

    async def _synthesize_combined_answer(
        self,
        *,
        question: str,
        candidates: list[RetrievalResult],
    ) -> str:
        """Synthesize a single final answer from multiple strategy candidates."""
        if not candidates:
            return "I could not generate an answer from the configured retrieval strategies."

        if len(candidates) == 1:
            return candidates[0].answer

        answer_block = "\n\n".join(
            f"Candidate {idx + 1}:\n{candidate.answer}"
            for idx, candidate in enumerate(candidates)
        )
        prompt = (
            "You are combining outputs from multiple retrieval strategies "
            "(Self-CRAG, DeepRAG, and LightRAG). "
            "Produce one factual, concise, non-duplicative final answer grounded in the candidates.\n\n"
            f"Question: {question}\n\n"
            f"Candidates:\n{answer_block}"
        )

        try:
            return await self._llm.complete(prompt=prompt)
        except Exception as exc:
            logger.warning(
                "Combined answer synthesis failed -- falling back to longest candidate",
                workflow="adaptive-rag",
                error=str(exc),
                error_type=type(exc).__name__,
            )
            return max(candidates, key=lambda c: len(c.answer)).answer

    def _get_self_crag_pipeline(self) -> object:
        """Lazily initialize the Self-CRAG pipeline."""
        if self._self_crag_pipeline is not None:
            return self._self_crag_pipeline

        from {{ project_slug }}.ai.rag.retrievers.vector_retriever import VectorRetriever
        from {{ project_slug }}.ai.rag.self_crag_pipeline import SelfCRAGPipeline

        retriever = VectorRetriever(
            embedding=self._embedding,
            vector_store=self._vector_store,
        )

        self._self_crag_pipeline = SelfCRAGPipeline(
            llm=self._llm,
            retriever=retriever,
        )
        logger.info("Self-CRAG pipeline initialized")
        return self._self_crag_pipeline

    def _get_deep_rag_pipeline(self) -> object | None:
        """Lazily initialize the DeepRAG pipeline."""
        if self._deep_rag_pipeline is not None:
            return self._deep_rag_pipeline

        from {{ project_slug }}.ai.rag.deep_rag_pipeline import DeepRAGPipeline
        from {{ project_slug }}.ai.rag.retrievers.vector_retriever import VectorRetriever

        retriever = VectorRetriever(
            embedding=self._embedding,
            vector_store=self._vector_store,
        )

        self._deep_rag_pipeline = DeepRAGPipeline(
            llm=self._llm,
            retriever=retriever,
        )
        logger.info("DeepRAG pipeline initialized")
        return self._deep_rag_pipeline

    async def _rerank_if_available(
        self,
        *,
        query: str,
        results: list[VectorSearchResult],
        top_k: int,
    ) -> list[VectorSearchResult]:
        """Apply reranking to search results if reranker is available.

        Args:
            query: User's natural language question.
            results: Vector search results to rerank.
            top_k: Number of results to return after reranking.

        Returns:
            Reranked results (or original results if reranker unavailable).
        """
        if self._reranker is None:
            logger.debug("Reranker unavailable -- skipping reranking")
            return results[:top_k]

        try:
            # Convert VectorSearchResult to dict for reranker
            rerank_input = [
                {
                    "id": r.id,
                    "content": str(r.metadata.get("content", "")) if r.metadata else "",
                    "score": r.score,
                    "metadata": r.metadata or {},
                }
                for r in results
            ]

            ranked_results = await self._reranker.rerank(
                query=query,
                results=rerank_input,
                top_k=top_k,
            )

            # Convert back to VectorSearchResult
            reranked = [
                VectorSearchResult(
                    id=rr.id,
                    score=rr.rerank_score,
                    metadata={**rr.metadata, "content": rr.content, "original_score": rr.original_score},
                )
                for rr in ranked_results
            ]

            logger.info(
                "Reranking completed",
                workflow="adaptive-rag",
                original_count=len(results),
                reranked_count=len(reranked),
            )
            return reranked

        except Exception as exc:
            logger.warning(
                "Reranker failed -- continuing with original ranking",
                workflow="adaptive-rag",
                error=str(exc),
                error_type=type(exc).__name__,
            )
            return results[:top_k]

    async def _detect_hallucination(
        self,
        *,
        question: str,
        answer: str,
        sources: list[VectorSearchResult],
    ) -> tuple[bool, str]:
        """Detect hallucination in generated answer using LLM.

        Args:
            question: User's original question.
            answer: Generated answer to verify.
            sources: Retrieved source documents.

        Returns:
            Tuple of (is_hallucinated, corrected_answer).
            If is_hallucinated=True, corrected_answer contains re-generated response.
        """
        # Simple heuristic: if no sources, likely hallucinated
        if not sources:
            logger.warning(
                "Hallucination detected -- no sources provided",
                workflow="adaptive-rag",
                question_len=len(question),
                answer_len=len(answer),
            )
            return (True, "I cannot answer this question as I have no relevant sources.")

        # Placeholder for more sophisticated hallucination detection
        # Could use LLM to grade answer-source alignment
        # For now, we trust the answer if sources exist
        logger.debug(
            "Hallucination check passed",
            workflow="adaptive-rag",
            source_count=len(sources),
        )
        return (False, answer)

    async def query(
        self,
        question: str,
        *,
        top_k: int = 5,
        system_prompt: str | None = None,
        use_graph: bool = False,
        strategy: str = "auto",
        use_lightrag: bool = False,
        lightrag_mode: str = "mix",
        combine_strategies: bool = False,
    ) -> RetrievalResult:
        """Execute an adaptive RAG query with routing.

        Routes to Self-CRAG or DeepRAG based on use_graph flag.
        Integrates reranking and hallucination detection.

        Args:
            question: User's natural language question.
            top_k: Number of source chunks to retrieve.
            system_prompt: Optional custom system prompt for LLM instructions.
            use_graph: If True, route to DeepRAG (multi-hop graph traversal).
                      If False, route to Self-CRAG (self-corrective retrieval).
            strategy: Routing strategy ('auto', 'self_crag', 'deep_rag', 'lightrag', 'combined').
            use_lightrag: If True, route to LightRAG when strategy='auto'.
            lightrag_mode: LightRAG query mode (typically 'hybrid' or 'mix').
            combine_strategies: If True, execute combined orchestration.

        Returns:
            RetrievalResult with answer and workflow metadata.

        Raises:
            ValueError: If question is empty, top_k is invalid, or system_prompt is too long.
            TimeoutError: If LLM or vector store times out.
        """
        # Input validation
        if not question or not question.strip():
            msg = "Question cannot be empty"
            raise ValueError(msg)

        if top_k < 0:
            msg = "top_k must be non-negative"
            raise ValueError(msg)

        if top_k == 0:
            logger.info("top_k=0 received, defaulting to 5")
            top_k = 5

        if top_k > 100:
            logger.warning("top_k > 100 received, capping at 100", requested_top_k=top_k)
            top_k = 100

        if system_prompt and len(system_prompt) > 10000:
            msg = "system_prompt exceeds 10K characters"
            raise ValueError(msg)

        allowed_strategies = {"auto", "self_crag", "deep_rag", "lightrag", "combined"}
        normalized_strategy = strategy.strip().lower()
        if normalized_strategy not in allowed_strategies:
            msg = f"strategy must be one of {sorted(allowed_strategies)}"
            raise ValueError(msg)

        # Determine routing decision
        if combine_strategies or normalized_strategy == "combined":
            routing_decision = "combined"
        elif normalized_strategy == "self_crag":
            routing_decision = "self-crag"
        elif normalized_strategy == "deep_rag":
            routing_decision = "deeprag"
        elif normalized_strategy == "lightrag":
            routing_decision = "lightrag"
        elif use_graph:
            routing_decision = "deeprag"
        elif use_lightrag:
            routing_decision = "lightrag"
        else:
            routing_decision = "self-crag"

        log = logger.bind(
            workflow="adaptive-rag",
            routing_decision=routing_decision,
            use_graph=use_graph,
            strategy=normalized_strategy,
            use_lightrag=use_lightrag,
            combine_strategies=combine_strategies,
            query_len=len(question),
            top_k=top_k,
        )
        log.info(
            "Routing decision",
            has_kg=self._knowledge_graph is not None,
            use_graph=use_graph,
        )

        # Route to appropriate workflow
        if routing_decision == "combined":
            tasks: list[tuple[str, asyncio.Future[RetrievalResult] | asyncio.Task[RetrievalResult]]] = [
                (
                    "self_crag",
                    asyncio.create_task(
                        self._route_to_self_crag(
                            question=question,
                            top_k=top_k,
                            system_prompt=system_prompt,
                        )
                    ),
                ),
                (
                    "deep_rag",
                    asyncio.create_task(
                        self._route_to_deeprag(
                            question=question,
                            top_k=top_k,
                            system_prompt=system_prompt,
                        )
                    ),
                ),
            ]
            if self._lightrag_service is not None:
                tasks.append(
                    (
                        "lightrag",
                        asyncio.create_task(
                            self._route_to_lightrag(
                                question=question,
                                top_k=top_k,
                                lightrag_mode=lightrag_mode,
                                user_prompt=system_prompt,
                            )
                        ),
                    )
                )

            combined_results = await asyncio.gather(
                *(task for _, task in tasks),
                return_exceptions=True,
            )

            candidates: list[RetrievalResult] = []
            for (name, _), maybe_result in zip(tasks, combined_results, strict=False):
                if isinstance(maybe_result, Exception):
                    logger.warning(
                        "Sub-strategy failed in combined mode",
                        workflow="adaptive-rag",
                        strategy=name,
                        error=str(maybe_result),
                        error_type=type(maybe_result).__name__,
                    )
                    continue
                candidates.append(maybe_result)

            merged_sources: dict[str, VectorSearchResult] = {}
            merged_graph_context: list[dict[str, object]] = []
            for candidate in candidates:
                for source in candidate.sources:
                    existing = merged_sources.get(source.id)
                    if existing is None or source.score > existing.score:
                        merged_sources[source.id] = source
                merged_graph_context.extend(candidate.graph_context)

            final_answer = await self._synthesize_combined_answer(
                question=question,
                candidates=candidates,
            )

            result = RetrievalResult(
                query=question,
                answer=final_answer,
                sources=sorted(merged_sources.values(), key=lambda s: s.score, reverse=True)[:top_k],
                graph_context=merged_graph_context,
            )
        elif routing_decision == "deeprag":
            result = await self._route_to_deeprag(
                question=question,
                top_k=top_k,
                system_prompt=system_prompt,
            )
        elif routing_decision == "lightrag":
            if self._lightrag_service is None:
                logger.warning(
                    "LightRAG requested but unavailable -- falling back to Self-CRAG",
                    workflow="adaptive-rag",
                )
                result = await self._route_to_self_crag(
                    question=question,
                    top_k=top_k,
                    system_prompt=system_prompt,
                )
            else:
                result = await self._route_to_lightrag(
                    question=question,
                    top_k=top_k,
                    lightrag_mode=lightrag_mode,
                    user_prompt=system_prompt,
                )
        else:
            result = await self._route_to_self_crag(
                question=question,
                top_k=top_k,
                system_prompt=system_prompt,
            )

        # Apply hallucination detection
        is_hallucinated, corrected_answer = await self._detect_hallucination(
            question=question,
            answer=result.answer,
            sources=result.sources,
        )

        if is_hallucinated:
            logger.warning(
                "Hallucination detected -- re-generating answer",
                workflow="adaptive-rag",
            )
            result = RetrievalResult(
                query=result.query,
                answer=corrected_answer,
                sources=result.sources,
                graph_context=result.graph_context,
            )

        log.info(
            "Pipeline completion",
            workflow="adaptive-rag",
            answer_len=len(result.answer),
            source_count=len(result.sources),
            graph_context_count=len(result.graph_context),
        )

        return result

    async def _route_to_self_crag(
        self,
        *,
        question: str,
        top_k: int,
        system_prompt: str | None,
    ) -> RetrievalResult:
        """Route query to Self-CRAG pipeline.

        Args:
            question: User's natural language question.
            top_k: Number of source chunks to retrieve.
            system_prompt: Optional custom system prompt.

        Returns:
            RetrievalResult from Self-CRAG workflow.
        """
        logger.info("Routing to Self-CRAG", workflow="adaptive-rag")

        pipeline = self._get_self_crag_pipeline()
        result = await pipeline.query(
            question=question,
            top_k=top_k,
            system_prompt=system_prompt,
        )

        logger.info(
            "Self-CRAG pipeline completed",
            workflow="adaptive-rag",
            source_count=len(result.sources),
        )
        return result

    async def _route_to_deeprag(
        self,
        *,
        question: str,
        top_k: int,
        system_prompt: str | None,
    ) -> RetrievalResult:
        """Route query to DeepRAG MDP pipeline.

        Args:
            question: User's natural language question.
            top_k: Number of source chunks to retrieve.
            system_prompt: Optional custom system prompt.

        Returns:
            RetrievalResult from DeepRAG workflow with graph context.
        """
        logger.info("Routing to DeepRAG", workflow="adaptive-rag")

        pipeline = self._get_deep_rag_pipeline()
        result = await pipeline.query(
            question,
            top_k=top_k,
            system_prompt=system_prompt,
        )

        # Apply reranking if available
        if self._reranker is not None and result.sources:
            reranked = await self._rerank_if_available(
                query=question,
                results=result.sources,
                top_k=top_k,
            )
            result = RetrievalResult(
                query=result.query,
                answer=result.answer,
                sources=reranked,
                graph_context=result.graph_context,
            )

        logger.info(
            "DeepRAG pipeline completed",
            workflow="adaptive-rag",
            source_count=len(result.sources),
        )

        return result
