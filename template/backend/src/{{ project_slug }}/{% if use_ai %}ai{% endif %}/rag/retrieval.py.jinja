"""RAG retrieval result -- shared data structure for pipeline outputs."""

from __future__ import annotations

from typing import final

from dataclasses import dataclass, field

from {{ project_slug }}.core.interfaces.vector_store import VectorSearchResult


@dataclass(frozen=True, slots=True)
@final
class RetrievalResult:
    """Result of a RAG retrieval-and-generation cycle."""

    query: str
    answer: str
    sources: list[VectorSearchResult] = field(default_factory=list)
    graph_context: list[dict[str, object]] = field(default_factory=list)

