"""LlamaIndex retriever adapter — bridges LlamaIndex query engines to 'RetrieverPort'.

Uses LlamaIndex's 'VectorStoreIndex' to build a query engine
and maps results to the core 'RetrievedContext' data class.

Requires: 'pip install llama-index-core>=0.14'
"""

from __future__ import annotations

import structlog
from typing import override

from {{ project_slug }}.core.interfaces.embedding import EmbeddingPort
from {{ project_slug }}.core.interfaces.retriever import (
    _DEFAULT_RETRIEVAL_TOP_K,
    RetrievedContext,
    RetrieverPort,
)
from {{ project_slug }}.core.interfaces.vector_store import VectorStorePort

logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)


class LlamaIndexRetrieverAdapter(RetrieverPort):
    """Retriever backed by LlamaIndex's query engine.

    Wraps a LlamaIndex 'VectorStoreIndex' and provides the
    standard 'RetrieverPort' interface for the application layer.
    """

    __slots__ = ("_embedding", "_index", "_vector_store")

    def __init__(
        self,
        *,
        embedding: EmbeddingPort,
        vector_store: VectorStorePort,
    ) -> None:
        self._embedding = embedding
        self._vector_store = vector_store
        self._index: object | None = None

    def _get_index(self) -> object:
        """Lazily initialize the LlamaIndex VectorStoreIndex."""
        if self._index is not None:
            return self._index

        try:
            from llama_index.core import VectorStoreIndex
        except ImportError as exc:
            msg = "llama-index-core>=0.14 is required — pip install llama-index-core"
            raise ImportError(msg) from exc

        self._index = VectorStoreIndex([])
        return self._index

    @override
    async def retrieve(
        self,
        *,
        query: str,
        top_k: int = _DEFAULT_RETRIEVAL_TOP_K,
        filters: dict[str, object] | None = None,
    ) -> list[RetrievedContext]:
        """Retrieve using the underlying vector store via embeddings.

        Falls back to direct vector store search when LlamaIndex
        index construction is not yet populated.
        """
        query_vec = await self._embedding.embed_text(query)
        results = await self._vector_store.search(
            query_vector=query_vec,
            top_k=top_k,
            filters=filters,
        )

        contexts: list[RetrievedContext] = []
        for r in results:
            content = str(r.metadata.get("content", "")) if r.metadata else ""
            contexts.append(
                RetrievedContext(
                    id=r.id,
                    content=content,
                    score=r.score,
                    metadata=r.metadata or {},
                )
            )

        logger.info("LlamaIndex retriever returned %d results for query", len(contexts))
        return contexts
