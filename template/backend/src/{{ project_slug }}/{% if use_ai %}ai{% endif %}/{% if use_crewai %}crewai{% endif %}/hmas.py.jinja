"""CrewAI HMAS — Hierarchical Multi-Agent System supervisor.

Implements a production-ready hierarchical supervisor that:

1. Receives high-level goals from the application layer.
2. Decomposes goals into sub-goals using an LLM planner.
3. Routes sub-goals to **CrewAI crews** (local).
4. Manages nested hierarchy — crews can delegate to sub-crews.
5. Aggregates results with conflict resolution and quality checks.

.. code-block:: text

   ┌────────────────────────────────┐
   │       Application Layer        │
   │       (CrewAI Service)         │
   └──────────────┬─────────────────┘
                  │
   ┌──────────────▼─────────────────┐
   │   HMAS Supervisor (this file)  │
   │   - goal decomposition         │
   │   - routing & delegation       │
   │   - result aggregation         │
   └──┬────────┬────────────────────┘
      │        │
      ▼        ▼
   ┌──────┐ ┌──────┐
   │Crew A│ │Crew B│
   │(hier)│ │(seql)│
   └──────┘ └──────┘
"""

from __future__ import annotations

import structlog
from dataclasses import dataclass, field
from enum import StrEnum, auto, unique
from typing import TYPE_CHECKING

from {{ project_slug }}.ai.crewai.config import HMAS_MAX_DEPTH
from {{ project_slug }}.core.interfaces.llm import LLMGateway

_LOG_TRUNCATE_LEN: int = 200

if TYPE_CHECKING:
    from crewai import Crew

logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)
@unique
class DelegationTarget(StrEnum):
    """Type of target for sub-goal delegation."""

    CREWAI_CREW = auto()
{%- if use_agents %}
    LANGGRAPH_WORKFLOW = auto()
{%- endif %}


@unique
class SubGoalState(StrEnum):
    """Lifecycle state of a delegated sub-goal."""

    PENDING = auto()
    IN_PROGRESS = auto()
    COMPLETED = auto()
    FAILED = auto()
    SKIPPED = auto()


@dataclass
class SubGoal:
    """Decomposed sub-goal within the HMAS plan."""

    id: str
    description: str
    target_type: DelegationTarget = DelegationTarget.CREWAI_CREW
    target_name: str = ""
    state: SubGoalState = SubGoalState.PENDING
    result: str = ""
    error: str = ""
    priority: int = 0
    dependencies: list[str] = field(default_factory=list)


@dataclass
class HMASPlan:
    """Execution plan produced by the HMAS planner."""

    goal: str
    sub_goals: list[SubGoal] = field(default_factory=list)
    depth: int = 0
    metadata: dict[str, object] = field(default_factory=dict)


class CrewAIHMASSupervisor:
    """Hierarchical Multi-Agent System supervisor using CrewAI.

    Combines CrewAI's native hierarchical process with optional
    cross-framework delegation. Supports nested hierarchies up to
    'HMAS_MAX_DEPTH' levels.

    Args:
        crews (dict[str, Crew] | None): Named crew instances available for delegation.
        llm (LLMGateway | None): LLM adapter for planning and aggregation.
        max_depth (int): Maximum nesting depth for recursive delegation.
    """

    def __init__(
        self,
        *,
        crews: dict[str, Crew] | None = None,
        llm: LLMGateway | None = None,
        max_depth: int = HMAS_MAX_DEPTH,
    ) -> None:
        self._crews = crews or {}
        self._llm = llm
        self._max_depth = max_depth

    def register_crew(self, name: str, crew: Crew) -> None:
        """Register a named crew for HMAS delegation.

        Args:
            name (str): Unique crew identifier.
            crew (Crew): Assembled 'crewai.Crew' instance.
        """
        self._crews[name] = crew
        logger.info("hmas_crew_registered", name=name)

    async def orchestrate(
        self,
        goal: str,
        *,
        inputs: dict[str, object] | None = None,
        depth: int = 0,
    ) -> str:
        """Execute the full HMAS orchestration loop.

        1. **Plan** — decompose the goal into sub-goals.
        2. **Route** — assign each sub-goal to the best target.
        3. **Execute** — delegate to crews or workflows.
        4. **Aggregate** — combine results into a unified response.

        Args:
            goal (str): High-level task description.
            inputs (dict[str, object] | None): Template variables for crew task descriptions.
            depth (int): Current recursion depth (internal use).

        Returns:
            str: Aggregated result string.
        """
        if depth >= self._max_depth:
            logger.warning("hmas_max_depth_reached", depth=depth)
            return f"Maximum hierarchy depth ({self._max_depth}) reached."

        logger.info("hmas_orchestrate_start", goal=goal[:_LOG_TRUNCATE_LEN], depth=depth)

        plan = await self._plan(goal)
        await self._execute_plan(plan, inputs=inputs, depth=depth)
        result = await self._aggregate(plan)

        logger.info(
            "hmas_orchestrate_complete",
            depth=depth,
            sub_goals=len(plan.sub_goals),
            completed=sum(1 for sg in plan.sub_goals if sg.state == SubGoalState.COMPLETED),
        )
        return result

    # ------------------------------------------------------------------
    # Planning
    # ------------------------------------------------------------------

    async def _plan(self, goal: str) -> HMASPlan:
        """Decompose a goal into sub-goals using an LLM planner."""
        if self._llm is None:
            return self._simple_plan(goal)
        return await self._llm_plan(goal)

    def _simple_plan(self, goal: str) -> HMASPlan:
        """Fallback: single sub-goal delegated to the first available crew."""
        import uuid

        target = next(iter(self._crews), "")
        return HMASPlan(
            goal=goal,
            sub_goals=[
                SubGoal(
                    id=str(uuid.uuid4()),
                    description=goal,
                    target_type=DelegationTarget.CREWAI_CREW,
                    target_name=target,
                ),
            ],
        )

    async def _llm_plan(self, goal: str) -> HMASPlan:
        """Use the LLM to intelligently decompose a goal."""
        import json
        import uuid

        available = []
        for name in self._crews:
            available.append({"name": name, "type": "crewai_crew"})

        target_types = '"crewai_crew"'

        prompt = (
            "You are a hierarchical multi-agent system planner.\n"
            f"Available execution targets: {json.dumps(available)}\n\n"
            f"Goal: {goal}\n\n"
            "Decompose this goal into sub-goals. For each sub-goal:\n"
            '- "description": what needs to be done\n'
            '- "target_name": name of the best target\n'
            f'- "target_type": {target_types}\n'
            '- "priority": 0 (highest) to 9 (lowest)\n'
            '- "dependencies": list of sub-goal IDs this depends on\n\n'
            "Output valid JSON array only."
        )

        try:
            response = await self._llm.complete(prompt)
            text = response.content if hasattr(response, "content") else str(response)
            data = json.loads(text)

            sub_goals = []
            for item in data:
                sg_id = str(uuid.uuid4())
                target_type = DelegationTarget.CREWAI_CREW
                sub_goals.append(
                    SubGoal(
                        id=sg_id,
                        description=item.get("description", ""),
                        target_type=target_type,
                        target_name=item.get("target_name", ""),
                        priority=item.get("priority", 0),
                        dependencies=item.get("dependencies", []),
                    )
                )

            return HMASPlan(
                goal=goal,
                sub_goals=sub_goals or [SubGoal(id=str(uuid.uuid4()), description=goal)],
            )
        except Exception:  # noqa: BLE001 — graceful fallback to simple plan
            logger.warning("hmas_llm_plan_failed", exc_info=True)
            return self._simple_plan(goal)

    # ------------------------------------------------------------------
    # Execution
    # ------------------------------------------------------------------

    async def _execute_plan(
        self,
        plan: HMASPlan,
        *,
        inputs: dict[str, object] | None = None,
        depth: int = 0,
    ) -> None:
        """Execute all sub-goals with dependency awareness."""
        import asyncio

        # Sort by priority, then execute groups respecting dependencies
        pending = list(plan.sub_goals)
        completed_ids: set[str] = set()

        while pending:
            # Find ready sub-goals (all dependencies met)
            ready = [
                sg for sg in pending
                if all(dep in completed_ids for dep in sg.dependencies)
            ]

            if not ready:
                # Deadlock — force remaining as failed
                for sg in pending:
                    sg.state = SubGoalState.FAILED
                    sg.error = "Dependency deadlock"
                break

            # Execute ready sub-goals concurrently
            tasks = [
                self._execute_sub_goal(sg, inputs=inputs, depth=depth)
                for sg in ready
            ]
            await asyncio.gather(*tasks, return_exceptions=True)

            for sg in ready:
                pending.remove(sg)
                if sg.state == SubGoalState.COMPLETED:
                    completed_ids.add(sg.id)

    async def _execute_sub_goal(
        self,
        sub_goal: SubGoal,
        *,
        inputs: dict[str, object] | None = None,
        depth: int = 0,
    ) -> None:
        """Execute a single sub-goal by delegating to the appropriate target."""
        sub_goal.state = SubGoalState.IN_PROGRESS

        try:
            if sub_goal.target_type == DelegationTarget.CREWAI_CREW:
                result = await self._delegate_to_crew(sub_goal, inputs=inputs)
            else:
                result = f"Unsupported delegation target: {sub_goal.target_type}"

            sub_goal.result = result
            sub_goal.state = SubGoalState.COMPLETED
            logger.info(
                "hmas_sub_goal_completed",
                id=sub_goal.id,
                target=sub_goal.target_name,
            )
        except Exception as exc:  # noqa: BLE001 — top-level error boundary
            sub_goal.state = SubGoalState.FAILED
            sub_goal.error = str(exc)
            logger.warning(
                "hmas_sub_goal_failed",
                id=sub_goal.id,
                target=sub_goal.target_name,
                error=str(exc),
            )

    async def _delegate_to_crew(
        self,
        sub_goal: SubGoal,
        *,
        inputs: dict[str, object] | None = None,
    ) -> str:
        """Delegate a sub-goal to a CrewAI crew.

        Uses native async kickoff for non-blocking execution.
        """
        crew = self._crews.get(sub_goal.target_name)
        if crew is None:
            # Fall back to first available crew
            if self._crews:
                crew = next(iter(self._crews.values()))
            else:
                return "No crews available for delegation."

        crew_inputs = dict(inputs or {})
        crew_inputs["task"] = sub_goal.description

        result = await crew.akickoff(inputs=crew_inputs)
        return str(result)

    # ------------------------------------------------------------------
    # Aggregation
    # ------------------------------------------------------------------

    async def _aggregate(self, plan: HMASPlan) -> str:
        """Aggregate results from completed sub-goals."""
        completed = [sg for sg in plan.sub_goals if sg.state == SubGoalState.COMPLETED]
        failed = [sg for sg in plan.sub_goals if sg.state == SubGoalState.FAILED]

        if not completed:
            errors = "; ".join(f"{sg.description}: {sg.error}" for sg in failed)
            return f"All sub-goals failed. Errors: {errors}"

        if self._llm is not None and len(completed) > 1:
            return await self._llm_aggregate(plan.goal, completed)

        parts = []
        for sg in completed:
            parts.append(f"## {sg.description}\n{sg.result}")
        if failed:
            parts.append(
                "\n---\n**Note:** Some sub-goals failed: "
                + ", ".join(sg.description for sg in failed)
            )
        return "\n\n".join(parts)

    async def _llm_aggregate(self, goal: str, sub_goals: list[SubGoal]) -> str:
        """Use the LLM to synthesize a unified response from sub-goal results."""
        results_text = "\n\n".join(
            f"Sub-goal: {sg.description}\nResult: {sg.result}" for sg in sub_goals
        )
        prompt = (
            f"Original goal: {goal}\n\n"
            f"Sub-goal results:\n{results_text}\n\n"
            "Synthesize these results into a coherent, unified response. "
            "Resolve any conflicts between results. Be thorough but concise."
        )
        try:
            response = await self._llm.complete(prompt)
            return response.content if hasattr(response, "content") else str(response)
        except Exception:  # noqa: BLE001 — graceful fallback to concatenation
            logger.warning("hmas_llm_aggregate_failed", exc_info=True)
            return "\n\n".join(f"## {sg.description}\n{sg.result}" for sg in sub_goals)
