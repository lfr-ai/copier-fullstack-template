"""CrewAI task factory — type-safe task construction with guardrails.

Provides factories for creating 'crewai.Task' instances with
structured outputs, guardrails, and dependency wiring.
"""

from __future__ import annotations

import structlog
from dataclasses import dataclass, field
from typing import TYPE_CHECKING, final

from {{ project_slug }}.ai.crewai.config import DEFAULT_GUARDRAIL_MAX_RETRIES

_LOG_DESCRIPTION_LEN = 80

if TYPE_CHECKING:
    from crewai import Agent, Task
    from pydantic import BaseModel

logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)
@dataclass(frozen=True, slots=True)
@final
class TaskSpec:
    """Specification for a CrewAI task.

    Framework-agnostic definition that is converted to a
    'crewai.Task' via :func:`build_task`.
    """

    description: str
    expected_output: str
    agent: Agent | None = None
    tools: list[object] = field(default_factory=list)
    context: list[Task] = field(default_factory=list)
    async_execution: bool = False
    human_input: bool = False
    markdown: bool = False
    output_file: str | None = None
    output_json: type[BaseModel] | None = None
    output_pydantic: type[BaseModel] | None = None
    guardrails: list[object] = field(default_factory=list)
    guardrail_max_retries: int = DEFAULT_GUARDRAIL_MAX_RETRIES
    callback: object | None = None


def build_task(spec: TaskSpec) -> Task:
    """Create a 'crewai.Task' from a 'TaskSpec'.

    Args:
        spec (TaskSpec): Task specification with description, agent, guardrails, etc.

    Returns:
        Task: A configured 'crewai.Task' instance.
    """
    from crewai import Task

    kwargs: dict[str, object] = {
        "description": spec.description,
        "expected_output": spec.expected_output,
    }

    if spec.agent is not None:
        kwargs["agent"] = spec.agent
    if spec.tools:
        kwargs["tools"] = spec.tools
    if spec.context:
        kwargs["context"] = spec.context
    if spec.async_execution:
        kwargs["async_execution"] = True
    if spec.human_input:
        kwargs["human_input"] = True
    if spec.markdown:
        kwargs["markdown"] = True
    if spec.output_file:
        kwargs["output_file"] = spec.output_file
    if spec.output_json is not None:
        kwargs["output_json"] = spec.output_json
    if spec.output_pydantic is not None:
        kwargs["output_pydantic"] = spec.output_pydantic
    if spec.guardrails:
        kwargs["guardrails"] = spec.guardrails
        kwargs["guardrail_max_retries"] = spec.guardrail_max_retries
    if spec.callback is not None:
        kwargs["callback"] = spec.callback

    task = Task(**kwargs)

    logger.debug(
        "crewai_task_built",
        description=spec.description[:_LOG_DESCRIPTION_LEN],
        agent=getattr(spec.agent, "role", "unassigned"),
        async_exec=spec.async_execution,
    )
    return task


def build_tasks_from_config(
    tasks_config: dict[str, dict[str, object]],
    agents: dict[str, Agent],
) -> dict[str, Task]:
    """Build multiple tasks from a YAML-style config dict.

    Args:
        tasks_config (dict[str, dict[str, object]]): Mapping of task name to config dict.
        agents (dict[str, Agent]): Mapping of agent name to 'crewai.Agent' (for assignment).

    Returns:
        dict[str, Task]: Mapping of task name to built 'crewai.Task'.
    """
    tasks: dict[str, Task] = {}
    for name, cfg in tasks_config.items():
        agent = agents.get(cfg.get("agent", ""))
        context_names = cfg.get("context", [])
        context_tasks = [tasks[c] for c in context_names if c in tasks]

        spec = TaskSpec(
            description=cfg["description"],
            expected_output=cfg["expected_output"],
            agent=agent,
            context=context_tasks,
            async_execution=cfg.get("async_execution", False),
            human_input=cfg.get("human_input", False),
            markdown=cfg.get("markdown", False),
            output_file=cfg.get("output_file"),
            guardrail_max_retries=cfg.get("guardrail_max_retries", DEFAULT_GUARDRAIL_MAX_RETRIES),
        )
        tasks[name] = build_task(spec)

    logger.info("crewai_tasks_batch_built", count=len(tasks))
    return tasks
