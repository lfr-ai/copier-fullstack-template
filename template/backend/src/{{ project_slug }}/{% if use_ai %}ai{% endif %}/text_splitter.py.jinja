"""Recursive character text splitter — implements 'TextSplitterPort'.

Zero-dependency text splitter that recursively splits
text by a hierarchy of separators. Compatible with the core
'TextSplitterPort' protocol.
"""

from __future__ import annotations

from typing import override

from {{ project_slug }}.ai.config import DEFAULT_CHUNK_OVERLAP, DEFAULT_CHUNK_SIZE
from {{ project_slug }}.core.entities.document import Chunk, Document
from {{ project_slug }}.core.interfaces.text_splitter import TextSplitterPort
_SEPARATORS: list[str] = ["\n\n", "\n", ". ", " ", ""]


class RecursiveTextSplitter(TextSplitterPort):
    """Recursive character-based text splitter.

    Splits text by trying separators in order of preference,
    with configurable chunk size and overlap.
    """

    __slots__ = ("_chunk_overlap", "_chunk_size", "_separators")

    def __init__(
        self,
        *,
        chunk_size: int = DEFAULT_CHUNK_SIZE,
        chunk_overlap: int = DEFAULT_CHUNK_OVERLAP,
        separators: list[str] | None = None,
    ) -> None:
        self._chunk_size = chunk_size
        self._chunk_overlap = chunk_overlap
        self._separators = separators or _SEPARATORS

    @override
    def split(self, document: Document) -> list[Chunk]:
        """Split a document into overlapping chunks.

        Args:
            document (Document): Source document to split.

        Returns:
            list[Chunk]: Ordered chunks with provenance metadata.
        """
        raw_chunks = self._split_text(document.content, self._separators)

        chunks: list[Chunk] = []
        for i, text in enumerate(raw_chunks):
            chunk = Chunk(
                document_id=document.id,
                content=text,
                index=i,
                metadata={**document.metadata, "source": document.source},
            )
            chunks.append(chunk)
        return chunks

    def _split_text(self, text: str, separators: list[str]) -> list[str]:
        if len(text) <= self._chunk_size:
            return [text] if text.strip() else []

        sep = separators[0] if separators else ""
        remaining_seps = separators[1:] if len(separators) > 1 else []

        if sep:
            parts = text.split(sep)
        else:
            # Character-level split as last resort
            return [
                text[i : i + self._chunk_size]
                for i in range(0, len(text), self._chunk_size - self._chunk_overlap)
            ]

        chunks: list[str] = []
        current = ""

        for part in parts:
            candidate = f"{current}{sep}{part}" if current else part
            if len(candidate) <= self._chunk_size:
                current = candidate
            else:
                if current.strip():
                    chunks.append(current.strip())
                if len(part) > self._chunk_size and remaining_seps:
                    chunks.extend(self._split_text(part, remaining_seps))
                    current = ""
                else:
                    current = part

        if current.strip():
            chunks.append(current.strip())

        # Apply overlap: re-introduce trailing context from the previous chunk
        if self._chunk_overlap > 0 and len(chunks) > 1:
            overlapped: list[str] = [chunks[0]]
            for i in range(1, len(chunks)):
                prev_suffix = chunks[i - 1][-self._chunk_overlap :]
                merged = prev_suffix + chunks[i]
                if len(merged) <= self._chunk_size:
                    overlapped.append(merged)
                else:
                    overlapped.append(chunks[i])
            chunks = overlapped

        return chunks
