"""pgvector vector store adapter -- implements 'VectorStoreGateway'.

Uses PostgreSQL with the pgvector extension for dense vector storage
and similarity search via SQLAlchemy async.

Add 'pgvector' and 'asyncpg' to project dependencies before using.
"""

from __future__ import annotations

import os
import re
from typing import final

import structlog

from {{ project_slug }}.ai.config import DEFAULT_SEARCH_TOP_K
from {{ project_slug }}.core.interfaces.vector_store import VectorSearchResult, VectorStoreGateway

logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)
_VALID_IDENTIFIER: re.Pattern[str] = re.compile(r"^[a-zA-Z_][a-zA-Z0-9_]{0,62}$")
_ENV_ALIAS_MAP: dict[str, str] = {
    "local": "local",
    "dev": "dev",
    "development": "dev",
    "test": "test",
    "staging": "staging",
    "stage": "staging",
    "prod": "prod",
    "production": "prod",
}


def _canonical_environment(raw_environment: str) -> str:
    """Normalize an environment label to a small canonical set."""
    normalized = raw_environment.strip().lower()
    return _ENV_ALIAS_MAP.get(normalized, normalized or "local")


@final
class PgvectorStore(VectorStoreGateway):
    """PostgreSQL + pgvector backed vector store.

    Stores vectors in a dedicated table with HNSW indexing for
    approximate nearest-neighbor search.
    """

    __slots__ = ("_database_url", "_dimension", "_environment", "_pool", "_schema_name", "_table_name")

    def __init__(
        self,
        *,
        database_url: str,
        dimension: int,
        table_name: str = "vector_embeddings",
        schema_name: str | None = None,
        environment: str | None = None,
        include_env_suffix: bool = True,
    ) -> None:
        try:
            import asyncpg  # type: ignore[import-untyped]  # noqa: F401
        except ImportError as exc:
            msg = "asyncpg is required -- pip install asyncpg"
            raise ImportError(msg) from exc

        resolved_environment = _canonical_environment(
            environment
            or os.environ.get("{{ project_slug | upper }}_ENVIRONMENT", "")
            or os.environ.get("APP_ENV", "local")
        )
        resolved_schema = schema_name or f"{resolved_environment}_schema"
        resolved_table = (
            f"{table_name}_{resolved_environment}" if include_env_suffix else table_name
        )

        if not _VALID_IDENTIFIER.match(resolved_schema):
            msg = f"Invalid schema name: {resolved_schema!r}"
            raise ValueError(msg)
        if not _VALID_IDENTIFIER.match(resolved_table):
            msg = f"Invalid table name: {resolved_table!r}"
            raise ValueError(msg)

        self._dimension = dimension
        self._environment = resolved_environment
        self._schema_name = resolved_schema
        self._table_name = resolved_table
        self._pool: object | None = None
        self._database_url = database_url

    @classmethod
    def from_config(cls, config: dict[str, object]) -> PgvectorStore:
        """Create a PgvectorStore instance from a configuration dictionary.

        Expected config structure::

            {
                "database_url": "postgresql://user:pass@localhost/db",
                "dimension": 1536,
                "table_name": "vector_embeddings",  # optional (default: "vector_embeddings")
                "schema_name": "dev_schema",  # optional (default: <environment>_schema)
                "environment": "dev",  # optional (default from env vars)
                "include_env_suffix": true,  # optional (default: true)
            }

        Args:
            config (dict[str, object]): Configuration dictionary.

        Returns:
            PgvectorStore: Configured vector store instance.
        """
        database_url = config.get("database_url")
        if not database_url:
            msg = "database_url is required in config for PgvectorStore"
            raise ValueError(msg)

        dimension = int(config["dimension"])
        table_name = str(config.get("table_name", "vector_embeddings"))
        schema_name = config.get("schema_name")
        environment = config.get("environment")
        include_env_suffix = bool(config.get("include_env_suffix", True))

        return cls(
            database_url=str(database_url),
            dimension=dimension,
            table_name=table_name,
            schema_name=str(schema_name) if schema_name else None,
            environment=str(environment) if environment else None,
            include_env_suffix=include_env_suffix,
        )

    async def _ensure_pool(self) -> None:
        """Lazily create connection pool and provision the vector table."""
        if self._pool is not None:
            return

        import asyncpg

        self._pool = await asyncpg.create_pool(self._database_url)
        async with self._pool.acquire() as conn:
            await conn.execute("CREATE EXTENSION IF NOT EXISTS vector;")
            await conn.execute(f'CREATE SCHEMA IF NOT EXISTS "{self._schema_name}";')
            await conn.execute(f"""
                CREATE TABLE IF NOT EXISTS "{self._schema_name}"."{self._table_name}" (
                    id TEXT PRIMARY KEY,
                    embedding vector({self._dimension}),
                    metadata JSONB DEFAULT '{{}}'::jsonb
                );
            """)
            await conn.execute(f"""
                CREATE INDEX IF NOT EXISTS idx_{self._table_name}_embedding
                ON "{self._schema_name}"."{self._table_name}"
                USING hnsw (embedding vector_l2_ops);
            """)
        logger.info(
            "pgvector table ensured",
            schema=self._schema_name,
            table=self._table_name,
            environment=self._environment,
        )

    async def add_vectors(
        self,
        *,
        vectors: list[list[float]],
        ids: list[str],
        metadata: list[dict[str, object]] | None = None,
    ) -> None:
        import json

        await self._ensure_pool()
        async with self._pool.acquire() as conn:
            for i, (vid, vec) in enumerate(zip(ids, vectors, strict=True)):
                meta = json.dumps(metadata[i] if metadata and i < len(metadata) else {})
                vec_str = "[" + ",".join(str(v) for v in vec) + "]"
                await conn.execute(
                    f"""
                    INSERT INTO "{self._schema_name}"."{self._table_name}" (id, embedding, metadata)
                    VALUES ($1, $2::vector, $3::jsonb)
                    ON CONFLICT (id) DO UPDATE
                    SET embedding = EXCLUDED.embedding, metadata = EXCLUDED.metadata;
                    """,
                    vid,
                    vec_str,
                    meta,
                )
        logger.info("Added %d vectors to pgvector", len(ids))

    async def search(
        self,
        *,
        query_vector: list[float],
        top_k: int = DEFAULT_SEARCH_TOP_K,
        filters: dict[str, object] | None = None,
    ) -> list[VectorSearchResult]:
        import json

        await self._ensure_pool()
        vec_str = "[" + ",".join(str(v) for v in query_vector) + "]"

        where_clause = ""
        params: list[object] = [vec_str, top_k]
        if filters:
            conditions = []
            for k, v in filters.items():
                key_idx = len(params) + 1
                val_idx = key_idx + 1
                conditions.append(f"metadata->>${key_idx} = ${val_idx}")
                params.extend([str(k), str(v)])
            where_clause = "WHERE " + " AND ".join(conditions)

        async with self._pool.acquire() as conn:
            rows = await conn.fetch(
                f"""
                SELECT id, embedding <-> $1::vector AS distance, metadata
                FROM "{self._schema_name}"."{self._table_name}"
                {where_clause}
                ORDER BY embedding <-> $1::vector
                LIMIT $2;
                """,
                *params,
            )

        return [
            VectorSearchResult(
                id=row["id"],
                score=float(row["distance"]),
                metadata=json.loads(row["metadata"]) if row["metadata"] else {},
            )
            for row in rows
        ]

    async def delete_vectors(self, ids: list[str]) -> None:
        await self._ensure_pool()
        async with self._pool.acquire() as conn:
            await conn.execute(
                f'DELETE FROM "{self._schema_name}"."{self._table_name}" WHERE id = ANY($1::text[]);',
                ids,
            )
        logger.info("Deleted %d vectors from pgvector", len(ids))

    async def count(self) -> int:
        await self._ensure_pool()
        async with self._pool.acquire() as conn:
            row = await conn.fetchrow(
                f'SELECT COUNT(*) AS cnt FROM "{self._schema_name}"."{self._table_name}";'
            )
            return int(row["cnt"])
