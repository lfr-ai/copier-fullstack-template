"""Property-based tests for value objects using Hypothesis.

This test demonstrates the property marker pattern:
- Uses Hypothesis for generative testing
- Tests properties that should hold for all valid inputs
- Discovers edge cases through random generation
- Useful for validating invariants and constraints

Run with::

    uv run pytest tests/property/ -v
    uv run pytest tests/property/ -m property

The property/ conftest auto-applies @pytest.mark.property to all tests.
"""

from __future__ import annotations

from enum import StrEnum

import pytest
from hypothesis import given
from hypothesis import strategies as st

from {{ project_slug }}.core.enums.base import ParseableEnum
from {{ project_slug }}.core.validators import is_valid_email


class SampleStatus(ParseableEnum):
    """Sample enum for testing ParseableEnum."""

    ACTIVE = "active"
    INACTIVE = "inactive"
    PENDING = "pending"


class TestEmailProperty:
    """Property-based tests for email validation.

    The property/ conftest auto-applies @pytest.mark.property.
    """

    @given(st.emails())
    def test_hypothesis_emails_are_valid(self, email: str) -> None:
        """Verify Hypothesis-generated emails pass validation.

        Property: All emails generated by hypothesis.strategies.emails()
        should be recognized as valid by our validator.

        Arrange: Hypothesis generates valid email
        Act: Validate email
        Assert: Result is boolean (validator doesn't crash)
        """
        result = is_valid_email(email)
        assert isinstance(result, bool)

    @given(st.text(min_size=1, max_size=50).filter(lambda s: "@" not in s))
    def test_strings_without_at_are_invalid(self, text: str) -> None:
        """Verify strings without @ symbol are invalid emails.

        Property: Any string without an @ character should be invalid.

        Arrange: Hypothesis generates text without @
        Act: Validate as email
        Assert: Returns False
        """
        assert is_valid_email(text) is False


class TestParseableEnumProperty:
    """Property-based tests for ParseableEnum parsing.

    Tests the from_str parsing behavior with valid and invalid inputs.
    """

    @given(st.sampled_from(["active", "inactive", "pending"]))
    def test_valid_enum_values_parse(self, value: str) -> None:
        """Verify valid enum values parse successfully.

        Property: All valid enum member values should parse via from_str.

        Arrange: Hypothesis selects valid enum value
        Act: Parse via from_str
        Assert: Result is correct enum member
        """
        # Act
        result = SampleStatus.from_str(value)

        # Assert
        assert isinstance(result, SampleStatus)
        assert result.value == value

    @given(st.sampled_from(["ACTIVE", "InAcTiVe", "PENDING"]))
    def test_case_insensitive_parsing(self, value: str) -> None:
        """Verify enum parsing is case-insensitive.

        Property: from_str should handle any casing of valid values.

        Arrange: Hypothesis selects case-varied valid value
        Act: Parse via from_str
        Assert: Parses to correct member
        """
        # Act
        result = SampleStatus.from_str(value)

        # Assert
        assert isinstance(result, SampleStatus)
        assert result.value == value.lower()

    @given(
        st.text(min_size=1, max_size=20).filter(
            lambda s: s.lower() not in ["active", "inactive", "pending"]
        )
    )
    def test_invalid_values_raise_value_error(self, invalid_value: str) -> None:
        """Verify invalid enum values raise ValueError.

        Property: Any string not matching a valid enum member should
        raise ValueError with descriptive message.

        Arrange: Hypothesis generates non-member string
        Act: Attempt to parse
        Assert: ValueError raised
        """
        # Act & Assert
        with pytest.raises(ValueError) as exc_info:
            SampleStatus.from_str(invalid_value)

        # Verify error message is descriptive
        assert "Unknown SampleStatus" in str(exc_info.value)
        assert invalid_value in str(exc_info.value)

    def test_enum_round_trip(self) -> None:
        """Verify enum member -> value -> from_str round-trip.

        Property: Converting a member to its value and parsing back
        should return the original member.

        Arrange: Take enum member
        Act: Convert to value and parse back
        Assert: Returns original member
        """
        # Arrange
        original = SampleStatus.ACTIVE

        # Act
        value = original.value
        parsed = SampleStatus.from_str(value)

        # Assert
        assert parsed == original
