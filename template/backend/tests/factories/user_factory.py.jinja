"""User test data factories."""

from __future__ import annotations

from itertools import count

from {{ project_slug }}.application.dtos.user_dto import CreateUserDTO

_COUNTER = count(start=1)


def create_user_dto(
    *,
    email: str | None = None,
    display_name: str = "Test User",
) -> CreateUserDTO:
    """Create user DTO with unique email.

    Args:
        email (str | None): Optional email override.
        display_name (str): User display name.

    Returns:
        CreateUserDTO with test data.
    """
    counter_value = next(_COUNTER)
    effective_email = email or f"testuser{counter_value}@example.com"
    return CreateUserDTO(email=effective_email, display_name=display_name)
