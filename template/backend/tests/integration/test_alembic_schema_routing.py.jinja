"""Integration tests for Alembic schema-aware migrations."""

from __future__ import annotations

import os
from typing import TYPE_CHECKING

import pytest
from sqlalchemy import text
{%- if database_backend == "postgresql" %}
from sqlalchemy.ext.asyncio import create_async_engine

if TYPE_CHECKING:
    from sqlalchemy.ext.asyncio import AsyncEngine
{%- endif %}


pytestmark = pytest.mark.integration


{%- if database_backend == "postgresql" %}


@pytest.fixture
def test_database_url() -> str:
    """Provide test database URL for migration tests."""
    return "postgresql+psycopg://postgres:test-password@localhost:5432/{{ project_slug }}_test"


@pytest.mark.asyncio
async def test_ensure_schemas_exist_creates_all_schemas(
    test_database_url: str,
) -> None:
    """Test that ensure_schemas_exist creates all environment schemas."""
    engine: AsyncEngine = create_async_engine(test_database_url)

    try:
        # Import ensure_schemas_exist from Alembic env
        # Note: In real usage, this is called automatically during migrations
        from alembic import context
        from sqlalchemy.ext.asyncio import AsyncConnection

        async with engine.connect() as connection:
            # Manually create schemas for testing
            expected_schemas = [
                "dev_schema",
                "test_schema",
                "staging_schema",
                "prod_schema",
            ]

            for schema in expected_schemas:
                await connection.execute(
                    text(f"CREATE SCHEMA IF NOT EXISTS {schema}")
                )
            await connection.commit()

            # Verify schemas exist in pg_catalog
            result = await connection.execute(
                text(
                    """
                    SELECT schema_name
                    FROM information_schema.schemata
                    WHERE schema_name IN (
                        'dev_schema', 'test_schema',
                        'staging_schema', 'prod_schema'
                    )
                    ORDER BY schema_name
                    """
                )
            )
            schemas = [row[0] for row in result.fetchall()]

            assert "dev_schema" in schemas
            assert "test_schema" in schemas
            assert "staging_schema" in schemas
            assert "prod_schema" in schemas
            assert len(schemas) == 4

    finally:
        await engine.dispose()


@pytest.mark.asyncio
async def test_migration_targets_correct_schema(
    test_database_url: str,
) -> None:
    """Test that migrations run in the environment-specific schema."""
    from {{ project_slug }}.config.settings import get_settings

    # Clear settings cache
    get_settings.cache_clear()
    original_env = os.environ.get("{{ project_slug | upper }}_ENVIRONMENT")

    try:
        # Set DEV environment
        os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = "dev"
        get_settings.cache_clear()

        engine: AsyncEngine = create_async_engine(test_database_url)

        async with engine.connect() as connection:
            # Ensure dev_schema exists
            await connection.execute(text("CREATE SCHEMA IF NOT EXISTS dev_schema"))
            await connection.commit()

            # Set search_path as migrations would
            await connection.execute(text("SET search_path TO dev_schema"))

            # Create a test table in the current search_path
            await connection.execute(
                text(
                    """
                    CREATE TABLE IF NOT EXISTS test_table (
                        id SERIAL PRIMARY KEY,
                        name TEXT NOT NULL
                    )
                    """
                )
            )
            await connection.commit()

            # Verify table exists in dev_schema, not public
            result = await connection.execute(
                text(
                    """
                    SELECT table_schema, table_name
                    FROM information_schema.tables
                    WHERE table_name = 'test_table'
                    AND table_schema IN ('public', 'dev_schema')
                    """
                )
            )
            rows = result.fetchall()

            # Should be in dev_schema only
            assert len(rows) >= 1
            schemas_with_table = {row[0] for row in rows}
            assert "dev_schema" in schemas_with_table

            # Clean up test table
            await connection.execute(text("DROP TABLE IF EXISTS test_table CASCADE"))
            await connection.commit()

        await engine.dispose()

    finally:
        if original_env:
            os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = original_env
        else:
            os.environ.pop("{{ project_slug | upper }}_ENVIRONMENT", None)
        get_settings.cache_clear()


@pytest.mark.asyncio
async def test_migration_schema_idempotent(
    test_database_url: str,
) -> None:
    """Test that CREATE SCHEMA IF NOT EXISTS is idempotent."""
    engine: AsyncEngine = create_async_engine(test_database_url)

    try:
        async with engine.connect() as connection:
            # Create schema first time
            await connection.execute(text("CREATE SCHEMA IF NOT EXISTS dev_schema"))
            await connection.commit()

            # Create schema second time (should not error)
            await connection.execute(text("CREATE SCHEMA IF NOT EXISTS dev_schema"))
            await connection.commit()

            # Verify schema exists exactly once
            result = await connection.execute(
                text(
                    """
                    SELECT COUNT(*)
                    FROM information_schema.schemata
                    WHERE schema_name = 'dev_schema'
                    """
                )
            )
            count = result.scalar()
            assert count == 1

    finally:
        await engine.dispose()


@pytest.mark.asyncio
async def test_migration_preserves_public_schema(
    test_database_url: str,
) -> None:
    """Test that LOCAL environment continues to use public schema."""
    from {{ project_slug }}.config.settings import get_settings

    # Clear settings cache
    get_settings.cache_clear()
    original_env = os.environ.get("{{ project_slug | upper }}_ENVIRONMENT")

    try:
        # Set LOCAL environment
        os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = "local"
        get_settings.cache_clear()

        engine: AsyncEngine = create_async_engine(test_database_url)

        async with engine.connect() as connection:
            # In LOCAL mode, search_path should include public
            result = await connection.execute(text("SHOW search_path"))
            search_path = result.scalar()
            assert "public" in search_path.lower()

            # Create a test table (will go to public in LOCAL mode)
            await connection.execute(
                text(
                    """
                    CREATE TABLE IF NOT EXISTS test_local_table (
                        id SERIAL PRIMARY KEY
                    )
                    """
                )
            )
            await connection.commit()

            # Verify it's in public schema
            result = await connection.execute(
                text(
                    """
                    SELECT table_schema
                    FROM information_schema.tables
                    WHERE table_name = 'test_local_table'
                    """
                )
            )
            schema = result.scalar()
            assert schema == "public"

            # Clean up
            await connection.execute(
                text("DROP TABLE IF EXISTS test_local_table CASCADE")
            )
            await connection.commit()

        await engine.dispose()

    finally:
        if original_env:
            os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = original_env
        else:
            os.environ.pop("{{ project_slug | upper }}_ENVIRONMENT", None)
        get_settings.cache_clear()


