"""Integration tests for Self-CRAG pipeline workflow."""

from __future__ import annotations

from unittest.mock import AsyncMock

import pytest

from {{ project_slug }}.ai.rag.self_crag_pipeline import SelfCRAGPipeline
from {{ project_slug }}.core.interfaces.retriever import RetrievedContext


@pytest.fixture
def mock_llm() -> AsyncMock:
    """Mock LLMGateway for integration test."""
    llm = AsyncMock()
    return llm


@pytest.fixture
def mock_retriever() -> AsyncMock:
    """Mock RetrieverGateway for integration test."""
    retriever = AsyncMock()
    return retriever


@pytest.mark.integration
class TestSelfCRAGPipeline:
    """Integration tests for the complete Self-CRAG workflow."""

    @pytest.mark.asyncio
    async def test_complete_workflow_with_rewrite_cycle(
        self,
        mock_llm: AsyncMock,
        mock_retriever: AsyncMock,
    ) -> None:
        """Full workflow: low relevance triggers rewrite -> re-retrieval -> high relevance -> answer.

        Scenario:
        1. Initial retrieval returns 2 docs
        2. First grading returns [0.2, 0.3] (overall = 0.25 < threshold)
        3. Query gets rewritten
        4. Re-retrieval returns different 2 docs
        5. Second grading returns [0.8, 0.9] (overall = 0.85 > threshold)
        6. Final answer is generated

        Expected LLM call sequence:
        1. Grade first doc (0.2)
        2. Grade second doc (0.3)
        3. Rewrite query
        4. Grade third doc (0.8)
        5. Grade fourth doc (0.9)
        6. Generate final answer

        Expected retriever call sequence:
        1. Initial retrieve
        2. Re-retrieve with rewritten query
        """
        # Setup mock retriever to return different docs on each call
        initial_docs = [
            RetrievedContext(content="Low relevance doc 1", source="initial1.txt"),
            RetrievedContext(content="Low relevance doc 2", source="initial2.txt"),
        ]
        rewritten_docs = [
            RetrievedContext(content="High relevance doc 1", source="rewritten1.txt"),
            RetrievedContext(content="High relevance doc 2", source="rewritten2.txt"),
        ]
        mock_retriever.retrieve.side_effect = [initial_docs, rewritten_docs]

        # Setup mock LLM to return:
        # 1. First grading: 0.2, 0.3
        # 2. Query rewrite: "rewritten query"
        # 3. Second grading: 0.8, 0.9
        # 4. Final answer: "Generated answer"
        mock_llm.complete.side_effect = [
            "0.2",  # Grade initial doc 1
            "0.3",  # Grade initial doc 2
            "rewritten query",  # Rewrite query
            "0.8",  # Grade rewritten doc 1
            "0.9",  # Grade rewritten doc 2
            "Generated answer from high relevance documents.",  # Final answer
        ]

        pipeline = SelfCRAGPipeline(llm=mock_llm, retriever=mock_retriever)

        # Execute query
        result = await pipeline.query("What is Python?", top_k=5)

        # Verify final result
        assert result.answer == "Generated answer from high relevance documents."
        assert len(result.sources) == 2
        assert result.sources[0].metadata["content"] == "High relevance doc 1"
        assert result.sources[1].metadata["content"] == "High relevance doc 2"

        # Verify retriever was called twice: initial + re-retrieve
        assert mock_retriever.retrieve.call_count == 2
        mock_retriever.retrieve.assert_any_await(query="What is Python?")
        mock_retriever.retrieve.assert_any_await(query="rewritten query")

        # Verify LLM was called 6 times: grade(2) + rewrite(1) + grade(2) + answer(1)
        assert mock_llm.complete.call_count == 6

    @pytest.mark.asyncio
    async def test_workflow_without_rewrite_high_initial_relevance(
        self,
        mock_llm: AsyncMock,
        mock_retriever: AsyncMock,
    ) -> None:
        """Workflow should skip rewrite when initial relevance is high.

        Scenario:
        1. Initial retrieval returns 2 docs
        2. First grading returns [0.8, 0.9] (overall = 0.85 > threshold)
        3. Answer is generated directly (no rewrite)

        Expected LLM calls: grade(2) + answer(1) = 3
        Expected retriever calls: initial(1) = 1
        """
        docs = [
            RetrievedContext(content="Highly relevant doc 1", source="doc1.txt"),
            RetrievedContext(content="Highly relevant doc 2", source="doc2.txt"),
        ]
        mock_retriever.retrieve.return_value = docs

        mock_llm.complete.side_effect = [
            "0.8",  # Grade doc 1
            "0.9",  # Grade doc 2
            "Generated answer from relevant documents.",  # Final answer
        ]

        pipeline = SelfCRAGPipeline(llm=mock_llm, retriever=mock_retriever)

        result = await pipeline.query("What is Python?")

        # Verify final result
        assert result.answer == "Generated answer from relevant documents."
        assert len(result.sources) == 2

        # Verify only one retrieval (no rewrite)
        assert mock_retriever.retrieve.call_count == 1

        # Verify 3 LLM calls: grade(2) + answer(1)
        assert mock_llm.complete.call_count == 3

    @pytest.mark.asyncio
    async def test_workflow_max_rewrites_exhausted(
        self,
        mock_llm: AsyncMock,
        mock_retriever: AsyncMock,
    ) -> None:
        """Workflow should stop after MAX_QUERY_REWRITES and generate answer.

        Scenario:
        1. Initial retrieval: low relevance [0.2, 0.3]
        2. First rewrite + re-retrieve: still low [0.2, 0.3]
        3. Second rewrite + re-retrieve: still low [0.2, 0.3]
        4. Max rewrites reached (2), generate answer

        Expected retriever calls: initial + rewrite1 + rewrite2 = 3
        Expected LLM calls: grade(2) + rewrite + grade(2) + rewrite + grade(2) + answer = 10
        """
        docs = [
            RetrievedContext(content="Low relevance doc", source="doc1.txt"),
            RetrievedContext(content="Low relevance doc", source="doc2.txt"),
        ]
        mock_retriever.retrieve.return_value = docs

        # All grading returns low scores, forcing max rewrites
        mock_llm.complete.side_effect = [
            "0.2", "0.3",  # First grading
            "rewrite 1",
            "0.2", "0.3",  # Second grading
            "rewrite 2",
            "0.2", "0.3",  # Third grading (after max rewrites)
            "Final answer despite low relevance.",
        ]

        pipeline = SelfCRAGPipeline(llm=mock_llm, retriever=mock_retriever)

        result = await pipeline.query("What is Python?")

        # Verify final answer was generated despite low relevance
        assert result.answer == "Final answer despite low relevance."

        # Verify 3 retrievals: initial + 2 rewrites
        assert mock_retriever.retrieve.call_count == 3

        # Verify 10 LLM calls
        assert mock_llm.complete.call_count == 10

    @pytest.mark.asyncio
    async def test_workflow_preserves_original_query(
        self,
        mock_llm: AsyncMock,
        mock_retriever: AsyncMock,
    ) -> None:
        """Workflow should preserve original query throughout rewrites."""
        docs = [
            RetrievedContext(content="doc", source="doc.txt"),
        ]
        mock_retriever.retrieve.return_value = docs

        mock_llm.complete.side_effect = [
            "0.2",  # Low score triggers rewrite
            "rewritten query",
            "0.8",  # High score after rewrite
            "Final answer",
        ]

        pipeline = SelfCRAGPipeline(llm=mock_llm, retriever=mock_retriever)

        # The original query should be preserved in the workflow state
        result = await pipeline.query("original question")

        # Verify workflow completed
        assert result.answer == "Final answer"

        # Verify retriever was called with original, then rewritten query
        calls = mock_retriever.retrieve.call_args_list
        assert calls[0].kwargs["query"] == "original question"
        assert calls[1].kwargs["query"] == "rewritten query"

    @pytest.mark.asyncio
    async def test_workflow_returns_retrieval_result_format(
        self,
