    @pytest.mark.asyncio
    async def test_workflow_graph_lazy_compilation(
        self,
        mock_llm: AsyncMock,
        mock_retriever: AsyncMock,
    ) -> None:
        """Workflow graph should be lazily compiled on first query."""
        docs = [
            RetrievedContext(content="doc", source="doc.txt"),
        ]
        mock_retriever.retrieve.return_value = docs

        mock_llm.complete.side_effect = [
            "0.8",
            "Answer",
        ]

        pipeline = SelfCRAGPipeline(llm=mock_llm, retriever=mock_retriever)

        # Graph should be None before first query
        assert pipeline._graph is None

        # First query compiles the graph
        await pipeline.query("first question")
        assert pipeline._graph is not None

        # Second query reuses compiled graph
        mock_llm.complete.side_effect = ["0.8", "Second answer"]
        await pipeline.query("second question")

        # Graph should still be the same instance
        assert pipeline._graph is not None
