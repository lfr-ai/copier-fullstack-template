class TestReturnTypeConsistency:
    """Verify both pipelines share the same RetrievalResult interface."""

    def test_deep_rag_and_self_crag_share_result_type(self) -> None:
        """Both pipelines should define query() returning RetrievalResult."""
        import inspect

        deep_sig = inspect.signature(DeepRAGPipeline.query)
        self_sig = inspect.signature(SelfCRAGPipeline.query)

        # Both accept question, top_k, system_prompt
        deep_params = set(deep_sig.parameters.keys())
        self_params = set(self_sig.parameters.keys())
        assert "question" in deep_params
        assert "top_k" in deep_params
        assert "question" in self_params
        assert "top_k" in self_params


if __name__ == "__main__":
    unittest.main()
