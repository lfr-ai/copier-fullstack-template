"""End-to-end validation tests for DeepRAG pipeline.

Tests the complete DeepRAG pipeline including:
- Pipeline construction and from_config factory
- Graph building with LangGraph StateGraph
- Self-CRAG fallback routing via AdaptiveRAGPipeline
- RetrievalResult interface consistency
"""

import pytest
from unittest.mock import AsyncMock, MagicMock, patch

from {{ project_slug }}.ai.rag.deep_rag_pipeline import DeepRAGPipeline
from {{ project_slug }}.ai.rag.self_crag_pipeline import SelfCRAGPipeline
from {{ project_slug }}.ai.rag.retrieval import RetrievalResult


class TestDeepRAGPipelineConstruction:
    """Test DeepRAGPipeline construction and configuration."""

    def test_from_config_with_valid_config(self) -> None:
        """Pipeline should be constructable from a config dict."""
        mock_llm = AsyncMock()
        mock_retriever = AsyncMock()
        pipeline = DeepRAGPipeline.from_config({
            "llm": mock_llm,
            "retriever": mock_retriever,
        })
        assert pipeline._llm is mock_llm
        assert pipeline._retriever is mock_retriever

    def test_from_config_missing_llm(self) -> None:
        """Pipeline should raise ValueError when llm is missing."""
        with pytest.raises(ValueError, match="llm is required"):
            DeepRAGPipeline.from_config({"retriever": AsyncMock()})

    def test_from_config_missing_retriever(self) -> None:
        """Pipeline should raise ValueError when retriever is missing."""
        with pytest.raises(ValueError, match="retriever is required"):
            DeepRAGPipeline.from_config({"llm": AsyncMock()})


