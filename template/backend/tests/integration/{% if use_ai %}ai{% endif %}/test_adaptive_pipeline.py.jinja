    @pytest.mark.asyncio
    async def test_reranker_failure_continues_with_original_ranking(
        self,
        mock_llm: AsyncMock,
        mock_embedding: AsyncMock,
        mock_vector_store: AsyncMock,
        mock_reranker: AsyncMock,
        caplog: pytest.LogCaptureFixture,
    ) -> None:
        """Verify reranker failure logs WARNING and continues with original ranking."""
        pipeline = AdaptiveRAGPipeline(
            llm=mock_llm,
            embedding=mock_embedding,
            vector_store=mock_vector_store,
            reranker=mock_reranker,
        )

        # Mock reranker to raise exception
        mock_reranker.rerank.side_effect = RuntimeError("Reranker service unavailable")

        result = await pipeline.query("What is the answer?")

        # Verify warning logged
        assert "Reranker failed" in caplog.text or "continuing with original ranking" in caplog.text

        # Verify result still returned
        assert isinstance(result, RetrievalResult)
        assert result.answer

    @pytest.mark.asyncio
    async def test_concurrent_queries_state_isolation(
        self,
        mock_llm: AsyncMock,
        mock_embedding: AsyncMock,
        mock_vector_store: AsyncMock,
    ) -> None:
        """Verify concurrent queries to same pipeline instance handle state isolation correctly."""
        pipeline = AdaptiveRAGPipeline(
            llm=mock_llm,
            embedding=mock_embedding,
            vector_store=mock_vector_store,
        )

        # Execute concurrent queries
        import asyncio

        results = await asyncio.gather(
            pipeline.query("Question 1"),
            pipeline.query("Question 2"),
            pipeline.query("Question 3"),
        )

        # Verify all queries completed successfully
        assert len(results) == 3
        assert all(isinstance(r, RetrievalResult) for r in results)

        # Verify queries match original questions
        assert results[0].query == "Question 1"
        assert results[1].query == "Question 2"
        assert results[2].query == "Question 3"
