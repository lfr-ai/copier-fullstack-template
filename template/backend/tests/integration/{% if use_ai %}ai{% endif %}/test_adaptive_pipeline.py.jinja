        self,
        mock_llm: AsyncMock,
        mock_embedding: AsyncMock,
        mock_vector_store: AsyncMock,
    ) -> None:
        """Verify excessively long system_prompt raises ValueError."""
        pipeline = AdaptiveRAGPipeline(
            llm=mock_llm,
