@pytest.fixture
def mock_reranker() -> AsyncMock:
    """Mock RerankerGateway."""
    reranker = AsyncMock()

    # Mock rerank to return a simple ranked result
    async def rerank_fn(query: str, results: list[dict], top_k: int) -> list[MagicMock]:
        ranked_results = []
        for i, r in enumerate(results[:top_k]):
            mock_result = MagicMock()
            mock_result.id = r["id"]
            mock_result.content = r["content"]
            mock_result.rerank_score = 0.9 - (i * 0.1)
            mock_result.original_score = r["score"]
            mock_result.metadata = r["metadata"]
            ranked_results.append(mock_result)
        return ranked_results

    reranker.rerank.side_effect = rerank_fn
    return reranker


@pytest.mark.integration
class TestAdaptiveRAGPipelineRouting:
    """Test suite for routing and orchestration logic."""

    @pytest.mark.asyncio
    async def test_routing_to_self_crag(
        self,
        mock_llm: AsyncMock,
        mock_embedding: AsyncMock,
        mock_vector_store: AsyncMock,
        caplog: pytest.LogCaptureFixture,
    ) -> None:
        """Verify use_graph=False routes to Self-CRAG pipeline."""
        pipeline = AdaptiveRAGPipeline(
            llm=mock_llm,
            embedding=mock_embedding,
            vector_store=mock_vector_store,
        )

        # Use patch to spy on pipeline initialization
        with patch.object(pipeline, "_get_self_crag_pipeline", wraps=pipeline._get_self_crag_pipeline) as spy:
            result = await pipeline.query("What is the answer?", use_graph=False)

            # Verify routing decision
            spy.assert_called_once()
            assert "self-crag" in caplog.text.lower() or "Routing to Self-CRAG" in caplog.text

        # Verify result structure
        assert isinstance(result, RetrievalResult)
        assert result.answer
        assert result.query == "What is the answer?"

    @pytest.mark.asyncio
    async def test_routing_to_deeprag(
        self,
        mock_llm: AsyncMock,
        mock_embedding: AsyncMock,
        mock_vector_store: AsyncMock,
        mock_knowledge_graph: AsyncMock,
        caplog: pytest.LogCaptureFixture,
    ) -> None:
        """Verify use_graph=True routes to DeepRAG pipeline."""
        pipeline = AdaptiveRAGPipeline(
            llm=mock_llm,
            embedding=mock_embedding,
            vector_store=mock_vector_store,
            knowledge_graph=mock_knowledge_graph,
        )

        # Mock the DeepRAG pipeline query
        mock_deep_rag = AsyncMock()
        mock_deep_rag.query.return_value = RetrievalResult(
            query="What is the answer?",
            answer="The answer is 42.",
            sources=[],
            graph_context=[{"step": 1, "sub_query": "sub-query-1", "decision": "retrieve"}],
        )

        with patch.object(pipeline, "_get_deep_rag_pipeline", return_value=mock_deep_rag):
            result = await pipeline.query("What is the answer?", use_graph=True)

            # Verify routing decision
            mock_deep_rag.query.assert_awaited_once()
            assert "deeprag" in caplog.text.lower() or "Routing to DeepRAG" in caplog.text

        # Verify result structure
        assert isinstance(result, RetrievalResult)
        assert result.answer
        assert len(result.graph_context) > 0

    @pytest.mark.asyncio
    async def test_fallback_when_kg_unavailable(
        self,
        mock_llm: AsyncMock,
        mock_embedding: AsyncMock,
        mock_vector_store: AsyncMock,
        caplog: pytest.LogCaptureFixture,
    ) -> None:
        """Verify use_graph=True with knowledge_graph=None falls back to Self-CRAG."""
        pipeline = AdaptiveRAGPipeline(
            llm=mock_llm,
            embedding=mock_embedding,
            vector_store=mock_vector_store,
            knowledge_graph=None,  # No KG available
        )

        result = await pipeline.query("What is the answer?", use_graph=True)

        # Verify fallback to Self-CRAG
        assert "Knowledge graph unavailable" in caplog.text or "self-crag" in caplog.text.lower()

        # Verify result structure (should still work)
        assert isinstance(result, RetrievalResult)
        assert result.answer
        assert result.graph_context == []  # No graph context without KG

