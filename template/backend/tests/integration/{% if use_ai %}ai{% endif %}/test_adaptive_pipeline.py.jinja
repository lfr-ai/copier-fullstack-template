    @pytest.mark.asyncio
    async def test_system_prompt_propagation(
        self,
        mock_llm: AsyncMock,
        mock_embedding: AsyncMock,
        mock_vector_store: AsyncMock,
    ) -> None:
        """Verify system_prompt flows through to LLM generation."""
        pipeline = AdaptiveRAGPipeline(
            llm=mock_llm,
            embedding=mock_embedding,
            vector_store=mock_vector_store,
        )

        custom_prompt = "You are a domain expert. Be concise."
        await pipeline.query("What is the answer?", system_prompt=custom_prompt)

        # Verify LLM was called with system_prompt
        mock_llm.complete.assert_awaited()
        call_kwargs = mock_llm.complete.call_args.kwargs
        assert "system_prompt" in call_kwargs
        # System prompt should either match exactly or be the default fallback
        assert custom_prompt in call_kwargs["system_prompt"] or "helpful assistant" in call_kwargs["system_prompt"]


@pytest.mark.integration
class TestAdaptiveRAGPipelineNegativeCases:
    """Test suite for error handling and boundary conditions."""

    @pytest.mark.asyncio
    async def test_empty_question_raises_error(
        self,
        mock_llm: AsyncMock,
        mock_embedding: AsyncMock,
        mock_vector_store: AsyncMock,
    ) -> None:
        """Verify empty question string raises ValueError."""
        pipeline = AdaptiveRAGPipeline(
            llm=mock_llm,
            embedding=mock_embedding,
            vector_store=mock_vector_store,
        )

        with pytest.raises(ValueError, match="Question cannot be empty"):
            await pipeline.query("")

    @pytest.mark.asyncio
    async def test_negative_top_k_raises_error(
        self,
        mock_llm: AsyncMock,
        mock_embedding: AsyncMock,
        mock_vector_store: AsyncMock,
    ) -> None:
        """Verify negative top_k raises ValueError."""
        pipeline = AdaptiveRAGPipeline(
            llm=mock_llm,
            embedding=mock_embedding,
            vector_store=mock_vector_store,
        )

        with pytest.raises(ValueError, match="top_k must be non-negative"):
