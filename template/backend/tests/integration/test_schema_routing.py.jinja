from __future__ import annotations

import os

import pytest
from sqlalchemy import text
{%- if database_backend == "postgresql" %}
from sqlalchemy.ext.asyncio import AsyncEngine

from {{ project_slug }}.core.enums.environment import Environment
from {{ project_slug }}.infrastructure.persistence.session import (
    create_engine,
    schema_for_environment,
)
{%- endif %}


pytestmark = pytest.mark.integration


{%- if database_backend == "postgresql" %}


@pytest.fixture
def test_database_url() -> str:
    """Provide test database URL for schema routing tests."""
    return "postgresql+psycopg://postgres:test-password@localhost:5432/{{ project_slug }}_test"



def test_schema_for_environment_mapping() -> None:
    """Verify Environment enum maps to correct schema names."""
    assert schema_for_environment(Environment.LOCAL) == "public"
    assert schema_for_environment(Environment.DEV) == "dev_schema"
    assert schema_for_environment(Environment.TEST) == "test_schema"
    assert schema_for_environment(Environment.STAGING) == "staging_schema"
    assert schema_for_environment(Environment.PROD) == "prod_schema"


@pytest.mark.asyncio
async def test_schema_routing_local_environment(
    test_database_url: str,
) -> None:
    """Test that LOCAL environment routes to public schema."""
    from {{ project_slug }}.config.settings import get_settings

    # Clear settings cache
    get_settings.cache_clear()
    original_env = os.environ.get("{{ project_slug | upper }}_ENVIRONMENT")

    try:
        os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = "local"
        get_settings.cache_clear()

        engine: AsyncEngine = create_engine(test_database_url, echo=False)

        async with engine.begin() as conn:
            result = await conn.execute(text("SHOW search_path"))
            search_path = result.scalar()
            assert "public" in search_path.lower()

        await engine.dispose()
    finally:
        if original_env:
            os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = original_env
        else:
            os.environ.pop("{{ project_slug | upper }}_ENVIRONMENT", None)
        get_settings.cache_clear()


