@pytest.mark.asyncio
async def test_schema_routing_persists_across_connections(
    test_database_url: str,
) -> None:
    """Test that schema routing is applied to all connections from the pool."""
    from {{ project_slug }}.config.settings import get_settings

    # Clear settings cache
    get_settings.cache_clear()
    original_env = os.environ.get("{{ project_slug | upper }}_ENVIRONMENT")

    try:
        os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = "dev"
        get_settings.cache_clear()

        engine: AsyncEngine = create_engine(test_database_url, echo=False)

        # Check multiple connections from the pool
        for _ in range(3):
            async with engine.begin() as conn:
                result = await conn.execute(text("SHOW search_path"))
                search_path = result.scalar()
                assert "dev_schema" in search_path.lower()

        await engine.dispose()
    finally:
        if original_env:
            os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = original_env
        else:
            os.environ.pop("{{ project_slug | upper }}_ENVIRONMENT", None)
        get_settings.cache_clear()


@pytest.mark.asyncio
