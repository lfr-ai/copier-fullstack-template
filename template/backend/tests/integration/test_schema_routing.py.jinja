@pytest.fixture
async def dev_engine(test_database_url: str) -> AsyncIterator[AsyncEngine]:
    """Create engine configured for DEV environment.

    Args:
        test_database_url (str): Test database URL.

    Yields:
        AsyncEngine: Engine with search_path set to dev_schema.
    """
    from {{ project_slug }}.config.settings import get_settings

    get_settings.cache_clear()
    original_env = os.environ.get("{{ project_slug | upper }}_ENVIRONMENT")

    try:
        os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = "dev"
        get_settings.cache_clear()

        engine = create_engine(test_database_url, echo=False)

        # Create tables in dev_schema
        async with engine.begin() as conn:
            await conn.run_sync(ORMBase.metadata.create_all)

        yield engine

        # Cleanup: drop all tables from dev_schema
        async with engine.begin() as conn:
            await conn.run_sync(ORMBase.metadata.drop_all)
        await engine.dispose()
    finally:
        if original_env:
            os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = original_env
        else:
            os.environ.pop("{{ project_slug | upper }}_ENVIRONMENT", None)
        get_settings.cache_clear()


