@pytest.mark.asyncio
async def test_orm_queries_route_to_correct_schema(dev_engine: AsyncEngine) -> None:
    """Verify ORM insert in DEV routes to dev_schema.users, not public.users.

    Args:
        dev_engine (AsyncEngine): Engine configured for DEV environment.
    """
    session_factory = async_sessionmaker(
        dev_engine, class_=AsyncSession, expire_on_commit=False
    )

    # Create user via ORM
    test_email = f"orm_test_{uuid.uuid4().hex[:8]}@example.com"
    async with session_factory() as session:
        user = UserModel(
            email=test_email,
            display_name="ORM Test User",
            is_active=True,
        )
        session.add(user)
        await session.commit()

    # Verify row exists in dev_schema.users
    async with dev_engine.begin() as conn:
        result = await conn.execute(
            text(
                """
                SELECT COUNT(*)
                FROM dev_schema.users
                WHERE email = :email
                """
            ),
            {"email": test_email},
        )
        dev_count = result.scalar()
        assert dev_count == 1, "ORM insert should create row in dev_schema.users"

        # Verify public.users is empty (no cross-contamination)
        result = await conn.execute(
            text(
                """
                SELECT COUNT(*)
                FROM public.users
                WHERE email = :email
                """
            ),
            {"email": test_email},
        )
        public_count = result.scalar()
        assert public_count == 0, "ORM insert should NOT create row in public.users"


@pytest.mark.asyncio
async def test_raw_sql_respects_search_path(staging_engine: AsyncEngine) -> None:
    """Verify raw SQL INSERT in STAGING routes to staging_schema.users.

    Args:
        staging_engine (AsyncEngine): Engine configured for STAGING environment.
    """
    test_email = f"raw_sql_test_{uuid.uuid4().hex[:8]}@example.com"

    # Execute raw INSERT via text()
    async with staging_engine.begin() as conn:
        await conn.execute(
            text(
                """
                INSERT INTO users (id, email, display_name, is_active, created_at, updated_at)
                VALUES (gen_random_uuid(), :email, :display_name, true, now(), now())
                """
            ),
            {"email": test_email, "display_name": "Raw SQL Test User"},
        )

    # Verify data in staging_schema.users
    async with staging_engine.begin() as conn:
        result = await conn.execute(
            text(
                """
                SELECT COUNT(*)
                FROM staging_schema.users
                WHERE email = :email
                """
            ),
            {"email": test_email},
        )
        staging_count = result.scalar()
        assert staging_count == 1, "Raw SQL insert should create row in staging_schema.users"

        # Verify public.users is empty
        result = await conn.execute(
            text(
                """
                SELECT COUNT(*)
                FROM public.users
                WHERE email = :email
                """
            ),
            {"email": test_email},
        )
        public_count = result.scalar()
        assert public_count == 0, "Raw SQL insert should NOT create row in public.users"


@pytest.mark.asyncio
async def test_transactions_inherit_search_path(prod_engine: AsyncEngine) -> None:
    """Verify commit persists data and rollback discards data in correct schema.

    Args:
        prod_engine (AsyncEngine): Engine configured for PROD environment.
    """
    # Test commit: data should persist in prod_schema
    commit_email = f"commit_test_{uuid.uuid4().hex[:8]}@example.com"
    async with prod_engine.begin() as conn:
        await conn.execute(
            text(
                """
                INSERT INTO users (id, email, display_name, is_active, created_at, updated_at)
                VALUES (gen_random_uuid(), :email, 'Commit Test', true, now(), now())
                """
            ),
            {"email": commit_email},
        )
        # Transaction commits automatically at end of context manager

    # Verify committed data exists in prod_schema.users
    async with prod_engine.begin() as conn:
        result = await conn.execute(
            text(
                """
                SELECT COUNT(*)
                FROM prod_schema.users
                WHERE email = :email
                """
            ),
            {"email": commit_email},
        )
        count = result.scalar()
        assert count == 1, "Committed transaction should persist data in prod_schema.users"

    # Test rollback: data should NOT persist in prod_schema
    rollback_email = f"rollback_test_{uuid.uuid4().hex[:8]}@example.com"
    try:
        async with prod_engine.begin() as conn:
            await conn.execute(
                text(
                    """
                    INSERT INTO users (id, email, display_name, is_active, created_at, updated_at)
                    VALUES (gen_random_uuid(), :email, 'Rollback Test', true, now(), now())
                    """
                ),
                {"email": rollback_email},
            )
            # Simulate error to trigger rollback
            raise RuntimeError("Intentional rollback")
    except RuntimeError:
        pass  # Expected error

    # Verify rolled-back data does NOT exist in prod_schema.users
    async with prod_engine.begin() as conn:
        result = await conn.execute(
            text(
                """
                SELECT COUNT(*)
                FROM prod_schema.users
                WHERE email = :email
                """
            ),
            {"email": rollback_email},
        )
        count = result.scalar()
        assert count == 0, "Rolled-back transaction should NOT persist data in prod_schema.users"


@pytest.mark.asyncio
async def test_connection_pooling_preserves_schema(dev_engine: AsyncEngine) -> None:
    """Verify two sequential queries reusing pooled connection both target dev_schema.

    Args:
        dev_engine (AsyncEngine): Engine configured for DEV environment.
    """
    email1 = f"pool_test1_{uuid.uuid4().hex[:8]}@example.com"
    email2 = f"pool_test2_{uuid.uuid4().hex[:8]}@example.com"

    # Execute first insertion
    async with dev_engine.begin() as conn:
        await conn.execute(
            text(
                """
                INSERT INTO users (id, email, display_name, is_active, created_at, updated_at)
                VALUES (gen_random_uuid(), :email, 'Pool Test 1', true, now(), now())
                """
            ),
            {"email": email1},
        )

    # Execute second insertion (may reuse pooled connection)
    async with dev_engine.begin() as conn:
        await conn.execute(
            text(
                """
                INSERT INTO users (id, email, display_name, is_active, created_at, updated_at)
                VALUES (gen_random_uuid(), :email, 'Pool Test 2', true, now(), now())
                """
            ),
            {"email": email2},
        )

    # Verify both insertions went to dev_schema
    async with dev_engine.begin() as conn:
        result = await conn.execute(
            text(
                """
                SELECT COUNT(*)
                FROM dev_schema.users
                WHERE email IN (:email1, :email2)
                """
            ),
            {"email1": email1, "email2": email2},
        )
        dev_count = result.scalar()
        assert dev_count == 2, "Both pooled insertions should target dev_schema.users"

        # Verify public.users is empty
        result = await conn.execute(
            text(
                """
                SELECT COUNT(*)
                FROM public.users
                WHERE email IN (:email1, :email2)
                """
            ),
            {"email1": email1, "email2": email2},
        )
        public_count = result.scalar()
        assert public_count == 0, "Pooled insertions should NOT leak to public.users"


@pytest.mark.asyncio
async def test_alembic_creates_all_schemas(test_database_url: str) -> None:
    """Verify Alembic ensure_schemas_exist creates all four environment schemas.

    Args:
        test_database_url (str): Test database URL.
    """
    from {{ project_slug }}.config.settings import get_settings

    get_settings.cache_clear()
    original_env = os.environ.get("{{ project_slug | upper }}_ENVIRONMENT")

    try:
        # Use DEV environment for this test
        os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = "dev"
        get_settings.cache_clear()

        engine = create_engine(test_database_url, echo=False)

        # Query pg_catalog.pg_namespace for all expected schemas
        async with engine.begin() as conn:
            result = await conn.execute(
                text(
                    """
                    SELECT nspname
                    FROM pg_catalog.pg_namespace
                    WHERE nspname IN ('dev_schema', 'test_schema', 'staging_schema', 'prod_schema')
                    ORDER BY nspname
                    """
                )
            )
            schemas = [row[0] for row in result.fetchall()]

        await engine.dispose()

        # Verify all four schemas exist
        expected_schemas = ["dev_schema", "prod_schema", "staging_schema", "test_schema"]
        assert sorted(schemas) == expected_schemas, (
            f"Alembic should create all environment schemas. "
            f"Expected {expected_schemas}, got {sorted(schemas)}"
        )
    finally:
        if original_env:
            os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = original_env
        else:
            os.environ.pop("{{ project_slug | upper }}_ENVIRONMENT", None)
        get_settings.cache_clear()


@pytest.mark.asyncio
async def test_environment_isolation(test_database_url: str) -> None:
    """Verify data in LOCAL, DEV, TEST simultaneously with no cross-contamination.

    Args:
        test_database_url (str): Test database URL.
    """
    from {{ project_slug }}.config.settings import get_settings

    get_settings.cache_clear()
    original_env = os.environ.get("{{ project_slug | upper }}_ENVIRONMENT")

    local_email = f"local_isolation_{uuid.uuid4().hex[:8]}@example.com"
    dev_email = f"dev_isolation_{uuid.uuid4().hex[:8]}@example.com"
    test_email = f"test_isolation_{uuid.uuid4().hex[:8]}@example.com"

    try:
        # Create user in LOCAL (public schema)
        os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = "local"
        get_settings.cache_clear()
        local_engine = create_engine(test_database_url, echo=False)
        async with local_engine.begin() as conn:
            await conn.run_sync(ORMBase.metadata.create_all)
            await conn.execute(
                text(
                    """
                    INSERT INTO users (id, email, display_name, is_active, created_at, updated_at)
                    VALUES (gen_random_uuid(), :email, 'Local User', true, now(), now())
                    """
                ),
                {"email": local_email},
            )

        # Create user in DEV (dev_schema)
        os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = "dev"
        get_settings.cache_clear()
        dev_engine = create_engine(test_database_url, echo=False)
        async with dev_engine.begin() as conn:
            await conn.run_sync(ORMBase.metadata.create_all)
            await conn.execute(
                text(
                    """
                    INSERT INTO users (id, email, display_name, is_active, created_at, updated_at)
                    VALUES (gen_random_uuid(), :email, 'Dev User', true, now(), now())
                    """
                ),
                {"email": dev_email},
            )

        # Create user in TEST (test_schema)
        os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = "test"
        get_settings.cache_clear()
        test_engine = create_engine(test_database_url, echo=False)
        async with test_engine.begin() as conn:
            await conn.run_sync(ORMBase.metadata.create_all)
            await conn.execute(
                text(
                    """
                    INSERT INTO users (id, email, display_name, is_active, created_at, updated_at)
                    VALUES (gen_random_uuid(), :email, 'Test User', true, now(), now())
                    """
                ),
                {"email": test_email},
            )

        # Verify isolation: each environment has only its own data
        async with local_engine.begin() as conn:
            # public schema should have only local_email
            result = await conn.execute(
                text("SELECT COUNT(*) FROM public.users WHERE email IN (:local, :dev, :test)"),
                {"local": local_email, "dev": dev_email, "test": test_email},
            )
            public_count = result.scalar()
            assert public_count == 1, "public schema should have exactly 1 user (local_email)"

            result = await conn.execute(
                text("SELECT email FROM public.users WHERE email = :email"),
                {"email": local_email},
            )
            assert result.scalar() == local_email, "public schema should contain local_email"

        async with dev_engine.begin() as conn:
            # dev_schema should have only dev_email
            result = await conn.execute(
                text("SELECT COUNT(*) FROM dev_schema.users WHERE email IN (:local, :dev, :test)"),
                {"local": local_email, "dev": dev_email, "test": test_email},
            )
            dev_count = result.scalar()
            assert dev_count == 1, "dev_schema should have exactly 1 user (dev_email)"

            result = await conn.execute(
                text("SELECT email FROM dev_schema.users WHERE email = :email"),
                {"email": dev_email},
            )
            assert result.scalar() == dev_email, "dev_schema should contain dev_email"

        async with test_engine.begin() as conn:
            # test_schema should have only test_email
            result = await conn.execute(
                text("SELECT COUNT(*) FROM test_schema.users WHERE email IN (:local, :dev, :test)"),
                {"local": local_email, "dev": dev_email, "test": test_email},
            )
            test_count = result.scalar()
            assert test_count == 1, "test_schema should have exactly 1 user (test_email)"

            result = await conn.execute(
                text("SELECT email FROM test_schema.users WHERE email = :email"),
                {"email": test_email},
            )
            assert result.scalar() == test_email, "test_schema should contain test_email"

        # Cleanup
        async with local_engine.begin() as conn:
            await conn.run_sync(ORMBase.metadata.drop_all)
        await local_engine.dispose()

        async with dev_engine.begin() as conn:
            await conn.run_sync(ORMBase.metadata.drop_all)
        await dev_engine.dispose()

        async with test_engine.begin() as conn:
            await conn.run_sync(ORMBase.metadata.drop_all)
        await test_engine.dispose()
    finally:
        if original_env:
            os.environ["{{ project_slug | upper }}_ENVIRONMENT"] = original_env
        else:
            os.environ.pop("{{ project_slug | upper }}_ENVIRONMENT", None)
        get_settings.cache_clear()


