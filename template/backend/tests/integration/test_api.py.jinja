class TestRestHealthEndpoints:
    """Test suite for REST health check API endpoints."""

    async def test_rest_health_check(self, client: AsyncClient) -> None:
        """Verify REST health endpoint returns healthy status."""
        response = await client.get("/api/v1/health")
        assert response.status_code == HTTPStatus.OK
        assert response.json()["status"] == "healthy"

    async def test_readiness_check(self, client: AsyncClient) -> None:
        """Verify readiness endpoint returns ready status."""
        response = await client.get("/api/v1/health/ready")
        assert response.status_code == HTTPStatus.OK
        assert response.json()["status"] == "ready"


class TestUserEndpoints:
    """Test suite for user management API endpoints."""

    async def test_create_user(self, client: AsyncClient) -> None:
        """Verify user creation endpoint."""
        payload = {
            "email": "test@example.com",
            "display_name": "Test User",
            "password": "securepassword123",
        }
        response = await client.post("/api/v1/users", json=payload)
        assert response.status_code == HTTPStatus.CREATED
        data = response.json()
        assert data["email"] == "test@example.com"

    async def test_get_user_not_found(self, client: AsyncClient) -> None:
        """Verify 404 for nonexistent user."""
        response = await client.get("/api/v1/users/99999")
        assert response.status_code == HTTPStatus.NOT_FOUND
