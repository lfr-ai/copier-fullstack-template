"""Profiling test example demonstrating profiling marker pattern.

This test demonstrates the profiling marker pattern:
- Tests that verify profiling infrastructure works
- Uses the profiles_dir fixture for output
- Helps detect performance bottlenecks
- Provides CPU, memory, and SQL profiling examples

Run with::

    uv run pytest tests/performance/ -m profiling -v
    uv run tox -e performance

When to use profiling tests:
- Verifying profiling utilities function correctly
- Investigating performance bottlenecks in development
- Establishing baseline performance profiles
- Debugging slow operations or memory leaks

The performance/ conftest auto-applies @pytest.mark.performance.
We explicitly add @pytest.mark.profiling for profiling-specific filtering.
"""

from __future__ import annotations

import pathlib
from unittest.mock import MagicMock

import pytest


@pytest.mark.profiling
@pytest.mark.performance
class TestCpuProfiling:
    """CPU profiling via pyinstrument.

    CPU profiling helps identify computational hotspots by sampling
    the call stack at regular intervals.

    Use when:
    - Functions are slower than expected
    - Need to optimize algorithm performance
    - Investigating high CPU usage
    """

    async def test_cpu_profile_context_manager(
        self,
        profiles_dir: pathlib.Path,
    ) -> None:
        """Verify CPU profiling captures execution time.

        Arrange: Import cpu_profile utility
        Act: Profile simple computation
        Assert: Profile data captured with duration
        """
        from {{ project_slug }}.infrastructure.profiling.cpu import cpu_profile

        # Act - Profile a simple computation
        async with cpu_profile(label="test_basic") as result:
            total = sum(range(100_000))
            assert total > 0

        # Assert
        assert result.duration_s > 0
        assert result.label == "test_basic"
        assert result.console_output

    async def test_cpu_profile_saves_html(
        self,
        profiles_dir: pathlib.Path,
    ) -> None:
        """Verify CPU profile saves HTML report to profiles_dir.

        Arrange: Set profiling directory environment variable
        Act: Profile operation with HTML output
        Assert: HTML file created in profiles_dir
        """
        import os

        from {{ project_slug }}.infrastructure.profiling.cpu import cpu_profile

        # Arrange - Point to test profiles directory
        cpu_profile_dir = profiles_dir / "cpu"
        os.environ["{{ project_slug | upper }}_PROFILING_DIR"] = str(cpu_profile_dir)

        try:
            # Act - Profile with HTML output
            async with cpu_profile(label="test_html") as result:
                _ = [x**2 for x in range(10_000)]

            # Assert - HTML report should be created
            assert result.html_path is not None
            # Note: In test environment, HTML may not be written
            # This test verifies the profiling infrastructure works
        finally:
            os.environ.pop("{{ project_slug | upper }}_PROFILING_DIR", None)


@pytest.mark.profiling
@pytest.mark.performance
class TestMemoryProfiling:
    """Memory profiling via tracemalloc.

    Memory profiling tracks allocations to find memory leaks and
    optimize memory usage.

    Use when:
    - Memory usage grows unexpectedly
    - Investigating memory leaks
    - Optimizing data structure choices
    - Profiling batch operations
    """

    async def test_memory_snapshot_captures_allocations(
        self,
        profiles_dir: pathlib.Path,
    ) -> None:
        """Verify memory profiling captures allocations.

        Arrange: Import memory_snapshot utility
        Act: Allocate memory within profiling context
        Assert: Peak memory usage captured
        """
        from {{ project_slug }}.infrastructure.profiling.memory import memory_snapshot

        # Act - Allocate memory while profiling
        async with memory_snapshot(label="test_alloc") as result:
            data = [bytearray(1024) for _ in range(100)]
            assert len(data) == 100

        # Assert
        assert result.peak_mb > 0
        assert result.label == "test_alloc"

    async def test_memory_comparison(
        self,
        profiles_dir: pathlib.Path,
    ) -> None:
        """Verify memory snapshot comparison.

        Arrange: Take snapshot before allocation
        Act: Allocate memory, take after snapshot, compare
        Assert: Memory diff shows increase
        """
        from {{ project_slug }}.infrastructure.profiling.memory import (
            memory_compare,
            take_snapshot,
        )

        # Arrange - Snapshot before allocation
        before = take_snapshot()

        # Act - Allocate memory
        _data = [bytearray(1024) for _ in range(500)]

        # Take snapshot after allocation
        after = take_snapshot()

        # Compare snapshots
        diff = memory_compare(before, after, top_n=10)

        # Assert - Should show memory increase
        assert diff.added_mb >= 0


@pytest.mark.profiling
@pytest.mark.performance
class TestSqlProfiling:
    """SQL query profiling via SQLAlchemy events.

    SQL profiling tracks query counts, execution times, and query patterns.

    Use when:
    - Investigating N+1 query problems
    - Optimizing database interactions
    - Identifying slow queries
    - Verifying query batching works
    """

    async def test_sql_profile_context_manager(
        self,
        profiles_dir: pathlib.Path,
    ) -> None:
        """Verify SQL profiling captures query metrics.

        Arrange: Mock database engine
        Act: Profile within context
        Assert: Query tracking initialized

        Note: This is a structural test. Real SQL profiling requires
        actual database operations (see integration tests).
        """
        from {{ project_slug }}.infrastructure.profiling.sql import sql_profile

        # Arrange - Mock engine for structural testing
        mock_engine = MagicMock()
        mock_engine.sync_engine = MagicMock()

        try:
            # Act - Profiling context should work without errors
            async with sql_profile(mock_engine, label="test_sql") as result:
                pass

            # Assert - Structure is correct
            assert result.label == "test_sql"
            assert result.total_queries == 0
        except (AttributeError, TypeError):
            # Mock may not support SQLAlchemy event system
            pytest.skip("Mock engine does not support SQLAlchemy events")
