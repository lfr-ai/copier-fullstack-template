@pytest_asyncio.fixture(scope="session")
async def engine() -> AsyncIterator[AsyncEngine]:
    """Create async test database engine with schema isolation.

    Schema Routing and Isolation:
        All tests run in test_schema, isolated from public and other environment schemas.
        The ENVIRONMENT=TEST setting (set at module import time) triggers schema routing
        via the SQLAlchemy pool event listener in session.py, which sets search_path to
        test_schema on every connection. This ensures:
        - Test data never pollutes public schema
        - Tests can run in parallel with dev/staging deployments
        - Schema cleanup is simple: DROP/TRUNCATE test_schema only

    Yields:
        AsyncIterator[AsyncEngine]: Configured async engine with tables created in test_schema.

    Raises:
        pytest.skip: When no database URL is configured or test_schema does not exist.
    """
    if not TEST_DATABASE_URL:
        pytest.skip("No database URL configured for this template variant")

    eng = create_async_engine(TEST_DATABASE_URL, echo=False)

{%- if database_backend in ('postgresql', 'azure_postgresql') %}
    # Verify test_schema exists before running tests
    async with eng.begin() as conn:
        result = await conn.execute(
            text(
                """
                SELECT schema_name
                FROM information_schema.schemata
                WHERE schema_name = 'test_schema'
                """
            )
        )
        if result.scalar() is None:
            await eng.dispose()
            pytest.skip(
                "test_schema does not exist. Run 'alembic upgrade head' to create it."
            )
{%- endif %}

    # Create all tables in the active schema (test_schema for TEST environment)
    async with eng.begin() as conn:
        await conn.run_sync(ORMBase.metadata.create_all)

    yield eng

    # Drop all tables from test_schema after test session
    async with eng.begin() as conn:
        await conn.run_sync(ORMBase.metadata.drop_all)
    await eng.dispose()


@pytest_asyncio.fixture
async def session(engine: AsyncEngine) -> AsyncIterator[AsyncSession]:
    """Create async test database session with rollback.

    Args:
        engine (AsyncEngine): Test database engine.

    Yields:
        Async session rolled back after each test.
    """
    factory = async_sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)
    async with factory() as sess:
        yield sess
        await sess.rollback()


{%- if database_backend in ('postgresql', 'azure_postgresql') %}
@pytest_asyncio.fixture(scope="session")
async def clean_test_schema(engine: AsyncEngine) -> AsyncIterator[None]:
    """Optional fixture to clean test_schema between test sessions.

    This fixture truncates all tables in test_schema after the test session completes,
    ensuring a clean slate for the next test run. Useful when you need to inspect
    test data manually or when running tests repeatedly without recreating the schema.

    Usage:
        Add to your test function or class to enable cleanup:
        ```python
        @pytest.mark.usefixtures("clean_test_schema")
        class TestSomething:
            ...
        ```

    Args:
        engine (AsyncEngine): Test database engine.

    Yields:
        None
    """
    yield

    # Truncate all tables in test_schema after test session
    async with engine.begin() as conn:
        # Get all table names in test_schema
        result = await conn.execute(
            text(
                """
                SELECT tablename
                FROM pg_tables
                WHERE schemaname = 'test_schema'
                """
            )
        )
        tables = [row[0] for row in result.fetchall()]

        # Truncate each table (CASCADE to handle foreign keys)
        for table in tables:
            await conn.execute(
                text(f'TRUNCATE TABLE test_schema."{table}" RESTART IDENTITY CASCADE')
            )
{%- endif %}


