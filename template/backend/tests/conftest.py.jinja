@pytest.fixture(scope="session")
def event_loop_policy() -> asyncio.AbstractEventLoopPolicy:
    """Provide event loop policy for test session.

    Returns:
        asyncio.AbstractEventLoopPolicy: Event loop policy for current platform.
    """
    if sys.platform == "win32":
        return asyncio.WindowsSelectorEventLoopPolicy()
    return asyncio.get_event_loop_policy()


@pytest_asyncio.fixture(scope="session")
async def engine() -> AsyncIterator[AsyncEngine]:
    """Create async test database engine.

    Yields:
        AsyncIterator[AsyncEngine]: Configured async engine with tables created.
    """
    if not TEST_DATABASE_URL:
        pytest.skip("No database URL configured for this template variant")
    eng = create_async_engine(TEST_DATABASE_URL, echo=False)
    async with eng.begin() as conn:
        await conn.run_sync(ORMBase.metadata.create_all)
    yield eng
    async with eng.begin() as conn:
        await conn.run_sync(ORMBase.metadata.drop_all)
    await eng.dispose()


@pytest_asyncio.fixture
async def session(engine: AsyncEngine) -> AsyncIterator[AsyncSession]:
    """Create async test database session with rollback.

    Args:
        engine (AsyncEngine): Test database engine.

    Yields:
        Async session rolled back after each test.
    """
    factory = async_sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)
    async with factory() as sess:
        yield sess
        await sess.rollback()


