"""Unit tests for user API routes."""

from __future__ import annotations

import pytest
from httpx import ASGITransport, AsyncClient

from {{ project_slug }}.presentation.api.app import create_api_app

pytestmark = pytest.mark.asyncio

API_PREFIX = "/api/v1"


class TestUserRoutes:
    """Test suite for user management routes."""

    async def test_create_user_returns_201(self) -> None:
        """Verify POST /users returns 201 with user data."""
        app = create_api_app()
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url="http://test") as ac:
            response = await ac.post(
                f"{API_PREFIX}/users",
                json={"email": "route-test@example.com", "display_name": "Route Test"},
            )
        assert response.status_code == 201
        data = response.json()
        assert data["email"] == "route-test@example.com"
        assert data["display_name"] == "Route Test"
        assert data["is_active"] is True

    async def test_get_user_returns_404_for_missing(self) -> None:
        """Verify GET /users/<id> returns 404 for nonexistent user."""
        app = create_api_app()
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url="http://test") as ac:
            response = await ac.get(f"{API_PREFIX}/users/99999")
        assert response.status_code == 404

    async def test_create_then_get_user(self) -> None:
        """Verify created user can be retrieved."""
        app = create_api_app()
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url="http://test") as ac:
            create_resp = await ac.post(
                f"{API_PREFIX}/users",
                json={"email": "created@example.com", "display_name": "Created"},
            )
            user_id = create_resp.json()["id"]
            get_resp = await ac.get(f"{API_PREFIX}/users/{user_id}")
        assert get_resp.status_code == 200
        assert get_resp.json()["email"] == "created@example.com"

    async def test_create_user_invalid_payload(self) -> None:
        """Verify POST /users returns 422 for invalid payload."""
        app = create_api_app()
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url="http://test") as ac:
            response = await ac.post(f"{API_PREFIX}/users", json={})
        assert response.status_code == 422
