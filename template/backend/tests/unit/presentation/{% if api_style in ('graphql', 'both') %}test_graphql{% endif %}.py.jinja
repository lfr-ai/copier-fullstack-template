        assert "errors" in data

    async def test_graphql_ide_available_in_debug(self) -> None:
        """Verify GraphiQL IDE is accessible in debug mode."""
        app = create_api_app(debug=True)
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url="http://test") as ac:
            response = await ac.get(GRAPHQL_URL, headers={"Accept": "text/html"})
        assert response.status_code == 200

    async def test_introspection_works(self) -> None:
        """Verify schema introspection is functional."""
        app = create_api_app(debug=True)
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url="http://test") as ac:
            response = await ac.post(
                GRAPHQL_URL,
                json={
                    "query": """
                        query IntrospectionQuery {
                            __schema {
                                queryType { name }
                                mutationType { name }
                                types { name }
                            }
                        }
                    """
                },
            )
        assert response.status_code == 200
        schema = response.json()["data"]["__schema"]
        assert schema["queryType"]["name"] == "Query"
        assert schema["mutationType"]["name"] == "Mutation"


class TestGraphQLSchemaTypes:
    """Test suite for GraphQL type validation."""

    async def test_user_type_fields(self) -> None:
        """Verify UserType fields match the schema definition."""
        app = create_api_app(debug=True)
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url="http://test") as ac:
            response = await ac.post(
                GRAPHQL_URL,
                json={
                    "query": """
                        query {
                            __type(name: "UserType") {
                                fields {
                                    name
                                    type { name kind }
                                }
                            }
                        }
                    """
                },
            )
        assert response.status_code == 200
        fields = response.json()["data"]["__type"]["fields"]
        field_names = {f["name"] for f in fields}
        assert {"id", "email", "displayName", "isActive"} <= field_names


class TestQueryDepthLimiter:
    """Test suite for query depth limiting."""

    async def test_shallow_query_succeeds(self) -> None:
        """Verify queries within the max depth limit succeed."""
        app = create_api_app(debug=True)
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url="http://test") as ac:
            response = await ac.post(
                GRAPHQL_URL,
                json={
                    "query": """
                        query { health { status version } }
                    """
                },
            )
        assert response.status_code == 200
        assert "errors" not in response.json()

    async def test_excessively_deep_query_rejected(self) -> None:
        """Verify queries exceeding max depth limit are rejected."""
        from {{ project_slug }}.presentation.graphql.schema import create_schema

        schema = create_schema(max_depth=2)
        result = await schema.execute(
            """
            query {
                health {
                    dependencies {
                        name
                    }
                }
            }
            """
        )
        assert result.errors
        assert any("depth" in str(e).lower() for e in result.errors)


class TestProductionErrorMasking:
    """Test suite for production error masking in GraphQL router."""

    async def test_debug_mode_shows_error_details(self) -> None:
        """Verify debug mode does not mask error messages."""
        app = create_api_app(debug=True)
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url="http://test") as ac:
            response = await ac.post(
                GRAPHQL_URL,
                json={"query": "{ nonExistent }"},
            )
        data = response.json()
        assert "errors" in data
        assert data["errors"][0]["message"] != "Internal server error"

    async def test_non_debug_mode_masks_internal_errors(self) -> None:
        """Verify non-debug mode masks internal error details."""
        app = create_api_app(debug=False)
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url="http://test") as ac:
            response = await ac.post(
                GRAPHQL_URL,
                json={"query": "{ nonExistent }"},
            )
        # Validation errors are always shown; internal exceptions are masked.
        # This test verifies the endpoint is functional in non-debug mode.
        assert response.status_code == 200
