"""Unit tests for FastAPI application factory."""

from __future__ import annotations

import pytest
from httpx import ASGITransport, AsyncClient

from {{ project_slug }}.presentation.api.app import create_api_app

pytestmark = pytest.mark.asyncio


class TestCreateApiApp:
    """Test suite for create_api_app factory function."""

    def test_returns_fastapi_instance(self) -> None:
        """Verify factory returns a FastAPI application."""
        from fastapi import FastAPI

        app = create_api_app()
        assert isinstance(app, FastAPI)

    def test_debug_mode(self) -> None:
        """Verify debug flag is passed through."""
        app = create_api_app(debug=True)
        assert app.debug is True

    def test_non_debug_mode(self) -> None:
        """Verify non-debug mode."""
        app = create_api_app(debug=False)
        assert app.debug is False
{%- if api_style in ('rest', 'both') %}

    def test_openapi_url_configured(self) -> None:
        """Verify OpenAPI URL is set."""
        app = create_api_app()
        assert app.openapi_url == "/api/openapi.json"
{%- endif %}
{%- if api_style == 'graphql' %}

    def test_openapi_disabled_in_graphql_only(self) -> None:
        """Verify OpenAPI is disabled in graphql-only mode."""
        app = create_api_app()
        assert app.openapi_url is None
{%- endif %}

    async def test_cors_headers_present(self) -> None:
        """Verify CORS middleware is active."""
        app = create_api_app()
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url="http://test") as ac:
            response = await ac.options(
                "/health",
                headers={
                    "Origin": "http://localhost:3000",
                    "Access-Control-Request-Method": "GET",
                },
            )
        assert "access-control-allow-origin" in response.headers


class TestErrorHandlers:
    """Test suite for registered error handlers."""

    async def test_nonexistent_route_returns_404_or_405(self) -> None:
        """Verify unmatched route returns 404 or 405."""
        app = create_api_app()
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url="http://test") as ac:
            response = await ac.get("/does-not-exist")
        assert response.status_code in (404, 405)
