"""Unit tests for rate limiting middleware configuration."""

from __future__ import annotations

from unittest.mock import MagicMock


from {{ project_slug }}.presentation.api.middleware.rate_limit import (
    configure_rate_limiting,
)

class TestRateLimitConfiguration:
    """Test suite for rate limiting module-level config."""

    def test_configure_sets_app_state_limiter(self) -> None:
        """Verify configure_rate_limiting sets app.state.limiter."""
        mock_app = MagicMock()
        mock_app.state = MagicMock()
        mock_app.state.settings = MagicMock()
        mock_app.state.settings.rate_limit = "60/minute"
        configure_rate_limiting(mock_app)
        assert mock_app.state.limiter is not None

    def test_configure_adds_exception_handler(self) -> None:
        """Verify configure_rate_limiting registers exception handler."""
        mock_app = MagicMock()
        mock_app.state = MagicMock()
        mock_app.state.settings = MagicMock()
        mock_app.state.settings.rate_limit = "60/minute"
        configure_rate_limiting(mock_app)
        mock_app.add_exception_handler.assert_called_once()

    def test_configure_uses_settings_rate_limit(self) -> None:
        """Verify configure_rate_limiting reads rate_limit from settings."""
        mock_app = MagicMock()
        mock_app.state = MagicMock()
        mock_app.state.settings = MagicMock()
        mock_app.state.settings.rate_limit = "100/minute"
        configure_rate_limiting(mock_app)
        limiter = mock_app.state.limiter
        assert limiter is not None
