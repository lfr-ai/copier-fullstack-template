"""Unit tests for CrossEncoderReranker."""
{%- if use_rag %}

from __future__ import annotations

from unittest.mock import MagicMock, patch

import pytest

from {{ project_slug }}.core.interfaces.reranker import RankedResult

pytestmark = pytest.mark.asyncio


@pytest.fixture
def mock_cross_encoder() -> None:
    """Patch sentence_transformers.CrossEncoder."""
    with patch(
        "{{ project_slug }}.ai.rag.rerankers.cross_encoder.CrossEncoder",
        autospec=True,
    ) as mock_cls:
        instance = MagicMock()
        instance.predict.return_value = [0.95, 0.30, 0.72]
        mock_cls.return_value = instance
        yield mock_cls


@pytest.fixture
def reranker(mock_cross_encoder) -> None:
    """Create a CrossEncoderReranker with mocked model."""
    from {{ project_slug }}.ai.rag.rerankers.cross_encoder import CrossEncoderReranker

    return CrossEncoderReranker(model_name="cross-encoder/ms-marco-MiniLM-L-6-v2")


@pytest.fixture
def sample_results() -> list[dict[str, object]]:
    return [
        {"id": "doc1", "content": "Python is a programming language.", "score": 0.8},
        {"id": "doc2", "content": "Java is also a language.", "score": 0.6},
        {"id": "doc3", "content": "Python was created by Guido.", "score": 0.7},
    ]


class TestCrossEncoderReranker:
    """Tests for CrossEncoderReranker.rerank."""

    async def test_rerank_returns_sorted_by_score(
        self,
        reranker,
        sample_results: list[dict[str, object]],
    ) -> None:
        results = await reranker.rerank(query="What is Python?", results=sample_results, top_k=3)

        assert len(results) == 3
        assert isinstance(results[0], RankedResult)
        assert results[0].id == "doc1"
        assert results[0].rerank_score == pytest.approx(0.95)
        assert results[1].id == "doc3"
        assert results[2].id == "doc2"

    async def test_rerank_respects_top_k(
        self,
        reranker,
        sample_results: list[dict[str, object]],
    ) -> None:
        results = await reranker.rerank(query="What is Python?", results=sample_results, top_k=2)

        assert len(results) == 2
        assert results[0].id == "doc1"

    async def test_rerank_empty_results(self, reranker) -> None:
        results = await reranker.rerank(query="test", results=[], top_k=5)
        assert results == []

    async def test_rerank_preserves_content(
        self,
        reranker,
        sample_results: list[dict[str, object]],
    ) -> None:
        results = await reranker.rerank(query="test", results=sample_results, top_k=1)
        assert results[0].content == "Python is a programming language."

    async def test_rerank_preserves_original_score(
        self,
        reranker,
        sample_results: list[dict[str, object]],
    ) -> None:
        results = await reranker.rerank(query="test", results=sample_results, top_k=3)
        assert results[0].original_score == pytest.approx(0.8)
