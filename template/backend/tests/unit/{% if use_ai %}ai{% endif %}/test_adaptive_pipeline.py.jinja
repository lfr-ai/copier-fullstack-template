    def test_from_config_minimal(
        self,
        *,
        mock_llm: LLMGateway,
        mock_embedding: EmbeddingGateway,
        mock_vector_store: VectorStoreGateway,
    ) -> None:
        """from_config() should work with minimal required config."""
        config = {
            "llm": mock_llm,
            "embedding": mock_embedding,
            "vector_store": mock_vector_store,
        }

        pipeline = AdaptiveRAGPipeline.from_config(config)

        assert pipeline is not None
        assert pipeline._llm is mock_llm
        assert pipeline._embedding is mock_embedding
        assert pipeline._vector_store is mock_vector_store
        assert pipeline._knowledge_graph is None
        assert pipeline._reranker is None

