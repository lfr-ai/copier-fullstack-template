    @pytest.mark.asyncio
    async def test_routes_to_self_crag_when_use_graph_false(
        self,
        *,
        pipeline_minimal: AdaptiveRAGPipeline,
    ) -> None:
        """query() should route to Self-CRAG when use_graph=False."""
        # Mock the Self-CRAG pipeline
        mock_self_crag = AsyncMock()
        mock_self_crag.query = AsyncMock(
            return_value=RetrievalResult(
                query="Test question",
                answer="Self-CRAG answer",
                sources=[
                    VectorSearchResult(
                        id="doc1",
                        score=0.95,
                        metadata={"content": "Test content"},
                    )
                ],
                graph_context=[],
            )
        )

        with patch.object(
            AdaptiveRAGPipeline,
            "_get_self_crag_pipeline",
            return_value=mock_self_crag,
        ):
            result = await pipeline_minimal.query(
                "Test question",
                use_graph=False,
            )

        assert result.answer == "Self-CRAG answer"
        mock_self_crag.query.assert_called_once()

    @pytest.mark.asyncio
    async def test_routes_to_deeprag_when_use_graph_true(
        self,
