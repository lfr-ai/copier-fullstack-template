        assert is_hallucinated is False
        assert corrected == "Test answer"

    @pytest.mark.asyncio
    async def test_rerank_skipped_when_no_reranker(
        self,
        *,
        pipeline_minimal: AdaptiveRAGPipeline,
    ) -> None:
        """_rerank_if_available() should return original results when no reranker."""
        results = [
            VectorSearchResult(id="doc1", score=0.9, metadata={"content": "Test"}),
            VectorSearchResult(id="doc2", score=0.8, metadata={"content": "Test2"}),
        ]

        reranked = await pipeline_minimal._rerank_if_available(
            query="Test",
            results=results,
            top_k=1,
        )

        # Should return top_k results without reranking
        assert len(reranked) == 1
        assert reranked[0].id == "doc1"
        assert reranked[0].score == 0.9

    @pytest.mark.asyncio
    async def test_rerank_applied_when_reranker_available(
        self,
        *,
        pipeline_with_reranker: AdaptiveRAGPipeline,
        mock_reranker: RerankerGateway,
    ) -> None:
        """_rerank_if_available() should apply reranker when available."""
        results = [
            VectorSearchResult(id="doc1", score=0.9, metadata={"content": "Test"}),
        ]

        reranked = await pipeline_with_reranker._rerank_if_available(
            query="Test",
            results=results,
            top_k=1,
        )

        mock_reranker.rerank.assert_called_once()
        assert len(reranked) == 1
        assert reranked[0].score == 0.98  # Reranked score

    @pytest.mark.asyncio
    async def test_rerank_failure_gracefully_handled(
        self,
        *,
        pipeline_with_reranker: AdaptiveRAGPipeline,
        mock_reranker: RerankerGateway,
        caplog: pytest.LogCaptureFixture,
    ) -> None:
        """_rerank_if_available() should handle reranker errors gracefully."""
        # Make reranker fail
        mock_reranker.rerank = AsyncMock(side_effect=RuntimeError("Reranker failed"))

        results = [
            VectorSearchResult(id="doc1", score=0.9, metadata={"content": "Test"}),
        ]

        reranked = await pipeline_with_reranker._rerank_if_available(
            query="Test",
            results=results,
            top_k=1,
        )

        # Should return original results on error
        assert len(reranked) == 1
        assert reranked[0].score == 0.9

