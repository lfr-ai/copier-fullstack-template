    @pytest.mark.asyncio
    async def test_combined_strategy_merges_candidates(
        self,
        *,
        pipeline_with_kg: AdaptiveRAGPipeline,
    ) -> None:
        """combined strategy should merge answers and sources from multiple pipelines."""
        mock_self_crag = AsyncMock()
        mock_self_crag.query = AsyncMock(
            return_value=RetrievalResult(
                query="Test question",
                answer="Self answer",
                sources=[
                    VectorSearchResult(
                        id="doc-self",
                        score=0.80,
                        metadata={"content": "Self source"},
                    )
                ],
                graph_context=[],
            )
        )
        mock_deeprag = AsyncMock()
        mock_deeprag.query = AsyncMock(
            return_value=RetrievalResult(
                query="Test question",
                answer="Deep answer",
                sources=[
                    VectorSearchResult(
                        id="doc-deep",
                        score=0.90,
                        metadata={"content": "Deep source"},
                    )
                ],
                graph_context=[{"provider": "deep_rag"}],
            )
        )

        with (
            patch.object(
                AdaptiveRAGPipeline,
                "_get_self_crag_pipeline",
                return_value=mock_self_crag,
            ),
            patch.object(
                AdaptiveRAGPipeline,
                "_get_deep_rag_pipeline",
                return_value=mock_deeprag,
            ),
            patch.object(
                AdaptiveRAGPipeline,
                "_synthesize_combined_answer",
                new=AsyncMock(return_value="Combined answer"),
            ),
        ):
            result = await pipeline_with_kg.query(
                "Test question",
                strategy="combined",
                combine_strategies=True,
            )

        assert result.answer == "Combined answer"
        assert {source.id for source in result.sources} == {"doc-self", "doc-deep"}

