"""Unit tests for AI tools -- calculator, web search, database query."""
{%- if use_ai %}

from __future__ import annotations

import pytest

from {{ project_slug }}.ai.tools.base_tool import ToolResult
from {{ project_slug }}.ai.tools.calculator import CalculatorTool


class TestCalculatorTool:
    """Tests for CalculatorTool."""

    @pytest.fixture
    def calculator(self) -> CalculatorTool:
        return CalculatorTool()

    async def test_basic_addition(self, calculator: CalculatorTool) -> None:
        result = await calculator.execute(expression="2 + 3")
        assert result.content == "5.0"
        assert not result.is_error

    async def test_complex_expression(self, calculator: CalculatorTool) -> None:
        result = await calculator.execute(expression="2 + 3 * 4")
        assert result.content == "14.0"

    async def test_division(self, calculator: CalculatorTool) -> None:
        result = await calculator.execute(expression="10 / 3")
        assert float(result.content) == pytest.approx(3.333, rel=1e-2)

    async def test_power(self, calculator: CalculatorTool) -> None:
        result = await calculator.execute(expression="2 ** 8")
        assert result.content == "256.0"

    async def test_division_by_zero(self, calculator: CalculatorTool) -> None:
        result = await calculator.execute(expression="1 / 0")
        assert result.is_error
        assert "Calculation error" in result.error

    async def test_invalid_expression(self, calculator: CalculatorTool) -> None:
        result = await calculator.execute(expression="import os")
        assert result.is_error

    async def test_empty_expression(self, calculator: CalculatorTool) -> None:
        result = await calculator.execute(expression="")
        assert result.is_error
        assert "required" in result.error.lower()

    async def test_exponent_too_large(self, calculator: CalculatorTool) -> None:
        result = await calculator.execute(expression="2 ** 200")
        assert result.is_error
        assert "too large" in result.error.lower()

    def test_tool_metadata(self, calculator: CalculatorTool) -> None:
        assert calculator.name == "calculator"
        assert "mathematical" in calculator.description.lower()
        schema = calculator.parameters_schema
        assert schema["type"] == "object"
        assert "expression" in schema["properties"]


class TestToolResult:
    """Tests for ToolResult."""

    def test_default_result(self) -> None:
        result = ToolResult()
        assert result.content == ""
        assert result.error is None
        assert not result.is_error
        assert result.metadata == {}

    def test_error_result(self) -> None:
        result = ToolResult(error="Something went wrong")
        assert result.is_error
        assert result.error == "Something went wrong"

    def test_success_result(self) -> None:
        result = ToolResult(content="42", metadata={"key": "value"})
        assert not result.is_error
        assert result.content == "42"
        assert result.metadata["key"] == "value"
{%- endif %}
