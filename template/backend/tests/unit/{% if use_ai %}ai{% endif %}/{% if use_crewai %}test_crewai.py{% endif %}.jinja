class TestFlowRunner:
"""Tests for the CrewAI Flow runner utility."""

@pytest.mark.asyncio
async def test_flow_runner_executes_flow(self) -> None:
"""FlowRunner should call kickoff_async on the flow instance."""
from {{ project_slug }}.ai.crewai.flows import FlowRunner

mock_flow_instance = MagicMock()
mock_flow_instance.kickoff_async = AsyncMock(return_value="flow-result")
mock_flow_instance.state = {"key": "value"}

mock_flow_class = MagicMock(return_value=mock_flow_instance)

runner = FlowRunner(mock_flow_class)
result = await runner.run()
assert result.result == "flow-result"
assert result.error is None
assert result.state == {"key": "value"}
mock_flow_instance.kickoff_async.assert_awaited_once()

@pytest.mark.asyncio
async def test_flow_runner_captures_errors(self) -> None:
"""FlowRunner should capture exceptions as error strings."""
from {{ project_slug }}.ai.crewai.flows import FlowRunner

mock_flow_instance = MagicMock()
mock_flow_instance.kickoff_async = AsyncMock(side_effect=RuntimeError("boom"))
mock_flow_class = MagicMock(return_value=mock_flow_instance)

runner = FlowRunner(mock_flow_class)
result = await runner.run()
assert result.error == "boom"
assert result.result is None

def test_flow_runner_sync_execution(self) -> None:
"""FlowRunner.run_sync should call kickoff on the flow."""
from {{ project_slug }}.ai.crewai.flows import FlowRunner

mock_flow_instance = MagicMock()
mock_flow_instance.kickoff.return_value = "sync-result"
mock_flow_instance.state = None
mock_flow_class = MagicMock(return_value=mock_flow_instance)

runner = FlowRunner(mock_flow_class)
result = runner.run_sync()
assert result.result == "sync-result"
assert result.error is None


