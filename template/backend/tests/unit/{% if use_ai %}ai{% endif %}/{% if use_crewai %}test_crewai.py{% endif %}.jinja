class TestCrewAIService:
"""Tests for the CrewAI application service."""

@pytest.mark.asyncio
async def test_list_crew_templates(self) -> None:
"""Service should list all available crew templates."""
from {{ project_slug }}.application.services.crewai_service import CrewAIService

uow = MagicMock()
service = CrewAIService(uow=uow)
templates = await service.list_crew_templates()
assert len(templates) == 4
names = {t["name"] for t in templates}
assert names == {"research", "analysis", "content", "planning"}

@pytest.mark.asyncio
async def test_execute_crew_unknown_type(self) -> None:
"""Service should raise ValueError for unknown crew types."""
from {{ project_slug }}.application.services.crewai_service import CrewAIService

uow = MagicMock()
service = CrewAIService(uow=uow)
with pytest.raises(ValueError, match="Unknown crew type"):
await service.execute_crew("nonexistent", "test task")

@pytest.mark.asyncio
async def test_orchestrate_without_supervisor(self) -> None:
"""Service should raise RuntimeError when no supervisor configured."""
from {{ project_slug }}.application.services.crewai_service import CrewAIService

uow = MagicMock()
service = CrewAIService(uow=uow, supervisor=None)
with pytest.raises(RuntimeError, match="HMAS supervisor not configured"):
await service.orchestrate("test goal")

@pytest.mark.asyncio
async def test_orchestrate_delegates_to_supervisor(self) -> None:
"""Service should delegate to HMAS supervisor."""
from {{ project_slug }}.application.services.crewai_service import CrewAIService

uow = MagicMock()
supervisor = MagicMock()
supervisor.orchestrate = AsyncMock(return_value="orchestrated result")

service = CrewAIService(uow=uow, supervisor=supervisor)
result = await service.orchestrate("test goal")
assert result["goal"] == "test goal"
assert result["result"] == "orchestrated result"
supervisor.orchestrate.assert_awaited_once_with("test goal")

@pytest.mark.asyncio
async def test_execute_flow_without_registry(self) -> None:
"""Service should raise RuntimeError when no flow registry configured."""
from {{ project_slug }}.application.services.crewai_service import CrewAIService

uow = MagicMock()
service = CrewAIService(uow=uow, flow_registry=None)
with pytest.raises(RuntimeError, match="Flow registry not configured"):
await service.execute_flow("test_flow")


