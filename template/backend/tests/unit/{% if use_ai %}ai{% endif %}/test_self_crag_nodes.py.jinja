@pytest.mark.unit
class TestInitialRetrieveNode:
    """Tests for initial_retrieve_node."""

    @pytest.mark.asyncio
    async def test_retrieves_documents_for_query(
        self,
        mock_retriever: AsyncMock,
    ) -> None:
        """Initial retrieve should call retriever and return docs."""
        state: SelfCRAGState = {
            "query": "What is Python?",
            "original_query": "",
            "docs": [],
            "scores": [],
            "cycle_count": 0,
            "answer": "",
        }

        result = await initial_retrieve_node(state, retriever=mock_retriever)

        assert len(result["docs"]) == 2
        assert result["docs"][0].content == "document 1"
        assert result["docs"][1].content == "document 2"
        assert result["original_query"] == "What is Python?"
        assert result["cycle_count"] == 0
        mock_retriever.retrieve.assert_awaited_once_with(query="What is Python?")

    @pytest.mark.asyncio
    async def test_initializes_cycle_count(
        self,
        mock_retriever: AsyncMock,
    ) -> None:
        """Initial retrieve should set cycle_count to 0."""
        state: SelfCRAGState = {
            "query": "test query",
            "original_query": "",
            "docs": [],
            "scores": [],
            "cycle_count": 0,
            "answer": "",
        }

        result = await initial_retrieve_node(state, retriever=mock_retriever)

        assert result["cycle_count"] == 0

    @pytest.mark.asyncio
    async def test_preserves_original_query(
        self,
        mock_retriever: AsyncMock,
    ) -> None:
        """Initial retrieve should store original query for fallback."""
        state: SelfCRAGState = {
            "query": "original question",
            "original_query": "",
            "docs": [],
            "scores": [],
            "cycle_count": 0,
            "answer": "",
        }

        result = await initial_retrieve_node(state, retriever=mock_retriever)

        assert result["original_query"] == "original question"


@pytest.mark.unit
class TestGradeDocumentsNode:
    """Tests for grade_documents_node."""

    @pytest.mark.asyncio
    async def test_grades_all_documents(
        self,
        mock_llm: AsyncMock,
    ) -> None:
        """Grade documents should call LLM for each document."""
        mock_llm.complete.side_effect = ["0.8", "0.6"]
        state: SelfCRAGState = {
            "query": "What is Python?",
            "original_query": "What is Python?",
            "docs": [
                RetrievedContext(content="Python is a language", source="doc1.txt"),
                RetrievedContext(content="Unrelated content", source="doc2.txt"),
            ],
            "scores": [],
            "cycle_count": 0,
            "answer": "",
        }

        result = await grade_documents_node(state, llm=mock_llm)

        assert len(result["scores"]) == 2
        assert result["scores"][0] == 0.8
        assert result["scores"][1] == 0.6
        assert mock_llm.complete.call_count == 2

    @pytest.mark.asyncio
    async def test_handles_unparsable_scores(
        self,
        mock_llm: AsyncMock,
    ) -> None:
        """Grade documents should assign 0.0 for invalid scores."""
        mock_llm.complete.side_effect = ["invalid_score", "0.7"]
        state: SelfCRAGState = {
            "query": "test query",
            "original_query": "test query",
            "docs": [
                RetrievedContext(content="doc 1", source="doc1.txt"),
                RetrievedContext(content="doc 2", source="doc2.txt"),
            ],
            "scores": [],
            "cycle_count": 0,
            "answer": "",
        }

        result = await grade_documents_node(state, llm=mock_llm)

        assert result["scores"][0] == 0.0
        assert result["scores"][1] == 0.7

    @pytest.mark.asyncio
    async def test_clamps_scores_to_valid_range(
        self,
        mock_llm: AsyncMock,
    ) -> None:
        """Grade documents should clamp scores to [0.0, 1.0]."""
        mock_llm.complete.side_effect = ["1.5", "-0.2"]
        state: SelfCRAGState = {
            "query": "test query",
            "original_query": "test query",
            "docs": [
                RetrievedContext(content="doc 1", source="doc1.txt"),
                RetrievedContext(content="doc 2", source="doc2.txt"),
            ],
            "scores": [],
            "cycle_count": 0,
            "answer": "",
        }

        result = await grade_documents_node(state, llm=mock_llm)

        assert result["scores"][0] == 1.0
        assert result["scores"][1] == 0.0

    @pytest.mark.asyncio
    async def test_uses_zero_temperature(
        self,
        mock_llm: AsyncMock,
    ) -> None:
        """Grade documents should use temperature=0.0 for deterministic grading."""
        state: SelfCRAGState = {
            "query": "test query",
            "original_query": "test query",
            "docs": [
                RetrievedContext(content="doc 1", source="doc1.txt"),
            ],
            "scores": [],
            "cycle_count": 0,
            "answer": "",
        }

        await grade_documents_node(state, llm=mock_llm)

        # Check that temperature=0.0 was used in the call
        call_kwargs = mock_llm.complete.call_args.kwargs
        assert call_kwargs["temperature"] == 0.0


