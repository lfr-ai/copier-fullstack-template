@pytest.mark.unit
class TestGenerateAnswerNode:
    """Tests for generate_answer_node."""

    @pytest.mark.asyncio
    async def test_generates_answer_from_documents(
        self,
        mock_llm: AsyncMock,
    ) -> None:
        """Generate answer should format context and call LLM."""
        mock_llm.complete.return_value = "Python is a high-level programming language."
        state: SelfCRAGState = {
            "query": "What is Python?",
            "original_query": "What is Python?",
            "docs": [
                RetrievedContext(content="Python is a language", source="doc1.txt"),
            ],
            "scores": [0.9],
            "cycle_count": 0,
            "answer": "",
        }

        result = await generate_answer_node(state, llm=mock_llm)

        assert result["answer"] == "Python is a high-level programming language."
        mock_llm.complete.assert_awaited_once()

    @pytest.mark.asyncio
    async def test_includes_scores_in_context(
        self,
        mock_llm: AsyncMock,
    ) -> None:
        """Generate answer should include relevance scores in formatted context."""
        state: SelfCRAGState = {
            "query": "test query",
            "original_query": "test query",
            "docs": [
                RetrievedContext(content="doc 1", source="doc1.txt"),
                RetrievedContext(content="doc 2", source="doc2.txt"),
            ],
            "scores": [0.8, 0.6],
            "cycle_count": 0,
            "answer": "",
        }

        await generate_answer_node(state, llm=mock_llm)

        # Check that the prompt includes scores
        call_args = mock_llm.complete.call_args
        prompt = call_args.kwargs["prompt"]
        assert "relevance=0.80" in prompt
        assert "relevance=0.60" in prompt

    @pytest.mark.asyncio
    async def test_handles_missing_scores(
        self,
        mock_llm: AsyncMock,
    ) -> None:
        """Generate answer should handle missing scores gracefully."""
        state: SelfCRAGState = {
            "query": "test query",
            "original_query": "test query",
            "docs": [
                RetrievedContext(content="doc 1", source="doc1.txt"),
            ],
            "scores": [],
            "cycle_count": 0,
            "answer": "",
        }

        result = await generate_answer_node(state, llm=mock_llm)

        assert "answer" in result
        mock_llm.complete.assert_awaited_once()


@pytest.mark.unit
class TestRouteAfterGrading:
    """Tests for route_after_grading routing function."""

    def test_routes_to_rewrite_when_low_relevance(self) -> None:
        """Should route to rewrite_query when relevance is below threshold."""
        state: SelfCRAGState = {
            "query": "test query",
            "original_query": "test query",
            "docs": [],
            "scores": [0.3, 0.4],  # Overall = 0.35 < 0.6
            "cycle_count": 0,
            "answer": "",
        }

        route = route_after_grading(state)

        assert route == "rewrite_query"

    def test_routes_to_generate_when_high_relevance(self) -> None:
        """Should route to generate_answer when relevance is above threshold."""
        state: SelfCRAGState = {
            "query": "test query",
            "original_query": "test query",
            "docs": [],
            "scores": [0.8, 0.9],  # Overall = 0.85 > 0.6
            "cycle_count": 0,
            "answer": "",
        }

        route = route_after_grading(state)

        assert route == "generate_answer"

    def test_routes_to_generate_when_max_rewrites_reached(self) -> None:
        """Should route to generate_answer when max rewrites exhausted."""
        state: SelfCRAGState = {
            "query": "test query",
            "original_query": "test query",
            "docs": [],
            "scores": [0.3, 0.4],  # Low relevance
            "cycle_count": MAX_QUERY_REWRITES,  # Max rewrites reached
            "answer": "",
        }

        route = route_after_grading(state)

        assert route == "generate_answer"

    def test_routes_to_rewrite_when_under_limit(self) -> None:
        """Should route to rewrite_query when under rewrite limit."""
        state: SelfCRAGState = {
            "query": "test query",
            "original_query": "test query",
            "docs": [],
            "scores": [0.3, 0.4],  # Low relevance
            "cycle_count": MAX_QUERY_REWRITES - 1,  # Under limit
            "answer": "",
        }

        route = route_after_grading(state)

        assert route == "rewrite_query"

    def test_handles_empty_scores(self) -> None:
        """Should handle empty scores by routing to generate_answer."""
        state: SelfCRAGState = {
            "query": "test query",
            "original_query": "test query",
            "docs": [],
            "scores": [],
            "cycle_count": 0,
            "answer": "",
        }

        route = route_after_grading(state)

        # Empty scores = 0.0 overall relevance, should rewrite
        assert route == "rewrite_query"

    def test_boundary_case_exactly_at_threshold(self) -> None:
        """Should route to generate_answer when exactly at threshold."""
        state: SelfCRAGState = {
            "query": "test query",
            "original_query": "test query",
            "docs": [],
            "scores": [RELEVANCE_THRESHOLD],  # Exactly at threshold
            "cycle_count": 0,
            "answer": "",
        }

        route = route_after_grading(state)

        assert route == "generate_answer"
