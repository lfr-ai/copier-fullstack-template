class TestIngestionPipeline:
    """Tests for the ingestion pipeline."""

    @pytest.mark.asyncio
    async def test_ingest_processes_documents(
        self,
        mock_loader: AsyncMock,
        mock_splitter: MagicMock,
        mock_embedding: AsyncMock,
        mock_vector_store: AsyncMock,
    ) -> None:
        """Ingestion should load, split, embed, and store."""
        pipeline = IngestionPipeline(
            loader=mock_loader,
            splitter=mock_splitter,
            embedding=mock_embedding,
            vector_store=mock_vector_store,
        )

        chunks = await pipeline.ingest("test.txt")

        assert len(chunks) == 2
        mock_loader.load.assert_awaited_once_with("test.txt")
        mock_splitter.split.assert_called_once()
        mock_embedding.embed_texts.assert_awaited_once()
        mock_vector_store.add_vectors.assert_awaited_once()

    @pytest.mark.asyncio
    async def test_ingest_stores_embeddings_on_chunks(
        self,
        mock_loader: AsyncMock,
        mock_splitter: MagicMock,
        mock_embedding: AsyncMock,
        mock_vector_store: AsyncMock,
    ) -> None:
        """Chunks should receive their embedding vectors."""
        pipeline = IngestionPipeline(
            loader=mock_loader,
            splitter=mock_splitter,
            embedding=mock_embedding,
            vector_store=mock_vector_store,
        )

        chunks = await pipeline.ingest("test.txt")

        assert chunks[0].embedding == [0.1] * 8
        assert chunks[1].embedding == [0.2] * 8


class TestDeepRAGPipeline:
    """Tests for the DeepRAG pipeline."""

    @pytest.mark.asyncio
    async def test_pipeline_initializes_from_config(
        self,
        mock_llm: AsyncMock,
    ) -> None:
        """DeepRAGPipeline.from_config should create a working instance."""
        mock_retriever = AsyncMock()

        pipeline = DeepRAGPipeline.from_config({
            "llm": mock_llm,
            "retriever": mock_retriever,
        })

        assert pipeline is not None

    @pytest.mark.asyncio
    async def test_from_config_requires_llm(self) -> None:
        """from_config should raise ValueError when llm is missing."""
        mock_retriever = AsyncMock()

        with pytest.raises(ValueError, match="llm is required"):
            DeepRAGPipeline.from_config({"retriever": mock_retriever})

    @pytest.mark.asyncio
    async def test_from_config_requires_retriever(
        self,
        mock_llm: AsyncMock,
    ) -> None:
        """from_config should raise ValueError when retriever is missing."""
        with pytest.raises(ValueError, match="retriever is required"):
            DeepRAGPipeline.from_config({"llm": mock_llm})
