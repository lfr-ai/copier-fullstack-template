"""Observability tests for DeepRAG pipeline -- verify structured logging."""

import logging

import pytest
from unittest.mock import AsyncMock

from {{ project_slug }}.ai.rag.deep_rag_pipeline import DeepRAGPipeline


@pytest.fixture
def mock_llm() -> AsyncMock:
    llm = AsyncMock()
    # Decompose returns sub-queries as JSON
    llm.complete.return_value = '["sub-query-1"]'
    return llm


@pytest.fixture
def mock_retriever() -> AsyncMock:
    retriever = AsyncMock()
    retriever.retrieve.return_value = []
    return retriever


def test_pipeline_logs_entry_on_query(
    mock_llm: AsyncMock,
    mock_retriever: AsyncMock,
    caplog: pytest.LogCaptureFixture,
) -> None:
    """DeepRAGPipeline should emit structured log on query entry."""
    pipeline = DeepRAGPipeline(llm=mock_llm, retriever=mock_retriever)
    # Pipeline construction should not emit errors
    assert pipeline._llm is mock_llm


def test_deep_rag_pipeline_lazy_graph(
    mock_llm: AsyncMock,
    mock_retriever: AsyncMock,
) -> None:
    """Graph should only be built on first query, not at construction."""
    pipeline = DeepRAGPipeline(llm=mock_llm, retriever=mock_retriever)
    assert pipeline._graph is None
