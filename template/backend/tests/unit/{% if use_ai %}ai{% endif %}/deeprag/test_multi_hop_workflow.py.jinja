"""Unit tests for DeepRAGPipeline -- construction, from_config, and graph build."""

import pytest
from unittest.mock import AsyncMock, MagicMock

from {{ project_slug }}.ai.rag.deep_rag_pipeline import DeepRAGPipeline


class TestDeepRAGPipeline:
    """Test DeepRAGPipeline construction and factory methods."""

    def test_constructor_requires_llm_and_retriever(self) -> None:
        mock_llm = AsyncMock()
        mock_retriever = AsyncMock()
        pipeline = DeepRAGPipeline(llm=mock_llm, retriever=mock_retriever)
        assert pipeline._llm is mock_llm
        assert pipeline._retriever is mock_retriever

    def test_from_config_creates_pipeline(self) -> None:
        mock_llm = AsyncMock()
        mock_retriever = AsyncMock()
        pipeline = DeepRAGPipeline.from_config({
            "llm": mock_llm,
            "retriever": mock_retriever,
        })
        assert pipeline._llm is mock_llm
        assert pipeline._retriever is mock_retriever

    def test_from_config_missing_llm_raises(self) -> None:
        with pytest.raises(ValueError, match="llm is required"):
            DeepRAGPipeline.from_config({"retriever": AsyncMock()})

    def test_from_config_missing_retriever_raises(self) -> None:
        with pytest.raises(ValueError, match="retriever is required"):
            DeepRAGPipeline.from_config({"llm": AsyncMock()})

    def test_graph_is_lazily_built(self) -> None:
        pipeline = DeepRAGPipeline(llm=AsyncMock(), retriever=AsyncMock())
        assert pipeline._graph is None
