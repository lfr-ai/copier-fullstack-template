"""Unit tests for LLM adapters (LiteLLM-based)."""

from __future__ import annotations

from unittest.mock import AsyncMock, MagicMock, patch

import pytest

from {{ project_slug }}.ai.llm.litellm_adapter import LiteLLMAdapter


@pytest.fixture
def adapter() -> LiteLLMAdapter:
    """Create LiteLLMAdapter for testing."""
    return LiteLLMAdapter(model="gpt-4o-mini", api_key="test-key")


class TestLiteLLMAdapterComplete:
    """Test suite for completion via LiteLLM."""

    @pytest.mark.asyncio
    async def test_complete_returns_content(self, adapter: LiteLLMAdapter) -> None:
        """Verify complete returns the first choice message content."""
        choice = MagicMock()
        choice.message.content = "Hello from GPT"
        response = MagicMock()
        response.choices = [choice]

        with patch("litellm.acompletion", new_callable=AsyncMock, return_value=response):
            result = await adapter.complete(prompt="Say hello")
        assert result == "Hello from GPT"

    @pytest.mark.asyncio
    async def test_complete_sends_prompt_as_user_message(self, adapter: LiteLLMAdapter) -> None:
        """Verify complete passes prompt as a user role message."""
        choice = MagicMock()
        choice.message.content = "ok"
        response = MagicMock()
        response.choices = [choice]

        mock_acompletion = AsyncMock(return_value=response)
        with patch("litellm.acompletion", mock_acompletion):
            await adapter.complete(prompt="test prompt")

        call_kwargs = mock_acompletion.call_args.kwargs
        messages = call_kwargs["messages"]
        assert any(m["role"] == "user" and "test prompt" in m["content"] for m in messages)

    @pytest.mark.asyncio
    async def test_complete_with_system_prompt(self, adapter: LiteLLMAdapter) -> None:
        """Verify system prompt is included in messages."""
        choice = MagicMock()
        choice.message.content = "ok"
        response = MagicMock()
        response.choices = [choice]

        mock_acompletion = AsyncMock(return_value=response)
        with patch("litellm.acompletion", mock_acompletion):
            await adapter.complete(prompt="test", system_prompt="Be concise")

        call_kwargs = mock_acompletion.call_args.kwargs
        messages = call_kwargs["messages"]
        assert messages[0]["role"] == "system"
        assert messages[0]["content"] == "Be concise"


class TestLiteLLMAdapterStream:
    """Test suite for streaming completion via LiteLLM."""

    @pytest.mark.asyncio
    async def test_stream_yields_chunks(self, adapter: LiteLLMAdapter) -> None:
        """Verify stream yields content chunks from the API."""
        chunk1 = MagicMock()
        chunk1.choices = [MagicMock()]
        chunk1.choices[0].delta.content = "Hello"
        chunk2 = MagicMock()
        chunk2.choices = [MagicMock()]
        chunk2.choices[0].delta.content = " world"

        async def mock_stream(**kwargs: object) -> object:  # noqa: ARG001
            for chunk in [chunk1, chunk2]:
                yield chunk

        with patch("litellm.acompletion", side_effect=mock_stream):
            chunks: list[str] = []
            async for text in adapter.stream(prompt="Say hello"):
                chunks.append(text)
        assert chunks == ["Hello", " world"]


class TestLiteLLMAdapterModel:
    """Test model string handling across adapter variants."""

    def test_litellm_adapter_preserves_model_string(self) -> None:
        """LiteLLMAdapter preserves model string as-is."""
        adapter = LiteLLMAdapter(model="gpt-4o", api_key="key")
        assert adapter.model == "gpt-4o"

    def test_litellm_adapter_azure_prefix(self) -> None:
        """LiteLLMAdapter accepts azure/ prefixed models."""
        adapter = LiteLLMAdapter(
            model="azure/my-deployment",
            api_key="key",
            api_base="https://test.openai.azure.com",
        )
        assert adapter.model == "azure/my-deployment"
