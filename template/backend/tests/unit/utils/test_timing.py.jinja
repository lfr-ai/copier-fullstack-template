"""Tests for timing module."""

from __future__ import annotations

import time

import pytest

from {{ project_slug }}.utils.timing import timed_block


class TestTimedBlock:
    """Test suite for timed_block context manager."""

    def test_measures_elapsed_time(self) -> None:
        """Verify timed_block completes without error."""
        with timed_block("test_sleep"):
            time.sleep(0.01)

    def test_propagates_exceptions(self) -> None:
        """Verify timed_block propagates exceptions from inner block."""
        with pytest.raises(ValueError, match="boom"):
            with timed_block("failing_block"):
                raise ValueError("boom")
