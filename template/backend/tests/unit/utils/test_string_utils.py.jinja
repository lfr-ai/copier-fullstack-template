"""Unit tests for string utility functions."""

from __future__ import annotations

import pytest

from {{ project_slug }}.utils.string_utils import slugify, truncate

class TestSlugify:
    """Test suite for slugify function."""

    def test_basic_slugify(self) -> None:
        """Verify simple string converted to slug."""
        assert slugify("Hello World") == "hello-world"

    def test_special_characters_removed(self) -> None:
        """Verify special characters stripped."""
        assert slugify("Hello, World!") == "hello-world"

    def test_multiple_spaces_collapsed(self) -> None:
        """Verify multiple spaces become single hyphen."""
        assert slugify("hello   world") == "hello-world"

    def test_unicode_normalized(self) -> None:
        """Verify unicode characters normalized to ASCII."""
        assert slugify("calf\u00e9") == "cafe"

    def test_empty_string(self) -> None:
        """Verify empty string returns empty."""
        assert slugify("") == ""

    def test_already_slug(self) -> None:
        """Verify slug-formatted string unchanged."""
        assert slugify("already-a-slug") == "already-a-slug"

    @pytest.mark.parametrize(
        ("input_val", "expected"),
        [
            ("  leading spaces  ", "leading-spaces"),
            ("UPPERCASE", "uppercase"),
            ("mixed-Case String", "mixed-case-string"),
        ],
    )
    def test_various_inputs(self, input_val: str, expected: str) -> None:
        """Verify slugification for various input patterns."""
        assert slugify(input_val) == expected

class TestTruncate:
    """Test suite for truncate function."""

    def test_short_string_unchanged(self) -> None:
        """Verify string shorter than limit returned as-is."""
        assert truncate("hello", max_length=10) == "hello"

    def test_exact_length_unchanged(self) -> None:
        """Verify string at exact limit returned as-is."""
        assert truncate("hello", max_length=5) == "hello"

    def test_long_string_truncated(self) -> None:
        """Verify long string truncated with suffix."""
        result = truncate("hello world test", max_length=10)
        assert len(result) == 10
        assert result.endswith("...")

    def test_custom_suffix(self) -> None:
        """Verify custom truncation suffix applied."""
        result = truncate("hello world", max_length=8, suffix="~")
        assert result.endswith("~")
        assert len(result) == 8

    def test_empty_string(self) -> None:
        """Verify empty input returns empty output."""
        assert truncate("", max_length=10) == ""
