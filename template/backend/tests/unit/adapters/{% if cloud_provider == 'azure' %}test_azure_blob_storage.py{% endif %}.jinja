class TestAzureBlobStorageExists:
"""Test suite for Azure Blob exists check."""

@pytest.mark.asyncio
async def test_exists_returns_true_when_present(
self,
storage: AzureBlobStorageAdapter,
mock_blob_service: MagicMock,
) -> None:
"""Verify exists returns True for an existing blob."""
blob_client = AsyncMock()
blob_client.exists = AsyncMock(return_value=True)
mock_blob_service.get_container_client.return_value.get_blob_client.return_value = (
blob_client
)

result = await storage.exists("key.txt")
assert result is True

@pytest.mark.asyncio
async def test_exists_returns_false_when_missing(
self,
storage: AzureBlobStorageAdapter,
mock_blob_service: MagicMock,
) -> None:
"""Verify exists returns False when blob does not exist."""
blob_client = AsyncMock()
blob_client.exists = AsyncMock(return_value=False)
mock_blob_service.get_container_client.return_value.get_blob_client.return_value = (
blob_client
)

result = await storage.exists("missing.txt")
assert result is False


