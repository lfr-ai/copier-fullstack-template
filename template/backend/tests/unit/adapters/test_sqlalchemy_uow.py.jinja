"""Unit tests for SQLAlchemyUnitOfWork."""

from __future__ import annotations

from unittest.mock import AsyncMock, MagicMock, patch

import pytest

from {{ project_slug }}.adapters.persistence.unit_of_work.sqlalchemy_uow import SQLAlchemyUnitOfWork

pytestmark = pytest.mark.asyncio


def _make_mock_session_factory() -> MagicMock:
    """Create a mock async_sessionmaker that returns an AsyncMock session."""
    mock_session = AsyncMock()
    mock_session.commit = AsyncMock()
    mock_session.rollback = AsyncMock()
    mock_session.close = AsyncMock()
    factory = MagicMock()
    factory.return_value = mock_session
    return factory


class TestSQLAlchemyUnitOfWork:
    """Test suite for SQLAlchemyUnitOfWork context manager."""

    async def test_enter_creates_session(self) -> None:
        """Verify __aenter__ creates a new session."""
        factory = _make_mock_session_factory()
        uow = SQLAlchemyUnitOfWork(factory)
        async with uow:
            assert uow.session is not None
        factory.assert_called_once()

    async def test_session_raises_outside_context(self) -> None:
        """Verify session property raises when not in context."""
        factory = _make_mock_session_factory()
        uow = SQLAlchemyUnitOfWork(factory)
        with pytest.raises(RuntimeError, match="not entered"):
            _ = uow.session

    async def test_commit_delegates_to_session(self) -> None:
        """Verify commit calls session.commit."""
        factory = _make_mock_session_factory()
        uow = SQLAlchemyUnitOfWork(factory)
        async with uow:
            await uow.commit()
        factory.return_value.commit.assert_awaited_once()

    async def test_rollback_delegates_to_session(self) -> None:
        """Verify rollback calls session.rollback."""
        factory = _make_mock_session_factory()
        uow = SQLAlchemyUnitOfWork(factory)
        async with uow:
            await uow.rollback()
        factory.return_value.rollback.assert_awaited_once()

    async def test_exit_closes_session(self) -> None:
        """Verify __aexit__ closes the session."""
        factory = _make_mock_session_factory()
        uow = SQLAlchemyUnitOfWork(factory)
        async with uow:
            pass
        factory.return_value.close.assert_awaited_once()

    async def test_exit_sets_session_to_none(self) -> None:
        """Verify session is None after exiting context."""
        factory = _make_mock_session_factory()
        uow = SQLAlchemyUnitOfWork(factory)
        async with uow:
            pass
        assert uow._session is None  # noqa: SLF001

    async def test_exit_rolls_back_on_exception(self) -> None:
        """Verify session.rollback called when exception occurs."""
        factory = _make_mock_session_factory()
        uow = SQLAlchemyUnitOfWork(factory)
        with pytest.raises(ValueError, match="test error"):
            async with uow:
                msg = "test error"
                raise ValueError(msg)
        factory.return_value.rollback.assert_awaited_once()

    async def test_exit_closes_session_even_on_exception(self) -> None:
        """Verify session closed even when exception occurs."""
        factory = _make_mock_session_factory()
        uow = SQLAlchemyUnitOfWork(factory)
        with pytest.raises(RuntimeError):
            async with uow:
                msg = "fail"
                raise RuntimeError(msg)
        factory.return_value.close.assert_awaited_once()

    async def test_reentrance_creates_new_session(self) -> None:
        """Verify entering context again creates fresh session."""
        factory = _make_mock_session_factory()
        uow = SQLAlchemyUnitOfWork(factory)
        async with uow:
            pass
        async with uow:
            pass
        assert factory.call_count == 2
