"""Protocol conformance tests.

Verifies that concrete adapter implementations satisfy
their corresponding interface protocols using runtime_checkable.
"""

from __future__ import annotations


from {{ project_slug }}.adapters.cache.memory_cache import MemoryCacheAdapter
from {{ project_slug }}.adapters.messaging.memory_event_bus import MemoryEventBus
from {{ project_slug }}.adapters.persistence.unit_of_work.sqlalchemy_uow import SQLAlchemyUnitOfWork
from {{ project_slug }}.core.interfaces.cache import CachePort
from {{ project_slug }}.core.interfaces.event_bus import EventBus
from {{ project_slug }}.core.interfaces.unit_of_work import UnitOfWork

class TestCachePortConformance:
    """Verify adapters satisfy CachePort protocol."""

    def test_memory_cache_is_cache_port(self) -> None:
        """Verify MemoryCacheAdapter is an instance of CachePort."""
        adapter = MemoryCacheAdapter()
        assert isinstance(adapter, CachePort)

class TestEventBusConformance:
