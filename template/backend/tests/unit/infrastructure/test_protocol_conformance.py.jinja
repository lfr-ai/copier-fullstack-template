class TestToolGatewayConformance:
    """Verify AI tool adapters satisfy ToolGateway protocol."""

    def test_base_tool_subclass_is_tool_gateway(self) -> None:
        """Verify a BaseTool subclass satisfies ToolGateway."""
        from {{ project_slug }}.ai.tools.base_tool import BaseTool, ToolResult
        from {{ project_slug }}.core.interfaces.tool import ToolGateway

        class DummyTool(BaseTool):
            @property
            def name(self) -> str:
                return "test"

            @property
            def description(self) -> str:
                return "Test tool"

            async def execute(self, **kwargs: object) -> ToolResult:
                return ToolResult(content="ok")

        tool = DummyTool()
        assert isinstance(tool, ToolGateway)


class TestChainGatewayConformance:
    """Verify AI chain adapters satisfy ChainGateway protocol."""

    def test_base_chain_subclass_is_chain_gateway(self) -> None:
        """Verify a BaseChain subclass satisfies ChainGateway."""
        from {{ project_slug }}.ai.chains.base_chain import BaseChain
        from {{ project_slug }}.core.interfaces.chain import ChainGateway

        class DummyChain(BaseChain):
            async def run(self, *, input_text: str, **kwargs: object) -> dict[str, str]:
                return {"content": input_text}

        chain = DummyChain()
        assert isinstance(chain, ChainGateway)


