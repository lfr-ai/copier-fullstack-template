class TestUnitOfWorkConformance:
    """Verify adapters satisfy UnitOfWork protocol."""

    def test_sqlalchemy_uow_is_unit_of_work(self) -> None:
        """Verify SQLAlchemyUnitOfWork is an instance of UnitOfWork."""
