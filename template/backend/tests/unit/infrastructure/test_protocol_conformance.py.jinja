"""Protocol conformance tests.

Verifies that concrete adapter implementations satisfy
their corresponding interface protocols using runtime_checkable.
"""

from __future__ import annotations


from {{ project_slug }}.infrastructure.cache.memory_cache import MemoryCacheAdapter
from {{ project_slug }}.infrastructure.messaging.memory_event_bus import MemoryEventBus
from {{ project_slug }}.infrastructure.persistence.unit_of_work.sqlalchemy_uow import SQLAlchemyUnitOfWork
from {{ project_slug }}.core.interfaces.cache import CacheGateway
from {{ project_slug }}.core.interfaces.event_bus import EventBus
from {{ project_slug }}.core.interfaces.unit_of_work import UnitOfWork

class TestCacheGatewayConformance:
    """Verify adapters satisfy CacheGateway protocol."""

    def test_memory_cache_is_cache_gateway(self) -> None:
        """Verify MemoryCacheAdapter is an instance of CacheGateway."""
        adapter = MemoryCacheAdapter()
        assert isinstance(adapter, CacheGateway)

class TestEventBusConformance:
