"""Unit tests for in-memory event bus adapter."""

from __future__ import annotations

import pytest

from {{ project_slug }}.infrastructure.messaging.memory_event_bus import MemoryEventBus
from {{ project_slug }}.core.events.user_events import UserCreated, UserDeactivated

@pytest.mark.asyncio
class TestMemoryEventBus:
    """Test suite for MemoryEventBus."""

    async def test_publish_invokes_handler(self) -> None:
        """Verify published event reaches subscribed handler."""
        bus = MemoryEventBus()
        received: list[UserCreated] = []

        async def handler(event: UserCreated) -> None:
            received.append(event)

        bus.subscribe(event_type=UserCreated, handler=handler)
        event = UserCreated(user_id="u-1", email="a@b.com")
        await bus.publish(event)
        assert len(received) == 1
        assert received[0] is event

    async def test_publish_multiple_handlers(self) -> None:
        """Verify event dispatched to all subscribed handlers."""
        bus = MemoryEventBus()
        call_count = 0

        async def handler_a(event: UserCreated) -> None:
            nonlocal call_count
            call_count += 1

        async def handler_b(event: UserCreated) -> None:
            nonlocal call_count
            call_count += 1

        bus.subscribe(event_type=UserCreated, handler=handler_a)
        bus.subscribe(event_type=UserCreated, handler=handler_b)
        await bus.publish(UserCreated(user_id="u-1", email="a@b.com"))
        assert call_count == 2

    async def test_publish_no_handlers(self) -> None:
        """Verify publishing with no subscribers does not raise."""
        bus = MemoryEventBus()
        event = UserCreated(user_id="u-1", email="a@b.com")
        await bus.publish(event)

    async def test_subscribe_only_receives_matching_type(self) -> None:
        """Verify handler only invoked for subscribed event type."""
        bus = MemoryEventBus()
        received: list[UserCreated] = []

        async def handler(event: UserCreated) -> None:
            received.append(event)

        bus.subscribe(event_type=UserCreated, handler=handler)
        await bus.publish(UserDeactivated(user_id="u-1", reason="test"))
        assert len(received) == 0

    async def test_handler_exception_does_not_stop_others(self) -> None:
        """Verify failing handler does not prevent subsequent handlers."""
        bus = MemoryEventBus()
        results: list[str] = []

        async def failing_handler(event: UserCreated) -> None:
            raise ValueError("handler error")

        async def succeeding_handler(event: UserCreated) -> None:
            results.append("ok")

        bus.subscribe(event_type=UserCreated, handler=failing_handler)
        bus.subscribe(event_type=UserCreated, handler=succeeding_handler)
        await bus.publish(UserCreated(user_id="u-1", email="a@b.com"))
        assert results == ["ok"]
