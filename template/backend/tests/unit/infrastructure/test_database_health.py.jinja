"""Unit tests for database health check utility."""

from __future__ import annotations

from unittest.mock import AsyncMock, MagicMock

import pytest
from sqlalchemy import Result

from {{ project_slug }}.infrastructure.database.health import check_database_health


class TestCheckDatabaseHealth:
    """Test suite for 'check_database_health'."""

    @pytest.mark.asyncio
    async def test_returns_true_when_db_responds(self) -> None:
        """Verify healthy database returns True."""
        mock_result = MagicMock(spec=Result)
        mock_result.scalar.return_value = 1

        session = AsyncMock()
        session.execute.return_value = mock_result

        assert await check_database_health(session) is True

    @pytest.mark.asyncio
    async def test_returns_false_on_exception(self) -> None:
        """Verify exception during query returns False."""
        session = AsyncMock()
        session.execute.side_effect = ConnectionError("connection refused")

        assert await check_database_health(session) is False

    @pytest.mark.asyncio
    async def test_returns_false_when_scalar_not_one(self) -> None:
        """Verify unexpected scalar value returns False."""
        mock_result = MagicMock(spec=Result)
        mock_result.scalar.return_value = None

        session = AsyncMock()
        session.execute.return_value = mock_result

        assert await check_database_health(session) is False
