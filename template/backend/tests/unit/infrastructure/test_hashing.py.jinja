"""Unit tests for cryptographic hashing utilities."""

from __future__ import annotations

import pytest

from {{ project_slug }}.infrastructure.security.hashing import (
    hash_password,
    verify_password,
)

_SALT_HEX_LENGTH: int = 64
"""Expected length of a 32-byte salt hex-encoded (32 × 2)."""


class TestHashPassword:
    """Test suite for ``hash_password``."""

    def test_returns_salt_dollar_hash_format(self) -> None:
        """Verify output follows ``salt_hex$hash_hex`` format."""
        result = hash_password("secret")
        parts = result.split("$")
        assert len(parts) == 2
        assert len(parts[0]) == _SALT_HEX_LENGTH
        assert len(parts[1]) > 0

    def test_deterministic_with_fixed_salt(self) -> None:
        """Verify hashing is deterministic when salt is provided."""
        salt = b"\x00" * 32
        h1 = hash_password("password", salt=salt)
        h2 = hash_password("password", salt=salt)
        assert h1 == h2

    def test_different_salt_produces_different_hash(self) -> None:
        """Verify different salts yield different hashes."""
        h1 = hash_password("password", salt=b"\x00" * 32)
        h2 = hash_password("password", salt=b"\x01" * 32)
        assert h1 != h2

    def test_random_salt_when_none(self) -> None:
        """Verify unique salt is generated when omitted."""
        h1 = hash_password("password")
        h2 = hash_password("password")
        assert h1 != h2

    def test_empty_password(self) -> None:
        """Verify empty string can be hashed without error."""
        result = hash_password("")
        assert "$" in result


class TestVerifyPassword:
    """Test suite for ``verify_password``."""

    def test_correct_password_returns_true(self) -> None:
        """Verify matching password returns True."""
        hashed = hash_password("my-password")
        assert verify_password(password="my-password", hashed=hashed) is True

    def test_wrong_password_returns_false(self) -> None:
        """Verify wrong password returns False."""
        hashed = hash_password("my-password")
        assert verify_password(password="wrong-password", hashed=hashed) is False

    def test_malformed_hash_returns_false(self) -> None:
        """Verify malformed hash without ``$`` returns False."""
        assert verify_password(password="password", hashed="nope") is False

    def test_tampered_hash_returns_false(self) -> None:
        """Verify tampered hash bytes return False."""
        hashed = hash_password("password")
        salt_hex, hash_hex = hashed.split("$")
        tampered = salt_hex + "$" + "0" * len(hash_hex)
        assert verify_password(password="password", hashed=tampered) is False

    @pytest.mark.parametrize(
        "hashed",
        [
            "",
            "no-dollar-sign",
            "$only-hash",
        ],
    )
    def test_invalid_formats_return_false(self, hashed: str) -> None:
        """Verify various invalid hash formats return False."""
        assert verify_password(password="password", hashed=hashed) is False
