"""Unit tests for OpenAI LLM adapter."""

from __future__ import annotations

from typing import TYPE_CHECKING
from unittest.mock import AsyncMock, MagicMock, patch

import pytest

from {{ project_slug }}.ai.llm.openai_adapter import OpenAIAdapter

if TYPE_CHECKING:
    from collections.abc import Generator


@pytest.fixture
def mock_openai() -> Generator[MagicMock, None, None]:
    """Patch the openai module for adapter tests."""
    with patch(
        "{{ project_slug }}.ai.llm.openai_adapter.AsyncOpenAI",
        autospec=True,
    ) as mock_cls:
        yield mock_cls


@pytest.fixture
def adapter(mock_openai: MagicMock) -> OpenAIAdapter:
    """Create OpenAIAdapter backed by a mock AsyncOpenAI client."""
    return OpenAIAdapter(api_key="test-key", model="gpt-4o-mini")


class TestOpenAIAdapterComplete:
    """Test suite for synchronous completion."""

    @pytest.mark.asyncio
    async def test_complete_returns_content(
        self,
        adapter: OpenAIAdapter,
        mock_openai: MagicMock,
    ) -> None:
        """Verify complete returns the first choice message content."""
        choice = MagicMock()
        choice.message.content = "Hello from GPT"
        response = MagicMock()
        response.choices = [choice]

        client_instance = mock_openai.return_value
        client_instance.chat.completions.create = AsyncMock(return_value=response)

        result = await adapter.complete("Say hello")
        assert result == "Hello from GPT"

    @pytest.mark.asyncio
    async def test_complete_sends_prompt_as_user_message(
        self,
        adapter: OpenAIAdapter,
        mock_openai: MagicMock,
    ) -> None:
        """Verify complete passes prompt as a user role message."""
        choice = MagicMock()
        choice.message.content = "ok"
        response = MagicMock()
        response.choices = [choice]

        client_instance = mock_openai.return_value
        client_instance.chat.completions.create = AsyncMock(return_value=response)

        await adapter.complete("test prompt")

        call_kwargs = client_instance.chat.completions.create.call_args
        messages = call_kwargs.kwargs.get("messages") or call_kwargs[1].get("messages")
        assert any(m["role"] == "user" and "test prompt" in m["content"] for m in messages)


class TestOpenAIAdapterStream:
    """Test suite for streaming completion."""

    @pytest.mark.asyncio
    async def test_stream_yields_chunks(
        self,
        adapter: OpenAIAdapter,
        mock_openai: MagicMock,
    ) -> None:
        """Verify stream yields content chunks from the API."""
        chunk1 = MagicMock()
        chunk1.choices = [MagicMock()]
        chunk1.choices[0].delta.content = "Hello"
        chunk2 = MagicMock()
        chunk2.choices = [MagicMock()]
        chunk2.choices[0].delta.content = " world"

        async def mock_stream(*args: object, **kwargs: object) -> object:  # noqa: ARG001, ANN002
            for chunk in [chunk1, chunk2]:
                yield chunk

        client_instance = mock_openai.return_value
        client_instance.chat.completions.create = mock_stream

        chunks: list[str] = []
        async for text in adapter.stream("Say hello"):
            chunks.append(text)
        assert chunks == ["Hello", " world"]


class TestOpenAIAdapterImportGuard:
    """Test suite for optional openai dependency handling."""

    def test_missing_openai_raises_import_error(self) -> None:
        """Verify ImportError when openai package is not installed."""
        with patch.dict("sys.modules", {"openai": None}):
            with pytest.raises(ImportError):
                OpenAIAdapter(api_key="key", model="gpt-4o")
