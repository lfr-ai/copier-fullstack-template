{%- if use_celery %}
"""Unit tests for Celery application configuration."""

from __future__ import annotations

from unittest.mock import patch, MagicMock

import pytest

pytestmark = pytest.mark.unit


class TestCreateCeleryApp:
    """Test suite for create_celery_app factory."""

    @patch("{{ project_slug }}.config.celery.get_settings")
    @patch("{{ project_slug }}.config.celery.Celery")
    def test_creates_celery_instance(
        self,
        mock_celery_cls: MagicMock,
        mock_settings: MagicMock,
    ) -> None:
        """Verify Celery app is created with correct broker and backend."""
        from {{ project_slug }}.config.celery import create_celery_app

        mock_settings.return_value.celery_broker_url = "redis://localhost:6379/1"
        mock_settings.return_value.celery_result_backend = "redis://localhost:6379/2"
        mock_app = MagicMock()
        mock_celery_cls.return_value = mock_app

        app = create_celery_app()

        mock_celery_cls.assert_called_once_with(
            "{{ project_slug }}",
            broker="redis://localhost:6379/1",
            backend="redis://localhost:6379/2",
        )

    @patch("{{ project_slug }}.config.celery.get_settings")
    @patch("{{ project_slug }}.config.celery.Celery")
    def test_configures_serialization(
        self,
        mock_celery_cls: MagicMock,
        mock_settings: MagicMock,
    ) -> None:
        """Verify Celery app configured with JSON serialization."""
        from {{ project_slug }}.config.celery import create_celery_app

        mock_settings.return_value.celery_broker_url = "redis://localhost:6379/1"
        mock_settings.return_value.celery_result_backend = "redis://localhost:6379/2"
        mock_app = MagicMock()
        mock_celery_cls.return_value = mock_app

        create_celery_app()

        conf_update_kwargs = mock_app.conf.update.call_args[1]
        assert conf_update_kwargs["task_serializer"] == "json"
        assert conf_update_kwargs["result_serializer"] == "json"
        assert conf_update_kwargs["timezone"] == "UTC"
        assert conf_update_kwargs["enable_utc"] is True

    @patch("{{ project_slug }}.config.celery.get_settings")
    @patch("{{ project_slug }}.config.celery.Celery")
    def test_autodiscovers_tasks(
        self,
        mock_celery_cls: MagicMock,
        mock_settings: MagicMock,
    ) -> None:
        """Verify Celery app autodiscovers tasks from correct module."""
        from {{ project_slug }}.config.celery import create_celery_app

        mock_settings.return_value.celery_broker_url = "redis://localhost:6379/1"
        mock_settings.return_value.celery_result_backend = "redis://localhost:6379/2"
        mock_app = MagicMock()
        mock_celery_cls.return_value = mock_app

        create_celery_app()

        mock_app.autodiscover_tasks.assert_called_once_with(
            ["{{ project_slug }}.application.tasks"],
        )

    @patch("{{ project_slug }}.config.celery.get_settings")
    @patch("{{ project_slug }}.config.celery.Celery")
    def test_task_reliability_settings(
        self,
        mock_celery_cls: MagicMock,
        mock_settings: MagicMock,
    ) -> None:
        """Verify Celery reliability settings (acks_late, track_started)."""
        from {{ project_slug }}.config.celery import create_celery_app

        mock_settings.return_value.celery_broker_url = "redis://localhost:6379/1"
        mock_settings.return_value.celery_result_backend = "redis://localhost:6379/2"
        mock_app = MagicMock()
        mock_celery_cls.return_value = mock_app

        create_celery_app()

        conf_update_kwargs = mock_app.conf.update.call_args[1]
        assert conf_update_kwargs["task_track_started"] is True
        assert conf_update_kwargs["task_acks_late"] is True
        assert conf_update_kwargs["worker_prefetch_multiplier"] == 1
{%- endif %}
