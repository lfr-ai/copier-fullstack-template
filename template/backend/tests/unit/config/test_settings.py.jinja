_VALID_SECRET_KEY = "super-secure-secret-key-value-with-32-chars"


@pytest.fixture(autouse=True)
def _clear_settings_cache() -> None:
    """Clear cached settings between tests for isolation."""
    get_settings.cache_clear()
    yield
    get_settings.cache_clear()

class TestGetSettings:
    """Test suite for settings factory function."""

    def test_default_returns_local_settings(self) -> None:
        """Verify default environment returns LocalSettings."""
        with patch.dict(os.environ, {}, clear=True):
            settings = get_settings()
        assert isinstance(settings, LocalSettings)

    def test_local_env_returns_local_settings(self) -> None:
        """Verify LOCAL env returns LocalSettings."""
        with patch.dict(os.environ, {"{{ project_slug | upper }}_ENVIRONMENT": "LOCAL"}):
            settings = get_settings()
        assert isinstance(settings, LocalSettings)
        assert settings.environment == Environment.LOCAL

    def test_dev_env_returns_local_settings(self) -> None:
        """Verify DEV env returns DevSettings."""
        with patch.dict(os.environ, {"{{ project_slug | upper }}_ENVIRONMENT": "DEV"}):
            settings = get_settings()
        assert isinstance(settings, DevSettings)
        assert settings.environment == Environment.DEV

    def test_test_env_returns_test_settings(self) -> None:
        """Verify TEST env returns TestSettings."""
        with patch.dict(os.environ, {"{{ project_slug | upper }}_ENVIRONMENT": "TEST"}):
            settings = get_settings()
        assert isinstance(settings, TestSettings)
        assert settings.environment == Environment.TEST

    def test_staging_env_returns_prod_settings(self) -> None:
        """Verify STAGING env returns StagingSettings."""
        with patch.dict(
            os.environ,
            {
                "{{ project_slug | upper }}_ENVIRONMENT": "STAGING",
                "{{ project_slug | upper }}_SECRET_KEY": _VALID_SECRET_KEY,
{%- if use_auth %}
                "{{ project_slug | upper }}_JWT_SECRET_KEY": _VALID_SECRET_KEY,
{%- endif %}
            },
        ):
            settings = get_settings()
        assert isinstance(settings, StagingSettings)
        assert settings.environment == Environment.STAGING

    def test_prod_env_returns_prod_settings(self) -> None:
        """Verify PROD env returns ProdSettings."""
        with patch.dict(
            os.environ,
            {
                "{{ project_slug | upper }}_ENVIRONMENT": "PROD",
                "{{ project_slug | upper }}_SECRET_KEY": _VALID_SECRET_KEY,
{%- if use_auth %}
                "{{ project_slug | upper }}_JWT_SECRET_KEY": _VALID_SECRET_KEY,
{%- endif %}
            },
        ):
            settings = get_settings()
        assert isinstance(settings, ProdSettings)
        assert settings.environment == Environment.PROD

    def test_case_insensitive(self) -> None:
        """Verify environment variable is case insensitive."""
        with patch.dict(os.environ, {"{{ project_slug | upper }}_ENVIRONMENT": "test"}):
            settings = get_settings()
        assert isinstance(settings, TestSettings)

