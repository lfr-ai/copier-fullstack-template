class TestProdSettings:
    """Test suite for ProdSettings defaults."""

    def test_debug_disabled(self) -> None:
        """Verify debug is False in prod."""
        settings = ProdSettings(secret_key=_VALID_SECRET_KEY{%- if use_auth %}, jwt_secret_key=_VALID_SECRET_KEY{% endif %})
        assert settings.debug is False

    def test_log_level_warning(self) -> None:
        """Verify log level is WARNING in prod."""
        settings = ProdSettings(secret_key=_VALID_SECRET_KEY{%- if use_auth %}, jwt_secret_key=_VALID_SECRET_KEY{% endif %})
        assert settings.log_level == "WARNING"

    def test_database_echo_disabled(self) -> None:
        """Verify SQL echo is disabled in prod."""
        settings = ProdSettings(secret_key=_VALID_SECRET_KEY{%- if use_auth %}, jwt_secret_key=_VALID_SECRET_KEY{% endif %})
        assert settings.database_echo is False

    def test_rejects_insecure_default_secret(self) -> None:
        """Verify prod rejects insecure default secret values."""
        with pytest.raises(ValueError, match="secret_key"):
            ProdSettings(secret_key="change-me-in-production"{%- if use_auth %}, jwt_secret_key=_VALID_SECRET_KEY{% endif %})


