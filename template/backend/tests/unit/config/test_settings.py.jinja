"""Unit tests for settings factory and settings classes."""

from __future__ import annotations

import os
from unittest.mock import patch

import pytest

from {{ project_slug }}.config.settings import get_settings
from {{ project_slug }}.config.settings.base import BaseAppSettings
from {{ project_slug }}.config.settings.local import LocalSettings
from {{ project_slug }}.config.settings.production import ProductionSettings
from {{ project_slug }}.config.settings.test import TestSettings
from {{ project_slug }}.core.enums.environment import Environment

class TestGetSettings:
    """Test suite for settings factory function."""

    def test_default_returns_local_settings(self) -> None:
        """Verify default environment returns LocalSettings."""
        with patch.dict(os.environ, {}, clear=True):
            settings = get_settings()
        assert isinstance(settings, LocalSettings)

    def test_local_env_returns_local_settings(self) -> None:
        """Verify LOCAL env returns LocalSettings."""
        with patch.dict(os.environ, {"{{ project_slug | upper }}_ENVIRONMENT": "LOCAL"}):
            settings = get_settings()
        assert isinstance(settings, LocalSettings)
        assert settings.environment == Environment.LOCAL

    def test_dev_env_returns_local_settings(self) -> None:
        """Verify DEV env returns LocalSettings."""
        with patch.dict(os.environ, {"{{ project_slug | upper }}_ENVIRONMENT": "DEV"}):
            settings = get_settings()
        assert isinstance(settings, LocalSettings)

    def test_test_env_returns_test_settings(self) -> None:
        """Verify TEST env returns TestSettings."""
        with patch.dict(os.environ, {"{{ project_slug | upper }}_ENVIRONMENT": "TEST"}):
            settings = get_settings()
        assert isinstance(settings, TestSettings)
        assert settings.environment == Environment.TEST

    def test_staging_env_returns_production_settings(self) -> None:
        """Verify STAGING env returns ProductionSettings."""
        with patch.dict(os.environ, {"{{ project_slug | upper }}_ENVIRONMENT": "STAGING"}):
            settings = get_settings()
        assert isinstance(settings, ProductionSettings)

    def test_production_env_returns_production_settings(self) -> None:
        """Verify PRODUCTION env returns ProductionSettings."""
        with patch.dict(os.environ, {"{{ project_slug | upper }}_ENVIRONMENT": "PRODUCTION"}):
            settings = get_settings()
        assert isinstance(settings, ProductionSettings)
        assert settings.environment == Environment.PRODUCTION

    def test_case_insensitive(self) -> None:
        """Verify environment variable is case insensitive."""
        with patch.dict(os.environ, {"{{ project_slug | upper }}_ENVIRONMENT": "test"}):
            settings = get_settings()
        assert isinstance(settings, TestSettings)

class TestLocalSettings:
    """Test suite for LocalSettings defaults."""

    def test_debug_enabled(self) -> None:
        """Verify debug is True by default in local."""
        settings = LocalSettings()
        assert settings.debug is True

    def test_log_level_debug(self) -> None:
        """Verify log level is DEBUG in local."""
        settings = LocalSettings()
        assert settings.log_level == "DEBUG"

    def test_database_echo_enabled(self) -> None:
        """Verify SQL echo is enabled in local."""
        settings = LocalSettings()
        assert settings.database_echo is True

