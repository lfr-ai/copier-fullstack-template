"""Unit tests for health check routes."""

from __future__ import annotations

import pytest
from httpx import ASGITransport, AsyncClient

from {{ project_slug }}.ports.api.app import create_api_app

pytestmark = pytest.mark.asyncio


class TestHealthRoutes:
    """Test suite for health check API routes."""

    async def test_health_returns_200(self) -> None:
        """Verify /health returns 200 with healthy status."""
        app = create_api_app()
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url="http://test") as ac:
            response = await ac.get("/api/v1/health")
        assert response.status_code == 200
        assert response.json()["status"] == "healthy"

    async def test_readiness_returns_200(self) -> None:
        """Verify /health/ready returns 200 with ready status."""
        app = create_api_app()
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url="http://test") as ac:
            response = await ac.get("/api/v1/health/ready")
        assert response.status_code == 200
        assert response.json()["status"] == "ready"

    async def test_health_response_content_type(self) -> None:
        """Verify health endpoint returns JSON content type."""
        app = create_api_app()
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url="http://test") as ac:
            response = await ac.get("/api/v1/health")
        assert "application/json" in response.headers.get("content-type", "")
