"""Unit tests for core value objects."""

from __future__ import annotations

import pytest

from {{ project_slug }}.core.exceptions.validation import ValidationError
from {{ project_slug }}.core.value_objects.email import Email

class TestEmailValueObject:
    """Test suite for Email value object."""

    def test_valid_email(self) -> None:
        """Verify valid email creation succeeds."""
        email = Email(value="user@example.com")
        assert email.value == "user@example.com"

    def test_invalid_email_raises(self) -> None:
        """Verify invalid email raises ValidationError."""
        with pytest.raises(ValidationError, match="Invalid email"):
            Email(value="not-an-email")

    def test_email_immutability(self) -> None:
        """Verify email value object is immutable."""
        email = Email(value="user@example.com")
        with pytest.raises(AttributeError):
            email.value = "other@example.com"  # type: ignore[misc]
