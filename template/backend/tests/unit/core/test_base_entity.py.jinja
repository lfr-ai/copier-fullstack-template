"""Unit tests for base entity classes."""

from __future__ import annotations

from datetime import UTC

import pytest

from {{ project_slug }}.core.entities.base import DomainEvent, Entity, ValueObject

class TestDomainEvent:
    """Test suite for DomainEvent base class."""

    def test_event_has_unique_id(self) -> None:
        """Verify each event gets a unique identifier."""
        event_a = DomainEvent()
        event_b = DomainEvent()
        assert event_a.event_id != event_b.event_id

    def test_event_has_utc_timestamp(self) -> None:
        """Verify event timestamp is timezone-aware UTC."""
        event = DomainEvent()
        assert event.occurred_at.tzinfo is not None
        assert event.occurred_at.tzinfo == UTC

    def test_event_is_frozen(self) -> None:
        """Verify domain event is immutable."""
        event = DomainEvent()
        with pytest.raises(AttributeError):
            event.event_id = "mutated"  # type: ignore[misc]

class TestEntity:
    """Test suite for Entity base class."""

    def test_entity_generates_id(self) -> None:
        """Verify entity receives auto-generated identifier."""
        entity = Entity()
        assert entity.id is not None
        assert len(entity.id) > 0

    def test_entity_equality_by_id(self) -> None:
        """Verify entities compared by identity, not attributes."""
        entity_a = Entity(id="same-id")
        entity_b = Entity(id="same-id")
        assert entity_a == entity_b

    def test_entity_inequality_different_ids(self) -> None:
        """Verify entities with different IDs are not equal."""
        entity_a = Entity(id="id-1")
        entity_b = Entity(id="id-2")
        assert entity_a != entity_b

    def test_entity_not_equal_to_non_entity(self) -> None:
        """Verify entity not equal to non-entity objects."""
        entity = Entity(id="id-1")
        assert entity != "id-1"

    def test_entity_hash_by_id(self) -> None:
        """Verify entity hash derived from identity."""
        entity_a = Entity(id="same-id")
        entity_b = Entity(id="same-id")
        assert hash(entity_a) == hash(entity_b)

    def test_entity_can_be_used_in_sets(self) -> None:
        """Verify entities usable in set collections."""
        entity_a = Entity(id="id-1")
        entity_b = Entity(id="id-1")
        entity_c = Entity(id="id-2")
        result = {entity_a, entity_b, entity_c}
        assert len(result) == 2

    def test_register_event(self) -> None:
        """Verify domain event registration."""
        entity = Entity()
        event = DomainEvent()
        entity.register_event(event)
        collected = entity.collect_events()
        assert len(collected) == 1

    def test_collect_events_returns_and_clears(self) -> None:
        """Verify collect_events returns events then empties list."""
        entity = Entity()
        event = DomainEvent()
        entity.register_event(event)
        collected = entity.collect_events()
        assert len(collected) == 1
        assert collected[0] is event
        second_collect = entity.collect_events()
        assert len(second_collect) == 0

    def test_collect_events_empty(self) -> None:
        """Verify collect_events returns empty list when no events."""
        entity = Entity()
        assert entity.collect_events() == []

class TestValueObject:
    """Test suite for ValueObject base class."""

    def test_value_object_is_frozen(self) -> None:
        """Verify value object is immutable."""
        vo = ValueObject()
        with pytest.raises(AttributeError):
            vo.__dict__["test"] = "mutated"
