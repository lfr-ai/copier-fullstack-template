"""Unit tests for domain enumerations."""

from __future__ import annotations

import pytest

from {{ project_slug }}.core.enums.environment import Environment
from {{ project_slug }}.core.enums.service_status import ServiceStatus
from {{ project_slug }}.core.enums.sort_order import SortOrder
from {{ project_slug }}.core.enums.status import Status

class TestEnvironmentEnum:
    """Test suite for Environment enumeration."""

    def test_all_environments_defined(self) -> None:
        """Verify all expected environments exist."""
        expected = {"LOCAL", "DEV", "TEST", "STAGING", "PRODUCTION"}
        actual = {e.name for e in Environment}
        assert actual == expected

    def test_environment_is_str_enum(self) -> None:
        """Verify environment values are strings."""
        for env in Environment:
            assert isinstance(env.value, str)

    def test_environment_auto_generates_lowercase(self) -> None:
        """Verify auto() generates lowercase string values."""
        assert Environment.LOCAL.value == "local"
        assert Environment.PRODUCTION.value == "production"

    def test_environment_from_value(self) -> None:
        """Verify construction from string value."""
        assert Environment("local") is Environment.LOCAL
        assert Environment("production") is Environment.PRODUCTION

    def test_environment_from_str(self) -> None:
        """Verify from_str classmethod handles case-insensitive lookup."""
        assert Environment.from_str("LOCAL") is Environment.LOCAL
        assert Environment.from_str("production") is Environment.PRODUCTION

    def test_environment_from_str_invalid_raises(self) -> None:
        """Verify from_str raises ValueError for unknown values."""
        with pytest.raises(ValueError, match="Unknown Environment"):
            Environment.from_str("bogus")

