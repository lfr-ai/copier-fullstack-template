[alembic]
script_location = alembic
{%- if database_backend in ("postgresql", "azure_postgresql") %}
# Placeholder — overridden at runtime by env.py using settings.database_url.
# Do NOT store real credentials here.
sqlalchemy.url = driver://user:pass@localhost/dbname
{%- elif database_backend == "sqlite" %}
# Placeholder — overridden at runtime by env.py using settings.database_url.
sqlalchemy.url = sqlite+aiosqlite:///data/{{ project_slug }}.db
{%- else %}
# No database backend selected. Set sqlalchemy.url when a database is configured.
sqlalchemy.url =
{%- endif %}

[loggers]
keys = root,sqlalchemy,alembic

[handlers]
keys = console

[formatters]
keys = generic

[logger_root]
level = WARN
handlers = console

[logger_sqlalchemy]
level = WARN
handlers =
qualname = sqlalchemy.engine

[logger_alembic]
level = INFO
handlers =
qualname = alembic

[handler_console]
class = StreamHandler
args = (sys.stderr,)
level = NOTSET
formatter = generic

[formatter_generic]
format = %%(levelname)-5.5s [%%(name)s] %%(message)s
datefmt = %%H:%%M:%%S