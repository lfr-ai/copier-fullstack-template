{%- if use_playwright %}
"""End-to-end smoke tests using Playwright."""

from __future__ import annotations

import pytest
from playwright.sync_api import Page

pytestmark = pytest.mark.e2e


class TestSmoke:
    """Smoke tests verifying basic application flow."""

    def test_home_page_loads(self, page: Page, base_url: str | None) -> None:
        """Verify home page renders successfully."""
        if not base_url:
            pytest.skip("base_url is not configured")
        page.goto(f"{base_url}/")
        assert page.title() != ""

    def test_api_docs_accessible(self, page: Page, base_url: str | None) -> None:
        """Verify API documentation page loads."""
        if not base_url:
            pytest.skip("base_url is not configured")
        response = page.goto(f"{base_url}/api/docs")
        assert response is not None
        assert response.status == 200
{%- endif %}
