"""Unit tests for async utility functions."""

from __future__ import annotations

from {{ project_slug }}.utils.async_utils import async_to_sync, run_sync


class TestRunSync:
    """Test suite for run_sync function."""

    def test_run_simple_coroutine(self) -> None:
        """Verify coroutine executed and result returned."""

        async def coro() -> int:
            return 42

        result = run_sync(coro())
        assert result == 42

    def test_run_coroutine_with_arguments(self) -> None:
        """Verify coroutine arguments passed correctly."""

        async def add(a: int, b: int) -> int:
            return a + b

        result = run_sync(add(3, 7))
        assert result == 10


class TestAsyncToSync:
    """Test suite for async_to_sync decorator."""

    def test_decorated_function_callable_sync(self) -> None:
        """Verify decorated async function callable synchronously."""

        @async_to_sync
        async def greeting(name: str) -> str:
            return f"hello {name}"

        result = greeting("world")
        assert result == "hello world"

    def test_preserves_function_name(self) -> None:
        """Verify wrapper preserves original function name."""

        @async_to_sync
        async def my_func() -> None:
            pass

        assert my_func.__name__ == "my_func"
