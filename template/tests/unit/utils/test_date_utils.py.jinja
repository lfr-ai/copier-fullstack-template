"""Unit tests for date utility functions."""

from __future__ import annotations

from datetime import UTC, datetime

from {{ project_slug }}.utils.date_utils import format_iso, parse_iso, utc_now


class TestUtcNow:
    """Test suite for utc_now function."""

    def test_returns_utc_datetime(self) -> None:
        """Verify returned datetime is UTC timezone-aware."""
        now = utc_now()
        assert now.tzinfo is not None
        assert now.tzinfo == UTC

    def test_returns_recent_timestamp(self) -> None:
        """Verify returned time is approximately current."""
        before = datetime.now(UTC)
        now = utc_now()
        after = datetime.now(UTC)
        assert before <= now <= after


class TestFormatIso:
    """Test suite for format_iso function."""

    def test_formats_utc_datetime(self) -> None:
        """Verify ISO 8601 formatting of UTC datetime."""
        dt = datetime(2024, 1, 15, 12, 30, 45, tzinfo=UTC)
        result = format_iso(dt)
        assert "2024-01-15" in result
        assert "12:30:45" in result

    def test_format_roundtrip(self) -> None:
        """Verify format then parse returns equivalent datetime."""
        original = utc_now()
        formatted = format_iso(original)
        parsed = parse_iso(formatted)
        assert parsed == original


class TestParseIso:
    """Test suite for parse_iso function."""

    def test_parses_iso_string(self) -> None:
        """Verify parsing of ISO 8601 string."""
        result = parse_iso("2024-06-15T10:30:00+00:00")
        assert result.year == 2024
        assert result.month == 6
        assert result.hour == 10

    def test_parses_naive_datetime(self) -> None:
        """Verify parsing of naive ISO string."""
        result = parse_iso("2024-01-01T00:00:00")
        assert result.year == 2024
