"""Unit tests for cryptographic utility functions."""

from __future__ import annotations

from {{ project_slug }}.utils.crypto_utils import generate_token, hash_sha256


class TestGenerateToken:
    """Test suite for generate_token function."""

    def test_returns_nonempty_string(self) -> None:
        """Verify token is a non-empty string."""
        token = generate_token()
        assert isinstance(token, str)
        assert len(token) > 0

    def test_generates_unique_tokens(self) -> None:
        """Verify consecutive tokens are unique."""
        tokens = {generate_token() for _ in range(100)}
        assert len(tokens) == 100

    def test_custom_byte_length(self) -> None:
        """Verify custom byte length produces different length token."""
        short_token = generate_token(nbytes=8)
        long_token = generate_token(nbytes=64)
        assert len(short_token) < len(long_token)


class TestHashSha256:
    """Test suite for hash_sha256 function."""

    def test_returns_hex_string(self) -> None:
        """Verify result is lowercase hex string."""
        result = hash_sha256("test")
        assert isinstance(result, str)
        assert all(c in "0123456789abcdef" for c in result)

    def test_consistent_hash(self) -> None:
        """Verify same input always produces same hash."""
        assert hash_sha256("hello") == hash_sha256("hello")

    def test_different_inputs_different_hashes(self) -> None:
        """Verify different inputs produce different hashes."""
        assert hash_sha256("hello") != hash_sha256("world")

    def test_sha256_length(self) -> None:
        """Verify SHA-256 produces 64-character hex digest."""
        result = hash_sha256("test")
        assert len(result) == 64

    def test_empty_string_hashes(self) -> None:
        """Verify empty string produces valid hash."""
        result = hash_sha256("")
        assert len(result) == 64
