"""Unit tests for application DTOs."""

from __future__ import annotations

import pytest
from pydantic import ValidationError

from {{ project_slug }}.application.dtos.base import ErrorResponse, PaginatedResponse


class TestPaginatedResponse:
    """Test suite for PaginatedResponse DTO."""

    def test_create_paginated_response(self) -> None:
        """Verify paginated response creation."""
        response = PaginatedResponse[str](
            items=["a", "b"],
            total=10,
            offset=0,
            limit=20,
        )
        assert response.items == ["a", "b"]
        assert response.total == 10

    def test_has_more_true(self) -> None:
        """Verify has_more when more pages exist."""
        response = PaginatedResponse[str](
            items=["a"],
            total=50,
            offset=0,
            limit=20,
        )
        assert response.has_more is True

    def test_has_more_false(self) -> None:
        """Verify has_more when all items shown."""
        response = PaginatedResponse[str](
            items=["a"],
            total=1,
            offset=0,
            limit=20,
        )
        assert response.has_more is False

    def test_negative_total_rejected(self) -> None:
        """Verify negative total raises validation error."""
        with pytest.raises(ValidationError):
            PaginatedResponse[str](
                items=[],
                total=-1,
                offset=0,
                limit=20,
            )

    def test_zero_limit_rejected(self) -> None:
        """Verify zero limit raises validation error."""
        with pytest.raises(ValidationError):
            PaginatedResponse[str](
                items=[],
                total=0,
                offset=0,
                limit=0,
            )

    def test_negative_offset_rejected(self) -> None:
        """Verify negative offset raises validation error."""
        with pytest.raises(ValidationError):
            PaginatedResponse[str](
                items=[],
                total=0,
                offset=-1,
                limit=20,
            )


class TestErrorResponse:
    """Test suite for ErrorResponse DTO."""

    def test_create_error_response(self) -> None:
        """Verify error response creation."""
        response = ErrorResponse(
            error_code="NOT_FOUND",
            message="Resource not found",
        )
        assert response.error_code == "NOT_FOUND"
        assert response.message == "Resource not found"
        assert response.details is None

    def test_error_response_with_details(self) -> None:
        """Verify error response with additional details."""
        response = ErrorResponse(
            error_code="VALIDATION_ERROR",
            message="Invalid input",
            details={"field": "email", "reason": "invalid format"},
        )
        assert response.details is not None
        assert response.details["field"] == "email"

    def test_strips_whitespace(self) -> None:
        """Verify whitespace stripped from string fields."""
        response = ErrorResponse(
            error_code="  NOT_FOUND  ",
            message="  spaced  ",
        )
        assert response.error_code == "NOT_FOUND"
        assert response.message == "spaced"
