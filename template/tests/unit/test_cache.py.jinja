"""Unit tests for in-memory cache adapter."""

from __future__ import annotations

import asyncio

import pytest

from {{ project_slug }}.adapters.cache.memory_cache import MemoryCacheAdapter


@pytest.mark.asyncio
class TestMemoryCache:
    """Test suite for memory cache operations."""

    async def test_set_and_get(self) -> None:
        """Verify cache set and get round-trip."""
        cache = MemoryCacheAdapter()
        await cache.set("key1", "some-value")
        result = await cache.get("key1")
        assert result == "some-value"

    async def test_get_missing_key(self) -> None:
        """Verify None returned for missing key."""
        cache = MemoryCacheAdapter()
        result = await cache.get("nonexistent")
        assert result is None

    async def test_delete(self) -> None:
        """Verify cache entry deletion."""
        cache = MemoryCacheAdapter()
        await cache.set("key1", "value")
        deleted = await cache.delete("key1")
        assert deleted is True
        assert await cache.get("key1") is None

    async def test_delete_missing_key(self) -> None:
        """Verify deleting missing key returns False."""
        cache = MemoryCacheAdapter()
        deleted = await cache.delete("nonexistent")
        assert deleted is False

    async def test_exists(self) -> None:
        """Verify existence check for cached entry."""
        cache = MemoryCacheAdapter()
        await cache.set("key1", "value")
        assert await cache.exists("key1") is True
        assert await cache.exists("missing") is False

    async def test_set_with_ttl(self) -> None:
        """Verify cache entry expires after TTL."""
        cache = MemoryCacheAdapter()
        await cache.set("expiring", "data", ttl_seconds=1)
        assert await cache.get("expiring") == "data"
        await asyncio.sleep(1.1)
        assert await cache.get("expiring") is None

    async def test_overwrite_existing_key(self) -> None:
        """Verify setting same key overwrites previous value."""
        cache = MemoryCacheAdapter()
        await cache.set("key1", "first")
        await cache.set("key1", "second")
        assert await cache.get("key1") == "second"
