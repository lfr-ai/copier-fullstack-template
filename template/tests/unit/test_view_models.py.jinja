"""Unit tests for base view model."""

from __future__ import annotations

from {{ project_slug }}.ports.web.view_models.base import BaseViewModel


class TestBaseViewModel:
    """Test suite for BaseViewModel."""

    def test_default_values(self) -> None:
        """Verify default field values."""
        view_model = BaseViewModel()
        assert view_model.title == ""
        assert view_model.messages == []
        assert view_model.is_authenticated is False

    def test_custom_title(self) -> None:
        """Verify title can be set."""
        view_model = BaseViewModel(title="Home Page")
        assert view_model.title == "Home Page"

    def test_whitespace_stripping(self) -> None:
        """Verify string fields strip whitespace."""
        view_model = BaseViewModel(title="  padded  ")
        assert view_model.title == "padded"

    def test_messages_list(self) -> None:
        """Verify messages accept list of strings."""
        view_model = BaseViewModel(messages=["info", "warning"])
        assert len(view_model.messages) == 2
        assert "info" in view_model.messages

    def test_is_authenticated_flag(self) -> None:
        """Verify authentication flag can be set."""
        view_model = BaseViewModel(is_authenticated=True)
        assert view_model.is_authenticated is True
