"""Unit tests for settings factory."""

from __future__ import annotations

import os
from unittest.mock import patch

from {{ project_slug }}.config.settings import get_settings
from {{ project_slug }}.config.settings.base import BaseAppSettings
from {{ project_slug }}.config.settings.local import LocalSettings
from {{ project_slug }}.config.settings.production import ProductionSettings
from {{ project_slug }}.config.settings.test import TestSettings as AppTestSettings


class TestSettingsFactory:
    """Test suite for environment-based settings factory."""

    @patch.dict(os.environ, {"{{ project_slug | upper }}_ENVIRONMENT": "local"})
    def test_local_environment(self) -> None:
        """Verify local environment returns LocalSettings."""
        settings = get_settings()
        assert isinstance(settings, LocalSettings)

    @patch.dict(os.environ, {"{{ project_slug | upper }}_ENVIRONMENT": "test"})
    def test_test_environment(self) -> None:
        """Verify test environment returns AppTestSettings."""
        settings = get_settings()
        assert isinstance(settings, AppTestSettings)

    @patch.dict(os.environ, {"{{ project_slug | upper }}_ENVIRONMENT": "production"})
    def test_production_environment(self) -> None:
        """Verify production environment returns ProductionSettings."""
        settings = get_settings()
        assert isinstance(settings, ProductionSettings)

    @patch.dict(os.environ, {"{{ project_slug | upper }}_ENVIRONMENT": "staging"})
    def test_staging_environment(self) -> None:
        """Verify staging environment returns ProductionSettings."""
        settings = get_settings()
        assert isinstance(settings, ProductionSettings)

    def test_default_environment(self) -> None:
        """Verify fallback to LocalSettings when env var is missing."""
        env_key = "{{ project_slug | upper }}_ENVIRONMENT"
        with patch.dict(os.environ, {}, clear=False):
            os.environ.pop(env_key, None)
            settings = get_settings()
            assert isinstance(settings, (LocalSettings, BaseAppSettings))

    def test_base_settings_defaults(self) -> None:
        """Verify base settings have expected defaults."""
        settings = BaseAppSettings()
        assert settings.debug is False
        assert settings.log_level == "INFO"
        assert settings.port == 8000
        assert settings.host == "127.0.0.1"
