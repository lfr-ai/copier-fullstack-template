"""Integration tests for API endpoints."""

from __future__ import annotations

import sys

import pytest
from httpx import AsyncClient

API_PREFIX = "/api/v1"
pytestmark = [
    pytest.mark.asyncio,
    pytest.mark.skipif(
        sys.platform == "win32",
        reason="Async integration tests are skipped on Windows due event loop conflicts",
    ),
]


class TestHealthEndpoints:
    """Test suite for health check API endpoints."""

    async def test_health_check(self, client: AsyncClient) -> None:
        """Verify health endpoint returns healthy status."""
        response = await client.get(f"{API_PREFIX}/health")
        assert response.status_code == 200
        assert response.json()["status"] == "healthy"

    async def test_readiness_check(self, client: AsyncClient) -> None:
        """Verify readiness endpoint returns ready status."""
        response = await client.get(f"{API_PREFIX}/health/ready")
        assert response.status_code == 200
        assert response.json()["status"] == "ready"


class TestUserEndpoints:
    """Test suite for user management API endpoints."""

    async def test_create_user(self, client: AsyncClient) -> None:
        """Verify user creation endpoint."""
        payload = {
            "email": "test@example.com",
            "display_name": "Test User",
        }
        response = await client.post(f"{API_PREFIX}/users", json=payload)
        assert response.status_code == 201
        data = response.json()
        assert data["email"] == "test@example.com"

    async def test_get_user_not_found(self, client: AsyncClient) -> None:
        """Verify 404 for nonexistent user."""
        response = await client.get(f"{API_PREFIX}/users/99999")
        assert response.status_code == 404
