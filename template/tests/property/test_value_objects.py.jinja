"""Property-based tests for value objects using Hypothesis."""

from __future__ import annotations

from hypothesis import given, strategies as st

from {{ project_slug }}.utils.validators import is_valid_email


class TestEmailProperty:
    """Property-based tests for email validation."""

    @given(st.emails())
    def test_hypothesis_emails_are_valid(self, email: str) -> None:
        """Verify Hypothesis-generated emails pass validation."""
        # Hypothesis generates RFC-valid emails; most should pass
        # Some edge cases may not match our simple regex
        result = is_valid_email(email)
        assert isinstance(result, bool)

    @given(st.text(min_size=1, max_size=50).filter(lambda s: "@" not in s))
    def test_strings_without_at_are_invalid(self, text: str) -> None:
        """Verify strings without @ symbol are invalid emails."""
        assert is_valid_email(text) is False
