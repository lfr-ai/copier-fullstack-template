"""Base command handler for CQRS write operations."""

from __future__ import annotations

from abc import ABC, abstractmethod
from typing import Generic, TypeVar

from {{ project_slug }}.core.interfaces.unit_of_work import UnitOfWork


CommandT = TypeVar("CommandT")
ResultT = TypeVar("ResultT")


class CommandHandler(ABC, Generic[CommandT, ResultT]):
    """Abstract base for command handlers.

    Implements CQRS write side with unit of work
    for transactional consistency.
    """

    def __init__(self, uow: UnitOfWork) -> None:
        """Initialize command handler.

        Args:
            uow: Unit of work for transactional boundaries.
        """
        self._uow = uow

    @abstractmethod
    async def handle(self, command: CommandT) -> ResultT:
        """Execute command and return result.

        Args:
            command: Command payload to process.

        Returns:
            Command execution result.
        """
        ...
