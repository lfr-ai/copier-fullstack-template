"""User management API routes."""

from __future__ import annotations

from typing import Final

from fastapi import APIRouter, HTTPException

from {{ project_slug }}.application.dtos.user_dto import CreateUserDTO, UserDTO

router = APIRouter()
HTTP_NOT_FOUND: Final[int] = 404
_FIRST_USER_ID: int = 1
_USERS: dict[int, UserDTO] = {}


def _next_user_id() -> int:
    """Return next in-memory user identifier."""
    if not _USERS:
        return _FIRST_USER_ID
    return max(_USERS) + 1


@router.post("/users", response_model=UserDTO, status_code=201)
async def create_user(payload: CreateUserDTO) -> UserDTO:
    """Create new user.

    Args:
        payload: User creation data.

    Returns:
        Created user data.
    """
    user_id = _next_user_id()
    user = UserDTO(
        id=str(user_id),
        email=payload.email,
        display_name=payload.display_name,
        is_active=True,
    )
    _USERS[user_id] = user
    return user


@router.get("/users/{user_id}", response_model=UserDTO)
async def get_user(user_id: int) -> UserDTO:
    """Retrieve user by ID.

    Args:
        user_id: User primary key.

    Returns:
        User data.

    Raises:
        HTTPException: If user not found.
    """
    user = _USERS.get(user_id)
    if user is None:
        raise HTTPException(
            status_code=HTTP_NOT_FOUND,
            detail="User not found",
        )
    return user
