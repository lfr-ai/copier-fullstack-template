"""FastAPI application factory."""

from __future__ import annotations

import logging

from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware

from {{ project_slug }}.ports.api.middleware.error_handler import register_error_handlers
from {{ project_slug }}.ports.api.middleware.request_id import RequestIdMiddleware
from {{ project_slug }}.ports.api.routes import health
from {{ project_slug }}.ports.api.routes import users


logger = logging.getLogger(__name__)
API_VERSION = "v1"


def create_api_app(*, debug: bool = False) -> FastAPI:
    """Create and configure FastAPI application.

    Factory function wiring middleware, routes, and error handlers.

    Args:
        debug: Enable debug mode with verbose logging.

    Returns:
        Configured FastAPI instance.
    """
    app = FastAPI(
        title="{{ project_name }}",
        version=API_VERSION,
        debug=debug,
        docs_url="/api/docs",
        redoc_url="/api/redoc",
        openapi_url="/api/openapi.json",
    )

    _configure_middleware(app)
    _register_routes(app)
    register_error_handlers(app)

    logger.info("API application created (debug=%s)", debug)
    return app


def _configure_middleware(app: FastAPI) -> None:
    """Configure application middleware stack.

    Args:
        app: FastAPI application instance.
    """
    app.add_middleware(RequestIdMiddleware)
    app.add_middleware(
        CORSMiddleware,
        allow_origins=["*"],
        allow_credentials=True,
        allow_methods=["*"],
        allow_headers=["*"],
    )


def _register_routes(app: FastAPI) -> None:
    """Register API route modules.

    Args:
        app: FastAPI application instance.
    """
    prefix = f"/api/{API_VERSION}"
    app.include_router(health.router, prefix=prefix, tags=["health"])
    app.include_router(users.router, prefix=prefix, tags=["users"])
