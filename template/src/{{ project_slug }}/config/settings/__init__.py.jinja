"""Settings module with environment-based factory."""

from __future__ import annotations

import os

from {{ project_slug }}.config.settings.base import BaseAppSettings
from {{ project_slug }}.config.settings.local import LocalSettings
from {{ project_slug }}.config.settings.production import ProductionSettings
from {{ project_slug }}.config.settings.test import TestSettings
from {{ project_slug }}.core.enums.environment import Environment

_SETTINGS_MAP: dict[Environment, type[BaseAppSettings]] = {
    Environment.LOCAL: LocalSettings,
    Environment.DEV: LocalSettings,
    Environment.TEST: TestSettings,
    Environment.STAGING: ProductionSettings,
    Environment.PRODUCTION: ProductionSettings,
}


def get_settings() -> BaseAppSettings:
    """Create settings instance based on environment variable.

    Reads APP_ENVIRONMENT to select the appropriate settings class.

    Returns:
        Configured application settings.
    """
    env_name = os.getenv("APP_ENVIRONMENT", "local").upper()
    environment = Environment(env_name.lower())
    settings_class = _SETTINGS_MAP.get(environment, LocalSettings)
    return settings_class()
