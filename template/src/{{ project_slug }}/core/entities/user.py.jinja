"""User domain entity."""

from __future__ import annotations

from dataclasses import dataclass, field

from {{ project_slug }}.core.entities.base import Entity, _generate_id, _utcnow


@dataclass(slots=True)
class User(Entity):
    """User domain entity with authentication attributes.

    Represents a user in the system with email-based
    identification and activation status.
    """

    id: str = field(default_factory=_generate_id)
    email: str = ""
    display_name: str = ""
    is_active: bool = True
    created_at: str = field(default_factory=lambda: _utcnow().isoformat())
