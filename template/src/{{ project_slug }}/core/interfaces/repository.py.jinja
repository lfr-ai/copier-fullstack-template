"""Repository protocol definitions for domain persistence."""

from __future__ import annotations

from typing import Protocol, TypeVar, runtime_checkable

from {{ project_slug }}.core.entities.base import Entity


EntityT = TypeVar("EntityT", bound=Entity)


@runtime_checkable
class Repository(Protocol[EntityT]):
    """Generic repository protocol for entity persistence."""

    async def get_by_id(self, entity_id: str) -> EntityT | None:
        """Retrieve entity by unique identifier.

        Args:
            entity_id: Unique entity identifier.

        Returns:
            Entity instance or None if not found.
        """
        ...

    async def add(self, entity: EntityT) -> EntityT:
        """Persist new entity.

        Args:
            entity: Entity instance to persist.

        Returns:
            Persisted entity with generated fields populated.
        """
        ...

    async def update(self, entity: EntityT) -> EntityT:
        """Update existing entity.

        Args:
            entity: Entity instance with updated fields.

        Returns:
            Updated entity instance.
        """
        ...

    async def delete(self, entity_id: str) -> bool:
        """Remove entity by identifier.

        Args:
            entity_id: Unique entity identifier.

        Returns:
            True if entity was deleted, False if not found.
        """
        ...

    async def list_all(
        self,
        *,
        offset: int = 0,
        limit: int = 100,
    ) -> list[EntityT]:
        """Retrieve paginated list of entities.

        Args:
            offset: Number of records to skip.
            limit: Maximum records to return.

        Returns:
            List of entity instances.
        """
        ...
