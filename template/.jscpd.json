{
  "threshold": 3,
  "skipBlocks": [
    {
      "open": "\"\"\"",
      "close": "\"\"\""
    }
  ],
  "ignore": [
    "node_modules",
    "dist",
    "build",
    ".venv",
    "__pycache__",
    "*.egg-info",
    ".tox",
    ".git",
    "*.lock",
    "*.min.js",
    "*.min.css",
    "bun.lock",
    "uv.lock",
    "package-lock.json",
    "alembic/versions",
    "htmlcov",
    "coverage",
    ".lycheecache",
    "logs/**"
  ],
  "format": ["python", "typescript", "javascript", "markup", "css"],
  "absolute": true,
  "gitignore": true,
  "blame": false,
  "exitCode": 1
}
