#!/usr/bin/env zsh
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

# Install Node.js via fnm and pnpm

NODE_TARGET_VERSION="${1:-{{ node_version }}}"
PNPM_TARGET_VERSION="9.15.4"

install_fnm() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    if command -v fnm &>/dev/null; then
        echo "fnm already installed: $(fnm --version)"
        return 0
    fi

    echo "Installing fnm (Fast Node Manager)..."
    curl -fsSL https://fnm.vercel.app/install | bash

    export PATH="${HOME}/.local/share/fnm:${HOME}/.fnm:${PATH}"
    eval "$(fnm env --use-on-cd --shell zsh 2>/dev/null || true)"

    if ! command -v fnm &>/dev/null; then
        echo "ERROR: fnm installation failed"
        return 1
    fi

    echo "fnm installed: $(fnm --version)"
}

install_node() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    local target_version="${1}"

    echo "Installing Node.js ${target_version}..."
    fnm install "${target_version}"
    fnm use "${target_version}"
    fnm default "${target_version}"

    echo "Node.js installed: $(node --version)"
}

install_pnpm() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    if command -v pnpm &>/dev/null; then
        echo "pnpm already installed: $(pnpm --version)"
        return 0
    fi

    echo "Installing pnpm ${PNPM_TARGET_VERSION}..."
    corepack enable
    corepack prepare "pnpm@${PNPM_TARGET_VERSION}" --activate

    if ! command -v pnpm &>/dev/null; then
        npm install -g "pnpm@${PNPM_TARGET_VERSION}"
    fi

    echo "pnpm installed: $(pnpm --version)"
}

main() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    echo "Target Node.js version: ${NODE_TARGET_VERSION}"
    echo "Target pnpm version: ${PNPM_TARGET_VERSION}"
    echo ""

    install_fnm
    install_node "${NODE_TARGET_VERSION}"
    install_pnpm

    echo ""
    echo "=== Installation Verification ==="
    echo "fnm:    $(fnm --version 2>/dev/null || echo 'NOT FOUND')"
    echo "Node:   $(node --version 2>/dev/null || echo 'NOT FOUND')"
    echo "pnpm:   $(pnpm --version 2>/dev/null || echo 'NOT FOUND')"
    echo ""
    echo "Installation complete"
}

main "$@"
