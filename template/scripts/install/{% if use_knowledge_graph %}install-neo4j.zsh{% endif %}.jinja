#!/usr/bin/env zsh
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

# Install Neo4j graph database (Community Edition).
# Supports Linux (apt/dnf), macOS (homebrew), and container-based fallback.
# Reference: https://neo4j.com/docs/operations-manual/current/installation/

NEO4J_MAJOR="2026"

detect_platform() {
emulate -L zsh
local os_type
os_type="$(uname -s)"
case "${os_type}" in
Linux)
if [[ -f /proc/version ]] && grep -qi microsoft /proc/version; then
print "wsl"
else
print "linux"
fi
;;
Darwin) print "macos" ;;
*) print "unknown" ;;
esac
}

check_existing() {
emulate -L zsh
if command -v neo4j &>/dev/null; then
local version
version="$(neo4j --version 2>/dev/null)"
print "Neo4j already installed: ${version}"
return 0
fi
# Check container-based install
local runtime="{{ container_runtime }}"
if command -v "${runtime}" &>/dev/null; then
if "${runtime}" ps -a --format '{{ '{{' }}.Names{{ '}}' }}' 2>/dev/null | grep -q neo4j; then
print "Neo4j container exists."
return 0
fi
fi
return 1
}

_ensure_java21() {
emulate -L zsh
# Neo4j 2025.x+ requires Java 21 (Java 25 also supported from 2025.10+).
if command -v java &>/dev/null; then
local java_ver
java_ver="$(java -version 2>&1 | head -1 | sed 's/.*"\([0-9]*\).*/\1/')"
if (( java_ver >= 21 )); then
print "Java ${java_ver} detected -- OK"
return 0
fi
fi

print "Installing OpenJDK 21..."
if command -v apt-get &>/dev/null; then
sudo apt-get update -qq
sudo apt-get install -y openjdk-21-jre-headless
elif command -v dnf &>/dev/null; then
sudo dnf install -y java-21-openjdk-headless
elif command -v brew &>/dev/null; then
brew install openjdk@21
else
print "WARNING: Could not install Java 21 automatically" >&2
print "Install OpenJDK 21 from https://openjdk.org/ before starting Neo4j" >&2
fi
}

install_neo4j_linux() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

print "Installing Neo4j on Linux..."

_ensure_java21

if command -v apt-get &>/dev/null; then
# Debian/Ubuntu -- Official Neo4j apt repository
# Reference: https://neo4j.com/docs/operations-manual/current/installation/linux/debian/
if [[ ! -f /etc/apt/sources.list.d/neo4j.list ]]; then
sudo mkdir -p /etc/apt/keyrings
wget -O - https://debian.neo4j.com/neotechnology.gpg.key \
| sudo gpg --dearmor -o /etc/apt/keyrings/neotechnology.gpg
sudo chmod a+r /etc/apt/keyrings/neotechnology.gpg
echo 'deb [signed-by=/etc/apt/keyrings/neotechnology.gpg] https://debian.neo4j.com stable latest' \
| sudo tee /etc/apt/sources.list.d/neo4j.list > /dev/null
fi
sudo apt-get update -qq
sudo apt-get install -y neo4j

elif command -v dnf &>/dev/null; then
# RHEL/CentOS/Fedora -- Official Neo4j RPM repository
# Reference: https://neo4j.com/docs/operations-manual/current/installation/linux/rpm/
sudo rpm --import https://debian.neo4j.com/neotechnology.gpg.key 2>/dev/null || true
if [[ ! -f /etc/yum.repos.d/neo4j.repo ]]; then
sudo tee /etc/yum.repos.d/neo4j.repo > /dev/null <<'REPO' [neo4j] name=Neo4j RPM Repository
    baseurl=https://yum.neo4j.com/stable/latest enabled=1 gpgcheck=1 REPO fi sudo dnf install -y neo4j else
    print "No supported package manager (apt/dnf), using container..." _install_neo4j_container return fi # Set initial
    password (avoids default-password prompt on first login) if command -v neo4j-admin &>/dev/null; then
    print "Setting initial Neo4j password..."
    sudo neo4j-admin dbms set-initial-password "changeme" 2>/dev/null || true
    fi

    _install_python_driver
    }

    install_neo4j_macos() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    print "Installing Neo4j on macOS..."

    _ensure_java21

    if command -v brew &>/dev/null; then
    brew install neo4j
    else
    print "Homebrew not found, using container..."
    _install_neo4j_container
    return
    fi

    _install_python_driver
    }

    _install_neo4j_container() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    local runtime="{{ container_runtime }}"
    if ! command -v "${runtime}" &>/dev/null; then
    print "Container runtime '${runtime}' not found." >&2
    print "Install {{ container_runtime }} first or use a system package." >&2
    return 1
    fi

    print "Starting Neo4j via ${runtime}..."
    "${runtime}" run -d \
    --name neo4j \
    --restart unless-stopped \
    -p 7474:7474 \
    -p 7687:7687 \
    -e NEO4J_AUTH=neo4j/changeme \
    -v neo4j-data:/data \
    neo4j:5-community

    print "Neo4j started on bolt://localhost:7687 (user: neo4j, password: changeme)"
    print "Web UI: http://localhost:7474"
    print "WARNING: Default credentials -- change NEO4J_AUTH for any non-local environment!"
    }

    _install_python_driver() {
    emulate -L zsh
    # Install Python driver via uv if available, else pip
    if command -v uv &>/dev/null; then
    uv pip install --upgrade "neo4j>=5.0"
    else
    python3 -m pip install --upgrade "neo4j>=5.0"
    fi
    }

    main() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    print "==== Neo4j Installation ===="
    if check_existing; then
    print "Neo4j is already available."
    _install_python_driver 2>/dev/null || true
    return 0
    fi

    local platform
    platform="$(detect_platform)"

    case "${platform}" in
    linux|wsl) install_neo4j_linux ;;
    macos) install_neo4j_macos ;;
    *)
    print "Unsupported platform: ${platform}, trying container..." >&2
    _install_neo4j_container
    ;;
    esac

    print "Neo4j installation complete."
    }

    main "$@"