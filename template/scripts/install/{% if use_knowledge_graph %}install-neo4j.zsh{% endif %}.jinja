#!/usr/bin/env zsh
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

# Install Neo4j graph database.
# Supports Linux (apt), macOS (homebrew), and Docker-based installs.

detect_platform() {
emulate -L zsh
local os_type
os_type="$(uname -s)"
case "${os_type}" in
Linux)
if [[ -f /proc/version ]] && grep -qi microsoft /proc/version; then
print "wsl"
else
print "linux"
fi
;;
Darwin) print "macos" ;;
*) print "unknown" ;;
esac
}

check_existing() {
emulate -L zsh
if command -v neo4j &>/dev/null; then
local version
version="$(neo4j --version 2>/dev/null)"
print "Neo4j already installed: ${version}"
return 0
fi
# Check Docker-based install
if command -v docker &>/dev/null; then
if docker ps -a --format '{{ '{{' }}.Names{{ '}}' }}' 2>/dev/null | grep -q neo4j; then
print "Neo4j container exists."
return 0
fi
fi
return 1
}

install_neo4j_linux() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

print "Installing Neo4j on Linux..."
if command -v apt-get &>/dev/null; then
# Add Neo4j repository
if [[ ! -f /etc/apt/sources.list.d/neo4j.list ]]; then
wget -qO - https://debian.neo4j.com/neotechnology.gpg.key | sudo gpg --dearmor -o
/usr/share/keyrings/neo4j-archive-keyring.gpg
echo "deb [signed-by=/usr/share/keyrings/neo4j-archive-keyring.gpg] https://debian.neo4j.com stable latest" | sudo tee
/etc/apt/sources.list.d/neo4j.list
fi
sudo apt-get update -qq
sudo apt-get install -y neo4j
else
print "apt-get not available, using Docker instead..."
_install_neo4j_docker
fi

# Install Python driver
pip install --upgrade "neo4j>=5.0"
}

install_neo4j_macos() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

print "Installing Neo4j on macOS..."
if command -v brew &>/dev/null; then
brew install neo4j
else
print "Homebrew not found, using Docker..."
_install_neo4j_docker
fi
pip install --upgrade "neo4j>=5.0"
}

_install_neo4j_docker() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

if ! command -v docker &>/dev/null; then
print "Docker not found. Install Docker first or use the system package." >&2
return 1
fi

print "Starting Neo4j via Docker..."
docker run -d \
--name neo4j \
--restart unless-stopped \
-p 7474:7474 \
-p 7687:7687 \
-e NEO4J_AUTH=neo4j/changeme \
-v neo4j-data:/data \
neo4j:5-community

print "Neo4j started on bolt://localhost:7687 (user: neo4j, password: changeme)"
print "Web UI: http://localhost:7474"
}

main() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

print "==== Neo4j Installation ===="
if check_existing; then
print "Neo4j is already available."
# Still ensure Python driver is present
pip install --upgrade "neo4j>=5.0" 2>/dev/null || true
return 0
fi

local platform
platform="$(detect_platform)"

case "${platform}" in
linux|wsl) install_neo4j_linux ;;
macos) install_neo4j_macos ;;
*)
print "Unsupported platform: ${platform}, trying Docker..." >&2
_install_neo4j_docker
;;
esac

print "Neo4j installation complete."
}

main "$@"