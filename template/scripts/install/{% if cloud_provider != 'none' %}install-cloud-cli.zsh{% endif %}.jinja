#!/usr/bin/env zsh
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT


CLOUD_PROVIDER="{{ cloud_provider }}"

detect_platform() {
emulate -L zsh

local os_type
os_type="$(uname -s)"

case "${os_type}" in
Linux)
if [[ -f /proc/version ]] && grep -qi microsoft /proc/version; then
print "wsl"
else
print "linux"
fi
;;
Darwin) print "macos" ;;
*) print "unknown" ;;
esac
}


install_azure_cli() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

if command -v az &>/dev/null; then
print "Azure CLI already installed: $(az version --output tsv 2>/dev/null | head -1)"
return 0
fi

print "Installing Azure CLI..."

local platform
platform="$(detect_platform)"

case "${platform}" in
linux|wsl)
if command -v apt-get &>/dev/null; then
curl -sL https://aka.ms/InstallAzureCLIDeb | sudo bash
elif command -v dnf &>/dev/null; then
sudo rpm --import https://packages.microsoft.com/keys/microsoft.asc
sudo dnf install -y azure-cli
elif command -v pip3 &>/dev/null; then
pip3 install azure-cli
else
print "Unsupported Linux distro. See https://aka.ms/InstallAzureCli"
return 1
fi
;;
macos)
if command -v brew &>/dev/null; then
brew install azure-cli
else
print "Install Homebrew first, or see https://aka.ms/InstallAzureCli"
return 1
fi
;;
*)
print "Unsupported platform. See https://aka.ms/InstallAzureCli"
return 1
;;
esac

print "Azure CLI installed: $(az version --output tsv 2>/dev/null | head -1)"

print "Installing Bicep CLI..."
az bicep install 2>/dev/null || print "Bicep install deferred (login may be required)"
}


main() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

print "=== Cloud CLI Installer ==="
print "Provider: ${CLOUD_PROVIDER}"
print ""

case "${CLOUD_PROVIDER}" in
azure)
install_azure_cli
;;
none)
print "No cloud provider selected -- skipping cloud CLI installation"
return 0
;;
*)
print "Unknown cloud provider: ${CLOUD_PROVIDER}"
return 1
;;
esac

print ""
print "Cloud CLI installation complete"
}

main "$@"