#!/usr/bin/env zsh
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT


CONTAINER_ENGINE="${1:-{{ container_runtime }}}"

install_docker_linux() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

if command -v docker &>/dev/null; then
print "Docker already installed: $(docker --version)"
return 0
fi

print "Installing Docker Engine..."

# Remove conflicting packages (apt-based distros only)
if command -v apt-get &>/dev/null; then
for pkg in docker.io docker-doc docker-compose docker-compose-v2 podman-docker containerd runc; do
sudo apt-get remove -y "${pkg}" 2>/dev/null || true
done
fi

if command -v apt-get &>/dev/null; then
sudo apt-get update -qq
sudo apt-get install -y -qq ca-certificates curl
sudo install -m 0755 -d /etc/apt/keyrings
sudo curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc
sudo chmod a+r /etc/apt/keyrings/docker.asc

echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] \
https://download.docker.com/linux/ubuntu \
$(. /etc/os-release && echo "${UBUNTU_CODENAME:-$VERSION_CODENAME}") stable" | \
sudo tee /etc/apt/sources.list.d/docker.list > /dev/null

sudo apt-get update -qq
sudo apt-get install -y -qq docker-ce docker-ce-cli containerd.io \
docker-buildx-plugin docker-compose-plugin
elif command -v dnf &>/dev/null; then
sudo dnf -y install dnf-plugins-core
sudo dnf-3 config-manager --add-repo https://download.docker.com/linux/fedora/docker-ce.repo 2>/dev/null || \
sudo dnf config-manager addrepo --from-repofile=https://download.docker.com/linux/fedora/docker-ce.repo
sudo dnf install -y docker-ce docker-ce-cli containerd.io \
docker-buildx-plugin docker-compose-plugin
sudo systemctl start docker
sudo systemctl enable docker
else
print "WARNING: Unsupported package manager, falling back to convenience script..."
curl -fsSL https://get.docker.com | sudo sh
fi

sudo usermod -aG docker "${USER}"

print "Docker installed: $(docker --version)"
print "NOTE: Log out and back in for group changes to take effect"
}

install_docker_macos() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

if command -v docker &>/dev/null; then
print "Docker already installed: $(docker --version)"
return 0
fi

print "Installing Docker Desktop for macOS..."

if command -v brew &>/dev/null; then
brew install --cask docker
else
print "ERROR: Homebrew not found"
print "Install Docker Desktop from: https://docs.docker.com/desktop/install/mac-install/"
return 1
fi

print "Docker Desktop installed. Launch it from Applications to complete setup."
}

install_podman_linux() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

if command -v podman &>/dev/null; then
print "Podman already installed: $(podman --version)"
return 0
fi

print "Installing Podman..."

if command -v apt-get &>/dev/null; then
sudo apt-get update -qq
sudo apt-get install -y -qq podman podman-compose
elif command -v dnf &>/dev/null; then
sudo dnf install -y podman podman-compose
else
print "ERROR: Unsupported package manager"
return 1
fi

print "Podman installed: $(podman --version)"
}

install_podman_macos() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

if command -v podman &>/dev/null; then
print "Podman already installed: $(podman --version)"
return 0
fi

print "Installing Podman for macOS..."

if command -v brew &>/dev/null; then
brew install podman podman-compose
podman machine init
print "Start Podman machine with: podman machine start"
else
print "ERROR: Homebrew not found"
return 1
fi
}

main() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

local os_type
os_type="$(uname -s)"

print "Container engine: ${CONTAINER_ENGINE}"
print "OS: ${os_type}"
print ""

case "${CONTAINER_ENGINE}" in
docker)
case "${os_type}" in
Linux) install_docker_linux ;;
Darwin) install_docker_macos ;;
*) print "ERROR: Unsupported OS: ${os_type}"; return 1 ;;
esac
;;
podman)
case "${os_type}" in
Linux) install_podman_linux ;;
Darwin) install_podman_macos ;;
*) print "ERROR: Unsupported OS: ${os_type}"; return 1 ;;
esac
;;
*)
print "ERROR: Unknown container engine: ${CONTAINER_ENGINE}"
return 1
;;
esac

print ""
print "Installation complete"
}

main "$@"