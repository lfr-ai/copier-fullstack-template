#!/usr/bin/env zsh
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

# Install Docker or Podman based on preference

CONTAINER_ENGINE="${1:-{{ container_runtime }}}"

install_docker_linux() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    if command -v docker &>/dev/null; then
        echo "Docker already installed: $(docker --version)"
        return 0
    fi

    echo "Installing Docker Engine..."

    for pkg in docker.io docker-doc docker-compose podman-docker containerd runc; do
        sudo apt-get remove -y "${pkg}" 2>/dev/null || true
    done

    curl -fsSL https://get.docker.com | sudo sh
    sudo usermod -aG docker "${USER}"

    echo "Docker installed: $(docker --version)"
    echo "NOTE: Log out and back in for group changes to take effect"
}

install_docker_macos() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    if command -v docker &>/dev/null; then
        echo "Docker already installed: $(docker --version)"
        return 0
    fi

    echo "Installing Docker Desktop for macOS..."

    if command -v brew &>/dev/null; then
        brew install --cask docker
    else
        echo "ERROR: Homebrew not found"
        echo "Install Docker Desktop from: https://docs.docker.com/desktop/install/mac-install/"
        return 1
    fi

    echo "Docker Desktop installed. Launch it from Applications to complete setup."
}

install_podman_linux() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    if command -v podman &>/dev/null; then
        echo "Podman already installed: $(podman --version)"
        return 0
    fi

    echo "Installing Podman..."

    if command -v apt-get &>/dev/null; then
        sudo apt-get update -qq
        sudo apt-get install -y -qq podman podman-compose
    elif command -v dnf &>/dev/null; then
        sudo dnf install -y podman podman-compose
    else
        echo "ERROR: Unsupported package manager"
        return 1
    fi

    echo "Podman installed: $(podman --version)"
}

install_podman_macos() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    if command -v podman &>/dev/null; then
        echo "Podman already installed: $(podman --version)"
        return 0
    fi

    echo "Installing Podman for macOS..."

    if command -v brew &>/dev/null; then
        brew install podman podman-compose
        podman machine init
        echo "Start Podman machine with: podman machine start"
    else
        echo "ERROR: Homebrew not found"
        return 1
    fi
}

main() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    local os_type
    os_type="$(uname -s)"

    echo "Container engine: ${CONTAINER_ENGINE}"
    echo "OS: ${os_type}"
    echo ""

    case "${CONTAINER_ENGINE}" in
        docker)
            case "${os_type}" in
                Linux)  install_docker_linux ;;
                Darwin) install_docker_macos ;;
                *) echo "ERROR: Unsupported OS: ${os_type}"; return 1 ;;
            esac
            ;;
        podman)
            case "${os_type}" in
                Linux)  install_podman_linux ;;
                Darwin) install_podman_macos ;;
                *) echo "ERROR: Unsupported OS: ${os_type}"; return 1 ;;
            esac
            ;;
        *)
            echo "ERROR: Unknown container engine: ${CONTAINER_ENGINE}"
            return 1
            ;;
    esac

    echo ""
    echo "Installation complete"
}

main "$@"
