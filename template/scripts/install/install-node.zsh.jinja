emulate -L zsh
setopt PIPE_FAIL ERR_EXIT


NODE_TARGET_VERSION="${1:-{{ node_version }}}"
PNPM_TARGET_VERSION="9.15.4"

install_fnm() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    if command -v fnm &>/dev/null; then
        print "fnm already installed: $(fnm --version)"
        return 0
    fi

    print "Installing fnm (Fast Node Manager)..."
    curl -fsSL https://fnm.vercel.app/install | bash

    export PATH="${HOME}/.local/share/fnm:${HOME}/.fnm:${PATH}"
    eval "$(fnm env --use-on-cd --shell zsh 2>/dev/null || true)"

    if ! command -v fnm &>/dev/null; then
        print "ERROR: fnm installation failed"
        return 1
    fi

    print "fnm installed: $(fnm --version)"
}

install_node() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    local target_version="${1}"

    print "Installing Node.js ${target_version}..."
    fnm install "${target_version}"
    fnm use "${target_version}"
    fnm default "${target_version}"

    print "Node.js installed: $(node --version)"
}

install_pnpm() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    if command -v pnpm &>/dev/null; then
        print "pnpm already installed: $(pnpm --version)"
        return 0
    fi

    print "Installing pnpm ${PNPM_TARGET_VERSION}..."
    corepack enable
    corepack prepare "pnpm@${PNPM_TARGET_VERSION}" --activate

    if ! command -v pnpm &>/dev/null; then
        npm install -g "pnpm@${PNPM_TARGET_VERSION}"
    fi

    print "pnpm installed: $(pnpm --version)"
}

main() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    print "Target Node.js version: ${NODE_TARGET_VERSION}"
    print "Target pnpm version: ${PNPM_TARGET_VERSION}"
    print ""

    install_fnm
    install_node "${NODE_TARGET_VERSION}"
    install_pnpm

    print ""
    print "=== Installation Verification ==="
    print "fnm:    $(fnm --version 2>/dev/null || print 'NOT FOUND')"
    print "Node:   $(node --version 2>/dev/null || print 'NOT FOUND')"
    print "pnpm:   $(pnpm --version 2>/dev/null || print 'NOT FOUND')"
    print ""
    print "Installation complete"
}

main "$@"
