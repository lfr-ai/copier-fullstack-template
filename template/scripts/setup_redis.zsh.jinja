{%- if use_redis %}
#!/usr/bin/env zsh
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

# Start Redis for local development
local CONTAINER_RUNTIME="{{ container_runtime }}"
local REDIS_PORT=6379
local CONTAINER_NAME="{{ project_slug }}-redis"

echo "Starting Redis container..."

if $CONTAINER_RUNTIME ps -a --format '{{ '{{.Names}}' }}' | grep -q "^${CONTAINER_NAME}$"; then
    $CONTAINER_RUNTIME start $CONTAINER_NAME
else
    $CONTAINER_RUNTIME run -d \
        --name $CONTAINER_NAME \
        -p ${REDIS_PORT}:6379 \
        redis:7-alpine
fi

echo "Redis running on port $REDIS_PORT"
{%- endif %}
