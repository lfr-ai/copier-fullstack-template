#!/usr/bin/env zsh
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT NO_UNSET


SCRIPT_DIR="${0:A:h}"
PROJECT_ROOT="${SCRIPT_DIR:h}"

check_command() {
emulate -L zsh
local cmd="${1}"
local install_hint="${2}"

if ! command -v "${cmd}" &>/dev/null; then
print "ERROR: ${cmd} not found"
print " Install with: ${install_hint}"
return 1
fi
}

verify_prerequisites() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

local missing_count=0

print "=== Checking prerequisites ==="

check_command "curl" "apt-get install -y curl OR brew install curl" || ((missing_count++))
check_command "git" "https://git-scm.com/downloads" || ((missing_count++))
check_command "task" "https://taskfile.dev/installation" || ((missing_count++))
check_command "uv" "curl -LsSf https://astral.sh/uv/install.sh | sh" || ((missing_count++))
check_command "bun" "curl -fsSL https://bun.sh/install | bash" || ((missing_count++))
check_command "{{ container_runtime }}" "zsh scripts/install/install-container.zsh" || ((missing_count++))
{% if use_caddy %}
check_command "caddy" "zsh scripts/install/install-caddy.zsh" || ((missing_count++))
{% endif %}
{% if cloud_provider == "azure" %}
check_command "az" "curl -sL https://aka.ms/InstallAzureCLIDeb | sudo bash" || ((missing_count++))
{% endif %}

if (( missing_count > 0 )); then
print ""
print "ERROR: ${missing_count} prerequisite(s) missing"
print " Run: zsh scripts/install/install-all.zsh"
return 1
fi

print "All prerequisites satisfied"
print ""
}

install_dependencies() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

print "=== Installing backend dependencies ==="
cd "${PROJECT_ROOT}/backend"
uv sync --all-groups
print "Backend dependencies installed"
print ""

print "=== Installing frontend dependencies ==="
cd "${PROJECT_ROOT}/frontend"
bun install --frozen-lockfile 2>/dev/null || bun install
print "Frontend dependencies installed"
print ""
{% if use_playwright %}

print "=== Installing Playwright browsers ==="
cd "${PROJECT_ROOT}/frontend"
bunx playwright install --with-deps chromium 2>/dev/null || \
print "WARNING: Playwright browser install failed -- run manually: bunx playwright install --with-deps"
print ""
{% endif %}

print "=== Setting up pre-commit hooks ==="
cd "${PROJECT_ROOT}/backend"
uv run pre-commit install
uv run pre-commit install --hook-type commit-msg
print "Pre-commit hooks installed"
print ""

# Ensure Copilot agent hook scripts are executable
if [[ -d "${PROJECT_ROOT}/.github/hooks/scripts" ]]; then
chmod +x "${PROJECT_ROOT}"/.github/hooks/scripts/*.sh 2>/dev/null || true
print "Copilot agent hook scripts marked executable"
fi
}

setup_environment() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

cd "${PROJECT_ROOT}"

if [[ ! -f .env ]]; then
print "=== Creating .env from .env.example ==="
cp .env.example .env
print ".env created. Review and replace all __CHANGE_ME__ placeholders before running shared/prod environments."
print ""
fi

print "Environment file strategy:"
print " - Local: .env (from .env.example)"
print " - Shared/dev server: .env.dev (from .env.example)"
print " - Test: .env.test (from .env.example)"
print " - Staging: .env.staging (from .env.example)"
print " - Production: .env.prod (from .env.example)"
print " - Optional local backend overrides: .env.local (from .env.local.example)"
print " - Optional local frontend overrides: frontend/.env.local (from frontend/.env.local.example)"
print " See the Per-Environment Quick Reference at the bottom of .env.example."
print ""

if [[ "${BOOTSTRAP_CREATE_ALL_ENV_FILES:-false}" == "true" ]]; then
for env_name in dev test staging prod; do
local target_file=".env.${env_name}"
if [[ ! -f "${target_file}" ]]; then
cp .env.example "${target_file}"
print "Created ${target_file} from .env.example — adjust values for ${env_name} environment"
fi
done
print ""
fi
}

verify_setup() {
emulate -L zsh
setopt PIPE_FAIL

print "=== Environment Summary ==="
print "Git: $(git --version 2>/dev/null || print 'NOT FOUND')"
print "Task: $(task --version 2>/dev/null || print 'NOT FOUND')"
print "UV: $(uv --version 2>/dev/null || print 'NOT FOUND')"
print "Python: $(python3 --version 2>/dev/null || print 'NOT FOUND')"
print "Bun: $(bun --version 2>/dev/null || print 'NOT FOUND')"
print "Container: $({{ container_runtime }} --version 2>/dev/null || print 'NOT FOUND')"
{% if use_caddy %}
print "Caddy: $(caddy version 2>/dev/null || print 'NOT FOUND')"
{% endif %}
{% if cloud_provider == "azure" %}
print "Azure CLI: $(az version --output tsv 2>/dev/null | head -1 || print 'NOT FOUND')"
{% endif %}
print ""
print "Bootstrap complete. Run 'task dev' to start developing."
}

main() {
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

cd "${PROJECT_ROOT}"

print "========================================="
print " {{ project_name }} Bootstrap"
print "========================================="
print ""

verify_prerequisites
setup_environment
install_dependencies
verify_setup
}

main "$@"
