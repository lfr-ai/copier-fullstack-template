#!/usr/bin/env zsh
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT


BACKEND_PORT="${PORT_BACKEND:-8000}"
FRONTEND_PORT="${PORT_FRONTEND:-3000}"

MAX_RETRIES=30
RETRY_INTERVAL=2

check_endpoint() {
emulate -L zsh
local name="${1}"
local url="${2}"
local retries=0

print "Checking ${name} at ${url}..."

while (( retries < MAX_RETRIES )); do if curl -sf "${url}"> /dev/null 2>&1; then
    print " OK ${name} is healthy"
    return 0
    fi
    ((retries++))
    sleep "${RETRY_INTERVAL}"
    done

    print " FAIL ${name} failed health check after ${MAX_RETRIES} retries"
    return 1
    }

    main() {
    emulate -L zsh
    setopt PIPE_FAIL ERR_EXIT

    print "=== Health Check ==="
    print ""

    local failures=0

    check_endpoint "Backend API" "http://localhost:${BACKEND_PORT}/health" || ((failures++))
    check_endpoint "Frontend" "http://localhost:${FRONTEND_PORT}" || ((failures++))

    print ""
    if (( failures > 0 )); then
    print "FAILED: ${failures} service(s) unhealthy"
    return 1
    fi

    print "All services healthy"
    }

    main "$@"
