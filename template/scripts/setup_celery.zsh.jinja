{%- if use_celery %}
#!/usr/bin/env zsh
emulate -L zsh
setopt PIPE_FAIL ERR_EXIT

# Start Celery worker for local development
echo "Starting Celery worker..."

uv run celery -A {{ project_slug }}.config.celery:celery_app worker \
    --loglevel=info \
    --concurrency=2 \
    --queues=default
{%- endif %}
