{
  "name": "{{ project_name }} Dev Container",
  "dockerComposeFile": "compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "overrideCommand": false,
  "waitFor": "postCreateCommand",
  "mounts": [
    "source={{ project_slug }}-uv-cache,target=/home/vscode/.cache/uv,type=volume",
    "source={{ project_slug }}-precommit-cache,target=/home/vscode/.cache/pre-commit,type=volume",
    "source={{ project_slug }}-zsh-history,target=/commandhistory,type=volume"
  ],
  "remoteEnv": {
    "PYTHONPATH": "/workspace/backend/src",
    "UV_LINK_MODE": "copy",
    "UV_CACHE_DIR": "/home/vscode/.cache/uv"
  },
  "forwardPorts": [8000, 3000{% if use_redis %}, 6379{% endif %}{% if database_backend in ("postgresql", "azure_postgresql") %}, 5432{% endif %}{% if use_storybook %}, 6006{% endif %}],
  "portsAttributes": {
    "8000": {
      "label": "FastAPI Backend",
      "onAutoForward": "openBrowserOnce"
    },
    "3000": {
      "label": "Frontend (Vite)"
    }{% if database_backend in ("postgresql", "azure_postgresql") %},
    "5432": {
      "label": "PostgreSQL"
    }{% endif %}{% if use_redis %},
    "6379": {
      "label": "Redis"
    }{% endif %}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        // Python
        "ms-python.python",
        "ms-python.debugpy",
        "charliermarsh.ruff",
        "astral-sh.ty",

        // JavaScript / TypeScript — Biome (replaces ESLint + Prettier)
        "biomejs.biome",
        "vitest.explorer",

        // Frontend / CSS
        "bradlc.vscode-tailwindcss",
        "anseki.vscode-color",
        "naumovs.color-highlight",

        // Data formats & editors
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml",
        "samuelcolvin.jinjahtml",
        "editorconfig.editorconfig",

        // Markdown & docs
        "davidanson.vscode-markdownlint",
        "shd101wyy.markdown-preview-enhanced",

        // Container & shell
        "exiasr.hadolint",
        "timonwong.shellcheck",

        // Git
        "waderyan.gitblame",
        "codezombiech.gitignore",

        // AI / Copilot
        "github.copilot-chat",

        // Spell checking
        "streetsidesoftware.code-spell-checker",

        // Quality of life
        "vscode-icons-team.vscode-icons",
        "wayou.vscode-todo-highlight"{% if database_backend == "postgresql" %},

        // Database (PostgreSQL)
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"{% elif database_backend == "sqlite" %},

        // Database (SQLite)
        "mtxr.sqltools",
        "mtxr.sqltools-driver-sqlite",
        "alexcvzz.vscode-sqlite"{% endif %}{% if use_playwright %},

        // E2E testing
        "ms-playwright.playwright"{% endif %}
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/backend/.venv/bin/python",
        "python.terminal.activateEnvironment": false,
        "python.testing.pytestEnabled": true,
        "editor.formatOnSave": true,
        "editor.rulers": [88],
        "editor.trimAutoWhitespace": true,
        "files.trimTrailingWhitespace": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
          }
        },
        "[typescript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[javascript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[json]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[jsonc]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[css]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[yaml]": {
          "editor.defaultFormatter": "redhat.vscode-yaml"
        },
        "[markdown]": {
          "editor.defaultFormatter": "davidanson.vscode-markdownlint"
        },
        "[toml]": {
          "editor.defaultFormatter": "tamasfe.even-better-toml"
        },
        "[shellscript]": {
          "editor.defaultFormatter": "timonwong.shellcheck"
        },
        "editor.autoIndentOnPaste": true,
        "editor.folding": false,
        "editor.tabCompletion": "on",
        "diffEditor.ignoreTrimWhitespace": true,
        "files.autoSave": "afterDelay",
        "workbench.iconTheme": "vscode-icons",
        "cSpell.language": "en",
        "files.associations": {
          "*.css": "tailwindcss",
          "Containerfile": "dockerfile",
          "Containerfile.*": "dockerfile"
        }
      }
    }
  },
  "postCreateCommand": "zsh scripts/bootstrap.zsh",
  "updateRemoteUserUID": true,
  "remoteUser": "vscode",
  "shutdownAction": "stopCompose"
}
