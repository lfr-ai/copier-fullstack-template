{
  "name": "{{ project_name }} Dev Container",
  "dockerComposeFile": "compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [8000, 3000{% if use_redis %}, 6379{% endif %}{% if database_backend == "postgresql" %}, 5432{% endif %}],
  "customizations": {
    "vscode": {
      "extensions": [
        // Python
        "ms-python.python",
        "ms-python.debugpy",
        "charliermarsh.ruff",
        "astral-sh.ty",

        // JavaScript / TypeScript
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "vitest.explorer",

        // Frontend / CSS
        "bradlc.vscode-tailwindcss",
        "naumovs.color-highlight",

        // Data formats & editors
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml",
        "samuelcolvin.jinjahtml",
        "editorconfig.editorconfig",

        // Markdown & docs
        "davidanson.vscode-markdownlint",
        "shd101wyy.markdown-preview-enhanced",

        // Container & shell
        "exiasr.hadolint",
        "timonwong.shellcheck",

        // Git
        "waderyan.gitblame",
        "codezombiech.gitignore",

        // AI / Copilot
        "github.copilot-chat",

        // Spell checking
        "streetsidesoftware.code-spell-checker",

        // Quality of life
        "vscode-icons-team.vscode-icons",
        "wayou.vscode-todo-highlight"{% if database_backend == "postgresql" %},

        // Database
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"{% endif %}{% if use_playwright %},

        // E2E testing
        "ms-playwright.playwright"{% endif %}
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/backend/.venv/bin/python",
        "python.terminal.activateEnvironment": false,
        "python.testing.pytestEnabled": true,
        "editor.formatOnSave": true,
        "editor.rulers": [88],
        "editor.trimAutoWhitespace": true,
        "files.trimTrailingWhitespace": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
          }
        },
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "prettier.printWidth": 88
        },
        "[javascript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "prettier.printWidth": 88
        },
        "[json]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "prettier.printWidth": 88
        },
        "[yaml]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "prettier.printWidth": 88
        },
        "[markdown]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "files.associations": {
          "*.css": "tailwindcss",
          "Containerfile": "dockerfile",
          "Containerfile.*": "dockerfile"
        }
      }
    }
  },
  "postCreateCommand": "zsh scripts/bootstrap.zsh",
  "remoteUser": "vscode"
}
