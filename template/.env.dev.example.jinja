
# ─── Dev environment file (shared development server / containers) ───
# Copy to .env.dev:  cp .env.dev.example .env.dev
# Use with:  task docker:dev  (or: docker compose -f compose.yml -f compose.dev.yml --env-file .env.dev up)
# Hostnames use container service names (db, redis) not localhost.

{{ project_slug | upper }}_ENVIRONMENT=dev
{{ project_slug | upper }}_DEBUG=true
{{ project_slug | upper }}_LOG_LEVEL=DEBUG
{{ project_slug | upper }}_SECRET_KEY=dev-secret-key-change-in-production-at-least-32-chars
{%- if database_backend in ('postgresql', 'azure_postgresql') %}
{{ project_slug | upper }}_DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/{{ project_slug }}_dev
{%- endif %}
{% if use_redis %}
{{ project_slug | upper }}_REDIS_URL=redis://redis:6379/0
{% endif %}
{% if use_celery %}
{{ project_slug | upper }}_CELERY_BROKER_URL=redis://redis:6379/1
{{ project_slug | upper }}_CELERY_RESULT_BACKEND=redis://redis:6379/1
{% endif %}
{% if use_auth %}
{{ project_slug | upper }}_JWT_SECRET_KEY=dev-jwt-secret-change-in-production-at-least-32-ch
{% endif %}
{% if secret_backend == 'azure_kv' %}
{{ project_slug | upper }}_AZURE_KEY_VAULT_URL=https://your-dev-vault.vault.azure.net/
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
{% endif %}

{{ project_slug | upper }}_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://dev.{{ project_slug | replace('_', '-') }}.example.com
