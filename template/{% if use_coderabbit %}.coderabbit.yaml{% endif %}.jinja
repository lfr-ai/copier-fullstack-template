# CodeRabbit Configuration — https://docs.coderabbit.ai/reference/configuration
# Auto-generated by copier-fullstack-template
# yaml-language-server: $schema=https://coderabbit.ai/integrations/schema.v2.json
---
language: "en-US"
tone_instructions: |
  Be concise, direct, and technically precise. Focus on actionable feedback.
  Prioritize security, maintainability, and adherence to Clean Architecture.
  Use code examples when suggesting improvements.
early_access: false
enable_free_tier: true

reviews:
  profile: "assertive"
  request_changes_workflow: true
  high_level_summary: true
  high_level_summary_placeholder: "@coderabbitai summary"
  high_level_summary_in_walkthrough: false
  auto_title_placeholder: "@coderabbitai"
  review_status: true
  review_details: true
  commit_status: true
  fail_commit_status: false
  collapse_walkthrough: true
  changed_files_summary: true
  sequence_diagrams: true
  estimate_code_review_effort: true
  assess_linked_issues: true
  related_issues: true
  related_prs: true
  suggested_labels: true
  auto_apply_labels: false
  suggested_reviewers: true
  auto_assign_reviewers: false
  poem: false
  in_progress_fortune: false
  enable_prompt_for_ai_agents: true
  abort_on_close: true
  disable_cache: false

  auto_review:
    enabled: true
    auto_incremental_review: true
    auto_pause_after_reviewed_commits: 0
    ignore_title_keywords:
      - "WIP"
      - "DO NOT MERGE"
      - "DRAFT"
      - "[skip ci]"
      - "[skip review]"
    labels: []
    drafts: false
    base_branches:
      - "main"
      - "develop"
      - "release/*"
      - "hotfix/*"
    ignore_usernames:
      - "dependabot[bot]"
      - "renovate[bot]"
      - "github-actions[bot]"

  path_filters:
    # Exclude auto-generated and vendored files
    - "!**/node_modules/**"
    - "!**/.venv/**"
    - "!**/venv/**"
    - "!**/__pycache__/**"
    - "!**/*.pyc"
    - "!**/dist/**"
    - "!**/build/**"
    - "!**/.next/**"
    - "!**/coverage/**"
    - "!**/.pytest_cache/**"
    - "!**/.tox/**"
    - "!**/.mypy_cache/**"
    - "!**/.ruff_cache/**"
    - "!**/htmlcov/**"
    # Exclude lock files (but review package manifests)
    - "!**/bun.lock"
    - "!**/uv.lock"
    - "!**/package-lock.json"
    - "!**/yarn.lock"
    - "!**/pnpm-lock.yaml"
    # Exclude generated API clients
    - "!**/openapi-client/**"
    # Exclude IDE configs (but review .vscode/settings.json if scoped)
    - "!**/.idea/**"
    # Exclude large data files
    - "!**/seeds/**/*.json"
    - "!**/fixtures/**/*.json"
    # Include all source code
    - "backend/src/**"
    - "backend/tests/**"
    - "frontend/src/**"
    - "frontend/tests/**"
    - "scripts/**"
    - "tasks/**"
{% if api_style in ("rest", "both") %}
    - "docs/api/**"
{% endif %}
{% if cloud_provider == "azure" %}
    - "infra/**"
{% endif %}

  path_instructions:
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # Clean Architecture Layer Instructions
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    - path: "backend/src/{{ project_slug }}/core/**"
      instructions: |
        This is the CORE (domain) layer — the innermost layer in Clean Architecture.

        STRICT RULES:
        - NO framework imports (no FastAPI, SQLAlchemy, Pydantic BaseSettings, Redis, httpx)
        - NO infrastructure dependencies whatsoever
        - ONLY stdlib imports + domain-specific pure Python libraries
        - Defines interfaces (protocols/ABCs) that outer layers implement
        - Contains domain entities, value objects, domain services, and domain events

        Check for:
        - Dependency Rule violations (importing from application/, infrastructure/, presentation/)
        - Framework leakage (any import from fastapi, sqlalchemy, redis, httpx, etc.)
        - Domain logic purity (no I/O operations, no side effects except domain events)
        - Proper use of Protocol classes for defining contracts
        - Type hints on all public methods and attributes

    - path: "backend/src/{{ project_slug }}/application/**"
      instructions: |
        This is the APPLICATION layer — orchestrates use cases using domain logic.

        RULES:
        - CAN import from: core/ only
        - CANNOT import from: infrastructure/, presentation/, composition/
        - Contains: Use cases, CQRS commands/queries, DTOs, mappers, application services
        - Orchestrates domain objects but contains no business rules itself

        Check for:
        - Dependency Rule violations (no infrastructure or presentation imports)
        - Proper separation of Commands (write) and Queries (read) if using CQRS
        - DTOs should be defined here, not in presentation layer
        - Use cases should be single-purpose and testable in isolation
        - Async methods should use protocols, not concrete implementations

    - path: "backend/src/{{ project_slug }}/infrastructure/**"
      instructions: |
        This is the INFRASTRUCTURE layer — implements interfaces defined in core/.

        RULES:
        - CAN import from: core/ and external libraries (SQLAlchemy, Redis, httpx, etc.)
        - CANNOT import from: application/, presentation/, composition/
        - Implements repository interfaces, cache adapters, external API clients
        - Contains database models, migrations, cache implementations

        Check for:
        - Proper implementation of core/ interfaces (Repository, UnitOfWork, etc.)
        - SQLAlchemy 2.x async patterns (async_sessionmaker, AsyncSession)
        - Connection pooling and proper resource cleanup
        - Error handling with proper exception translation to domain exceptions
        - No business logic — only technical concerns

    - path: "backend/src/{{ project_slug }}/presentation/**"
      instructions: |
        This is the PRESENTATION layer — exposes the application to the outside world.

        RULES:
        - CAN import from: application/, core/, and framework (FastAPI, Pydantic)
        - CANNOT import from: infrastructure/, composition/
        - Contains: API routes, request/response schemas, middleware, CLI commands
        - Translates between external formats and application DTOs

        Check for:
        - Proper Pydantic v2 model usage (model_config, field_validator, etc.)
        - FastAPI best practices (Depends for DI, proper status codes, OpenAPI docs)
        - Input validation at the edge (Pydantic schemas, not in use cases)
        - Proper error handling with HTTPException and custom exception handlers
        - No direct infrastructure access (use injected services)
{% if api_style in ("graphql", "both") %}
        - GraphQL resolvers should delegate to use cases, not contain logic
{% endif %}

    - path: "backend/src/{{ project_slug }}/composition/**"
      instructions: |
        This is the COMPOSITION ROOT — the only layer that can import from everywhere.

        RULES:
        - CAN import from: all layers (this is where DI wiring happens)
        - Contains: Dependency injection container, application factory, startup hooks
        - Assembles the application by wiring interfaces to implementations

        Check for:
        - Proper dependency injection setup
        - Lazy initialization patterns for heavy resources
        - Configuration-driven wiring (environment-based implementations)
        - Startup/shutdown lifecycle management

    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # Testing Instructions
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    - path: "backend/tests/unit/**"
      instructions: |
        Unit tests — fast, isolated, no I/O.

        REQUIREMENTS:
        - Use pytest with async support (pytest-asyncio)
        - Mock all external dependencies (use protocols from core/)
        - Use factories (factory_boy) for test data, not fixtures with hardcoded values
        - Test one behavior per test function
        - Follow Arrange-Act-Assert pattern
        - Name tests: test_<unit>_<scenario>_<expected_outcome>

    - path: "backend/tests/integration/**"
      instructions: |
        Integration tests — test real infrastructure interactions.

        REQUIREMENTS:
        - Use real database (PostgreSQL/SQLite test instance)
        - Use testcontainers or docker-compose services
        - Clean up test data after each test (use transactions/truncation)
        - Test repository implementations, not mocks
        - Mark with @pytest.mark.integration

    - path: "backend/tests/property/**"
      instructions: |
        Property-based tests using Hypothesis.

        REQUIREMENTS:
        - Use @given decorator with strategies
        - Test invariants, not specific values
        - Define custom strategies for domain objects
        - Use @settings for timeout/examples configuration
        - Mark with @pytest.mark.property

    - path: "frontend/src/**/*.test.{ts,tsx}"
      instructions: |
        Frontend tests using Vitest and React Testing Library.

        REQUIREMENTS:
        - Use user-centric queries (getByRole, getByLabelText, not getByTestId)
        - Test behavior, not implementation details
        - Use userEvent for interactions, not fireEvent
        - Mock API calls with MSW or vitest mocking
        - Test accessibility (axe-core integration)
        - Avoid testing implementation (no internal state checks)

    - path: "frontend/tests/**"
      instructions: |
        Frontend test utilities and E2E tests.

        For Playwright E2E tests:
        - Use Page Object Model pattern
        - Test critical user journeys
        - Use data-testid only when semantic queries aren't possible
        - Run against realistic test data
        - Handle flakiness with proper waits (not arbitrary sleeps)

    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # Configuration & Infrastructure
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    - path: "backend/src/{{ project_slug }}/config/**"
      instructions: |
        Application configuration using Pydantic Settings.

        REQUIREMENTS:
        - Use pydantic-settings for env var parsing
        - Define sensible defaults for development
        - Use SecretStr for sensitive values
        - Document all settings with Field(description=...)
        - Validate settings at startup (model_validator)
        - Support multiple environments (dev, test, staging, prod)

{% if cloud_provider == "azure" %}
    - path: "infra/**/*.bicep"
      instructions: |
        Azure Bicep infrastructure-as-code.

        REQUIREMENTS:
        - Use parameter files for environment-specific values
        - Follow Azure naming conventions
        - Enable diagnostic logging on all resources
        - Use managed identities instead of connection strings where possible
        - Configure RBAC with least-privilege principle
        - Use Key Vault references for secrets
        - Include resource locks for production resources
{% endif %}

    - path: ".github/workflows/**"
      instructions: |
        GitHub Actions CI/CD workflows.

        REQUIREMENTS:
        - Pin action versions with SHA (not just major version)
        - Use composite actions for reusable steps
        - Set appropriate timeouts on all jobs
        - Use concurrency groups to cancel stale runs
        - Cache dependencies (uv, bun, docker layers)
        - Use OIDC for cloud authentication (not long-lived secrets)
        - Set minimal permissions at job level

    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # Frontend Architecture
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    - path: "frontend/src/components/**"
      instructions: |
        React components using TypeScript.

        REQUIREMENTS:
        - Use functional components with hooks
        - Prefer composition over inheritance
        - Use Tailwind CSS v4 for styling (no inline styles or CSS modules)
        - Implement proper accessibility (ARIA attributes, keyboard navigation)
        - Use React.memo() only when profiling shows benefit
        - Extract complex logic to custom hooks
        - Use Radix UI primitives for accessible UI patterns

    - path: "frontend/src/hooks/**"
      instructions: |
        Custom React hooks.

        REQUIREMENTS:
        - Name must start with "use" prefix
        - Handle cleanup in useEffect return
        - Use useCallback/useMemo appropriately (not prematurely)
        - Document hook purpose and return type
        - Consider race conditions in async hooks

    - path: "frontend/src/stores/**"
      instructions: |
        Zustand state management stores.

        REQUIREMENTS:
        - Keep stores focused (single responsibility)
        - Use immer middleware for complex state updates
        - Define actions alongside state
        - Use selectors to minimize re-renders
        - Persist only necessary state

{% if api_style in ("rest", "both") %}
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # OpenAPI / REST API
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    - path: "docs/api/openapi*.yaml"
      instructions: |
        OpenAPI specification files.

        REQUIREMENTS:
        - Use OpenAPI 3.1.x specification
        - Include comprehensive examples for all endpoints
        - Define reusable components (schemas, responses, parameters)
        - Document all error responses (400, 401, 403, 404, 500)
        - Use semantic versioning in info.version
        - Include security schemes documentation
{% endif %}

{% if use_ai %}
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    # AI/LLM Components
    # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    - path: "backend/src/{{ project_slug }}/**/ai/**"
      instructions: |
        AI/LLM integration code.

        REQUIREMENTS:
        - Use LiteLLM for provider abstraction (not direct API calls)
        - Implement proper rate limiting and retry logic
        - Handle API errors gracefully with fallbacks
        - Log prompts and responses for debugging (redact PII)
        - Use structured outputs (Pydantic models) where possible
        - Implement cost tracking and budget limits
        - Cache responses where appropriate (embeddings, deterministic queries)
{% if use_langchain %}
        - Follow LangChain best practices for chains and agents
        - Use LCEL (LangChain Expression Language) for composable chains
{% endif %}
{% if use_llamaindex %}
        - Follow LlamaIndex patterns for indexing and retrieval
        - Use appropriate chunking strategies for document types
{% endif %}
{% if use_rag %}
        - Implement proper retrieval pipelines with reranking
        - Monitor retrieval quality metrics
{% endif %}
{% endif %}

  labeling_instructions:
    - label: "backend"
      instructions: "Apply when PR modifies backend/ directory (Python code)"
    - label: "frontend"
      instructions: "Apply when PR modifies frontend/ directory (TypeScript/React code)"
    - label: "infrastructure"
      instructions: "Apply when PR modifies infra/, .github/workflows/, or container files"
    - label: "documentation"
      instructions: "Apply when PR primarily modifies docs/ or *.md files"
    - label: "dependencies"
      instructions: "Apply when PR modifies pyproject.toml, package.json, or lock files"
    - label: "breaking-change"
      instructions: "Apply when PR introduces breaking changes to API or behavior"
    - label: "security"
      instructions: "Apply when PR affects authentication, authorization, or security-sensitive code"
    - label: "performance"
      instructions: "Apply when PR focuses on performance improvements"
{% if use_ai %}
    - label: "ai"
      instructions: "Apply when PR modifies AI/LLM/RAG related code"
{% endif %}
    - label: "tests"
      instructions: "Apply when PR primarily adds or modifies tests"

  finishing_touches:
    docstrings:
      enabled: true
    unit_tests:
      enabled: true
    simplify:
      enabled: true
    custom:
      - enabled: true
        name: "architecture-check"
        instructions: |
          Verify Clean Architecture Dependency Rule compliance:
          - core/ must not import from application/, infrastructure/, presentation/, composition/
          - application/ must not import from infrastructure/, presentation/, composition/
          - infrastructure/ must not import from presentation/, composition/
          - presentation/ must not import from composition/
          Flag any violations as critical issues.

      - enabled: true
        name: "naming-conventions"
        instructions: |
          Check adherence to naming conventions:
          - Python: snake_case for functions/variables, PascalCase for classes
          - TypeScript: camelCase for functions/variables, PascalCase for components/types
          - Files: snake_case.py for Python, kebab-case.tsx for React components
          - Test files: test_*.py for Python, *.test.tsx for React

  pre_merge_checks:
    override_requested_reviewers_only: false
    docstrings:
      mode: "warning"
      threshold: 80
    title:
      mode: "warning"
      requirements: |
        Must follow Conventional Commits format: type(scope): description
        Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore
        Scopes: backend, frontend, infra, ci, registry, scripts, docs, config, ai, deps
        Max 72 characters
    description:
      mode: "warning"
    issue_assessment:
      mode: "warning"
    custom_checks:
      - mode: "warning"
        name: "dependency-rule"
        instructions: |
          PASS if all imports respect Clean Architecture layer boundaries.
          FAIL if any inner layer imports from an outer layer.

      - mode: "warning"
        name: "test-coverage"
        instructions: |
          PASS if new code has corresponding unit tests or test modifications.
          WARN if test coverage appears insufficient for the changes.

  tools:
    # Python tools
    ruff:
      enabled: true
    # JavaScript/TypeScript tools
    biome:
      enabled: true
    eslint:
      enabled: false  # Using Biome instead
    # Shell scripts
    shellcheck:
      enabled: true
    # Container files
    hadolint:
      enabled: true
    # YAML files
    yamllint:
      enabled: true
    # Markdown files
    markdownlint:
      enabled: true
    # GitHub Actions
    actionlint:
      enabled: true
    # Security scanning
    gitleaks:
      enabled: true
    semgrep:
      enabled: true
    # Python type checking (via CI, not CodeRabbit directly)
    ast-grep:
      enabled: true
      rule_dirs: []
      essential_rules: true
    # GitHub checks integration
    github-checks:
      enabled: true
      timeout_ms: 120000
    # Language/Grammar
    languagetool:
      enabled: true
      enabled_only: false
      level: "default"
      disabled_rules:
        - "WHITESPACE_RULE"
        - "EN_QUOTES"
{% if use_ai %}
    # IaC security
    checkov:
      enabled: true
{% endif %}

chat:
  art: false
  allow_non_org_members: true
  auto_reply: true
  integrations:
    jira:
      usage: "auto"
    linear:
      usage: "auto"

knowledge_base:
  opt_out: false
  web_search:
    enabled: true
  code_guidelines:
    enabled: true
    filePatterns:
      - "CLAUDE.md"
      - ".claude/rules/*.md"
      - ".github/instructions/*.instructions.md"
      - "docs/conventions/*.md"
  learnings:
    scope: "auto"
  issues:
    scope: "auto"
  pull_requests:
    scope: "auto"
  jira:
    usage: "auto"
  linear:
    usage: "auto"
  mcp:
    usage: "auto"
  linked_repositories: []

code_generation:
  docstrings:
    language: "en-US"
    path_instructions:
      - path: "**/*.py"
        instructions: |
          Use Google-style docstrings. Include:
          - One-line summary
          - Args section for parameters
          - Returns section for return values
          - Raises section for exceptions
          - Examples section for complex functions
      - path: "**/*.ts"
        instructions: |
          Use JSDoc comments. Include:
          - @description for function purpose
          - @param for parameters
          - @returns for return value
          - @throws for exceptions
          - @example for complex functions
  unit_tests:
    path_instructions:
      - path: "backend/src/**/*.py"
        instructions: |
          Generate pytest tests with:
          - pytest-asyncio for async tests
          - factory_boy for test data
          - Arrange-Act-Assert pattern
          - Descriptive test names: test_<unit>_<scenario>_<expected>
          - Mock external dependencies using protocols
      - path: "frontend/src/**/*.tsx"
        instructions: |
          Generate Vitest tests with React Testing Library:
          - Use getByRole, getByLabelText (not getByTestId)
          - Use userEvent for interactions
          - Test behavior, not implementation
          - Include accessibility checks

issue_enrichment:
  auto_enrich:
    enabled: false
  planning:
    enabled: true
    auto_planning:
      enabled: false
      labels:
        - "feature"
        - "enhancement"
        - "!wip"
  labeling:
    auto_apply_labels: false
    labeling_instructions:
      - label: "bug"
        instructions: "Issue describes unexpected behavior or defect"
      - label: "enhancement"
        instructions: "Issue requests new functionality or improvement"
      - label: "documentation"
        instructions: "Issue relates to documentation improvements"
      - label: "good first issue"
        instructions: "Issue is well-defined and suitable for newcomers"
