---
# Development-only overrides  loaded automatically by Docker Compose.
# Do NOT commit environment-specific secrets.
{% if project_style in ['backend', 'hybrid'] %}
services:
  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile.dev
    volumes:
      - ./backend/src:/app/src:cached
    environment:
      - {{ env_prefix }}DEBUG=true
      - {{ env_prefix }}LOG_LEVEL=DEBUG
{% if has_db %}
      - {{ env_prefix }}DATABASE_URL=postgresql+asyncpg://{{ project_slug }}:{{ project_slug }}@db:5432/{{ project_slug }}
{% endif %}
    ports:
      - "${BACKEND_PORT:-8000}:8000"
{% if has_frontend %}

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
      target: dev
    volumes:
      - ./frontend/src:/app/src:cached
    environment:
      - VITE_API_BASE_URL=http://localhost:${BACKEND_PORT:-8000}
    ports:
      - "${FRONTEND_PORT:-5173}:5173"
    command: ["pnpm", "dev", "--host"]
{% endif %}
{% if has_db %}

  db:
    ports:
      - "${DB_PORT:-5432}:5432"
    environment:
      - POSTGRES_USER={{ project_slug }}
      - POSTGRES_PASSWORD={{ project_slug }}
      - POSTGRES_DB={{ project_slug }}
{% endif %}
{% if use_redis %}

  redis:
    ports:
      - "${REDIS_PORT:-6379}:6379"
{% endif %}
{% endif %}
