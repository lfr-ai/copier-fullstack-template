{
  "threshold": 5,
  "minLines": 10,
  "minTokens": 70,
  "skipBlocks": [
    {
      "open": "\"\"\"",
      "close": "\"\"\""
    }
  ],
  "ignore": [
    "node_modules",
    "dist",
    "build",
    ".venv",
    "__pycache__",
    "*.egg-info",
    ".tox",
    ".git",
    "*.lock",
    "*.min.js",
    "*.min.css",
    "bun.lock",
    "uv.lock",
    "package-lock.json",
    "template",
    "htmlcov",
    "coverage",
    ".pre-commit-cache",
    "logs/**"
  ]
}
